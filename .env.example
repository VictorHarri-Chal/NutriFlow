# NutriFlow — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs manquantes.
# Ne jamais committer .env dans git.

# ── Rails ──────────────────────────────────────────────────────────────────────
RAILS_MASTER_KEY=                    # Contenu de config/master.key

# ── Base de données ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=                   # Mot de passe PostgreSQL production
DB_HOST=localhost                    # Hôte DB (Kamal le surcharge avec nutri_flow-db)
RAILS_MAX_THREADS=5                  # Taille du pool de connexions + threads Puma

# ── Stockage objet (Cloudflare R2) ────────────────────────────────────────────
ACCESS_KEY_ID=                       # Clé API R2 — section "R2 API tokens" dans CF dashboard
SECRET_ACCESS_KEY=                   # Secret R2
S3_ENDPOINT=                         # https://<account_id>.r2.cloudflarestorage.com

# ── APIs externes ─────────────────────────────────────────────────────────────
RAPIDAPI_KEY=                        # RapidAPI — ExerciseDB (données exercices)
DEEPL_API_KEY=                       # DeepL — traduction exercices vers FR (format key:fx)
SENTRY_DSN=                          # DSN du projet Rails sur sentry.io (error tracking)

# ── Serveur web ────────────────────────────────────────────────────────────────
PORT=3000                            # Port HTTP Puma (optionnel)
SOLID_QUEUE_IN_PUMA=true             # Active le plugin Solid Queue dans Puma (prod)
JOB_CONCURRENCY=1                    # Nombre de workers Solid Queue

# ── Logs ──────────────────────────────────────────────────────────────────────
RAILS_LOG_LEVEL=info                 # debug | info | warn | error

# ── Déploiement (Kamal) ────────────────────────────────────────────────────────
KAMAL_SERVER_IP=                     # IP du VPS de production
KAMAL_HOST=                          # Domaine (ex: nutriflow.in)
KAMAL_REGISTRY_PASSWORD=             # Token Docker Hub (lecture + écriture)

# ── API iOS (JWT) ─────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
# Doit être différent de RAILS_MASTER_KEY et stable en production
DEVISE_JWT_SECRET_KEY=               # Secret pour signer les JWT — OBLIGATOIRE en production

# ── Seeds ─────────────────────────────────────────────────────────────────────
SEED_EMAIL=                          # Email du compte administrateur créé par db:seed
