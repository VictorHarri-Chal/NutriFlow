<%# ============================================================ %>
<%# NAVBAR %>
<%# ============================================================ %>
<header class="fixed top-0 inset-x-0 z-50 bg-surface-base/80 backdrop-blur-md border-b border-surface-border/40">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="<%= root_path %>" class="flex items-center gap-2.5">
      <%= image_tag "logo.png", class: "h-16 w-16", alt: "NutriFlow" %>
      <span class="text-xl font-bold text-ink-primary">NutriFlow</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-ink-muted">
      <a href="#features" class="hover:text-ink-primary transition-colors"><%= t("views.home.nav.features") %></a>
      <a href="#how-it-works" class="hover:text-ink-primary transition-colors"><%= t("views.home.nav.how_it_works") %></a>
    </nav>

    <div class="flex items-center gap-2">
      <%= link_to t("views.home.nav.login"), new_user_session_path,
            class: "text-sm font-medium text-ink-muted hover:text-ink-primary transition-colors px-4 py-2 rounded-lg" %>
      <%= link_to t("views.home.nav.signup"), new_user_registration_path,
            class: "btn-primary text-sm" %>
    </div>
  </div>
</header>


<%# ============================================================ %>
<%# HERO %>
<%# ============================================================ %>
<section class="relative min-h-screen bg-gradient-to-br from-zinc-950 via-surface-base to-zinc-900 flex items-center overflow-hidden pt-16">

  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-brand/8 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-brand/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-20 grid lg:grid-cols-2 gap-16 items-center w-full">

    <div>
      <h1 class="text-5xl lg:text-6xl font-bold text-white leading-[1.1] tracking-tight mb-6">
        <%= t("views.home.hero.title_line1") %>
        <span class="block bg-gradient-to-r from-brand to-amber-300 bg-clip-text text-transparent">
          <%= t("views.home.hero.title_line2") %>
        </span>
      </h1>

      <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-md">
        <%= t("views.home.hero.subtitle") %>
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <%= link_to new_user_registration_path,
              class: "inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-hover text-zinc-900 font-semibold px-6 py-3.5 rounded-xl transition-all duration-200 shadow-lg shadow-brand/30 hover:-translate-y-px" do %>
          <%= t("views.home.hero.cta_start") %>
          <i class="fas fa-arrow-right text-sm"></i>
        <% end %>
        <%= link_to new_user_session_path,
              class: "inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 border border-white/20 text-white font-semibold px-6 py-3.5 rounded-xl transition-all duration-200" do %>
          <%= t("views.home.hero.cta_login") %>
        <% end %>
      </div>

      <p class="mt-5 text-sm text-slate-500"><%= t("views.home.hero.free_label") %></p>
    </div>

    <%# App mockup %>
    <div class="hidden lg:block">
      <div class="relative">
        <div class="absolute -inset-4 bg-brand/10 blur-3xl rounded-3xl"></div>

        <div class="relative bg-surface-raised border border-surface-border/60 rounded-2xl overflow-hidden shadow-2xl">
          <%# Browser chrome %>
          <div class="bg-surface-base px-4 py-3 flex items-center gap-2 border-b border-surface-border/60">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
            </div>
            <div class="ml-3 flex-1 bg-surface-hover/50 rounded-md h-5 flex items-center px-3">
              <span class="text-xs text-ink-subtle">nutriflow.app/calendars</span>
            </div>
          </div>

          <%# App layout %>
          <div class="flex h-[340px]">
            <%# Mini sidebar %>
            <div class="w-14 bg-surface-base border-r border-surface-border/40 flex flex-col items-center py-5 gap-3">
              <div class="w-8 h-8 rounded-lg bg-brand flex items-center justify-center">
                <i class="fas fa-calendar-alt text-zinc-900 text-xs"></i>
              </div>
              <div class="w-8 h-8 rounded-lg bg-surface-hover flex items-center justify-center">
                <i class="fas fa-utensils text-ink-subtle text-xs"></i>
              </div>
              <div class="w-8 h-8 rounded-lg bg-surface-hover flex items-center justify-center">
                <i class="fas fa-book-open text-ink-subtle text-xs"></i>
              </div>
              <div class="w-8 h-8 rounded-lg bg-surface-hover flex items-center justify-center">
                <i class="fas fa-user text-ink-subtle text-xs"></i>
              </div>
            </div>

            <%# Main content — demo data, intentionally not translated %>
            <div class="flex-1 p-4 space-y-3 overflow-hidden">
              <div class="flex items-center justify-between">
                <span class="text-ink-primary text-sm font-semibold">Mardi 25 mars 2025</span>
                <span class="text-xs bg-macro-proteins/20 text-macro-proteins border border-macro-proteins/20 px-2.5 py-0.5 rounded-full font-medium">
                  1 540 kcal restantes
                </span>
              </div>

              <%# Macro progress %>
              <div class="bg-surface-hover/30 rounded-xl p-3.5 space-y-2.5">
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-ink-muted font-medium">Calories</span>
                    <span class="text-ink-subtle">660 / 2 200 kcal</span>
                  </div>
                  <div class="h-1.5 bg-surface-hover rounded-full">
                    <div class="h-full w-[30%] bg-gradient-to-r from-macro-calories to-blue-300 rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-ink-muted font-medium">Protéines</span>
                    <span class="text-ink-subtle">48 / 160 g</span>
                  </div>
                  <div class="h-1.5 bg-surface-hover rounded-full">
                    <div class="h-full w-[30%] bg-gradient-to-r from-macro-proteins to-emerald-300 rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-ink-muted font-medium">Glucides</span>
                    <span class="text-ink-subtle">82 / 275 g</span>
                  </div>
                  <div class="h-1.5 bg-surface-hover rounded-full">
                    <div class="h-full w-[30%] bg-gradient-to-r from-macro-carbs to-amber-300 rounded-full"></div>
                  </div>
                </div>
              </div>

              <%# Meal groups %>
              <div class="space-y-2">
                <div class="bg-surface-hover/30 rounded-xl p-3">
                  <p class="text-xs font-semibold text-ink-muted mb-2 flex items-center gap-1.5">
                    <i class="fas fa-sun text-brand"></i> Petit-déjeuner
                    <span class="ml-auto text-ink-subtle font-normal">428 kcal</span>
                  </p>
                  <div class="space-y-1.5">
                    <div class="flex justify-between">
                      <span class="text-xs text-ink-muted">Flocons d'avoine</span>
                      <span class="text-xs text-ink-subtle">80g</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-xs text-ink-muted">Yaourt grec nature</span>
                      <span class="text-xs text-ink-subtle">150g</span>
                    </div>
                  </div>
                </div>

                <div class="bg-surface-hover/30 rounded-xl p-3">
                  <p class="text-xs font-semibold text-ink-muted mb-2 flex items-center gap-1.5">
                    <i class="fas fa-cloud-sun text-macro-calories"></i> Déjeuner
                    <span class="ml-auto text-ink-subtle font-normal">232 kcal</span>
                  </p>
                  <div class="flex justify-between">
                    <span class="text-xs text-ink-muted">Poulet rôti & légumes</span>
                    <span class="text-xs text-ink-subtle">350g</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>


<%# ============================================================ %>
<%# FEATURES %>
<%# ============================================================ %>
<section id="features" class="py-24 bg-surface-raised">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="text-sm font-semibold text-brand uppercase tracking-widest mb-3"><%= t("views.home.features.section_label") %></p>
      <h2 class="text-4xl font-bold text-ink-primary tracking-tight"><%= t("views.home.features.section_title") %></h2>
      <p class="mt-4 text-lg text-ink-muted max-w-xl mx-auto"><%= t("views.home.features.section_subtitle") %></p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">

      <div class="group bg-surface-base hover:bg-surface-hover border border-surface-border/40 hover:border-brand/30 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-brand-muted group-hover:bg-brand/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-calendar-alt text-brand"></i>
        </div>
        <h3 class="text-base font-semibold text-ink-primary mb-2"><%= t("views.home.features.calendar_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.features.calendar_desc") %></p>
      </div>

      <div class="group bg-surface-base hover:bg-surface-hover border border-surface-border/40 hover:border-macro-proteins/30 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-macro-proteins/10 group-hover:bg-macro-proteins/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-apple-alt text-macro-proteins"></i>
        </div>
        <h3 class="text-base font-semibold text-ink-primary mb-2"><%= t("views.home.features.foods_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.features.foods_desc") %></p>
      </div>

      <div class="group bg-surface-base hover:bg-surface-hover border border-surface-border/40 hover:border-brand/30 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-brand-muted group-hover:bg-brand/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-book-open text-brand"></i>
        </div>
        <h3 class="text-base font-semibold text-ink-primary mb-2"><%= t("views.home.features.recipes_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.features.recipes_desc") %></p>
      </div>

      <div class="group bg-surface-base hover:bg-surface-hover border border-surface-border/40 hover:border-macro-sugars/30 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-macro-sugars/10 group-hover:bg-macro-sugars/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-fire-flame-simple text-macro-sugars"></i>
        </div>
        <h3 class="text-base font-semibold text-ink-primary mb-2"><%= t("views.home.features.calories_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.features.calories_desc") %></p>
      </div>

      <div class="group bg-surface-base hover:bg-surface-hover border border-surface-border/40 hover:border-macro-fats/30 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-macro-fats/10 group-hover:bg-macro-fats/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-star text-macro-fats"></i>
        </div>
        <h3 class="text-base font-semibold text-ink-primary mb-2"><%= t("views.home.features.ratings_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.features.ratings_desc") %></p>
      </div>

      <div class="group bg-surface-base hover:bg-surface-hover border border-surface-border/40 hover:border-macro-calories/30 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-macro-calories/10 group-hover:bg-macro-calories/20 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-tags text-macro-calories"></i>
        </div>
        <h3 class="text-base font-semibold text-ink-primary mb-2"><%= t("views.home.features.labels_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.features.labels_desc") %></p>
      </div>

    </div>
  </div>
</section>


<%# ============================================================ %>
<%# HOW IT WORKS %>
<%# ============================================================ %>
<section id="how-it-works" class="py-24 bg-surface-base">
  <div class="max-w-5xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-16">
      <p class="text-sm font-semibold text-brand uppercase tracking-widest mb-3"><%= t("views.home.how_it_works.section_label") %></p>
      <h2 class="text-4xl font-bold text-ink-primary tracking-tight"><%= t("views.home.how_it_works.section_title") %></h2>
    </div>

    <div class="relative grid md:grid-cols-3 gap-10">
      <div class="hidden md:block absolute top-9 left-[calc(16.67%+2rem)] right-[calc(16.67%+2rem)] h-px bg-gradient-to-r from-surface-border via-brand/40 to-surface-border"></div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-[4.5rem] h-[4.5rem] rounded-2xl bg-brand text-zinc-900 flex items-center justify-center text-2xl font-bold mb-6 shadow-lg shadow-brand/20 relative z-10">
          1
        </div>
        <h3 class="text-lg font-semibold text-ink-primary mb-2"><%= t("views.home.how_it_works.step1_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.how_it_works.step1_desc") %></p>
      </div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-[4.5rem] h-[4.5rem] rounded-2xl bg-brand text-zinc-900 flex items-center justify-center text-2xl font-bold mb-6 shadow-lg shadow-brand/20 relative z-10">
          2
        </div>
        <h3 class="text-lg font-semibold text-ink-primary mb-2"><%= t("views.home.how_it_works.step2_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.how_it_works.step2_desc") %></p>
      </div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-[4.5rem] h-[4.5rem] rounded-2xl bg-brand text-zinc-900 flex items-center justify-center text-2xl font-bold mb-6 shadow-lg shadow-brand/20 relative z-10">
          3
        </div>
        <h3 class="text-lg font-semibold text-ink-primary mb-2"><%= t("views.home.how_it_works.step3_title") %></h3>
        <p class="text-sm text-ink-muted leading-relaxed"><%= t("views.home.how_it_works.step3_desc") %></p>
      </div>
    </div>

  </div>
</section>


<%# ============================================================ %>
<%# CTA FINAL %>
<%# ============================================================ %>
<section class="relative py-28 bg-gradient-to-br from-zinc-950 via-surface-base to-zinc-900 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-24 -right-24 w-80 h-80 bg-brand/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-brand/8 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-2xl mx-auto px-6 text-center">
    <h2 class="text-4xl lg:text-5xl font-bold text-white tracking-tight mb-5">
      <%= t("views.home.cta.title") %>
    </h2>
    <p class="text-lg text-ink-muted mb-10 leading-relaxed">
      <%= t("views.home.cta.subtitle") %>
    </p>
    <%= link_to new_user_registration_path,
          class: "inline-flex items-center gap-2 bg-brand text-zinc-900 font-bold px-8 py-4 rounded-xl text-base hover:bg-brand-hover transition-all duration-200 shadow-2xl shadow-brand/30 hover:-translate-y-0.5" do %>
      <%= t("views.home.cta.button") %>
      <i class="fas fa-arrow-right"></i>
    <% end %>
  </div>
</section>


<%# ============================================================ %>
<%# FOOTER %>
<%# ============================================================ %>
<footer class="bg-surface-base py-10 border-t border-surface-border/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <%= image_tag "logo.png", class: "h-12 w-12", alt: "NutriFlow" %>
      <span class="text-ink-primary font-semibold text-sm">NutriFlow</span>
    </div>

    <div class="flex items-center gap-6 text-sm text-ink-subtle">
      <%= link_to t("views.home.footer.login"), new_user_session_path, class: "hover:text-ink-muted transition-colors" %>
      <%= link_to t("views.home.footer.signup"), new_user_registration_path, class: "hover:text-ink-muted transition-colors" %>
    </div>

    <p class="text-ink-subtle text-sm">© <%= Date.current.year %> NutriFlow</p>
  </div>
</footer>
