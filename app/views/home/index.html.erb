<%# ============================================================ %>
<%# NAVBAR %>
<%# ============================================================ %>
<header class="fixed top-0 inset-x-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="<%= root_path %>" class="flex items-center gap-2.5">
      <%= image_tag "logo.png", class: "h-8 w-8", alt: "NutriFlow" %>
      <span class="text-xl font-bold text-gray-900">NutriFlow</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-500">
      <a href="#features" class="hover:text-gray-900 transition-colors">Fonctionnalités</a>
      <a href="#how-it-works" class="hover:text-gray-900 transition-colors">Comment ça marche</a>
    </nav>

    <div class="flex items-center gap-2">
      <%= link_to "Se connecter", new_user_session_path,
            class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors px-4 py-2 rounded-lg" %>
      <%= link_to "S'inscrire", new_user_registration_path,
            class: "text-sm font-semibold bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors" %>
    </div>
  </div>
</header>


<%# ============================================================ %>
<%# HERO %>
<%# ============================================================ %>
<section class="relative min-h-screen bg-gradient-to-br from-slate-900 via-blue-950 to-indigo-950 flex items-center overflow-hidden pt-16">

  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-blue-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-20 grid lg:grid-cols-2 gap-16 items-center w-full">

    <div>
      <h1 class="text-5xl lg:text-6xl font-bold text-white leading-[1.1] tracking-tight mb-6">
        Prenez le contrôle
        <span class="block bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">
          de votre nutrition
        </span>
      </h1>

      <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-md">
        Suivez vos repas jour par jour, créez vos recettes, et atteignez vos objectifs nutritionnels — simplement.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <%= link_to new_user_registration_path,
              class: "inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3.5 rounded-xl transition-all duration-200 shadow-lg shadow-blue-900/50 hover:-translate-y-px" do %>
          Commencer gratuitement
          <i class="fas fa-arrow-right text-sm"></i>
        <% end %>
        <%= link_to new_user_session_path,
              class: "inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 border border-white/20 text-white font-semibold px-6 py-3.5 rounded-xl transition-all duration-200" do %>
          Se connecter
        <% end %>
      </div>

      <p class="mt-5 text-sm text-slate-500">Gratuit · Aucune carte bancaire requise</p>
    </div>

    <%# App mockup %>
    <div class="hidden lg:block">
      <div class="relative">
        <div class="absolute -inset-4 bg-blue-500/15 blur-3xl rounded-3xl"></div>

        <div class="relative bg-slate-800 border border-slate-700/60 rounded-2xl overflow-hidden shadow-2xl">
          <%# Browser chrome %>
          <div class="bg-slate-900 px-4 py-3 flex items-center gap-2 border-b border-slate-700/60">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
            </div>
            <div class="ml-3 flex-1 bg-slate-700/50 rounded-md h-5 flex items-center px-3">
              <span class="text-xs text-slate-500">nutriflow.app/calendars</span>
            </div>
          </div>

          <%# App layout %>
          <div class="flex h-[340px]">
            <%# Mini sidebar %>
            <div class="w-14 bg-slate-900/80 border-r border-slate-700/40 flex flex-col items-center py-5 gap-3">
              <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center">
                <i class="fas fa-calendar-alt text-white text-xs"></i>
              </div>
              <div class="w-8 h-8 rounded-lg bg-slate-700/60 flex items-center justify-center">
                <i class="fas fa-utensils text-slate-500 text-xs"></i>
              </div>
              <div class="w-8 h-8 rounded-lg bg-slate-700/60 flex items-center justify-center">
                <i class="fas fa-book-open text-slate-500 text-xs"></i>
              </div>
              <div class="w-8 h-8 rounded-lg bg-slate-700/60 flex items-center justify-center">
                <i class="fas fa-user text-slate-500 text-xs"></i>
              </div>
            </div>

            <%# Main content %>
            <div class="flex-1 p-4 space-y-3 overflow-hidden">
              <div class="flex items-center justify-between">
                <span class="text-white text-sm font-semibold">Mardi 25 mars 2025</span>
                <span class="text-xs bg-emerald-500/20 text-emerald-400 border border-emerald-500/20 px-2.5 py-0.5 rounded-full font-medium">
                  1 540 kcal restantes
                </span>
              </div>

              <%# Macro progress %>
              <div class="bg-slate-700/30 rounded-xl p-3.5 space-y-2.5">
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-slate-300 font-medium">Calories</span>
                    <span class="text-slate-400">660 / 2 200 kcal</span>
                  </div>
                  <div class="h-1.5 bg-slate-700 rounded-full">
                    <div class="h-full w-[30%] bg-gradient-to-r from-blue-500 to-blue-400 rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-slate-300 font-medium">Protéines</span>
                    <span class="text-slate-400">48 / 160 g</span>
                  </div>
                  <div class="h-1.5 bg-slate-700 rounded-full">
                    <div class="h-full w-[30%] bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-xs mb-1.5">
                    <span class="text-slate-300 font-medium">Glucides</span>
                    <span class="text-slate-400">82 / 275 g</span>
                  </div>
                  <div class="h-1.5 bg-slate-700 rounded-full">
                    <div class="h-full w-[30%] bg-gradient-to-r from-amber-500 to-amber-400 rounded-full"></div>
                  </div>
                </div>
              </div>

              <%# Meal groups %>
              <div class="space-y-2">
                <div class="bg-slate-700/30 rounded-xl p-3">
                  <p class="text-xs font-semibold text-slate-300 mb-2 flex items-center gap-1.5">
                    <i class="fas fa-sun text-amber-400"></i> Petit-déjeuner
                    <span class="ml-auto text-slate-500 font-normal">428 kcal</span>
                  </p>
                  <div class="space-y-1.5">
                    <div class="flex justify-between">
                      <span class="text-xs text-slate-300">Flocons d'avoine</span>
                      <span class="text-xs text-slate-500">80g</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-xs text-slate-300">Yaourt grec nature</span>
                      <span class="text-xs text-slate-500">150g</span>
                    </div>
                  </div>
                </div>

                <div class="bg-slate-700/30 rounded-xl p-3">
                  <p class="text-xs font-semibold text-slate-300 mb-2 flex items-center gap-1.5">
                    <i class="fas fa-cloud-sun text-blue-400"></i> Déjeuner
                    <span class="ml-auto text-slate-500 font-normal">232 kcal</span>
                  </p>
                  <div class="flex justify-between">
                    <span class="text-xs text-slate-300">Poulet rôti & légumes</span>
                    <span class="text-xs text-slate-500">350g</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>


<%# ============================================================ %>
<%# FEATURES %>
<%# ============================================================ %>
<section id="features" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-3">Fonctionnalités</p>
      <h2 class="text-4xl font-bold text-gray-900 tracking-tight">Tout ce dont vous avez besoin</h2>
      <p class="mt-4 text-lg text-gray-500 max-w-xl mx-auto">Un suivi nutritionnel complet, conçu pour être aussi simple qu'efficace.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">

      <div class="group bg-gray-50 hover:bg-blue-50 border border-transparent hover:border-blue-100 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-blue-100 group-hover:bg-blue-200 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-calendar-alt text-blue-600"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Calendrier nutritionnel</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Naviguez jour par jour et ajoutez vos aliments ou recettes. Organisez vos repas en catégories personnalisables.</p>
      </div>

      <div class="group bg-gray-50 hover:bg-emerald-50 border border-transparent hover:border-emerald-100 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-emerald-100 group-hover:bg-emerald-200 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-apple-alt text-emerald-600"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Base d'aliments</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Constituez votre bibliothèque d'aliments avec leurs valeurs nutritionnelles. Recherchez et filtrez en quelques secondes.</p>
      </div>

      <div class="group bg-gray-50 hover:bg-orange-50 border border-transparent hover:border-orange-100 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-orange-100 group-hover:bg-orange-200 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-book-open text-orange-600"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Recettes personnalisées</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Composez des recettes avec leurs ingrédients et quantités. Les macros se calculent automatiquement au gramme près.</p>
      </div>

      <div class="group bg-gray-50 hover:bg-purple-50 border border-transparent hover:border-purple-100 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-purple-100 group-hover:bg-purple-200 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-fire-flame-simple text-purple-600"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Besoins caloriques</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Calculez vos apports idéaux selon votre profil, votre niveau d'activité et votre objectif — perte de poids, maintien ou prise de masse.</p>
      </div>

      <div class="group bg-gray-50 hover:bg-pink-50 border border-transparent hover:border-pink-100 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-pink-100 group-hover:bg-pink-200 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-star text-pink-600"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Notes & commentaires</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Notez vos recettes de 1 à 5 étoiles et laissez des commentaires pour retrouver vos coups de cœur.</p>
      </div>

      <div class="group bg-gray-50 hover:bg-cyan-50 border border-transparent hover:border-cyan-100 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="w-11 h-11 bg-cyan-100 group-hover:bg-cyan-200 rounded-xl flex items-center justify-center mb-4 transition-colors">
          <i class="fas fa-tags text-cyan-600"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Étiquettes & groupes</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Étiquetez vos aliments par catégorie et regroupez vos repas du jour comme vous le souhaitez.</p>
      </div>

    </div>
  </div>
</section>


<%# ============================================================ %>
<%# HOW IT WORKS %>
<%# ============================================================ %>
<section id="how-it-works" class="py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-16">
      <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-3">Comment ça marche</p>
      <h2 class="text-4xl font-bold text-gray-900 tracking-tight">Démarrez en 3 étapes</h2>
    </div>

    <div class="relative grid md:grid-cols-3 gap-10">
      <%# Connector line — spans from center of col 1 to center of col 3 %>
      <div class="hidden md:block absolute top-9 left-[calc(16.67%+2rem)] right-[calc(16.67%+2rem)] h-px bg-gradient-to-r from-blue-200 via-blue-300 to-blue-200"></div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-[4.5rem] h-[4.5rem] rounded-2xl bg-blue-600 text-white flex items-center justify-center text-2xl font-bold mb-6 shadow-lg shadow-blue-200 relative z-10">
          1
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Créez votre profil</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Renseignez votre poids, taille, âge et objectif. NutriFlow calcule vos apports quotidiens idéaux.</p>
      </div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-[4.5rem] h-[4.5rem] rounded-2xl bg-blue-600 text-white flex items-center justify-center text-2xl font-bold mb-6 shadow-lg shadow-blue-200 relative z-10">
          2
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Ajoutez vos aliments</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Constituez votre base d'aliments et créez vos recettes favorites avec tous leurs ingrédients.</p>
      </div>

      <div class="relative flex flex-col items-center text-center">
        <div class="w-[4.5rem] h-[4.5rem] rounded-2xl bg-blue-600 text-white flex items-center justify-center text-2xl font-bold mb-6 shadow-lg shadow-blue-200 relative z-10">
          3
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Suivez vos journées</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Loggez ce que vous mangez chaque jour et visualisez vos macros en temps réel.</p>
      </div>
    </div>

  </div>
</section>


<%# ============================================================ %>
<%# CTA FINAL %>
<%# ============================================================ %>
<section class="relative py-28 bg-gradient-to-br from-blue-600 to-indigo-700 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-24 -right-24 w-80 h-80 bg-white/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-white/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-2xl mx-auto px-6 text-center">
    <h2 class="text-4xl lg:text-5xl font-bold text-white tracking-tight mb-5">
      Prêt à mieux manger ?
    </h2>
    <p class="text-lg text-blue-100 mb-10 leading-relaxed">
      Rejoignez NutriFlow et commencez à suivre votre nutrition dès aujourd'hui. C'est gratuit.
    </p>
    <%= link_to new_user_registration_path,
          class: "inline-flex items-center gap-2 bg-white text-blue-700 font-bold px-8 py-4 rounded-xl text-base hover:bg-blue-50 transition-all duration-200 shadow-2xl shadow-blue-900/30 hover:-translate-y-0.5" do %>
      Commencer gratuitement
      <i class="fas fa-arrow-right"></i>
    <% end %>
  </div>
</section>


<%# ============================================================ %>
<%# FOOTER %>
<%# ============================================================ %>
<footer class="bg-slate-900 py-10 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <%= image_tag "logo.png", class: "h-6 w-6", alt: "NutriFlow" %>
      <span class="text-white font-semibold text-sm">NutriFlow</span>
    </div>

    <div class="flex items-center gap-6 text-sm text-slate-500">
      <%= link_to "Se connecter", new_user_session_path, class: "hover:text-slate-300 transition-colors" %>
      <%= link_to "S'inscrire", new_user_registration_path, class: "hover:text-slate-300 transition-colors" %>
    </div>

    <p class="text-slate-600 text-sm">© <%= Date.current.year %> NutriFlow</p>
  </div>
</footer>
