<% content_for :page_title, t("views.weight_entries.page_title.#{weight_sidebar_label_key(current_user)}") %>

<div class="max-w-4xl mx-auto mt-16 space-y-5 pb-12">

  <% if @available_tabs.size > 1 %>
    <div class="flex items-center gap-2">
      <% @available_tabs.each do |tab| %>
        <%= link_to weight_entries_path(tab: tab),
            class: @tab == tab \
              ? "px-4 py-2 rounded-full text-sm font-semibold bg-brand/20 text-brand border border-brand/30 transition-colors" \
              : "px-4 py-2 rounded-full text-sm font-medium text-ink-muted border border-surface-border/40 hover:text-ink-primary hover:border-surface-border/70 transition-colors" do %>
          <%= t("views.weight_entries.tabs.#{tab}") %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%= render partial: "weight_entries/#{@tab}" %>

</div>
