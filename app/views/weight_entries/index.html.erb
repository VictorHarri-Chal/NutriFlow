<% content_for :page_title, t("views.weight_entries.page_title") %>

<div class="max-w-4xl mx-auto mt-16 space-y-5 pb-12">

  <%# ── KPI cards ── %>
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-3">

    <%# Poids actuel %>
    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1">
        <%= t("views.weight_entries.stats.current") %>
      </p>
      <% if @current_weight %>
        <p class="text-2xl font-bold text-ink-primary">
          <%= @current_weight %><span class="text-sm font-normal text-ink-subtle ml-1">kg</span>
        </p>
        <% if @trend_weekly %>
          <%
            good   = @positive_is_good
            toward = @trend_weekly > 0.05 ? :up : @trend_weekly < -0.05 ? :down : :flat
            trend_color = toward == :flat ? "text-ink-subtle" :
                          (toward == :up && good || toward == :down && !good) ? "text-status-success" : "text-status-danger"
            trend_icon  = toward == :up ? "fa-arrow-trend-up" : toward == :down ? "fa-arrow-trend-down" : "fa-minus"
          %>
          <p class="text-xs <%= trend_color %> mt-1.5 flex items-center gap-1">
            <i class="fas <%= trend_icon %> text-[9px]"></i>
            <%= @trend_weekly > 0 ? "+#{@trend_weekly}" : @trend_weekly %> kg/sem
          </p>
        <% end %>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle">—</p>
      <% end %>
    </div>

    <%# IMC %>
    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1">
        <%= t("views.weight_entries.stats.bmi_label") %>
      </p>
      <% if @bmi %>
        <%
          bmi_color = case @bmi_category
                      when :underweight then "text-status-info"
                      when :normal      then "text-status-success"
                      when :overweight  then "text-status-warning"
                      else                   "text-status-danger"
                      end
        %>
        <p class="text-2xl font-bold <%= bmi_color %>"><%= @bmi %></p>
        <p class="text-[10px] <%= bmi_color %> mt-1.5 font-medium">
          <%= t("views.weight_entries.stats.bmi_category.#{@bmi_category}") %>
        </p>
      <% elsif @current_weight %>
        <p class="text-2xl font-bold text-ink-subtle">—</p>
        <p class="text-[10px] text-ink-subtle mt-1.5"><%= t("views.weight_entries.stats.no_height") %></p>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle">—</p>
      <% end %>
    </div>

    <%# Delta 30j %>
    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1">
        <%= t("views.weight_entries.stats.delta_30d") %>
      </p>
      <% if @delta_30d %>
        <%
          delta_color = @delta_30d == 0 ? "text-ink-primary" :
                        (@delta_30d > 0) == @positive_is_good ? "text-status-success" : "text-status-danger"
          delta_icon  = @delta_30d < 0 ? "fa-arrow-down" : @delta_30d > 0 ? "fa-arrow-up" : "fa-minus"
        %>
        <p class="text-2xl font-bold <%= delta_color %>">
          <i class="fas <%= delta_icon %> text-lg mr-0.5"></i>
          <%= @delta_30d.abs %><span class="text-sm font-normal ml-1">kg</span>
        </p>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle">—</p>
        <p class="text-xs text-ink-subtle mt-1"><%= t("views.weight_entries.stats.not_enough_data") %></p>
      <% end %>
    </div>

    <%# Delta 90j %>
    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1">
        <%= t("views.weight_entries.stats.delta_90d") %>
      </p>
      <% if @delta_90d %>
        <%
          d_color = @delta_90d == 0 ? "text-ink-primary" :
                    (@delta_90d > 0) == @positive_is_good ? "text-status-success" : "text-status-danger"
          d_icon  = @delta_90d < 0 ? "fa-arrow-down" : @delta_90d > 0 ? "fa-arrow-up" : "fa-minus"
        %>
        <p class="text-2xl font-bold <%= d_color %>">
          <i class="fas <%= d_icon %> text-lg mr-0.5"></i>
          <%= @delta_90d.abs %><span class="text-sm font-normal ml-1">kg</span>
        </p>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle">—</p>
        <p class="text-xs text-ink-subtle mt-1"><%= t("views.weight_entries.stats.not_enough_data") %></p>
      <% end %>
    </div>

    <%# Objectif %>
    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1">
        <%= t("views.weight_entries.stats.goal") %>
      </p>
      <% if @profile&.goal_weight %>
        <p class="text-2xl font-bold text-ink-primary">
          <%= @profile.goal_weight %><span class="text-sm font-normal text-ink-subtle ml-1">kg</span>
        </p>
        <% if @goal_delta %>
          <% remaining_color = @goal_delta.abs < 1 ? "text-status-success" : "text-ink-subtle" %>
          <p class="text-xs <%= remaining_color %> mt-1">
            <% if @goal_delta > 0 %>
              <%= t("views.weight_entries.stats.to_lose", kg: @goal_delta) %>
            <% elsif @goal_delta < 0 %>
              <%= t("views.weight_entries.stats.to_gain", kg: @goal_delta.abs) %>
            <% else %>
              <%= t("views.weight_entries.stats.goal_reached") %>
            <% end %>
          </p>
        <% end %>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle">—</p>
        <div class="mt-2">
          <%= link_to edit_profile_path,
                class: "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-medium bg-brand/10 border border-brand/25 text-brand hover:bg-brand/15 hover:border-brand/40 transition-colors" do %>
            <i class="fas fa-circle-user text-[9px]"></i>
            <%= t("views.weight_entries.stats.set_goal") %>
            <i class="fas fa-arrow-right text-[9px] opacity-60"></i>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>

  <%# ── Graphique ── %>
  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-ink-primary flex items-center gap-2">
        <i class="fas fa-chart-line text-brand text-sm"></i>
        <%= t("views.weight_entries.chart.title") %>
      </h2>
      <div class="flex items-center gap-1.5">
        <% [30, 90].each do |p| %>
          <%= link_to weight_entries_path(period: p),
                class: "px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@period == p ? 'bg-brand/20 text-brand border-brand/50' : 'text-ink-subtle border-surface-border/50 hover:border-brand/30 hover:text-ink-muted'}" do %>
            <%= t("views.weight_entries.chart.period_label", days: p) %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @chart_data.size >= 2 %>
      <div class="relative h-56">
        <canvas data-controller="weight-chart"
                data-weight-chart-labels-value="<%= @chart_labels.to_json %>"
                data-weight-chart-data-value="<%= @chart_data.to_json %>"
                data-weight-chart-goal-value="<%= @chart_goal %>"
                data-weight-chart-proj-labels-value="<%= (@proj_labels || []).to_json %>"
                data-weight-chart-proj-data-value="<%= (@proj_data || []).to_json %>">
        </canvas>
      </div>
      <% if @proj_labels&.any? %>
        <p class="text-[10px] text-ink-subtle/50 mt-3 flex items-center gap-2">
          <span class="inline-block w-6 border-t border-dashed border-brand/40"></span>
          <%= t("views.weight_entries.chart.projection_hint") %>
        </p>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center h-48 border border-dashed border-surface-border/50 rounded-xl">
        <i class="fas fa-chart-line text-2xl text-ink-subtle mb-2"></i>
        <p class="text-sm text-ink-subtle"><%= t("views.weight_entries.chart.not_enough_data") %></p>
      </div>
    <% end %>
  </div>

  <%# ── Saisie + historique ── %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

    <%# Formulaire de saisie %>
    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4">
        <%= t("views.weight_entries.form.title") %>
      </h2>

      <%
        entries_json = @entries.map { |e| { date: e.date.to_s, weight: e.weight_kg.to_f } }.to_json
      %>
      <%= form_with model: @today_entry, url: weight_entries_path, method: :post, local: true,
          data: {
            controller: "weight-entry-form",
            weight_entry_form_entries_value: entries_json
          },
          class: "space-y-4" do |f| %>
        <% if @today_entry.errors.any? %>
          <div class="text-xs text-status-danger bg-status-danger_dim/20 rounded-lg px-3 py-2">
            <%= @today_entry.errors.full_messages.first %>
          </div>
        <% end %>

        <div>
          <label class="label-dark"><%= t("views.weight_entries.form.weight_label") %></label>
          <div class="relative mt-1">
            <%= f.number_field :weight_kg,
                step: 0.1, min: 20, max: 400,
                value: @today_entry.weight_kg,
                class: "input-dark pr-10",
                data: { "weight-entry-form-target": "weightField" } %>
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle">kg</span>
          </div>
        </div>

        <div>
          <label class="label-dark"><%= t("views.weight_entries.form.date_label") %></label>
          <%= f.date_field :date,
              value: @today_entry.date || Date.today,
              max: Date.today,
              class: "input-dark mt-1",
              data: {
                "weight-entry-form-target": "dateField",
                action: "change->weight-entry-form#checkDate"
              } %>
        </div>

        <p class="hidden text-xs text-status-warning bg-status-warning/10 rounded-lg px-3 py-2"
           data-weight-entry-form-target="hint"
           data-existing-message="<%= t("views.weight_entries.form.existing_entry", weight: "%{weight}") %>">
        </p>

        <%= f.submit t("views.weight_entries.form.submit"), class: "btn-primary w-full cursor-pointer" %>
      <% end %>
    </div>

    <%# Historique %>
    <div class="md:col-span-2 bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4">
        <%= t("views.weight_entries.history.title") %>
      </h2>

      <% recent = @entries.last(20).reverse %>

      <% if recent.any? %>
        <div class="overflow-y-auto max-h-[15.5rem] divide-y divide-surface-border/30 pr-1 scrollbar-thin">
          <% recent.each_with_index do |entry, idx| %>
            <div class="flex items-center justify-between py-2.5 group">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-surface-hover flex items-center justify-center shrink-0">
                  <i class="fas fa-weight-scale text-xs text-ink-subtle"></i>
                </div>
                <div>
                  <p class="text-sm font-medium text-ink-primary">
                    <%= entry.weight_kg %> kg
                  </p>
                  <p class="text-xs text-ink-subtle"><%= l(entry.date, format: :long) %></p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <% if idx < recent.size - 1 %>
                  <% prev_entry = recent[idx + 1] %>
                  <% diff = (entry.weight_kg - prev_entry.weight_kg).round(1) %>
                  <% if diff != 0 %>
                    <%
                      diff_color = (diff > 0) == @positive_is_good ? 'text-status-success' : 'text-status-danger'
                    %>
                    <span class="text-xs <%= diff_color %>">
                      <%= diff > 0 ? "+#{diff}" : diff %> kg
                    </span>
                  <% end %>
                <% end %>
                <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                  <%= link_to weight_entry_path(entry),
                      data: {
                        turbo_method: :delete,
                        action: "click->confirm#show",
                        confirm_message: t("views.weight_entries.history.delete_confirm")
                      },
                      class: "inline-flex items-center justify-center w-7 h-7 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors" do %>
                    <i class="fas fa-trash text-xs"></i>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-12 border border-dashed border-surface-border/50 rounded-xl">
          <i class="fas fa-weight-scale text-2xl text-ink-subtle mb-2"></i>
          <p class="text-sm text-ink-subtle"><%= t("views.weight_entries.history.empty") %></p>
        </div>
      <% end %>
    </div>

  </div>

</div>
