<%# ── KPI cards ── %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3">

  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
    <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1 flex items-center gap-1">
      <%= t("views.weight_entries.measurements.stats.waist") %>
      <i class="fas fa-circle-info normal-case text-ink-subtle/60 hover:text-ink-primary transition-colors cursor-default"
         data-tooltip="<%= t("views.weight_entries.measurements.stats.waist_info") %>"></i>
    </p>
    <% if @latest_waist %>
      <p class="text-2xl font-bold text-ink-primary">
        <%= @latest_waist %><span class="text-sm font-normal text-ink-subtle ml-1">cm</span>
      </p>
    <% else %>
      <p class="text-2xl font-bold text-ink-subtle">—</p>
    <% end %>
  </div>

  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
    <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1 flex items-center gap-1">
      <%= t("views.weight_entries.measurements.stats.waist_hip_ratio") %>
      <i class="fas fa-circle-info normal-case text-ink-subtle/60 hover:text-ink-primary transition-colors cursor-default"
         data-tooltip="<%= t("views.weight_entries.measurements.stats.waist_hip_ratio_info") %>"></i>
    </p>
    <% if @latest_waist_hip %>
      <p class="text-2xl font-bold text-ink-primary"><%= @latest_waist_hip %></p>
    <% else %>
      <p class="text-2xl font-bold text-ink-subtle">—</p>
    <% end %>
  </div>

  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
    <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1 flex items-center gap-1">
      <%= t("views.weight_entries.measurements.stats.waist_height_ratio") %>
      <i class="fas fa-circle-info normal-case text-ink-subtle/60 hover:text-ink-primary transition-colors cursor-default"
         data-tooltip="<%= t("views.weight_entries.measurements.stats.waist_height_ratio_info") %>"></i>
    </p>
    <% if @latest_waist_height %>
      <p class="text-2xl font-bold text-ink-primary"><%= @latest_waist_height %></p>
    <% else %>
      <p class="text-2xl font-bold text-ink-subtle">—</p>
    <% end %>
  </div>

  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-4">
    <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-1 flex items-center gap-1">
      <%= t("views.weight_entries.measurements.stats.body_fat") %>
      <i class="fas fa-circle-info normal-case text-ink-subtle/60 hover:text-ink-primary transition-colors cursor-default"
         data-tooltip="<%= t("views.weight_entries.measurements.stats.body_fat_info") %>"></i>
    </p>
    <% if @latest_body_fat %>
      <p class="text-2xl font-bold text-ink-primary">
        <%= @latest_body_fat %><span class="text-sm font-normal text-ink-subtle ml-1">%</span>
      </p>
    <% else %>
      <p class="text-2xl font-bold text-ink-subtle">—</p>
    <% end %>
  </div>

</div>

<%# ── Graphique ── %>
<div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-ink-primary flex items-center gap-2">
      <i class="fas fa-ruler text-brand text-sm"></i>
      <%= t("views.weight_entries.measurements.chart.title") %>
    </h2>
    <div class="flex items-center gap-1.5">
      <% [30, 90].each do |p| %>
        <%= link_to weight_entries_path(tab: "mesures", measurement: @measurement_type, period: p),
              class: "px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@period == p ? 'bg-brand/20 text-brand border-brand/50' : 'text-ink-subtle border-surface-border/50 hover:border-brand/30 hover:text-ink-muted'}" do %>
          <%= t("views.weight_entries.chart.period_label", days: p) %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-1.5 mb-4">
    <% BodyMeasurement::MEASUREMENT_FIELDS.each do |field| %>
      <%= link_to weight_entries_path(tab: "mesures", measurement: field, period: @period),
            class: "px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@measurement_type == field.to_s ? 'bg-brand/20 text-brand border-brand/50' : 'text-ink-subtle border-surface-border/50 hover:border-brand/30 hover:text-ink-muted'}" do %>
        <%= t("views.weight_entries.measurements.fields.#{field}") %>
      <% end %>
    <% end %>
  </div>

  <% if @measurement_chart_data.size >= 2 %>
    <div class="relative h-56">
      <canvas data-controller="measurement-chart"
              data-measurement-chart-labels-value="<%= @measurement_chart_labels.to_json %>"
              data-measurement-chart-data-value="<%= @measurement_chart_data.to_json %>">
      </canvas>
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center h-48 border border-dashed border-surface-border/50 rounded-xl">
      <i class="fas fa-ruler text-2xl text-ink-subtle mb-2"></i>
      <p class="text-sm text-ink-subtle"><%= t("views.weight_entries.measurements.chart.not_enough_data") %></p>
    </div>
  <% end %>
</div>

<%# ── Saisie + historique ── %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-5">

  <%# Formulaire de saisie %>
  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
    <h2 class="text-sm font-semibold text-ink-primary mb-4">
      <%= t("views.weight_entries.measurements.form.title") %>
    </h2>

    <%
      measurements_json = @measurements.each_with_object({}) { |m, h|
        h[m.date.to_s] = BodyMeasurement::MEASUREMENT_FIELDS.index_with { |f| m.public_send(f) }
      }.to_json
    %>
    <%= form_with model: @today_measurement, url: body_measurements_path, method: :post, local: true,
        html: { multipart: true },
        data: {
          controller: "body-measurement-form",
          body_measurement_form_entries_value: measurements_json
        },
        class: "space-y-3" do |f| %>
      <%= render "shared/form_errors", record: @today_measurement, margin_class: "" %>

      <div>
        <label class="label-dark"><%= t("views.weight_entries.measurements.form.date_label") %></label>
        <%= f.date_field :date,
            value: @today_measurement.date || Date.today,
            max: Date.today,
            class: "input-dark mt-1",
            data: { "body-measurement-form-target": "dateField", action: "change->body-measurement-form#checkDate" } %>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <% BodyMeasurement::MEASUREMENT_FIELDS.each do |field| %>
          <div class="<%= "col-span-2" if field == BodyMeasurement::MEASUREMENT_FIELDS.last %>">
            <label class="label-dark"><%= t("views.weight_entries.measurements.fields.#{field}") %></label>
            <div class="relative mt-1">
              <%= f.number_field field,
                  step: 0.1, min: 0, max: 300,
                  value: @today_measurement.public_send(field),
                  placeholder: measurement_placeholder(field, current_user),
                  class: "input-dark pr-10",
                  data: {
                    controller: "digit-limit",
                    action: "input->digit-limit#limit",
                    "body-measurement-form-target": "field",
                    field: field,
                    digit_limit_max_integer_digits_value: 3,
                    digit_limit_max_decimal_digits_value: 1
                  } %>
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle">cm</span>
            </div>
          </div>
        <% end %>
      </div>

      <div>
        <label class="label-dark"><%= t("views.weight_entries.measurements.form.photo_label") %></label>
        <div class="flex items-center gap-2 mt-1" data-controller="file-input-preview">
          <%= f.label :image, t("views.weight_entries.measurements.form.photo_choose"),
              class: "btn-secondary text-xs px-3 py-1.5 cursor-pointer shrink-0" %>
          <%= f.file_field :image,
              class: "hidden",
              accept: "image/jpeg,image/png",
              data: { "file-input-preview-target": "input", action: "change->file-input-preview#update" } %>
          <i class="fas fa-xmark text-ink-subtle text-lg cursor-default"
             data-file-input-preview-target="icon" data-tooltip=""></i>
        </div>
        <p class="text-xs text-ink-subtle/60 mt-1.5"><%= t("views.weight_entries.measurements.form.photo_hint") %></p>
      </div>

      <%= f.submit t("views.weight_entries.measurements.form.submit"), class: "btn-primary w-full cursor-pointer" %>
    <% end %>
  </div>

  <%# Historique %>
  <div class="md:col-span-2 bg-surface-raised border border-surface-border/40 rounded-2xl p-6 flex flex-col"
       data-controller="measurement-photo">
    <h2 class="text-sm font-semibold text-ink-primary mb-4"><%= t("views.weight_entries.measurements.history.title") %></h2>

    <template data-measurement-photo-target="template">
      <div class="fixed inset-0 z-50 flex items-center justify-center p-4"
           data-measurement-photo-modal
           data-controller="modal"
           data-action="click->modal#handleBackdropClick keydown@document->modal#handleEscape">
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
        <div class="relative w-full max-w-lg bg-surface-raised border border-surface-border/50 rounded-2xl shadow-2xl transition-all duration-200 ease-out scale-95 opacity-0 flex flex-col max-h-[90vh] overflow-hidden"
             data-modal-target="panel">
          <div class="flex items-center justify-between px-5 py-4 border-b border-surface-border/40 shrink-0">
            <p class="text-sm font-semibold text-ink-primary" data-slot="date"></p>
            <button type="button" data-action="click->modal#close"
                    class="w-8 h-8 flex items-center justify-center rounded-lg text-ink-subtle hover:text-ink-primary hover:bg-surface-hover transition-colors">
              <i class="fas fa-times text-sm"></i>
            </button>
          </div>
          <img data-slot="image" class="w-full object-contain bg-surface-base flex-1 min-h-0" alt="">
          <p class="px-5 py-3 text-xs text-ink-subtle border-t border-surface-border/40 shrink-0" data-slot="measurements"></p>
        </div>
      </div>
    </template>

    <% recent = @history_measurements %>

    <% if recent.any? %>
      <div class="flex-1 min-h-0 overflow-y-auto divide-y divide-surface-border/30 pr-1 scrollbar-thin">
        <% recent.each do |entry| %>
          <%
            thumbnail_url = entry.image.attached? ? body_measurement_image_url(entry, variant: :thumbnail) : nil
            row_content = capture do
          %>
            <div class="flex items-center gap-3">
              <% if thumbnail_url.present? %>
                <%= image_tag thumbnail_url,
                      class: "w-10 h-10 rounded-lg object-cover border border-surface-border/40 group-hover:border-brand/50 transition-colors" %>
              <% end %>
              <p class="text-sm text-ink-muted"><%= l(entry.date, format: :long) %></p>
            </div>
            <div class="flex items-center gap-2 text-xs text-ink-subtle">
              <% BodyMeasurement::MEASUREMENT_FIELDS.each do |field| %>
                <% if entry.public_send(field).present? %>
                  <span><%= t("views.weight_entries.measurements.fields_short.#{field}") %> <%= entry.public_send(field) %></span>
                <% end %>
              <% end %>
            </div>
          <%
            end
          %>
          <div class="flex items-center justify-between py-2.5 group">
            <% if thumbnail_url.present? %>
              <%= tag.button row_content, type: "button", class: "flex items-center justify-between flex-1 gap-3 text-left cursor-pointer",
                    data: {
                      action: "click->measurement-photo#open",
                      measurement_photo_photo_url_param: body_measurement_image_url(entry, variant: :medium),
                      measurement_photo_date_param: l(entry.date, format: :long),
                      measurement_photo_measurements_param: measurement_summary_text(entry)
                    } %>
            <% else %>
              <div class="flex items-center justify-between flex-1 gap-3"><%= row_content %></div>
            <% end %>
            <div class="flex items-center gap-3">
              <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                <%= link_to body_measurement_path(entry),
                    data: {
                      turbo_method: :delete,
                      action: "click->confirm#show",
                      confirm_message: t("views.weight_entries.measurements.history.delete_confirm")
                    },
                    class: "inline-flex items-center justify-center w-7 h-7 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors" do %>
                  <i class="fas fa-trash text-xs"></i>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <% if @measurements_pagy&.pages&.> 1 %>
        <div class="mt-3 flex justify-center">
          <%= render PaginationComponent.new(pagy: @measurements_pagy) %>
        </div>
      <% end %>
    <% else %>
      <div class="flex-1 min-h-0 flex flex-col items-center justify-center border border-dashed border-surface-border/50 rounded-xl">
        <i class="fas fa-ruler text-2xl text-ink-subtle mb-2"></i>
        <p class="text-sm text-ink-subtle"><%= t("views.weight_entries.measurements.history.empty") %></p>
      </div>
    <% end %>
  </div>

</div>
