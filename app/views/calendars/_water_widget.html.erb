<%
  water_goal = profile&.water_goal_ml.presence || 2000

  workout_mins  = day.workout_sessions.sum { |s| s.duration_minutes.to_i }
  cardio_mins   = day.cardio_sessions.sum  { |s| s.total_duration.to_i }
  total_mins    = workout_mins + cardio_mins
  workout_bonus = if total_mins >= 90
    600
  elsif total_mins >= 60
    500
  elsif total_mins >= 30
    350
  else
    0
  end
  effective_goal = water_goal + workout_bonus

  water_ml  = day.water_ml.to_i
  raw_pct   = effective_goal > 0 ? (water_ml.to_f / effective_goal * 100) : 0
  pct       = [raw_pct, 100].min
  remaining = [effective_goal - water_ml, 0].max
  glasses   = remaining > 0 ? (remaining / 250.0).ceil : 0

  ring_color_class = if pct >= 100
    "stroke-status-success"
  elsif pct >= 66
    "stroke-status-info"
  elsif pct >= 33
    "stroke-status-warning"
  else
    "stroke-status-danger"
  end

  value_color = if pct >= 100
    "text-status-success"
  elsif pct >= 66
    "text-status-info"
  elsif pct >= 33
    "text-status-warning"
  else
    "text-status-danger"
  end

  btn_small  = [((water_goal / 8.0) / 50.0).round * 50, 50].max
  btn_medium = [((water_goal / 4.0) / 50.0).round * 50, 100].max
  btn_large  = [((water_goal / 2.0) / 50.0).round * 50, 200].max
%>

<div id="water_widget"
     data-controller="water-widget collapsible"
     data-collapsible-storage-key="water-widget"
     class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-3 mb-4">

  <%# Header %>
  <div class="flex items-center justify-between cursor-pointer select-none"
       data-action="click->collapsible#toggle"
       data-collapsible-target="trigger">
    <div class="flex items-center gap-2">
      <i class="fas fa-chevron-down text-xs text-ink-subtle transition-transform duration-200"
         data-collapsible-target="icon"></i>
      <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider">
        <%= t("views.calendars.water.title") %>
      </span>
    </div>
    <div class="flex items-center gap-1 text-sm">
      <span class="font-bold text-ink-primary"><%= water_ml %></span>
      <span class="text-ink-subtle text-xs">/ <%= effective_goal %> ml</span>
    </div>
  </div>

  <%# Corps collapsible %>
  <div data-collapsible-target="content" class="mt-4">

    <div class="flex gap-4 items-center">

      <%# Colonne gauche — Ring %>
      <div class="flex flex-col items-center justify-center flex-shrink-0 w-[38%]">
        <%= render RingComponent.new(value: water_ml, goal: effective_goal, size: :md,
              color_class: ring_color_class, percentage_color_class: value_color) do %>
          <% if water_ml >= 1000 %>
            <span class="text-lg font-bold leading-none <%= value_color %>">
              <%= "#{(water_ml / 1000.0).round(1)}L" %>
            </span>
          <% else %>
            <div class="flex items-baseline gap-0.5 leading-none">
              <span class="text-base font-bold <%= value_color %>"><%= water_ml %></span>
              <span class="text-[9px] text-ink-subtle">ml</span>
            </div>
          <% end %>
          <span class="text-[9px] text-ink-subtle">
            <% if effective_goal >= 1000 %>
              / <%= (effective_goal / 1000.0).round(1) %> L
            <% else %>
              / <%= effective_goal %> ml
            <% end %>
          </span>
        <% end %>
      </div>

      <%# Colonne droite %>
      <div class="flex flex-col flex-1 min-w-0 gap-2">

        <%# Callout contextuel %>
        <% if pct >= 100 %>
          <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-status-success/10 border border-status-success/20">
            <i class="fas fa-check-circle text-status-success text-xs shrink-0"></i>
            <span class="text-xs font-semibold text-status-success"><%= t("views.calendars.water.goal_reached") %></span>
          </div>
        <% else %>
          <div class="flex items-center justify-between gap-2 px-3 py-2 rounded-lg bg-surface-hover/60 border border-surface-border/40">
            <div>
              <p class="text-xs text-ink-muted">
                <%= t("views.calendars.water.remaining", ml: number_with_delimiter(remaining)) %>
              </p>
              <% if glasses > 0 %>
                <p class="text-[10px] text-ink-subtle/60 mt-0.5">
                  ≈ <%= t("views.calendars.water.glasses", count: glasses) %>
                </p>
              <% end %>
            </div>
            <% if workout_bonus > 0 %>
              <div class="flex items-center gap-1 shrink-0">
                <i class="fas fa-dumbbell text-[10px] text-brand"></i>
                <span class="text-[10px] font-medium text-brand">
                  <%= t("views.calendars.water.workout_bonus", ml: workout_bonus) %>
                </span>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Boutons dynamiques %>
        <div class="grid grid-cols-3 gap-1.5">
          <% [[btn_small, "fa-glass-water", "small_glass"], [btn_medium, "fa-glass-water-droplet", "medium_glass"], [btn_large, "fa-bottle-water", "bottle"]].each do |ml, icon, key| %>
            <%= link_to update_water_day_path(day, delta: ml),
                data: { turbo_method: :patch },
                title: t("views.calendars.water.#{key}"),
                class: "flex flex-col items-center gap-1 py-1.5 px-1 rounded-xl border border-surface-border/50 bg-surface-hover hover:border-brand/40 hover:bg-brand/5 transition-colors group" do %>
              <i class="fas <%= icon %> text-sm text-ink-subtle group-hover:text-brand transition-colors"></i>
              <span class="text-xs font-bold text-ink-primary leading-none">+<%= ml %></span>
              <span class="text-[9px] text-ink-subtle leading-none">ml</span>
            <% end %>
          <% end %>
        </div>

        <%# Form caché pour le montant custom %>
        <%= form_with url: update_water_day_path(day), method: :patch,
              data: { water_widget_target: "customAmountForm" } do |f| %>
          <%= f.hidden_field :delta, value: 0, data: { water_widget_target: "deltaInput" } %>
        <% end %>

        <%# Input custom inline (masqué par défaut) %>
        <div data-water-widget-target="customForm" class="hidden">
          <div class="flex gap-1.5">
            <div class="relative flex-1">
              <input type="number"
                     min="1" max="5000" step="10"
                     data-water-widget-target="customInput"
                     data-action="keydown.enter->water-widget#submitCustom"
                     class="input-dark text-xs py-1.5 pr-8 w-full"/>
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[10px] text-ink-subtle pointer-events-none">ml</span>
            </div>
            <button type="button"
                    data-action="click->water-widget#submitCustom"
                    aria-label="<%= t('views.calendars.water.custom_add') %>"
                    title="<%= t('views.calendars.water.custom_add') %>"
                    class="btn-primary px-3 py-1.5 shrink-0 flex items-center justify-center self-stretch">
              <i class="fas fa-check text-xs"></i>
            </button>
            <button type="button"
                    data-action="click->water-widget#toggleCustom"
                    aria-label="<%= t('views.calendars.water.custom_cancel') %>"
                    title="<%= t('views.calendars.water.custom_cancel') %>"
                    class="px-3 py-1.5 shrink-0 flex items-center justify-center self-stretch rounded-lg border border-status-danger/40 text-status-danger hover:bg-status-danger/10 transition-colors">
              <i class="fas fa-xmark text-xs"></i>
            </button>
          </div>
        </div>

        <%# Ligne basse : toggle custom + reset %>
        <div class="flex items-center gap-1.5">
          <button type="button"
                  data-action="click->water-widget#toggleCustom"
                  data-water-widget-target="customToggle"
                  class="flex-1 text-[10px] font-medium text-ink-subtle hover:text-ink-primary border border-surface-border/40 hover:border-surface-border rounded-lg py-1.5 transition-colors text-center">
            <%= t("views.calendars.water.custom_toggle") %>
          </button>
          <% if water_ml > 0 %>
            <%= link_to update_water_day_path(day, amount: 0),
                data: { turbo_method: :patch, water_widget_target: "resetBtn" },
                title: t("views.calendars.water.reset"),
                class: "p-1.5 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger/10 transition-colors" do %>
              <i class="fas fa-rotate-left text-xs"></i>
            <% end %>
          <% end %>
        </div>

      </div>
    </div>

  </div>
</div>
