<%
  water_goal = profile&.water_goal_ml.presence || 2000
  water_ml   = day.water_ml
  pct        = water_goal > 0 ? [(water_ml.to_f / water_goal * 100).round(1), 100].min : 0

  bar_color = if water_ml == 0
                "bg-transparent"
              elsif pct >= 100
                "bg-status-success"
              elsif pct >= 50
                "bg-status-info"
              else
                "bg-status-warning"
              end

  text_color = if water_ml == 0
                 "text-ink-subtle"
               elsif pct >= 100
                 "text-status-success"
               elsif pct >= 50
                 "text-status-info"
               else
                 "text-status-warning"
               end
%>

<div id="water_widget"
     data-controller="collapsible"
     data-collapsible-storage-key="water-widget"
     data-collapsible-open-by-default
     class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-3 mb-4">

  <%# Header (always visible, click to toggle) %>
  <div class="flex items-center justify-between cursor-pointer select-none"
       data-action="click->collapsible#toggle"
       data-collapsible-target="trigger">
    <div class="flex items-center gap-2">
      <i class="fas fa-chevron-down text-xs text-ink-subtle transition-transform duration-200"
         data-collapsible-target="icon"></i>
      <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider">
        <%= t("views.calendars.water.title") %>
      </span>
    </div>
    <div class="flex items-center gap-1 text-sm">
      <span class="font-bold <%= text_color %>"><%= water_ml %></span>
      <span class="text-ink-subtle text-xs">/ <%= water_goal %> ml</span>
      <% glasses = (water_ml / 250.0).floor %>
      <% if glasses > 0 %>
        <span class="text-ink-subtle/50 text-xs ml-0.5">
          · <%= t("views.calendars.water.glasses", count: glasses) %>
        </span>
      <% end %>
    </div>
  </div>

  <%# Collapsible content %>
  <div data-collapsible-target="content" class="mt-3">

    <%# Progress bar %>
    <div class="w-full bg-surface-hover rounded-full h-2 overflow-hidden mb-4">
      <div class="h-2 rounded-full transition-all duration-500 <%= bar_color %>"
           style="width: <%= pct %>%"></div>
    </div>

    <%# Quick-add buttons %>
    <div class="flex items-center gap-2 flex-wrap">
      <% [100, 200, 300, 400, 500].each do |ml| %>
        <%= link_to "+#{ml}", update_water_day_path(day, delta: ml),
            data: { turbo_method: :patch },
            class: "btn-secondary text-xs px-3 py-1.5" %>
      <% end %>

      <% if water_ml > 0 %>
        <div class="ml-auto">
          <%= link_to t("views.calendars.water.reset"), update_water_day_path(day, amount: 0),
              data: { turbo_method: :patch },
              class: "text-xs text-ink-subtle hover:text-status-danger transition-colors px-2 py-1.5 rounded-lg hover:bg-status-danger_dim/20" %>
        </div>
      <% end %>
    </div>

  </div>

</div>
