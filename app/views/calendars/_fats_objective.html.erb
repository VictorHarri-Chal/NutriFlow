<div class="<%= fats_percentage > 105 ? 'bg-status-danger_dim/30 border-status-danger/40' : fats_percentage >= 100 ? 'bg-status-success_dim/30 border-status-success/40' : 'bg-surface-raised border-surface-border/50' %> rounded-lg p-4 border transition-all duration-300">
  <div class="flex justify-between items-center mb-3">
    <div class="flex items-center">
      <h4 class="font-medium text-ink-muted"><%= t("views.calendars.fats") %></h4>
      <% if fats_percentage > 105 %>
        <div class="ml-2 flex items-center">
          <i class="fas fa-exclamation-triangle text-status-danger mr-1"></i>
          <span class="text-xs font-medium text-status-danger"><%= t("views.calendars.exceeded") %></span>
        </div>
      <% elsif fats_percentage >= 100 %>
        <div class="ml-2 flex items-center">
          <i class="fas fa-check-circle text-status-success mr-1"></i>
          <span class="text-xs font-medium text-status-success"><%= t("views.calendars.reached") %></span>
        </div>
      <% end %>
    </div>
    <span class="text-sm <%= fats_percentage > 105 ? 'text-status-danger font-medium' : fats_percentage >= 100 ? 'text-status-success font-medium' : 'text-ink-subtle' %>">
      <%= total_fats.round(1) %> / <%= daily_fats_goal.round(1) %> g
    </span>
  </div>

  <div class="progress-track mb-3">
    <div class="h-4 rounded-full transition-all duration-500 <%= fats_percentage > 105 ? 'bg-status-danger' : 'bg-brand' %>"
         style="width: <%= [fats_percentage, 100].min %>%"></div>
    <% if fats_percentage > 105 %>
      <div class="absolute inset-0 bg-status-danger opacity-20 animate-pulse"></div>
    <% end %>
  </div>

  <div class="flex justify-between items-center">
    <span class="text-sm font-bold <%= fats_percentage > 105 ? 'text-status-danger' : fats_percentage >= 100 ? 'text-status-success' : 'text-brand' %>">
      <%= fats_percentage %>%
    </span>
    <% if fats_percentage > 105 %>
      <span class="text-sm font-bold text-status-danger bg-status-danger_dim/30 px-2 py-1 rounded-full">
        +<%= (total_fats - daily_fats_goal).round(1) %> g
      </span>
    <% elsif fats_percentage >= 100 %>
      <span class="text-sm font-bold text-status-success bg-status-success_dim/30 px-2 py-1 rounded-full">
        <i class="fas fa-check mr-1"></i><%= t("views.calendars.goal_reached") %>
      </span>
    <% else %>
      <span class="text-sm text-ink-subtle bg-surface-hover px-2 py-1 rounded-full">
        -<%= (daily_fats_goal - total_fats).round(1) %> g
      </span>
    <% end %>
  </div>
</div>
