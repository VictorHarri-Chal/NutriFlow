<%# Cardio widget — mirrors _workout_widget pattern %>
<% sessions = day.cardio_sessions.includes(:day, cardio_blocks: {}).order(:created_at) %>
<% total_cal = sessions.sum(&:total_calories) %>
<% total_min = sessions.sum(&:total_duration) %>

<div id="cardio_widget"
     data-controller="collapsible"
     data-collapsible-storage-key="cardio-widget"
     data-collapsible-open-by-default
     class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-3 mb-4">

  <%# Header (click to toggle) %>
  <div class="flex items-center justify-between cursor-pointer select-none"
       data-action="click->collapsible#toggle"
       data-collapsible-target="trigger">
    <div class="flex items-center gap-2">
      <i class="fas fa-chevron-down text-xs text-ink-subtle transition-transform duration-200"
         data-collapsible-target="icon"></i>
      <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider">
        <%= t("views.cardio_sessions.widget.title") %>
      </span>
    </div>

    <% if sessions.any? %>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1 text-xs font-medium text-status-success/70">
          <i class="fas fa-fire-alt text-[9px]"></i>
          <%= total_cal %> kcal
        </span>
        <span class="text-xs text-ink-subtle/50">·</span>
        <span class="text-xs text-ink-subtle">
          <%= total_min %> min
        </span>
      </div>
    <% end %>
  </div>

  <%# Collapsible content %>
  <div data-collapsible-target="content" class="mt-3 space-y-2">

    <% if sessions.any? %>
      <% sessions.each do |cardio_session| %>
        <%= render "cardio_sessions/session_card",
                   cardio_session: cardio_session,
                   show_actions: true %>
      <% end %>
    <% else %>
      <p class="text-sm text-ink-subtle text-center py-4">
        <%= t("views.cardio_sessions.widget.empty") %>
      </p>
    <% end %>

  </div>
</div>
