<div class="flex items-center gap-2">

  <%# ── Date picker pill ── %>
  <div class="flex items-center bg-surface-raised border border-surface-border/50 rounded-xl overflow-hidden text-sm">
    <%= link_to calendars_path(date: (selected_date - 1.day).strftime('%Y-%m-%d')),
                class: "w-8 h-8 flex items-center justify-center text-ink-subtle hover:text-ink-primary hover:bg-surface-hover transition-colors",
                data: { turbo: false },
                title: t("views.calendars.previous_day") do %>
      <i class="fas fa-chevron-left text-xs"></i>
    <% end %>

    <input type="date"
           id="date-selector"
           value="<%= selected_date.strftime('%Y-%m-%d') %>"
           class="bg-transparent border-x border-surface-border/40 px-3 h-8 text-ink-primary text-sm focus:outline-none hover:bg-surface-hover focus:bg-surface-hover transition-colors cursor-pointer"
           autocomplete="off"
           data-lpignore="true"
           data-1p-ignore
           data-controller="date-selector">

    <%= link_to calendars_path(date: (selected_date + 1.day).strftime('%Y-%m-%d')),
                class: "w-8 h-8 flex items-center justify-center text-ink-subtle hover:text-ink-primary hover:bg-surface-hover transition-colors",
                data: { turbo: false },
                title: t("views.calendars.next_day") do %>
      <i class="fas fa-chevron-right text-xs"></i>
    <% end %>
  </div>

  <%# ── Secondary actions: icon-only buttons, same height as pill ── %>
  <div class="flex items-center gap-1">

    <% unless selected_date == Date.current %>
      <%= link_to calendars_path(date: Date.current.strftime('%Y-%m-%d')),
                  class: "w-8 h-8 flex items-center justify-center rounded-xl text-ink-primary bg-surface-raised border border-surface-border/50 hover:bg-surface-hover transition-all",
                  data: { turbo: false },
                  title: t("views.calendars.today") do %>
        <i class="fas fa-calendar-day text-xs"></i>
      <% end %>
    <% end %>

    <%= button_to copy_yesterday_calendars_path,
          params: { date: selected_date.to_s },
          method: :post,
          class: "w-8 h-8 flex items-center justify-center rounded-xl text-ink-primary bg-surface-raised border border-surface-border/50 hover:bg-surface-hover transition-all",
          form: { class: "contents" },
          title: t("views.calendars.copy_yesterday_title") do %>
      <i class="fas fa-copy text-xs"></i>
    <% end %>

    <button type="button"
            data-action="click->heatmap-panel#open"
            class="w-8 h-8 flex items-center justify-center rounded-xl text-ink-primary bg-surface-raised border border-surface-border/50 hover:bg-surface-hover hover:text-brand transition-all"
            title="<%= t("views.calendars.heatmap.open_button") %>">
      <i class="fas fa-calendar-alt text-xs"></i>
    </button>

  </div>

</div>
