<div id="nutrition_summary" class="bg-surface-base rounded-xl border border-surface-border/50 p-6">
  <div class="flex items-center mb-4">
    <i class="fas fa-chart-pie text-brand mr-3 text-xl"></i>
    <h2 class="text-lg font-semibold text-ink-primary"><%= t("views.calendars.nutrition_summary") %></h2>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
    <div class="macro-card">
      <div class="flex items-center justify-center mb-2">
        <i class="fas fa-fire text-brand mr-2"></i>
        <div class="text-2xl font-bold text-brand"><%= total_calories %> kcal</div>
      </div>
      <div class="text-xs text-ink-subtle mt-1"><%= Food.human_attribute_name(:calories) %></div>
    </div>

    <div class="macro-card">
      <div class="flex items-center justify-center mb-2">
        <i class="fas fa-dumbbell text-ink-subtle mr-2"></i>
        <div class="text-2xl font-bold text-ink-primary"><%= total_proteins %> g</div>
      </div>
      <div class="text-xs text-ink-subtle mt-1"><%= Food.human_attribute_name(:proteins) %></div>
    </div>

    <div class="macro-card">
      <div class="flex items-center justify-center mb-2">
        <i class="fas fa-bread-slice text-ink-subtle mr-2"></i>
        <div class="text-2xl font-bold text-ink-primary"><%= total_carbs %> g</div>
      </div>
      <div class="text-xs text-ink-subtle mt-1"><%= Food.human_attribute_name(:carbs) %></div>
    </div>

    <div class="macro-card">
      <div class="flex items-center justify-center mb-2">
        <i class="fas fa-oil-can text-ink-subtle mr-2"></i>
        <div class="text-2xl font-bold text-ink-primary"><%= total_fats %> g</div>
      </div>
      <div class="text-xs text-ink-subtle mt-1"><%= Food.human_attribute_name(:fats) %></div>
    </div>

    <div class="macro-card">
      <div class="flex items-center justify-center mb-2">
        <i class="fas fa-candy-cane text-ink-subtle mr-2"></i>
        <div class="text-2xl font-bold text-ink-primary"><%= total_sugars %> g</div>
      </div>
      <div class="text-xs text-ink-subtle mt-1"><%= Food.human_attribute_name(:sugars) %></div>
    </div>
  </div>
</div>
