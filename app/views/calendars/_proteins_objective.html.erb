<div class="<%= proteins_percentage >= 100 ? 'bg-status-success_dim/30 border-status-success/40' : 'bg-surface-raised border-surface-border/50' %> rounded-lg p-4 border transition-all duration-300">
  <div class="flex justify-between items-center mb-3">
    <div class="flex items-center">
      <h4 class="font-medium text-ink-muted"><%= t("views.calendars.proteins") %></h4>
      <% if proteins_percentage > 105 %>
        <div class="ml-2 flex items-center">
          <i class="fas fa-star text-status-success mr-1"></i>
          <span class="text-xs font-medium text-status-success"><%= t("views.calendars.excellent") %></span>
        </div>
      <% elsif proteins_percentage >= 100 %>
        <div class="ml-2 flex items-center">
          <i class="fas fa-check-circle text-status-success mr-1"></i>
          <span class="text-xs font-medium text-status-success"><%= t("views.calendars.reached") %></span>
        </div>
      <% end %>
    </div>
    <span class="text-sm <%= proteins_percentage >= 100 ? 'text-status-success font-medium' : 'text-ink-subtle' %>">
      <%= total_proteins.round(1) %> / <%= daily_protein_goal.round(1) %> g
    </span>
  </div>

  <div class="progress-track mb-3">
    <div class="h-4 rounded-full transition-all duration-500 bg-brand"
         style="width: <%= [proteins_percentage, 100].min %>%"></div>
    <% if proteins_percentage > 105 %>
      <div class="absolute inset-0 bg-status-success opacity-10 animate-pulse"></div>
    <% end %>
  </div>

  <div class="flex justify-between items-center">
    <span class="text-sm font-bold <%= proteins_percentage >= 100 ? 'text-status-success' : 'text-brand' %>">
      <%= proteins_percentage %>%
    </span>
    <% if proteins_percentage >= 100 %>
      <span class="text-sm font-bold text-status-success bg-status-success_dim/30 px-2 py-1 rounded-full">
        <% if proteins_percentage > 105 %>
          +<%= (total_proteins - daily_protein_goal).round(1) %> g
        <% else %>
          <i class="fas fa-check mr-1"></i><%= t("views.calendars.goal_reached") %>
        <% end %>
      </span>
    <% else %>
      <span class="text-sm text-ink-subtle bg-surface-hover px-2 py-1 rounded-full">
        -<%= (daily_protein_goal - total_proteins).round(1) %> g
      </span>
    <% end %>
  </div>
</div>
