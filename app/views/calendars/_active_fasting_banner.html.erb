<div id="active_fasting_banner" class="<%= 'mb-3' if active_fasting_session %>">
  <% if active_fasting_session %>
    <%= link_to "#fasting_widget",
          class: "flex items-center gap-2 px-4 py-2 rounded-xl bg-brand/10 border border-brand/25 hover:bg-brand/15 transition-colors" do %>
      <i class="fas fa-hourglass-half text-brand text-xs"></i>
      <p class="text-xs font-medium text-brand">
        <%= t("views.calendars.fasting.banner_text",
              protocol: t("enumerize.fasting_session.protocol.#{active_fasting_session.protocol}"),
              remaining: format_fasting_duration(active_fasting_session.remaining_hours),
              time: format_fasting_clock(active_fasting_session.expected_end_at)) %>
      </p>
    <% end %>
  <% end %>
</div>
