<div id="daily_objectives">
<% if profile&.weight.present? %>
  <div class="card-section p-6 mt-8">
    <h3 class="text-lg font-semibold text-ink-primary mb-4 flex items-center">
      <i class="fas fa-bullseye mr-2 text-brand"></i>
      <%= t("views.calendars.daily_objectives") %>
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <%= render 'calendars/calories_objective',
                 total_calories: total_calories,
                 daily_calorie_goal: daily_calorie_goal,
                 calories_percentage: calories_percentage %>

      <%= render 'calendars/proteins_objective',
                 total_proteins: total_proteins,
                 daily_protein_goal: daily_protein_goal,
                 proteins_percentage: proteins_percentage %>

      <%= render 'calendars/fats_objective',
                 total_fats: total_fats,
                 daily_fats_goal: daily_fats_goal,
                 fats_percentage: fats_percentage %>
    </div>
  </div>
<% else %>
  <div class="bg-status-warning_dim/20 border border-status-warning/30 rounded-lg p-6 mt-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <i class="fas fa-exclamation-triangle text-status-warning mr-3 text-xl"></i>
        <div>
          <h3 class="text-lg font-semibold text-status-warning"><%= t("views.calendars.objectives_unavailable") %></h3>
          <p class="text-status-warning/70 text-sm mt-1">
            <%= t("views.calendars.objectives_unavailable_hint") %>
          </p>
        </div>
      </div>
      <%= link_to edit_profile_path, class: "btn-primary" do %>
        <i class="fas fa-user-edit"></i>
        <%= t("views.calendars.complete_profile") %>
      <% end %>
    </div>
  </div>
<% end %>
</div>
