<% sessions = day.workout_sessions.includes(:day, workout_sets: :exercise).order(:created_at) %>
<% total_cal = sessions.sum { |s| s.estimated_calories(current_user.profile&.weight&.to_f) } %>

<div id="workout_widget"
     data-controller="collapsible"
     data-collapsible-storage-key="workout-widget"
     data-collapsible-open-by-default
     class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-3 mb-4">

  <%# Header (click to toggle) %>
  <div class="flex items-center justify-between cursor-pointer select-none"
       data-action="click->collapsible#toggle"
       data-collapsible-target="trigger">
    <div class="flex items-center gap-2">
      <i class="fas fa-chevron-down text-xs text-ink-subtle transition-transform duration-200"
         data-collapsible-target="icon"></i>
      <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider">
        <%= t("views.workout_sessions.widget.title") %>
      </span>
    </div>
    <% if sessions.any? %>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-400/75">
          <i class="fas fa-fire-alt text-[9px]"></i>
          <%= total_cal %> kcal
        </span>
        <span class="text-xs text-ink-subtle/50">·</span>
        <span class="text-xs text-ink-subtle">
          <%= t("views.workout_sessions.widget.session_count", count: sessions.size) %>
        </span>
      </div>
    <% end %>
  </div>

  <%# Collapsible content %>
  <div data-collapsible-target="content" class="mt-3 space-y-3">

    <% if sessions.any? %>
      <% sessions.each do |workout_session| %>
        <%= render "workout_sessions/session_card", workout_session: workout_session, show_actions: true %>
      <% end %>
    <% else %>
      <p class="text-sm text-ink-subtle text-center py-4"><%= t("views.workout_sessions.widget.empty") %></p>
    <% end %>

  </div>
</div>
