<%
  all_done = defined?(calories_percentage) && calories_percentage &&
             calories_percentage.between?(90, 115) &&
             proteins_percentage.between?(85, 115)
  has_breakdown = defined?(tdee_breakdown) && tdee_breakdown.present?
%>

<div id="daily_panel"
     class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-3 mb-4"
     data-controller="collapsible"
     data-collapsible-storage-key="daily-panel"
     data-collapsible-open-by-default>

  <% if defined?(daily_calorie_goal) && daily_calorie_goal %>

    <% if all_done %>
      <div class="flex items-center gap-1.5 mb-3 text-status-success text-xs font-medium tracking-wide uppercase">
        <i class="fas fa-check-circle"></i>
        <%= t("views.calendars.day_complete") %>
      </div>
    <% end %>

    <%# ── Header (trigger) ── %>
    <div class="flex items-center gap-2 cursor-pointer select-none"
         data-action="click->collapsible#toggle"
         data-collapsible-target="trigger">
      <i class="fas fa-chevron-down text-xs text-ink-subtle transition-transform duration-200"
         data-collapsible-target="icon"></i>
      <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider flex-1">
        <%= t("views.calendars.calories") %>
      </span>
      <span class="text-xs text-ink-subtle">
        <span class="text-base font-bold <%= calories_percentage > 105 ? 'text-status-danger' : calories_percentage >= 100 ? 'text-status-success' : 'text-ink-primary' %>">
          <%= total_calories.to_i %>
        </span>
        <span class="ml-0.5">/ <%= daily_calorie_goal %> kcal</span>
      </span>
    </div>

    <%# ── Collapsible content ── %>
    <div data-collapsible-target="content" class="mt-3">

      <%# Progress bar %>
      <div class="w-full bg-surface-hover rounded-full h-2 overflow-hidden mb-4">
        <div class="h-2 rounded-full transition-all duration-700 ease-out <%= calories_percentage > 105 ? 'bg-status-danger' : calories_percentage >= 100 ? 'bg-status-success' : 'bg-brand' %>"
             style="width: <%= [calories_percentage.to_f, 100].min %>%"></div>
      </div>

      <%# Macros grid %>
      <div class="grid grid-cols-2 gap-x-8 gap-y-3">

        <%# Protéines %>
        <div>
          <div class="flex justify-between items-baseline mb-1">
            <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider"><%= t("views.calendars.proteins") %></span>
            <span class="text-xs text-ink-subtle">
              <span class="font-semibold <%= proteins_percentage >= 100 ? 'text-status-success' : 'text-ink-primary' %>"><%= total_proteins %></span>
              <span class="ml-0.5">/ <%= daily_protein_goal.round(0) %> g</span>
            </span>
          </div>
          <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
            <div class="h-1.5 rounded-full transition-all duration-700 ease-out <%= proteins_percentage >= 100 ? 'bg-status-success' : 'bg-blue-400' %>"
                 style="width: <%= [proteins_percentage.to_f, 100].min %>%"></div>
          </div>
        </div>

        <%# Glucides (macro adaptif — budget restant après protéines + lipides) %>
        <div>
          <div class="flex justify-between items-baseline mb-1">
            <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider flex items-center gap-1">
              <%= t("views.calendars.carbs") %>
              <% if defined?(daily_carbs_goal) && daily_carbs_goal %>
                <span class="text-[9px] text-ink-subtle/50 font-normal normal-case tracking-normal"><%= t("views.calendars.carbs_adaptive_hint") %></span>
              <% end %>
            </span>
            <% if defined?(daily_carbs_goal) && daily_carbs_goal %>
              <span class="text-xs text-ink-subtle">
                <span class="font-semibold text-ink-primary"><%= total_carbs %></span>
                <span class="ml-0.5">/ <%= daily_carbs_goal %> g</span>
              </span>
            <% else %>
              <span class="text-xs font-semibold text-ink-primary"><%= total_carbs %> g</span>
            <% end %>
          </div>
          <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
            <% carbs_pct = defined?(carbs_percentage) && carbs_percentage ? carbs_percentage : 0 %>
            <div class="h-1.5 rounded-full transition-all duration-700 ease-out bg-amber-400"
                 style="width: <%= [carbs_pct.to_f, 100].min %>%"></div>
          </div>
        </div>

        <%# Lipides %>
        <div>
          <div class="flex justify-between items-baseline mb-1">
            <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider"><%= t("views.calendars.fats") %></span>
            <span class="text-xs text-ink-subtle">
              <span class="font-semibold <%= fats_percentage > 105 ? 'text-status-danger' : fats_percentage >= 100 ? 'text-status-success' : 'text-ink-primary' %>"><%= total_fats %></span>
              <span class="ml-0.5">/ <%= daily_fats_goal.round(0) %> g</span>
            </span>
          </div>
          <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
            <div class="h-1.5 rounded-full transition-all duration-700 ease-out <%= fats_percentage > 105 ? 'bg-status-danger' : fats_percentage >= 100 ? 'bg-status-success' : 'bg-orange-400' %>"
                 style="width: <%= [fats_percentage.to_f, 100].min %>%"></div>
          </div>
        </div>

        <%# Sucres %>
        <div>
          <div class="flex justify-between items-baseline mb-1">
            <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider flex items-center gap-1">
              <%= t("views.calendars.sugars") %>
              <span class="text-ink-subtle/50 font-normal normal-case tracking-normal"><%= t("views.calendars.sugars_of_carbs") %></span>
            </span>
            <span class="text-xs font-semibold text-ink-primary"><%= total_sugars %> g</span>
          </div>
          <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
            <% sugars_pct = defined?(daily_carbs_goal) && daily_carbs_goal && daily_carbs_goal > 0 ? [total_sugars.to_f / daily_carbs_goal * 100, 100].min : 0 %>
            <div class="h-1.5 rounded-full transition-all duration-700 ease-out bg-pink-400/60"
                 style="width: <%= sugars_pct %>%"></div>
          </div>
        </div>

      </div><%# /macros grid %>

      <%# ── Breakdown dépenses ── %>
      <% if has_breakdown && current_user.show_tdee_breakdown? %>
        <div class="mt-4 pt-4 border-t border-surface-border/30">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-ink-subtle/60 mb-3">
            <%= t("views.calendars.breakdown.title") %>
          </p>

          <div class="space-y-2 text-xs">

            <%# BMR %>
            <div class="flex items-center justify-between">
              <span class="text-ink-subtle flex items-center gap-1.5">
                <i class="fas fa-heart-pulse text-[9px] text-ink-subtle/50 w-3 text-center"></i>
                <%= t("views.calendars.breakdown.bmr") %>
              </span>
              <span class="font-medium text-ink-primary tabular-nums">
                <%= number_with_delimiter(tdee_breakdown[:bmr]) %> kcal
              </span>
            </div>

            <%# Job NEAT %>
            <div class="flex items-center justify-between">
              <span class="text-ink-subtle flex items-center gap-1.5">
                <i class="fas fa-briefcase text-[9px] text-ink-subtle/50 w-3 text-center"></i>
                <%= t("views.calendars.breakdown.job_neat") %>
              </span>
              <span class="font-medium text-ink-primary tabular-nums">
                +<%= number_with_delimiter(tdee_breakdown[:job_neat]) %> kcal
              </span>
            </div>

            <%# Steps — always-visible input %>
            <div class="flex items-center justify-between">
              <span class="text-ink-subtle flex items-center gap-1.5">
                <i class="fas fa-shoe-prints text-[9px] text-ink-subtle/50 w-3 text-center"></i>
                <%= t("views.calendars.breakdown.steps") %>
              </span>
              <div class="flex items-center gap-2">
                <%= form_with url: update_steps_day_path(day), method: :patch,
                              data: { controller: "auto-save", turbo_stream: true } do %>
                  <div class="flex items-center gap-1">
                    <input type="number"
                           name="steps"
                           value="<%= tdee_breakdown[:steps_custom] ? tdee_breakdown[:steps_count] : nil %>"
                           min="0" max="99999" step="1"
                           placeholder="<%= tdee_breakdown[:steps_count] %>"
                           class="w-20 bg-surface-base border border-surface-border rounded-lg px-2 py-1 text-xs text-ink-primary focus:outline-none focus:ring-1 focus:ring-brand focus:border-brand"
                           data-action="change->auto-save#save blur->auto-save#save">
                    <span class="text-ink-subtle text-[10px]"><%= t("views.calendars.breakdown.steps_unit") %></span>
                  </div>
                <% end %>
                <span class="font-medium text-ink-primary tabular-nums">
                  +<%= number_with_delimiter(tdee_breakdown[:steps_kcal]) %> kcal
                </span>
              </div>
            </div>

            <%# Workout %>
            <div class="flex items-center justify-between">
              <span class="text-ink-subtle flex items-center gap-1.5">
                <i class="fas fa-dumbbell text-[9px] text-ink-subtle/50 w-3 text-center"></i>
                <%= t("views.calendars.breakdown.workout") %>
              </span>
              <% if tdee_breakdown[:workout_kcal] > 0 %>
                <span class="font-medium text-emerald-400/80 tabular-nums">
                  +<%= number_with_delimiter(tdee_breakdown[:workout_kcal]) %> kcal
                </span>
              <% else %>
                <span class="text-ink-subtle/50 text-[11px]"><%= t("views.calendars.breakdown.no_workout") %></span>
              <% end %>
            </div>

            <%# Séparateur + total + objectif ajusté %>
            <div class="pt-2 mt-1 border-t border-surface-border/20 space-y-2">

              <div class="flex items-center justify-between">
                <span class="text-ink-subtle/70"><%= t("views.calendars.breakdown.total_tdee") %></span>
                <span class="font-semibold text-ink-primary tabular-nums">
                  <%= number_with_delimiter(tdee_breakdown[:tdee]) %> kcal
                </span>
              </div>

              <% goal_key = profile&.goal.to_s.presence || "maintenance" %>
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-ink-subtle/70 block"><%= t("views.calendars.breakdown.goal_label.#{goal_key}") %></span>
                  <span class="text-[10px] text-ink-subtle/40"><%= t("views.calendars.breakdown.goal_intake_hint") %></span>
                </div>
                <span class="font-bold text-brand tabular-nums">
                  <%= number_with_delimiter(daily_calorie_goal) %> kcal
                </span>
              </div>

            </div>

          </div><%# /space-y %>
        </div><%# /breakdown %>
      <% end %>

    </div><%# /content %>

  <% else %>

    <%# No profile / no goal set — show raw totals %>
    <div class="flex items-center justify-between gap-6">
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-6 flex-1">
        <div>
          <div class="text-lg font-bold text-brand"><%= total_calories %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5">kcal</div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_proteins %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.proteins") %></div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_carbs %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.carbs") %></div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_fats %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.fats") %></div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_sugars %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.sugars") %></div>
        </div>
      </div>
      <%= link_to edit_profile_path,
            class: "inline-flex items-center gap-2 flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-medium bg-brand/10 border border-brand/25 text-brand hover:bg-brand/15 hover:border-brand/40 transition-colors" do %>
        <i class="fas fa-circle-user text-xs"></i>
        <%= t("views.calendars.complete_profile_hint") %>
        <i class="fas fa-arrow-right text-xs opacity-60"></i>
      <% end %>
    </div>

  <% end %>

</div>
