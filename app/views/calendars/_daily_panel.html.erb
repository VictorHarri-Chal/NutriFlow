<%
  all_done = defined?(calories_percentage) && calories_percentage &&
             calories_percentage.between?(90, 115) &&
             proteins_percentage.between?(85, 115)
%>

<div id="daily_panel"
     class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-3 mb-4"
     data-controller="collapsible"
     data-collapsible-storage-key="daily-panel"
     data-collapsible-open-by-default>

  <% if defined?(daily_calorie_goal) && daily_calorie_goal %>

    <% if all_done %>
      <div class="flex items-center gap-1.5 mb-3 text-status-success text-xs font-medium tracking-wide uppercase">
        <i class="fas fa-check-circle"></i>
        <%= t("views.calendars.day_complete") %>
      </div>
    <% end %>

    <%# ── Calories : header toujours visible (trigger) ── %>
    <div class="flex items-center gap-2 cursor-pointer select-none"
         data-action="click->collapsible#toggle"
         data-collapsible-target="trigger">
      <i class="fas fa-chevron-down text-xs text-ink-subtle transition-transform duration-200"
         data-collapsible-target="icon"></i>
      <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider flex-1"><%= t("views.calendars.calories") %></span>
      <span class="text-xs text-ink-subtle">
        <span class="text-base font-bold <%= calories_percentage > 105 ? 'text-status-danger' : calories_percentage >= 100 ? 'text-status-success' : 'text-ink-primary' %>"><%= total_calories %></span>
        <span class="ml-0.5">/ <%= daily_calorie_goal %> kcal</span>
      </span>
    </div>

    <%# ── Barre calories + macros : collapsible ── %>
    <div data-collapsible-target="content" class="mt-3">
      <div class="w-full bg-surface-hover rounded-full h-2 overflow-hidden mb-4">
        <div class="h-2 rounded-full transition-all duration-700 ease-out <%= calories_percentage > 105 ? 'bg-status-danger' : calories_percentage >= 100 ? 'bg-status-success' : 'bg-brand' %>"
             style="width: <%= [calories_percentage.to_f, 100].min %>%"></div>
      </div>
      <div class="grid grid-cols-2 gap-x-8 gap-y-3">

      <%# Protéines %>
      <div>
        <div class="flex justify-between items-baseline mb-1">
          <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider"><%= t("views.calendars.proteins") %></span>
          <span class="text-xs text-ink-subtle">
            <span class="font-semibold <%= proteins_percentage >= 100 ? 'text-status-success' : 'text-ink-primary' %>"><%= total_proteins %></span>
            <span class="ml-0.5">/ <%= daily_protein_goal.round(0) %> g</span>
          </span>
        </div>
        <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
          <div class="h-1.5 rounded-full transition-all duration-700 ease-out <%= proteins_percentage >= 100 ? 'bg-status-success' : 'bg-blue-400' %>"
               style="width: <%= [proteins_percentage.to_f, 100].min %>%"></div>
        </div>
      </div>

      <%# Glucides %>
      <div>
        <div class="flex justify-between items-baseline mb-1">
          <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider"><%= t("views.calendars.carbs") %></span>
          <% if defined?(daily_carbs_goal) && daily_carbs_goal %>
            <span class="text-xs text-ink-subtle">
              <span class="font-semibold <%= carbs_percentage > 105 ? 'text-status-danger' : carbs_percentage >= 100 ? 'text-status-success' : 'text-ink-primary' %>"><%= total_carbs %></span>
              <span class="ml-0.5">/ <%= daily_carbs_goal %> g</span>
            </span>
          <% else %>
            <span class="text-xs font-semibold text-ink-primary"><%= total_carbs %> g</span>
          <% end %>
        </div>
        <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
          <% carbs_pct = defined?(carbs_percentage) && carbs_percentage ? carbs_percentage : 0 %>
          <div class="h-1.5 rounded-full transition-all duration-700 ease-out <%= carbs_pct > 105 ? 'bg-status-danger' : carbs_pct >= 100 ? 'bg-status-success' : 'bg-amber-400' %>"
               style="width: <%= [carbs_pct.to_f, 100].min %>%"></div>
        </div>
      </div>

      <%# Lipides %>
      <div>
        <div class="flex justify-between items-baseline mb-1">
          <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider"><%= t("views.calendars.fats") %></span>
          <span class="text-xs text-ink-subtle">
            <span class="font-semibold <%= fats_percentage > 105 ? 'text-status-danger' : fats_percentage >= 100 ? 'text-status-success' : 'text-ink-primary' %>"><%= total_fats %></span>
            <span class="ml-0.5">/ <%= daily_fats_goal.round(0) %> g</span>
          </span>
        </div>
        <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
          <div class="h-1.5 rounded-full transition-all duration-700 ease-out <%= fats_percentage > 105 ? 'bg-status-danger' : fats_percentage >= 100 ? 'bg-status-success' : 'bg-orange-400' %>"
               style="width: <%= [fats_percentage.to_f, 100].min %>%"></div>
        </div>
      </div>

      <%# Sucres — informatif ── %>
      <div>
        <div class="flex justify-between items-baseline mb-1">
          <span class="text-xs font-medium text-ink-subtle uppercase tracking-wider flex items-center gap-1">
            <%= t("views.calendars.sugars") %>
            <span class="text-ink-subtle/50 font-normal normal-case tracking-normal">(dont gluc.)</span>
          </span>
          <span class="text-xs font-semibold text-ink-primary"><%= total_sugars %> g</span>
        </div>
        <div class="w-full bg-surface-hover rounded-full h-1.5 overflow-hidden">
          <% sugars_pct = defined?(daily_carbs_goal) && daily_carbs_goal && daily_carbs_goal > 0 ? [total_sugars.to_f / daily_carbs_goal * 100, 100].min : 0 %>
          <div class="h-1.5 rounded-full transition-all duration-700 ease-out bg-pink-400/60"
               style="width: <%= sugars_pct %>%"></div>
        </div>
      </div><%# last macro %>
      </div><%# /grid %>
    </div><%# /content %>

  <% else %>

    <div class="flex items-center justify-between gap-6">
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-6 flex-1">
        <div>
          <div class="text-lg font-bold text-brand"><%= total_calories %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5">kcal</div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_proteins %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.proteins") %></div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_carbs %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.carbs") %></div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_fats %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.fats") %></div>
        </div>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= total_sugars %></div>
          <div class="text-xs text-ink-subtle uppercase tracking-wider mt-0.5"><%= t("views.calendars.sugars") %></div>
        </div>
      </div>
      <%= link_to edit_profile_path, class: "text-xs text-brand hover:text-brand-hover transition-colors flex-shrink-0" do %>
        <i class="fas fa-user-edit mr-1"></i><%= t("views.calendars.complete_profile_hint") %>
      <% end %>
    </div>

  <% end %>

</div>
