<% content_for :page_title, t("views.calendars.page_title") %>

<div class="mt-16 pb-28">

  <div class="max-w-6xl mx-auto px-4 lg:px-0" id="calendar-content">

    <%# ── Header: date + controls ── %>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 py-4">
      <h1 class="text-2xl font-bold text-ink-primary"><%= l(@selected_date, format: :long) %></h1>
      <%= render 'calendars/date_navigation', selected_date: @selected_date, day: @day %>
    </div>

    <%# ── Daily nutrition panel ── %>
    <%= render 'calendars/daily_panel',
               total_calories:      @total_calories,
               total_proteins:      @total_proteins,
               total_carbs:         @total_carbs,
               total_fats:          @total_fats,
               total_sugars:        @total_sugars,
               profile:             @profile,
               daily_calorie_goal:  @daily_calorie_goal,
               daily_protein_goal:  @daily_protein_goal,
               daily_fats_goal:     @daily_fats_goal,
               calories_percentage: @calories_percentage,
               proteins_percentage: @proteins_percentage,
               fats_percentage:     @fats_percentage %>

    <%# ── Inline form (turbo frame) ── %>
    <%= turbo_frame_tag "item_form" %>

    <%# ── Food groups ── %>
    <div class="mt-2">
      <%= render 'calendars/day_items',
                 all_day_items:           @all_day_items,
                 day_items_by_group:      @day_items_by_group,
                 day_items_without_group: @day_items_without_group,
                 day:                     @day %>
    </div>

    <%# ── Daily note ── %>
    <%= render 'calendars/day_note', day: @day %>

  </div>
</div>

<%# ── FAB ── %>
<% if @all_day_items.any? %>
  <div class="fixed bottom-6 right-6 z-40 flex items-center gap-2">
    <%= link_to new_day_day_recipe_path(@day),
          class: "btn-secondary shadow-lg text-sm",
          data: { turbo_frame: "item_form" } do %>
      <i class="fas fa-plus"></i>
      <span class="hidden sm:inline"><%= t("views.calendars.add_recipe") %></span>
    <% end %>
    <%= link_to new_day_day_food_path(@day),
          class: "btn-primary shadow-lg shadow-brand/30 text-sm",
          data: { turbo_frame: "item_form" } do %>
      <i class="fas fa-plus"></i>
      <span class="hidden sm:inline"><%= t("views.calendars.add_food") %></span>
    <% end %>
  </div>
<% end %>
