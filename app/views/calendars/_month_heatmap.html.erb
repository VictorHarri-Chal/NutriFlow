<%
  goal      = daily_calorie_goal.to_f
  today     = Date.current
  first_day = heatmap_start
  last_day  = heatmap_end
  start_offset = (first_day.wday == 0 ? 6 : first_day.wday - 1)

  cell_bg = ->(date) {
    cals = month_heatmap[date]
    if date > today
      "bg-transparent border-transparent"
    elsif cals.nil? || cals == 0
      "bg-surface-hover/30 border-surface-border/20"
    elsif goal > 0
      pct = cals / goal * 100
      if pct >= 95
        "bg-status-success/25 border-status-success/40"
      elsif pct >= 70
        "bg-status-warning/25 border-status-warning/40"
      else
        "bg-status-danger/25 border-status-danger/40"
      end
    else
      "bg-brand/15 border-brand/25"
    end
  }

  cell_hover = ->(date) {
    cals = month_heatmap[date]
    if date > today
      ""
    elsif cals.nil? || cals == 0
      "hover:bg-surface-hover/60 hover:border-surface-border/40"
    elsif goal > 0
      pct = cals / goal * 100
      if pct >= 95
        "hover:bg-status-success/40 hover:border-status-success/60"
      elsif pct >= 70
        "hover:bg-status-warning/40 hover:border-status-warning/60"
      else
        "hover:bg-status-danger/40 hover:border-status-danger/60"
      end
    else
      "hover:bg-brand/30 hover:border-brand/40"
    end
  }

  day_text_class = ->(date) {
    if date == selected_date
      "text-brand font-bold"
    elsif date > today
      "text-ink-subtle/25"
    elsif month_heatmap[date]&.positive?
      "text-ink-primary font-semibold"
    else
      "text-ink-subtle/50"
    end
  }

  cal_text_class = ->(date) {
    cals = month_heatmap[date]
    return "text-transparent" if cals.nil? || cals == 0 || date > today
    goal > 0 ? (cals / goal * 100 >= 95 ? "text-status-success" : cals / goal * 100 >= 70 ? "text-status-warning" : "text-status-danger") : "text-brand/70"
  }

  fmt_cals = ->(cals) {
    return "" unless cals && cals > 0
    cals >= 1000 ? "#{(cals / 1000.0).round(1)}k" : cals.to_s
  }
%>

<div class="px-5 pb-6 pt-2">

  <%# En-tête %>
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-1.5">
      <%= link_to calendars_path(date: selected_date.to_s, heatmap_month: (first_day - 1.month).strftime("%Y-%m")),
                  class: "w-7 h-7 flex items-center justify-center rounded-lg text-ink-subtle hover:text-ink-primary hover:bg-surface-hover transition-colors",
                  data: { turbo_frame: "month_heatmap" },
                  title: t("views.calendars.heatmap.previous_month") do %>
        <i class="fas fa-chevron-left text-xs"></i>
      <% end %>

      <h3 class="text-base font-bold text-ink-primary w-36 text-center">
        <%= l(first_day, format: "%B %Y").capitalize %>
      </h3>

      <% if first_day.next_month.beginning_of_month <= today.beginning_of_month %>
        <%= link_to calendars_path(date: selected_date.to_s, heatmap_month: (first_day + 1.month).strftime("%Y-%m")),
                    class: "w-7 h-7 flex items-center justify-center rounded-lg text-ink-subtle hover:text-ink-primary hover:bg-surface-hover transition-colors",
                    data: { turbo_frame: "month_heatmap" },
                    title: t("views.calendars.heatmap.next_month") do %>
          <i class="fas fa-chevron-right text-xs"></i>
        <% end %>
      <% else %>
        <div class="w-7 h-7"></div>
      <% end %>

      <% unless first_day == today.beginning_of_month %>
        <%= link_to calendars_path(date: selected_date.to_s, heatmap_month: today.strftime("%Y-%m")),
                    class: "w-7 h-7 flex items-center justify-center rounded-lg text-ink-subtle bg-surface-raised border border-surface-border/50 hover:bg-surface-hover hover:text-ink-primary transition-colors ml-1",
                    data: { turbo_frame: "month_heatmap" },
                    title: t("views.calendars.heatmap.current_month") do %>
          <i class="fas fa-calendar-day text-xs"></i>
        <% end %>
      <% end %>
    </div>
    <div class="flex items-center gap-3 text-[10px] text-ink-subtle/60">
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-sm bg-status-success/40 border border-status-success/60 inline-block"></span>
        <%= t("views.calendars.heatmap.legend_goal") %>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-sm bg-status-warning/40 border border-status-warning/60 inline-block"></span>
        <%= t("views.calendars.heatmap.legend_partial") %>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-sm bg-status-danger/40 border border-status-danger/60 inline-block"></span>
        <%= t("views.calendars.heatmap.legend_low") %>
      </span>
    </div>
  </div>

  <%# Jours de la semaine %>
  <div class="grid grid-cols-7 gap-1.5 mb-1.5">
    <% %w[Lun Mar Mer Jeu Ven Sam Dim].each do |d| %>
      <div class="text-center text-[10px] font-medium text-ink-subtle/40 pb-1"><%= d %></div>
    <% end %>
  </div>

  <%# Grille %>
  <div class="grid grid-cols-7 gap-1.5">
    <% start_offset.times { %><div></div><% } %>

    <% (first_day..last_day).each do |date| %>
      <% cals = month_heatmap[date] %>
      <% is_future = date > today %>
      <% is_today  = date == today %>
      <%= link_to (is_future ? "#" : calendars_path(date: date.to_s)),
            class: "group flex flex-col items-center justify-center gap-0.5 rounded-lg border py-2 px-1 transition-all duration-150
                    #{cell_bg.call(date)} #{is_future ? 'cursor-default' : "cursor-pointer #{cell_hover.call(date)}"}
                    #{is_today ? 'ring-1 ring-brand/50' : ''}",
            data: (is_future ? {} : { turbo_frame: "_top" }) do %>

        <%# Numéro du jour %>
        <span class="text-xs leading-none <%= day_text_class.call(date) %>">
          <%= date.day %>
        </span>

        <%# Calories %>
        <span class="block h-[9px] text-[9px] leading-none font-medium <%= cal_text_class.call(date) %>">
          <%= fmt_cals.call(cals) %>
        </span>

        <%# Dot "aujourd'hui" %>
        <% if is_today %>
          <span class="w-1 h-1 rounded-full bg-brand mt-0.5"></span>
        <% end %>

      <% end %>
    <% end %>
  </div>

  <%# Statistiques du mois %>
  <% logged_days   = month_heatmap.count { |d, c| d <= today && c > 0 } %>
  <% count_end_day = today <= last_day ? today : last_day %>
  <% past_days     = (first_day..count_end_day).count %>
  <% if past_days > 0 %>
    <div class="mt-5 pt-4 border-t border-surface-border/30 grid grid-cols-3 gap-4 text-center">
      <div>
        <div class="text-lg font-bold text-ink-primary"><%= logged_days %></div>
        <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_logged") %></div>
      </div>
      <% if goal > 0 %>
        <% goal_days = month_heatmap.count { |d, c| d <= today && c > 0 && c / goal * 100 >= 95 } %>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= goal_days %></div>
          <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_goal_reached") %></div>
        </div>
        <% avg = month_heatmap.select { |d, c| d <= today && c > 0 }.values.sum / [logged_days, 1].max %>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= avg.round %></div>
          <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_avg_kcal") %></div>
        </div>
      <% else %>
        <div>
          <div class="text-lg font-bold text-ink-primary"><%= past_days %></div>
          <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_days") %></div>
        </div>
        <div></div>
      <% end %>
    </div>
  <% end %>

</div>
