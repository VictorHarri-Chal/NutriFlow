<%
  goal      = daily_calorie_goal.to_f
  today     = Date.current
  first_day = heatmap_start
  last_day  = heatmap_end
  start_offset = (first_day.wday == 0 ? 6 : first_day.wday - 1)

  cell_bg = ->(date) {
    cals = month_heatmap[date]
    if date > today
      "bg-transparent border-transparent"
    elsif cals.nil? || cals == 0
      "bg-surface-hover/30 border-surface-border/20"
    elsif goal > 0
      pct = cals / goal * 100
      if pct >= 95
        "bg-green-500/20 border-green-500/25"
      elsif pct >= 70
        "bg-amber-400/20 border-amber-400/25"
      else
        "bg-red-500/15 border-red-500/20"
      end
    else
      "bg-brand/15 border-brand/25"
    end
  }

  cell_hover = ->(date) {
    cals = month_heatmap[date]
    if date > today
      ""
    elsif cals.nil? || cals == 0
      "hover:bg-surface-hover/60 hover:border-surface-border/40"
    elsif goal > 0
      pct = cals / goal * 100
      if pct >= 95
        "hover:bg-green-500/35 hover:border-green-500/50"
      elsif pct >= 70
        "hover:bg-amber-400/35 hover:border-amber-400/50"
      else
        "hover:bg-red-500/30 hover:border-red-500/40"
      end
    else
      "hover:bg-brand/30 hover:border-brand/40"
    end
  }

  day_text_class = ->(date) {
    if date == selected_date
      "text-brand font-bold"
    elsif date > today
      "text-ink-subtle/25"
    elsif month_heatmap[date]&.positive?
      "text-ink-primary font-semibold"
    else
      "text-ink-subtle/50"
    end
  }

  cal_text_class = ->(date) {
    cals = month_heatmap[date]
    return "text-transparent" if cals.nil? || cals == 0 || date > today
    goal > 0 ? (cals / goal * 100 >= 95 ? "text-green-400/80" : cals / goal * 100 >= 70 ? "text-amber-400/80" : "text-red-400/70") : "text-brand/70"
  }

  fmt_cals = ->(cals) {
    return "" unless cals && cals > 0
    cals >= 1000 ? "#{(cals / 1000.0).round(1)}k" : cals.to_s
  }
%>

<div class="px-5 pb-6 pt-2">

  <%# En-tête %>
  <div class="flex items-center justify-between mb-5">
    <div>
      <h3 class="text-base font-bold text-ink-primary">
        <%= l(first_day, format: "%B %Y").capitalize %>
      </h3>
      <% if goal > 0 %>
        <p class="text-xs text-ink-subtle mt-0.5">
          <%= t("views.calendars.heatmap.goal_hint", goal: goal.round) %>
        </p>
      <% end %>
    </div>
    <div class="flex items-center gap-3 text-[10px] text-ink-subtle/60">
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-sm bg-green-500/20 border border-green-500/25 inline-block"></span>
        <%= t("views.calendars.heatmap.legend_goal") %>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-sm bg-amber-400/20 border border-amber-400/25 inline-block"></span>
        <%= t("views.calendars.heatmap.legend_partial") %>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-sm bg-red-500/15 border border-red-500/20 inline-block"></span>
        <%= t("views.calendars.heatmap.legend_low") %>
      </span>
    </div>
  </div>

  <%# Jours de la semaine %>
  <div class="grid grid-cols-7 gap-1.5 mb-1.5">
    <% %w[Lun Mar Mer Jeu Ven Sam Dim].each do |d| %>
      <div class="text-center text-[10px] font-medium text-ink-subtle/40 pb-1"><%= d %></div>
    <% end %>
  </div>

  <%# Grille %>
  <div class="grid grid-cols-7 gap-1.5">
    <% start_offset.times { %><div></div><% } %>

    <% (first_day..last_day).each do |date| %>
      <% cals = month_heatmap[date] %>
      <% is_future = date > today %>
      <% is_today  = date == today %>
      <%= link_to (is_future ? "#" : calendars_path(date: date.to_s)),
            class: "group flex flex-col items-center justify-center gap-0.5 rounded-lg border py-2 px-1 transition-all duration-150
                    #{cell_bg.call(date)} #{is_future ? 'cursor-default' : "cursor-pointer #{cell_hover.call(date)}"}
                    #{is_today ? 'ring-1 ring-brand/50' : ''}",
            data: { turbo: false } do %>

        <%# Numéro du jour %>
        <span class="text-xs leading-none <%= day_text_class.call(date) %>">
          <%= date.day %>
        </span>

        <%# Calories %>
        <span class="text-[9px] leading-none font-medium <%= cal_text_class.call(date) %>">
          <%= fmt_cals.call(cals) %>
        </span>

        <%# Dot "aujourd'hui" %>
        <% if is_today %>
          <span class="w-1 h-1 rounded-full bg-brand mt-0.5"></span>
        <% end %>

      <% end %>
    <% end %>
  </div>

  <%# Statistiques du mois %>
  <% logged_days   = month_heatmap.count { |d, c| d <= today && c > 0 } %>
  <% count_end_day = today <= last_day ? today : last_day %>
  <% past_days     = (first_day..count_end_day).count %>
  <% if past_days > 0 %>
    <div class="mt-5 pt-4 border-t border-surface-border/30 grid grid-cols-3 gap-4 text-center">
      <div>
        <div class="text-lg font-bold text-ink-primary"><%= logged_days %></div>
        <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_logged") %></div>
      </div>
      <% if goal > 0 %>
        <% goal_days = month_heatmap.count { |d, c| d <= today && c > 0 && c / goal * 100 >= 95 } %>
        <div>
          <div class="text-lg font-bold text-green-400"><%= goal_days %></div>
          <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_goal_reached") %></div>
        </div>
        <% avg = month_heatmap.select { |d, c| d <= today && c > 0 }.values.sum / [logged_days, 1].max %>
        <div>
          <div class="text-lg font-bold text-ink-muted"><%= avg.round %></div>
          <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_avg_kcal") %></div>
        </div>
      <% else %>
        <div>
          <div class="text-lg font-bold text-ink-muted"><%= past_days %></div>
          <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.calendars.heatmap.stats_days") %></div>
        </div>
        <div></div>
      <% end %>
    </div>
  <% end %>

</div>
