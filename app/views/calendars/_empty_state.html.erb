<div class="text-center py-12">
  <i class="fas fa-utensils text-6xl text-gray-300 mb-4"></i>
  <h3 class="text-lg font-medium text-gray-900 mb-2"><%= t("views.calendars.empty_state.title") %></h3>
  <p class="text-gray-600 mb-6"><%= t("views.calendars.empty_state.description") %></p>
  <%= link_to new_day_day_food_path(day), class: "inline-flex items-center px-6 py-3 bg-blue-800 text-white rounded-lg shadow hover:bg-blue-600 transition font-medium", data: { turbo_frame: "item_form" } do %>
    <i class="fas fa-plus mr-2"></i>
    <%= t("views.calendars.empty_state.add_first_food") %>
  <% end %>
</div>
