<% content_for :page_title, t("views.settings.show.page_title") %>

<div class="max-w-5xl mx-auto mt-16" data-controller="tabs" data-tabs-active-tab-value="<%= @active_tab %>">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 items-start">

    <%# ── Nav latérale ── %>
    <div class="lg:col-span-1">
      <div class="card p-2 space-y-0.5">
        <% SettingsController::TABS.each do |key, meta| %>
          <a href="#<%= key %>"
             data-tab="<%= key %>"
             data-tabs-target="tab"
             data-action="click->tabs#switchTab"
             data-active-classes="bg-brand-muted text-brand"
             data-inactive-classes="text-ink-muted"
             class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors cursor-pointer hover:bg-surface-hover hover:text-ink-primary text-ink-muted">
            <i class="fas <%= meta[:icon] %> w-4 text-center text-sm"></i>
            <%= t("views.settings.show.#{meta[:label_key]}") %>
          </a>
        <% end %>
      </div>
    </div>

    <%# ── Contenu ── %>
    <div class="lg:col-span-3">
      <div class="card p-8">
        <% SettingsController::TABS.each_key do |key| %>
          <div id="<%= key %>-tab" data-tabs-target="content" class="<%= @active_tab == key ? '' : 'hidden' %>">
            <%= render "settings/#{key}" %>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
