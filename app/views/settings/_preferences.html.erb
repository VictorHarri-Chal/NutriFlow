<div class="space-y-8">

  <div>
    <h2 class="text-base font-semibold text-ink-primary flex items-center gap-2">
      <i class="fas fa-sliders text-brand text-sm"></i>
      <%= t("views.settings.preferences.title") %>
    </h2>
    <p class="text-sm text-ink-subtle mt-1"><%= t("views.settings.preferences.description") %></p>
  </div>

  <%= form_with url: update_preferences_setting_path, method: :patch do |f| %>

    <%# ── Section journal ── %>
    <div class="border-t border-surface-border/40 pt-6 space-y-4">
      <h3 class="text-sm font-semibold text-ink-primary"><%= t("views.settings.preferences.journal_section") %></h3>

      <%# Toggle : Détail des dépenses énergétiques %>
      <div class="flex items-start justify-between gap-6 py-3">
        <div>
          <label class="text-sm font-medium text-ink-primary block mb-0.5">
            <%= t("views.settings.preferences.show_tdee_breakdown") %>
          </label>
          <p class="text-xs text-ink-subtle"><%= t("views.settings.preferences.show_tdee_breakdown_hint") %></p>
        </div>
        <label class="flex items-center cursor-pointer shrink-0 mt-0.5">
          <input type="hidden" name="user[show_tdee_breakdown]" value="0">
          <input type="checkbox"
                 name="user[show_tdee_breakdown]"
                 value="1"
                 class="sr-only peer"
                 <%= current_user.show_tdee_breakdown? ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <div class="relative w-9 h-5 rounded-full shrink-0 transition-colors bg-surface-border peer-checked:bg-brand
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:rounded-full after:bg-white after:shadow after:transition-transform peer-checked:after:translate-x-4"></div>
        </label>
      </div>

      <%# Toggle : Suivi d'hydratation %>
      <div class="flex items-start justify-between gap-6 py-3 border-t border-surface-border/30">
        <div>
          <label class="text-sm font-medium text-ink-primary block mb-0.5">
            <%= t("views.settings.preferences.show_water_tracking") %>
          </label>
          <p class="text-xs text-ink-subtle"><%= t("views.settings.preferences.show_water_tracking_hint") %></p>
        </div>
        <label class="flex items-center cursor-pointer shrink-0 mt-0.5">
          <input type="hidden" name="user[show_water_tracking]" value="0">
          <input type="checkbox"
                 name="user[show_water_tracking]"
                 value="1"
                 class="sr-only peer"
                 <%= current_user.show_water_tracking? ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <div class="relative w-9 h-5 rounded-full shrink-0 transition-colors bg-surface-border peer-checked:bg-brand
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:rounded-full after:bg-white after:shadow after:transition-transform peer-checked:after:translate-x-4"></div>
        </label>
      </div>

      <%# Toggle : Section entraînement %>
      <div class="flex items-start justify-between gap-6 py-3 border-t border-surface-border/30">
        <div>
          <label class="text-sm font-medium text-ink-primary block mb-0.5">
            <%= t("views.settings.preferences.show_workout_section") %>
          </label>
          <p class="text-xs text-ink-subtle"><%= t("views.settings.preferences.show_workout_section_hint") %></p>
        </div>
        <label class="flex items-center cursor-pointer shrink-0 mt-0.5">
          <input type="hidden" name="user[show_workout_section]" value="0">
          <input type="checkbox"
                 name="user[show_workout_section]"
                 value="1"
                 class="sr-only peer"
                 <%= current_user.show_workout_section? ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <div class="relative w-9 h-5 rounded-full shrink-0 transition-colors bg-surface-border peer-checked:bg-brand
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:rounded-full after:bg-white after:shadow after:transition-transform peer-checked:after:translate-x-4"></div>
        </label>
      </div>

      <%# Toggle : Section cardio %>
      <div class="flex items-start justify-between gap-6 py-3 border-t border-surface-border/30">
        <div>
          <label class="text-sm font-medium text-ink-primary block mb-0.5">
            <%= t("views.settings.preferences.show_cardio_section") %>
          </label>
          <p class="text-xs text-ink-subtle"><%= t("views.settings.preferences.show_cardio_section_hint") %></p>
        </div>
        <label class="flex items-center cursor-pointer shrink-0 mt-0.5">
          <input type="hidden" name="user[show_cardio_section]" value="0">
          <input type="checkbox"
                 name="user[show_cardio_section]"
                 value="1"
                 class="sr-only peer"
                 <%= current_user.show_cardio_section? ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <div class="relative w-9 h-5 rounded-full shrink-0 transition-colors bg-surface-border peer-checked:bg-brand
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:rounded-full after:bg-white after:shadow after:transition-transform peer-checked:after:translate-x-4"></div>
        </label>
      </div>

      <%# Toggle : Section notes & bien-être %>
      <div class="flex items-start justify-between gap-6 py-3 border-t border-surface-border/30">
        <div>
          <label class="text-sm font-medium text-ink-primary block mb-0.5">
            <%= t("views.settings.preferences.show_day_note") %>
          </label>
          <p class="text-xs text-ink-subtle"><%= t("views.settings.preferences.show_day_note_hint") %></p>
        </div>
        <label class="flex items-center cursor-pointer shrink-0 mt-0.5">
          <input type="hidden" name="user[show_day_note]" value="0">
          <input type="checkbox"
                 name="user[show_day_note]"
                 value="1"
                 class="sr-only peer"
                 <%= current_user.show_day_note? ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <div class="relative w-9 h-5 rounded-full shrink-0 transition-colors bg-surface-border peer-checked:bg-brand
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:rounded-full after:bg-white after:shadow after:transition-transform peer-checked:after:translate-x-4"></div>
        </label>
      </div>

    </div>

    <%# ── Section navigation ── %>
    <div class="border-t border-surface-border/40 pt-6 space-y-4">
      <h3 class="text-sm font-semibold text-ink-primary"><%= t("views.settings.preferences.navigation_section") %></h3>

      <%# Toggle : Suivi de poids %>
      <div class="flex items-start justify-between gap-6 py-3">
        <div>
          <label class="text-sm font-medium text-ink-primary block mb-0.5">
            <%= t("views.settings.preferences.show_weight_tracking") %>
          </label>
          <p class="text-xs text-ink-subtle"><%= t("views.settings.preferences.show_weight_tracking_hint") %></p>
        </div>
        <label class="flex items-center cursor-pointer shrink-0 mt-0.5">
          <input type="hidden" name="user[show_weight_tracking]" value="0">
          <input type="checkbox"
                 name="user[show_weight_tracking]"
                 value="1"
                 class="sr-only peer"
                 <%= current_user.show_weight_tracking? ? 'checked' : '' %>
                 onchange="this.form.submit()">
          <div class="relative w-9 h-5 rounded-full shrink-0 transition-colors bg-surface-border peer-checked:bg-brand
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:rounded-full after:bg-white after:shadow after:transition-transform peer-checked:after:translate-x-4"></div>
        </label>
      </div>

    </div>

  <% end %>

</div>
