<div class="space-y-6">

  <div>
    <h2 class="text-base font-semibold text-ink-primary flex items-center gap-2">
      <i class="fas fa-tag text-brand text-sm"></i>
      <%= t("views.settings.food_labels.title") %>
    </h2>
    <p class="text-sm text-ink-subtle mt-1"><%= t("views.settings.food_labels.description") %></p>
  </div>

  <%# ── Formulaire d'ajout ── %>
  <div class="border-t border-surface-border/40 pt-6" data-controller="form-validation">
    <%= simple_form_for @food_label, url: food_labels_path, html: { class: "space-y-3" } do |f| %>

      <div class="flex items-end gap-3">
        <div class="flex-1">
          <%= f.input :name,
              label: t("views.settings.food_labels.label_name_label"),
              placeholder: t("views.settings.food_labels.label_name_placeholder"),
              wrapper_html: { class: "mb-0" },
              label_html: { class: "label-dark" },
              input_html: {
                class: "input-dark",
                data: {
                  form_validation_target: "input",
                  action: "input->form-validation#input keyup->form-validation#keyup"
                }
              } %>
        </div>
        <%= f.submit t("views.settings.food_labels.create"),
            class: "btn-primary cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed shrink-0",
            data: { form_validation_target: "submit" },
            disabled: true %>
      </div>

      <%# Sélecteur de couleur %>
      <div>
        <label class="label-dark block mb-2"><%= t("views.settings.food_labels.color_label") %></label>
        <div class="flex flex-wrap gap-2">
          <% FoodLabel::COLORS.each do |color| %>
            <% style = FoodLabel::COLOR_STYLES[color] %>
            <label class="cursor-pointer group">
              <%= f.radio_button :color, color, class: "sr-only peer", id: "food_label_color_#{color}" %>
              <div class="w-7 h-7 rounded-full <%= style[:dot] %> ring-2 ring-transparent ring-offset-2 ring-offset-surface-raised
                          peer-checked:ring-white/70 transition-all group-hover:ring-white/40"
                   title="<%= color %>"></div>
            </label>
          <% end %>
        </div>
      </div>

    <% end %>
  </div>

  <%# ── Liste ── %>
  <div>
    <% if @food_labels.any? %>
      <div class="divide-y divide-surface-border/30">
        <% @food_labels.each do |label| %>
          <% style = label.color_style %>
          <div class="flex items-center justify-between py-3 group">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg <%= style[:bg] %> border <%= style[:border] %> flex items-center justify-center shrink-0">
                <span class="w-3 h-3 rounded-full <%= style[:dot] %>"></span>
              </div>
              <div>
                <div class="text-sm font-medium <%= style[:text] %>"><%= label.name %></div>
                <% food_count = label.foods.count %>
                <div class="text-xs text-ink-subtle mt-0.5">
                  <%= food_count > 0 ? t("shared.food_count", count: food_count) : t("views.settings.food_groups.no_food") %>
                </div>
              </div>
            </div>
            <div class="opacity-0 group-hover:opacity-100 transition-opacity">
              <%= delete_link_with_confirm(
                    food_label_path(label),
                    confirm: t("views.settings.food_labels.delete_confirm"),
                    icon_class: "fas fa-trash text-sm",
                    title: t("shared.delete"),
                    class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors") %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 border border-dashed border-surface-border/50 rounded-xl">
        <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
          <i class="fas fa-tag text-ink-subtle"></i>
        </div>
        <p class="text-sm font-medium text-ink-primary mb-1"><%= t("views.settings.food_labels.no_labels") %></p>
        <p class="text-xs text-ink-subtle"><%= t("views.settings.food_labels.no_labels_hint") %></p>
      </div>
    <% end %>
  </div>

</div>
