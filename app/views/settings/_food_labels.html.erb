<div class="space-y-6">

  <div>
    <h2 class="text-base font-semibold text-ink-primary flex items-center gap-2">
      <i class="fas fa-tag text-brand text-sm"></i>
      <%= t("views.settings.food_labels.title") %>
    </h2>
    <p class="text-sm text-ink-subtle mt-1"><%= t("views.settings.food_labels.description") %></p>
  </div>

  <%# ── Formulaire d'ajout ── %>
  <div class="border-t border-surface-border/40 pt-6" data-controller="form-validation">
    <%= simple_form_for @food_label, url: food_labels_path, html: { class: "space-y-3" } do |f| %>

      <div class="flex items-end gap-3">
        <div class="flex-1">
          <%= f.input :name,
              label: t("views.settings.food_labels.label_name_label"),
              placeholder: t("views.settings.food_labels.label_name_placeholder"),
              wrapper_html: { class: "mb-0" },
              label_html: { class: "label-dark" },
              input_html: {
                class: "input-dark",
                data: {
                  form_validation_target: "input",
                  action: "input->form-validation#input keyup->form-validation#keyup"
                }
              } %>
        </div>
        <%= f.submit t("views.settings.food_labels.create"),
            class: "btn-primary cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed shrink-0",
            data: { form_validation_target: "submit" },
            disabled: true %>
      </div>

      <%= render "food_labels/color_picker", f: f, id_prefix: "food_label" %>

    <% end %>
  </div>

  <%# ── Liste ── %>
  <div>
    <% if @food_labels.any? %>
      <div class="divide-y divide-surface-border/30">
        <% @food_labels.each do |label| %>
          <%= render "food_labels/food_label", food_label: label %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 border border-dashed border-surface-border/50 rounded-xl">
        <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
          <i class="fas fa-tag text-ink-subtle"></i>
        </div>
        <p class="text-sm font-medium text-ink-primary mb-1"><%= t("views.settings.food_labels.no_labels") %></p>
        <p class="text-xs text-ink-subtle"><%= t("views.settings.food_labels.no_labels_hint") %></p>
      </div>
    <% end %>
  </div>

</div>
