<h2 class="text-xl font-semibold text-ink-primary mb-6"><%= t("views.settings.security.title") %></h2>
<div class="space-y-8">
  <!-- Changement de mot de passe -->
  <div class="bg-surface-base border border-surface-border/40 p-6 rounded-lg">
    <h3 class="text-lg font-medium text-ink-primary mb-4"><%= t("views.settings.security.change_password") %></h3>
    <%= form_with(model: current_user, url: registration_path(current_user), local: true, method: :patch, class: "space-y-4") do |form| %>
      <div>
        <label class="label-dark"><%= t("views.settings.security.current_password") %></label>
        <%= form.password_field :current_password, required: true, autocomplete: "current-password",
                                class: "input-dark",
                                placeholder: t("views.settings.security.current_password_placeholder") %>
      </div>
      <div>
        <label class="label-dark"><%= t("views.settings.security.new_password") %></label>
        <%= form.password_field :password, required: true, autocomplete: "new-password",
                                class: "input-dark",
                                placeholder: t("views.settings.security.new_password_placeholder") %>
        <p class="text-xs text-ink-subtle mt-1"><%= t("views.settings.security.min_chars", count: @minimum_password_length || 6) %></p>
      </div>
      <div>
        <label class="label-dark"><%= t("views.settings.security.confirm_password") %></label>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
                                class: "input-dark",
                                placeholder: t("views.settings.security.confirm_password_placeholder") %>
      </div>

      <%= form.submit t("views.settings.security.update_password"), class: "btn-primary cursor-pointer" %>
    <% end %>
  </div>

  <!-- Réinitialisation par email -->
  <div class="bg-status-warning_dim/20 border border-status-warning/30 p-6 rounded-lg">
    <h3 class="text-lg font-medium text-ink-primary mb-4"><%= t("views.settings.security.forgot_password") %></h3>
    <p class="text-sm text-ink-muted mb-4"><%= t("views.settings.security.forgot_password_hint") %></p>

    <%= form_with(model: User.new, url: password_path(:user), local: true, method: :post, class: "space-y-4") do |form| %>
      <div>
        <label class="label-dark"><%= t("views.settings.security.email_address") %></label>
        <%= form.email_field :email, required: true, autocomplete: "email",
                              value: current_user.email, readonly: true,
                              class: "input-dark bg-surface-hover text-ink-subtle cursor-not-allowed" %>
      </div>

      <%= form.submit t("views.settings.security.send_reset_link"),
                      class: "btn-primary cursor-pointer" %>
    <% end %>
  </div>

  <!-- Suppression du compte -->
  <div class="bg-status-danger_dim/20 border border-status-danger/30 p-6 rounded-lg">
    <h3 class="text-lg font-medium text-status-danger mb-4"><%= t("views.settings.security.delete_account") %></h3>
    <div class="space-y-4">
      <div>
        <p class="text-sm text-status-danger/80 mb-4"><%= t("views.settings.security.delete_account_warning") %></p>
        <button class="btn-danger">
          <%= t("views.settings.security.delete_account_button") %>
        </button>
      </div>
    </div>
  </div>
</div>
