<h2 class="text-xl font-semibold text-gray-900 mb-6"><%= t("views.settings.general.title") %></h2>

<%= form_with url: setting_path, method: :patch, class: "space-y-6" do |f| %>
  <div>
    <label for="locale" class="block text-sm font-medium text-gray-700 mb-2">
      <i class="fas fa-globe mr-1 text-gray-400"></i>
      <%= t("views.settings.general.language") %>
    </label>
    <select name="locale" id="locale"
            class="mt-1 block w-64 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 bg-white">
      <option value="fr" <%= 'selected' if current_user.locale == 'fr' %>>🇫🇷 Français</option>
      <option value="en" <%= 'selected' if current_user.locale == 'en' %>>🇬🇧 English</option>
    </select>
    <p class="mt-1 text-xs text-gray-500"><%= t("views.settings.general.language_hint") %></p>
  </div>

  <div class="pt-2">
    <%= f.submit t("views.settings.general.save"),
          class: "bg-blue-800 text-white px-6 py-2 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200 cursor-pointer" %>
  </div>
<% end %>
