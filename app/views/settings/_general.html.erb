<div class="space-y-6">
  <div>
    <h2 class="text-base font-semibold text-ink-primary flex items-center gap-2">
      <i class="fas fa-sliders text-brand text-sm"></i>
      <%= t("views.settings.general.title") %>
    </h2>
    <p class="text-sm text-ink-subtle mt-1"><%= t("views.settings.general.description") %></p>
  </div>

  <div class="border-t border-surface-border/40 pt-6">
    <%= form_with url: setting_path, method: :patch do |f| %>
      <div class="flex items-start justify-between gap-6">
        <div>
          <label class="text-sm font-medium text-ink-primary block mb-0.5">
            <%= t("views.settings.general.language") %>
          </label>
          <p class="text-xs text-ink-subtle"><%= t("views.settings.general.language_hint") %></p>
        </div>
        <div class="shrink-0">
          <div data-controller="custom-select" class="relative w-40">
            <select name="locale" id="locale"
                    class="sr-only"
                    onchange="this.form.submit()"
                    data-custom-select-target="select">
              <option value="fr" <%= 'selected' if current_user.locale == 'fr' %>>🇫🇷 Français</option>
              <option value="en" <%= 'selected' if current_user.locale == 'en' %>>🇬🇧 English</option>
            </select>
            <button type="button" data-action="click->custom-select#toggle"
                    class="input-dark flex items-center justify-between cursor-pointer w-full text-left text-sm">
              <span data-custom-select-target="label"></span>
              <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
            </button>
            <div data-custom-select-target="dropdown" data-custom-select-dropdown
                 class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl overflow-hidden"></div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
