<h2 class="text-xl font-semibold text-ink-primary mb-6"><%= t("views.settings.general.title") %></h2>

<%= form_with url: setting_path, method: :patch, class: "space-y-6" do |f| %>
  <div>
    <label for="locale" class="label-dark">
      <i class="fas fa-globe mr-1 text-ink-subtle"></i>
      <%= t("views.settings.general.language") %>
    </label>
    <select name="locale" id="locale"
            class="input-dark select-chevron mt-1 block w-64 appearance-none pr-10">
      <option value="fr" <%= 'selected' if current_user.locale == 'fr' %>>🇫🇷 Français</option>
      <option value="en" <%= 'selected' if current_user.locale == 'en' %>>🇬🇧 English</option>
    </select>
    <p class="mt-1 text-xs text-ink-subtle"><%= t("views.settings.general.language_hint") %></p>
  </div>

  <div class="pt-2">
    <%= f.submit t("views.settings.general.save"), class: "btn-primary cursor-pointer" %>
  </div>
<% end %>
