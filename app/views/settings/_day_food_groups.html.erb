<div class="space-y-6">

  <div>
    <h2 class="text-base font-semibold text-ink-primary flex items-center gap-2">
      <i class="fas fa-utensils text-brand text-sm"></i>
      <%= t("views.settings.food_groups.title") %>
    </h2>
    <p class="text-sm text-ink-subtle mt-1"><%= t("views.settings.food_groups.description") %></p>
  </div>

  <%# ── Formulaire d'ajout ── %>
  <div class="border-t border-surface-border/40 pt-6" data-controller="form-validation">
    <%= simple_form_for @day_food_group, url: day_food_groups_path, html: { class: "flex items-end gap-3" } do |f| %>
      <div class="flex-1">
        <%= f.input :name,
            label: t("views.settings.food_groups.group_name_label"),
            placeholder: t("views.settings.food_groups.group_name_placeholder"),
            wrapper_html: { class: "mb-0" },
            label_html: { class: "label-dark" },
            input_html: {
              class: "input-dark",
              data: {
                form_validation_target: "input",
                action: "input->form-validation#input keyup->form-validation#keyup"
              }
            } %>
      </div>
      <%= f.submit t("views.settings.food_groups.create"),
          class: "btn-primary cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed shrink-0",
          data: { form_validation_target: "submit" },
          disabled: true %>
    <% end %>
  </div>

  <%# ── Liste ── %>
  <div>
    <% if @day_food_groups.any? %>
      <div class="divide-y divide-surface-border/30">
        <% @day_food_groups.each do |group| %>
          <div class="flex items-center justify-between py-3 group">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-surface-hover flex items-center justify-center shrink-0">
                <i class="fas fa-utensils text-xs text-ink-subtle"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-ink-primary"><%= group.name %></div>
              </div>
            </div>
            <div class="opacity-0 group-hover:opacity-100 transition-opacity">
              <%= delete_link_with_confirm(
                    day_food_group_path(group),
                    confirm: t("views.settings.food_groups.delete_confirm"),
                    icon_class: "fas fa-trash text-sm",
                    title: t("shared.delete"),
                    class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors") %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 border border-dashed border-surface-border/50 rounded-xl">
        <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
          <i class="fas fa-utensils text-ink-subtle"></i>
        </div>
        <p class="text-sm font-medium text-ink-primary mb-1"><%= t("views.settings.food_groups.no_groups") %></p>
        <p class="text-xs text-ink-subtle"><%= t("views.settings.food_groups.no_groups_hint") %></p>
      </div>
    <% end %>
  </div>

</div>
