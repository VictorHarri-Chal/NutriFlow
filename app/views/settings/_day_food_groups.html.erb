<h2 class="text-xl font-semibold text-gray-900 mb-6"><%= t("views.settings.food_groups.title") %></h2>

<!-- Formulaire pour créer un nouveau groupe -->
<div class="bg-gray-50 p-6 rounded-lg mb-6" data-controller="form-validation">
  <%= simple_form_for @day_food_group, url: day_food_groups_path, html: { class: "flex items-end gap-4" } do |f| %>
    <div class="flex-1">
      <%= f.input :name,
          label: t("views.settings.food_groups.group_name_label"),
          placeholder: t("views.settings.food_groups.group_name_placeholder"),
          wrapper_html: { class: "mb-0" },
          input_html: {
            class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
            data: {
              form_validation_target: "input",
              action: "input->form-validation#input keyup->form-validation#keyup"
            }
          } %>
    </div>
    <div>
      <%= f.submit t("views.settings.food_groups.create"),
          class: "bg-blue-800 text-white px-4 py-2 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:bg-gray-400 disabled:cursor-not-allowed disabled:hover:bg-gray-400",
          data: { form_validation_target: "submit" },
          disabled: true %>
    </div>
  <% end %>
</div>

<!-- Tableau des groupes existants -->
<div class="bg-white shadow-sm rounded-lg overflow-hidden">
  <% if @day_food_groups.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t("views.settings.food_groups.name_col") %>
          </th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t("views.settings.food_groups.foods_col") %>
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t("shared.actions") %>
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @day_food_groups.each do |group| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <i class="fas fa-utensils text-blue-500 mr-3"></i>
                <div class="text-sm font-medium text-gray-900"><%= group.name %></div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center justify-center">
                <% food_count = group.day_foods.count %>
                <% if food_count == 0 %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                    <i class="fas fa-circle text-gray-400 mr-1 text-xs"></i>
                    <%= t("views.settings.food_groups.no_food") %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <i class="fas fa-check-circle text-green-500 mr-1 text-xs"></i>
                    <%= t("shared.food_count", count: food_count) %>
                  </span>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= delete_link_with_confirm(day_food_group_path(group),
                                          confirm: t("views.settings.food_groups.delete_confirm"),
                                          icon_class: "fas fa-trash mr-2",
                                          class: "text-red-600 hover:text-red-900 inline-flex items-center",
                                          title: t("shared.delete")) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-12">
      <i class="fas fa-utensils text-gray-400 text-4xl mb-4"></i>
      <h3 class="text-lg font-medium text-gray-900 mb-2"><%= t("views.settings.food_groups.no_groups") %></h3>
      <p class="text-gray-500 mb-4"><%= t("views.settings.food_groups.no_groups_hint") %></p>
      <p class="text-sm text-gray-400">
        <%= t("views.settings.food_groups.explanation") %>
      </p>
    </div>
  <% end %>
</div>
