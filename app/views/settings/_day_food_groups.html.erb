<h2 class="text-xl font-semibold text-ink-primary mb-6"><%= t("views.settings.food_groups.title") %></h2>

<!-- Formulaire pour créer un nouveau groupe -->
<div class="bg-surface-base border border-surface-border/40 p-6 rounded-lg mb-6" data-controller="form-validation">
  <%= simple_form_for @day_food_group, url: day_food_groups_path, html: { class: "flex items-end gap-4" } do |f| %>
    <div class="flex-1">
      <%= f.input :name,
          label: t("views.settings.food_groups.group_name_label"),
          placeholder: t("views.settings.food_groups.group_name_placeholder"),
          wrapper_html: { class: "mb-0" },
          input_html: {
            class: "input-dark",
            data: {
              form_validation_target: "input",
              action: "input->form-validation#input keyup->form-validation#keyup"
            }
          } %>
    </div>
    <div>
      <%= f.submit t("views.settings.food_groups.create"),
          class: "btn-primary cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed",
          data: { form_validation_target: "submit" },
          disabled: true %>
    </div>
  <% end %>
</div>

<!-- Tableau des groupes existants -->
<div class="bg-surface-raised border border-surface-border/50 rounded-lg overflow-hidden">
  <% if @day_food_groups.any? %>
    <table class="min-w-full table-dark">
      <thead>
        <tr>
          <th class="text-left"><%= t("views.settings.food_groups.name_col") %></th>
          <th class="text-center"><%= t("views.settings.food_groups.foods_col") %></th>
          <th class="text-right"><%= t("shared.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @day_food_groups.each do |group| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <i class="fas fa-utensils text-brand mr-3"></i>
                <div class="text-sm font-medium text-ink-primary"><%= group.name %></div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center justify-center">
                <% food_count = group.day_foods.count %>
                <% if food_count == 0 %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-hover text-ink-subtle">
                    <i class="fas fa-circle mr-1 text-xs"></i>
                    <%= t("views.settings.food_groups.no_food") %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-status-success_dim/30 text-status-success border border-status-success/20">
                    <i class="fas fa-check-circle mr-1 text-xs"></i>
                    <%= t("shared.food_count", count: food_count) %>
                  </span>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= delete_link_with_confirm(day_food_group_path(group),
                                          confirm: t("views.settings.food_groups.delete_confirm"),
                                          icon_class: "fas fa-trash mr-2",
                                          class: "text-status-danger hover:text-red-400 inline-flex items-center transition-colors",
                                          title: t("shared.delete")) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-12">
      <i class="fas fa-utensils text-ink-subtle text-4xl mb-4"></i>
      <h3 class="text-lg font-medium text-ink-primary mb-2"><%= t("views.settings.food_groups.no_groups") %></h3>
      <p class="text-ink-muted mb-4"><%= t("views.settings.food_groups.no_groups_hint") %></p>
      <p class="text-sm text-ink-subtle">
        <%= t("views.settings.food_groups.explanation") %>
      </p>
    </div>
  <% end %>
</div>
