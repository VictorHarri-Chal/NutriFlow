<%= simple_form_for(food) do |f| %>
  <%= render "shared/form_errors", record: food, margin_class: "mb-4" %>
  <%# ── Hidden fields : données importées ── %>
  <%= f.hidden_field :source,           data: { "food-off-search-target": "sourceField" } %>
  <%= f.hidden_field :off_id,          data: { "food-off-search-target": "offIdField" } %>
  <%= f.hidden_field :nutriscore_grade, data: { "food-off-search-target": "nutriscoreField" } %>
  <%= f.hidden_field :nova_group,       data: { "food-off-search-target": "novaGroupField" } %>
  <%= f.hidden_field :ecoscore_grade,   data: { "food-off-search-target": "ecoscoreField" } %>
  <%= hidden_field_tag "food[micronutrients]", (food.micronutrients || {}).to_json, data: { "food-off-search-target": "micronutrientsField" } %>

  <%# ── Badge source ── %>
  <div data-food-off-search-target="badge" class="<%= food.off_id.present? ? 'flex' : 'hidden' %> items-center gap-2 px-3 py-2 mb-6 rounded-lg bg-brand/10 border border-brand/30 text-brand text-sm">
    <i class="fas fa-cloud-arrow-down"></i>
    <%= t("views.foods.off_badge") %>
  </div>
  <div data-food-off-search-target="ciqualBadge" class="<%= food.source == :ciqual ? 'flex' : 'hidden' %> items-center gap-2 px-3 py-2 mb-6 rounded-lg bg-status-success/10 border border-status-success/30 text-status-success text-sm">
    <i class="fas fa-database"></i>
    <%= t("views.foods.ciqual_badge") %>
  </div>

  <div data-controller="food-preview" data-action="food-off-search:import@document->food-preview#fillFromOff">

    <%# ── Identification ── %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <%= f.input :name,
                  label: t("activerecord.attributes.food.name"),
                  input_html: { class: "input-dark", autocomplete: "off", autofocus: true, maxlength: 80,
                                data: { "food-preview-target": "nameField" } },
                  label_html: { class: "label-dark" } %>
      <%= f.input :brand,
                  label: t("activerecord.attributes.food.brand"),
                  required: false,
                  input_html: { class: "input-dark", autocomplete: "off", maxlength: 80,
                                data: { "food-preview-target": "brandField" } },
                  label_html: { class: "label-dark" } %>
    </div>

    <%# ── Valeurs nutritionnelles ── %>
    <div class="border-t border-surface-border/40 pt-5 mb-6 space-y-4">
      <div class="flex items-center gap-2">
        <span class="text-sm font-semibold text-ink-primary"><%= t("views.foods.form.macros_section") %></span>
        <span class="text-xs text-ink-subtle">(<%= t("views.foods.form.per_100g") %>)</span>
      </div>

      <%# Calories ── pleine largeur %>
      <%= f.input :calories,
                  label: t("activerecord.attributes.food.calories"),
                  input_html: { class: "input-dark", step: 1,
                                data: { "food-preview-target": "calories", controller: "digit-limit", action: "input->digit-limit#limit",
                                        digit_limit_max_integer_digits_value: 4 } },
                  label_html: { class: "label-dark" },
                  append: "kcal" %>

      <%# Macros 2×2 %>
      <div class="grid grid-cols-2 gap-4">
        <%= f.input :proteins,
                    label: t("activerecord.attributes.food.proteins"),
                    required: false,
                    input_html: { class: "input-dark", step: 0.1,
                                  data: { "food-preview-target": "proteins", controller: "digit-limit", action: "input->digit-limit#limit",
                                          digit_limit_max_integer_digits_value: 4, digit_limit_max_decimal_digits_value: 1 } },
                    label_html: { class: "label-dark" },
                    append: "g" %>
        <%= f.input :carbs,
                    label: t("activerecord.attributes.food.carbs"),
                    required: false,
                    input_html: { class: "input-dark", step: 0.1,
                                  data: { "food-preview-target": "carbs", controller: "digit-limit", action: "input->digit-limit#limit",
                                          digit_limit_max_integer_digits_value: 4, digit_limit_max_decimal_digits_value: 1 } },
                    label_html: { class: "label-dark" },
                    append: "g" %>
        <%= f.input :fats,
                    label: t("activerecord.attributes.food.fats"),
                    required: false,
                    input_html: { class: "input-dark", step: 0.1,
                                  data: { "food-preview-target": "fats", controller: "digit-limit", action: "input->digit-limit#limit",
                                          digit_limit_max_integer_digits_value: 4, digit_limit_max_decimal_digits_value: 1 } },
                    label_html: { class: "label-dark" },
                    append: "g" %>
        <%= f.input :sugars,
                    label: t("activerecord.attributes.food.sugars"),
                    required: false,
                    input_html: { class: "input-dark", step: 0.1,
                                  data: { "food-preview-target": "sugars", controller: "digit-limit", action: "input->digit-limit#limit",
                                          digit_limit_max_integer_digits_value: 4, digit_limit_max_decimal_digits_value: 1 } },
                    label_html: { class: "label-dark" },
                    append: "g" %>
      </div>

      <%# Étiquette étendue : Fibres / Graisses sat. / Sel en 3 colonnes %>
      <div class="grid grid-cols-3 gap-4">
        <%= f.input :fiber,
                    label: t("views.foods.show.nutrients.fiber"),
                    required: false,
                    input_html: { class: "input-dark", step: 0.1,
                                  data: { "food-off-search-target": "fiberField", controller: "digit-limit", action: "input->digit-limit#limit",
                                          digit_limit_max_integer_digits_value: 4, digit_limit_max_decimal_digits_value: 1 } },
                    label_html: { class: "label-dark" },
                    append: "g" %>
        <%= f.input :saturated_fat,
                    label: t("views.foods.show.nutrients.saturated_fat"),
                    required: false,
                    input_html: { class: "input-dark", step: 0.1,
                                  data: { "food-off-search-target": "saturatedFatField", controller: "digit-limit", action: "input->digit-limit#limit",
                                          digit_limit_max_integer_digits_value: 4, digit_limit_max_decimal_digits_value: 1 } },
                    label_html: { class: "label-dark" },
                    append: "g" %>
        <%= f.input :salt,
                    label: t("views.foods.show.nutrients.salt"),
                    required: false,
                    input_html: { class: "input-dark", step: 0.01,
                                  data: { "food-off-search-target": "saltField", controller: "digit-limit", action: "input->digit-limit#limit",
                                          digit_limit_max_integer_digits_value: 4, digit_limit_max_decimal_digits_value: 2 } },
                    label_html: { class: "label-dark" },
                    append: "g" %>
      </div>
    </div>

    <%# ── Qualité OFF ── toujours dans le DOM, JS la montre après import barcode %>
    <%
      ns_colors   = { "a" => "#038141", "b" => "#85BB2F", "c" => "#FECB02", "d" => "#EE8100", "e" => "#E63E11" }
      eco_colors  = { "a-plus" => "#006400", "a" => "#038141", "b" => "#85BB2F", "c" => "#FECB02", "d" => "#EE8100", "e" => "#E63E11", "f" => "#8B1A1A" }
      eco_labels  = { "a-plus" => "A+" }
      nova_colors = { 1 => "#038141", 2 => "#85BB2F", 3 => "#EE8100", 4 => "#E63E11" }
      ns_grade    = %w[a b c d e].include?(food.nutriscore_grade&.downcase) ? food.nutriscore_grade.downcase : nil
      nova_num    = food.nova_group.present? && (1..4).include?(food.nova_group.to_i) ? food.nova_group.to_i : nil
      eco_grade   = %w[a-plus a b c d e f].include?(food.ecoscore_grade&.downcase) ? food.ecoscore_grade.downcase : nil
      has_quality = ns_grade.present? || nova_num.present? || eco_grade.present?
    %>
    <div class="border-t border-surface-border/40 pt-5 mb-6 <%= 'hidden' unless has_quality %>"
         data-food-off-search-target="qualitySection">
      <span class="text-sm font-semibold text-ink-primary block mb-3"><%= t("views.foods.show.tabs.quality") %></span>
      <div class="space-y-2">

        <div class="<%= ns_grade.present? ? 'flex' : 'hidden' %> items-center gap-3 px-4 py-3 rounded-xl border border-surface-border/40 bg-surface-base"
             data-food-off-search-target="nutriscoreWrapper">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white text-lg font-black shrink-0"
               style="background-color: <%= ns_colors[ns_grade] || '#52525B' %>;"
               data-food-off-search-target="nutriscoreBadge">
            <%= ns_grade&.upcase %>
          </div>
          <div class="min-w-0">
            <div class="text-xs font-semibold text-ink-primary">Nutri-Score</div>
            <div class="text-[11px] text-ink-muted mt-0.5 leading-tight" data-food-off-search-target="nutriscoreDesc">
              <%= ns_grade.present? ? t("views.foods.show.nutriscore_description.#{ns_grade}", default: "") : "" %>
            </div>
          </div>
        </div>

        <div class="<%= nova_num.present? ? 'flex' : 'hidden' %> items-center gap-3 px-4 py-3 rounded-xl border border-surface-border/40 bg-surface-base"
             data-food-off-search-target="novaWrapper">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white text-lg font-black shrink-0"
               style="background-color: <%= nova_colors[nova_num] || '#52525B' %>;"
               data-food-off-search-target="novaBadge">
            <%= nova_num %>
          </div>
          <div class="min-w-0">
            <div class="text-xs font-semibold text-ink-primary">NOVA</div>
            <div class="text-[11px] text-ink-muted mt-0.5 leading-tight" data-food-off-search-target="novaDesc">
              <%= nova_num.present? ? t("views.foods.show.nova_description.#{nova_num}", default: "") : "" %>
            </div>
          </div>
        </div>

        <div class="<%= eco_grade.present? ? 'flex' : 'hidden' %> items-center gap-3 px-4 py-3 rounded-xl border border-surface-border/40 bg-surface-base"
             data-food-off-search-target="ecoscoreWrapper">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white text-lg font-black shrink-0"
               style="background-color: <%= eco_colors[eco_grade] || '#52525B' %>;"
               data-food-off-search-target="ecoscoreBadge">
            <%= eco_labels[eco_grade] || eco_grade&.upcase %>
          </div>
          <div class="min-w-0">
            <div class="text-xs font-semibold text-ink-primary">Éco-Score</div>
            <div class="text-[11px] text-ink-muted mt-0.5 leading-tight" data-food-off-search-target="ecoscoreDesc">
              <%= eco_grade.present? ? t("views.foods.show.ecoscore_description.#{eco_grade}", default: "") : "" %>
            </div>
          </div>
        </div>

      </div>
    </div>

    <%# ── Données avancées (dépliable, lecture seule) ── %>
    <%
      _has_advanced = food.allergens.present? || food.traces.present? ||
                      food.additives.present? || food.labels.present? ||
                      (food.micronutrients.present? && food.micronutrients.any?) ||
                      food.source == :manual
    %>
    <div class="border-t border-surface-border/40 pt-5 mb-6 <%= 'hidden' unless _has_advanced %>"
         data-controller="collapsible"
         data-food-off-search-target="advancedSection">
      <button type="button"
              class="flex items-center justify-between w-full group"
              data-action="click->collapsible#toggle">
        <span class="text-sm font-semibold text-ink-primary group-hover:text-ink-muted transition-colors">
          <%= t("views.foods.form.advanced_section") %>
        </span>
        <i class="fas fa-chevron-down text-ink-subtle text-xs transition-transform duration-200 group-hover:text-ink-muted"
           data-collapsible-target="icon"></i>
      </button>

      <div class="hidden mt-5 space-y-5" data-collapsible-target="content">

          <%# Allergènes & Traces — lecture seule %>
          <input type="hidden" name="food[allergens_raw]" value="<%= food.allergens.join(",") %>"
                 data-food-off-search-target="allergensField">
          <input type="hidden" name="food[traces_raw]" value="<%= food.traces.join(",") %>"
                 data-food-off-search-target="tracesField">
          <input type="hidden" name="food[additives_raw]" value="<%= food.additives.join(",") %>"
                 data-food-off-search-target="additivesField">
          <input type="hidden" name="food[labels_raw]" value="<%= food.labels.join(",") %>"
                 data-food-off-search-target="labelsField">
          <input type="hidden" name="food[ingredients_text]" value="<%= food.ingredients_text %>">
          <div class="<%= food.allergens.empty? ? 'hidden' : '' %>"
               data-food-off-search-target="allergensSection">
            <p class="text-sm font-medium text-ink-muted mb-2"><%= t("views.foods.show.allergens") %></p>
            <div class="flex flex-wrap gap-1.5" data-food-off-search-target="allergensDisplay">
              <% food.allergens.each do |allergen| %>
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-status-danger/10 border border-status-danger/30 text-status-danger">
                  <i class="fas fa-triangle-exclamation text-[9px]"></i>
                  <%= translate_allergen(allergen) %>
                </span>
              <% end %>
            </div>
          </div>

          <div class="<%= food.traces.empty? ? 'hidden' : '' %>"
               data-food-off-search-target="tracesSection">
            <p class="text-sm font-medium text-ink-muted mb-2"><%= t("views.foods.show.traces") %></p>
            <div class="flex flex-wrap gap-1.5" data-food-off-search-target="tracesDisplay">
              <% food.traces.each do |trace| %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-surface-hover border border-surface-border/50 text-ink-muted">
                  <%= translate_allergen(trace) %>
                </span>
              <% end %>
            </div>
          </div>

          <%# Additifs — lecture seule, visible uniquement si présents %>
          <div class="<%= food.additives.empty? ? 'hidden' : '' %>"
               data-food-off-search-target="additivesSection">
            <p class="text-sm font-medium text-ink-muted mb-2"><%= t("views.foods.show.additives") %></p>
            <div class="flex flex-wrap gap-1.5" data-food-off-search-target="additivesDisplay">
              <% food.additives.each do |additive| %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-surface-hover border border-surface-border/50 text-ink-muted">
                  <%= additive.gsub("-", " ") %>
                </span>
              <% end %>
            </div>
          </div>

          <%# Labels & Certifications — lecture seule, visible uniquement si présents %>
          <div class="<%= food.labels.empty? ? 'hidden' : '' %>"
               data-food-off-search-target="labelsSection">
            <p class="text-sm font-medium text-ink-muted mb-2"><%= t("views.foods.show.labels") %></p>
            <div class="flex flex-wrap gap-1.5" data-food-off-search-target="labelsDisplay">
              <% food.labels.each do |label| %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-surface-hover border border-surface-border/50 text-ink-muted">
                  <%= translate_label(label) %>
                </span>
              <% end %>
            </div>
          </div>

          <%# Micronutriments — lecture seule (import), dérivé du registre Micronutrient.
              Toujours dans le DOM (targets JS), wrapper masqué si vide. %>
          <%
            mn = (food.micronutrients || {}).transform_keys(&:to_s)
            present_nutrients = Micronutrient::KEYS.select { |key| mn[key.to_s].present? }
          %>
          <%# Masqué pour un aliment manuel : la liste du widget d'ajout juste en dessous
              affiche déjà les valeurs présentes (avec suppression), pas besoin de les
              montrer deux fois. Le bloc reste quand même dans le DOM (uniquement masqué
              en CSS, pas retiré du rendu) pour que food_preview_controller.js puisse
              encore le révéler en JS sur foods/new si l'utilisateur choisit un import
              Ciqual ou Open Food Facts sans recharger la page.
              Sur foods/edit en revanche, `source` d'un aliment persisté ne change jamais
              côté client (pas de food-off-search sur cette page) : pour un aliment manuel
              déjà existant, ce bloc ne pourra donc jamais être révélé — on ne le rend
              carrément pas, plutôt que de le laisser en markup mort dans le DOM. %>
          <% unless food.persisted? && food.source == :manual %>
            <div class="<%= 'hidden' if present_nutrients.empty? || food.source == :manual %>"
                 data-food-preview-target="micronutrientsSection"
                 data-food-off-search-target="micronutrientsSection">
              <p class="text-sm font-medium text-ink-muted mb-3"><%= t("views.foods.show.minerals") %> & <%= t("views.foods.show.vitamins") %></p>
              <div class="divide-y divide-surface-border/20">
                <% Micronutrient::ALL.each do |entry| %>
                  <div class="flex items-center justify-between py-2 <%= 'hidden' if mn[entry.key.to_s].blank? %>" data-nutrient-row>
                    <span class="text-xs text-ink-muted"><%= entry.label %></span>
                    <% if mn[entry.key.to_s].present? %>
                      <span class="text-xs font-semibold text-ink-primary"
                            data-food-preview-target="micronutrientDisplay"
                            data-nutrient="<%= entry.key %>"
                            data-unit="<%= entry.unit %>">
                        <%= mn[entry.key.to_s] %> <%= entry.unit %>
                      </span>
                    <% else %>
                      <span class="text-xs text-ink-subtle"
                            data-food-preview-target="micronutrientDisplay"
                            data-nutrient="<%= entry.key %>"
                            data-unit="<%= entry.unit %>">—</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Ajout manuel — uniquement pour un aliment créé à la main, jamais pour un import Ciqual/OFF.
              Le rendu serveur suffit pour /edit (source ne change jamais côté client sur cette page) ;
              sur /new, food_off_search_controller.js (Tâche 16) masque ce bloc en JS dès qu'un import
              Ciqual/OFF est choisi, sans attendre un rechargement de page. %>
          <% if food.source == :manual %>
            <div data-controller="micronutrient-editor"
                 data-food-off-search-target="manualMicronutrientSection"
                 class="mt-4">
              <script type="application/json" data-micronutrient-editor-target="registry">
                <%= json_escape(Micronutrient::ALL.map { |e| { key: e.key, label: e.label, unit: e.unit } }.to_json).html_safe %>
              </script>

              <div class="flex gap-2 mb-3">
                <div data-controller="custom-select" class="relative flex-1">
                  <select data-micronutrient-editor-target="select"
                          data-custom-select-target="select"
                          data-action="change->micronutrient-editor#syncUnit"
                          class="sr-only">
                    <option value="" selected disabled><%= t("views.foods.form.micronutrient_select_placeholder") %></option>
                    <% Micronutrient::ALL.each do |entry| %>
                      <option value="<%= entry.key %>"><%= entry.label %></option>
                    <% end %>
                  </select>
                  <button type="button" data-action="click->custom-select#toggle"
                          class="input-dark flex items-center justify-between cursor-pointer w-full text-left text-sm">
                    <span data-custom-select-target="label" class="text-ink-subtle"></span>
                    <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
                  </button>
                  <div data-custom-select-target="dropdown"
                       class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-52 overflow-y-auto"></div>
                </div>
                <div class="relative w-32">
                  <input type="number" step="0.01" min="0"
                         data-micronutrient-editor-target="value"
                         class="input-dark w-full text-sm pr-10"
                         data-controller="digit-limit"
                         data-digit-limit-max-integer-digits-value="5"
                         data-digit-limit-max-decimal-digits-value="2"
                         data-action="input->digit-limit#limit input->micronutrient-editor#updateAddButtonState">
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none"
                        data-micronutrient-editor-target="unit"></span>
                </div>
                <button type="button" class="btn-secondary text-sm px-4 whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-surface-hover"
                        data-micronutrient-editor-target="addButton"
                        data-action="click->micronutrient-editor#add"
                        disabled>
                  <%= t("views.foods.form.add_micronutrient") %>
                </button>
              </div>

              <div class="divide-y divide-surface-border/20" data-micronutrient-editor-target="list"></div>
            </div>
          <% end %>

        </div>
      </div>
    </div>

    <%# ── Catégorie ── %>
    <div class="border-t border-surface-border/40 pt-5 mb-6">
      <span class="text-sm font-semibold text-ink-primary block mb-3"><%= t("views.foods.form.category") %></span>
      <div class="flex flex-wrap gap-2">
        <%
          effective_category = food.category.presence || "other"
          category_options = [
            { value: "other",       icon: "fa-box",             key: "other"       },
            { value: "proteins",    icon: "fa-drumstick-bite",  key: "proteins"    },
            { value: "grains",      icon: "fa-bread-slice",     key: "grains"      },
            { value: "vegetables",  icon: "fa-carrot",          key: "vegetables"  },
            { value: "fruits",      icon: "fa-apple-whole",     key: "fruits"      },
            { value: "dairy",       icon: "fa-cheese",          key: "dairy"       },
            { value: "beverages",   icon: "fa-glass-water",     key: "beverages"   },
            { value: "condiments",  icon: "fa-mortar-pestle",   key: "condiments"  },
            { value: "supplements", icon: "fa-capsules",        key: "supplements" },
          ]
        %>
        <% category_options.each do |opt| %>
          <label class="cursor-pointer">
            <%= f.radio_button :category, opt[:value], checked: effective_category == opt[:value], class: "sr-only peer" %>
            <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-xs font-medium transition-colors
                         bg-surface-hover border-surface-border/50 text-ink-muted
                         hover:border-brand/30 hover:text-ink-primary
                         peer-checked:bg-brand/15 peer-checked:border-brand/50 peer-checked:text-brand">
              <i class="fas <%= opt[:icon] %> text-[10px]"></i>
              <%= t("views.shopping_lists.categories.#{opt[:key]}") %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <%# ── Labels ── %>
    <% if @food_labels.any? %>
      <div class="border-t border-surface-border/40 pt-5 mb-6">
        <span class="text-sm font-semibold text-ink-primary block mb-3"><%= t("views.foods.form.food_labels") %></span>
        <div class="flex flex-wrap gap-2">
          <% @food_labels.each do |label| %>
            <label class="cursor-pointer">
              <%= check_box_tag "food[food_label_ids][]", label.id, food.food_labels.include?(label), class: "sr-only peer" %>
              <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-xs font-medium transition-colors
                           bg-surface-hover border-surface-border/50 text-ink-muted
                           hover:border-brand/30 hover:text-ink-primary
                           peer-checked:bg-brand/15 peer-checked:border-brand/50 peer-checked:text-brand">
                <i class="fas fa-tag text-[10px]"></i>
                <%= label.name %>
              </span>
            </label>
          <% end %>
        </div>
        <%= hidden_field_tag "food[food_label_ids][]", "" %>
      </div>
    <% end %>

    <%# ── Actions ── %>
