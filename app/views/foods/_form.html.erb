<%= simple_form_for(food) do |f| %>
  <%= render AlertComponent.new(title: t("views.foods.form.macros_hint"), level: "warning") %>
  <div class="grid grid-cols-1 gap-4">
    <%= f.input :name, input_html: { class: "input-dark" }, label_html: { class: "label-dark" } %>
    <%= f.input :brand, input_html: { class: "input-dark" }, label_html: { class: "label-dark" } %>
    <%= f.input :calories, step: 1, input_html: { class: "input-dark" }, label_html: { class: "label-dark" }, append: "kcal" %>

    <div class="grid grid-cols-2 gap-4">
      <%= f.input :proteins, step: 0.1, input_html: { class: "input-dark" }, label_html: { class: "label-dark" }, append: "g" %>
      <%= f.input :carbs, step: 0.1, input_html: { class: "input-dark" }, label_html: { class: "label-dark" }, append: "g" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <%= f.input :fats, step: 0.1, input_html: { class: "input-dark" }, label_html: { class: "label-dark" }, append: "g" %>
      <%= f.input :sugars, step: 0.1, input_html: { class: "input-dark" }, label_html: { class: "label-dark" }, append: "g" %>
    </div>

    <div class="form-group">
      <label class="label-dark block mb-3"><%= t("views.foods.form.food_labels") %></label>
      <div class="grid grid-cols-2 gap-3 p-4 border border-surface-border rounded-lg bg-surface-base">
        <% @food_labels.each do |label| %>
          <label class="flex items-center space-x-2 cursor-pointer hover:bg-surface-hover p-2 rounded transition">
            <%= check_box_tag "food[food_label_ids][]", label.id, food.food_labels.include?(label),
                class: "rounded border-surface-border text-brand focus:ring-brand/50" %>
            <span class="text-sm text-ink-muted"><%= label.name %></span>
          </label>
        <% end %>
        <% if @food_labels.empty? %>
          <div class="col-span-2 text-center py-6 px-4">
            <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
              <i class="fas fa-tag text-ink-subtle"></i>
            </div>
            <h3 class="text-sm font-medium text-ink-primary mb-1"><%= t("views.foods.form.no_labels") %></h3>
            <p class="text-ink-subtle text-xs mb-3"><%= t("views.foods.form.create_labels_hint") %></p>
          </div>
        <% end %>
      </div>
      <%= hidden_field_tag "food[food_label_ids][]", "" %>
    </div>
  </div>

  <div class="flex justify-center gap-4 mt-8">
    <%= link_to t("shared.cancel"), foods_path, class: "btn-ghost" %>
    <%= f.button :submit, t("shared.save"), class: "btn-primary" %>
  </div>
<% end %>
