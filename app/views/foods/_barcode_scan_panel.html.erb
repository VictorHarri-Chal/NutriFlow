<%# locals: (lookup_url:, auto_open_camera: false, show_cancel_link: true) %>
<div data-controller="barcode-scanner"
     data-barcode-scanner-url-value="<%= lookup_url %>"
     data-barcode-scanner-auto-open-value="<%= auto_open_camera %>"
     data-barcode-scanner-redirect-on-existing-value="<%= show_cancel_link %>"
     data-barcode-scanner-camera-denied-text="<%= t('views.foods.barcode_scanner.camera_denied') %>"
     data-barcode-scanner-camera-error-text="<%= t('views.foods.barcode_scanner.camera_error') %>"
     data-barcode-scanner-searching-text="<%= t('views.foods.barcode_scanner.searching') %>"
     data-barcode-scanner-not-found-text="<%= t('views.foods.barcode_scanner.not_found') %>"
     data-barcode-scanner-network-error-text="<%= t('views.foods.barcode_scanner.network_error') %>"
     data-barcode-scanner-url-invalid-text="<%= t('views.foods.barcode_scanner.url_invalid') %>">

  <%# ── Contenu par défaut (caché quand la caméra est ouverte) ── %>
  <div data-barcode-scanner-target="defaultContent">
    <% unless auto_open_camera %>
      <%# Bouton caméra %>
      <button type="button"
              class="w-full flex items-center justify-center gap-3 px-4 py-3.5 rounded-xl border border-surface-border/50 bg-surface-hover text-ink-primary hover:border-brand/50 hover:text-brand transition-colors text-sm font-medium mb-3"
              data-action="click->barcode-scanner#openCamera">
        <i class="fas fa-camera"></i>
        <%= t("views.foods.barcode_scanner.btn") %>
      </button>
    <% end %>
  </div><%# /defaultContent %>

  <%# ── Panel caméra (remplace le contenu par défaut) ── %>
  <div data-barcode-scanner-target="cameraPanel" class="hidden mb-3">
    <div class="flex items-center justify-between mb-3">
      <p class="text-sm text-ink-muted"><%= t("views.foods.barcode_scanner.camera_hint") %></p>
      <% unless auto_open_camera %>
        <button type="button" class="btn-ghost"
                data-action="click->barcode-scanner#closeCamera"
                data-tooltip="<%= t('views.foods.barcode_scanner.close_camera_tooltip') %>">
          <i class="fas fa-times text-sm"></i>
        </button>
      <% end %>
    </div>
    <div class="relative rounded-xl overflow-hidden bg-surface-base border border-surface-border/40 <%= auto_open_camera ? "h-72" : "h-[calc(100vh-23rem)] min-h-48" %>">
      <video data-barcode-scanner-target="video" class="w-full h-full object-cover" playsinline muted></video>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-2/3 h-2/5 border-2 border-brand/60 rounded-xl shadow-[0_0_0_9999px_rgba(0,0,0,0.35)]"></div>
      </div>
    </div>
  </div>

  <%# ── Saisie manuelle (toujours visible) ── %>
  <div class="flex gap-2 mt-3">
    <div class="relative flex-1">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <i class="fas fa-barcode text-ink-subtle text-sm"></i>
      </div>
      <input type="text"
             inputmode="numeric"
             autocomplete="off"
             class="input-dark w-full pl-10 text-sm"
             data-barcode-scanner-target="manualInput"
             data-action="input->barcode-scanner#validateManualInput keydown.enter->barcode-scanner#submitManual">
    </div>
    <button type="button"
            class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg border border-surface-border/50 bg-surface-hover text-ink-subtle hover:border-brand/50 hover:text-brand hover:bg-brand/10 transition-colors disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:border-surface-border/50 disabled:hover:text-ink-subtle disabled:hover:bg-surface-hover"
            disabled
            data-barcode-scanner-target="submitBtn"
            data-action="click->barcode-scanner#submitManual"
            data-tooltip="<%= t('views.foods.barcode_scanner.submit_tooltip') %>">
      <i class="fas fa-magnifying-glass text-sm"></i>
    </button>
  </div>

  <%# ── Saisie URL Open Food Facts ── %>
  <div class="flex items-center gap-3 my-4">
    <div class="flex-1 h-px bg-surface-border/40"></div>
    <span class="text-xs text-ink-subtle uppercase tracking-wider"><%= t("views.foods.barcode_scanner.url_separator") %></span>
    <div class="flex-1 h-px bg-surface-border/40"></div>
  </div>

  <div class="flex gap-2">
    <div class="relative flex-1">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <i class="fas fa-link text-ink-subtle text-sm"></i>
      </div>
      <input type="text"
             autocomplete="off"
             class="input-dark w-full pl-10 text-sm"
             placeholder="<%= t("views.foods.barcode_scanner.url_placeholder") %>"
             data-barcode-scanner-target="urlInput"
             data-action="input->barcode-scanner#validateUrlInput keydown.enter->barcode-scanner#submitUrl">
    </div>
    <button type="button"
            class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg border border-surface-border/50 bg-surface-hover text-ink-subtle hover:border-brand/50 hover:text-brand hover:bg-brand/10 transition-colors disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:border-surface-border/50 disabled:hover:text-ink-subtle disabled:hover:bg-surface-hover"
            disabled
            data-barcode-scanner-target="urlSubmitBtn"
            data-action="click->barcode-scanner#submitUrl"
            data-tooltip="<%= t('views.foods.barcode_scanner.submit_tooltip') %>">
      <i class="fas fa-magnifying-glass text-sm"></i>
    </button>
  </div>

  <%# Feedback ── %>
  <p data-barcode-scanner-target="status" class="hidden mt-3 text-sm text-ink-muted text-center"></p>
  <p data-barcode-scanner-target="error" class="hidden mt-3 text-sm text-status-danger text-center"></p>

  <% if show_cancel_link %>
    <%# Actions %>
    <div data-barcode-scanner-target="cancelBtn" class="flex justify-center mt-8 pt-6 border-t border-surface-border/40">
      <%= link_to t("shared.cancel"), foods_path, class: "btn-ghost" %>
    </div>
  <% end %>
</div>
