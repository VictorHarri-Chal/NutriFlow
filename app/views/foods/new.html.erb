<div class="max-w-6xl mx-auto mt-16 card p-8"
     data-controller="food-off-search"
     data-food-off-search-url-value="<%= search_import_foods_path %>"
     data-food-off-search-allergens-map-value="<%= json_escape(I18n.t('views.foods.show.allergens_map').transform_keys(&:to_s).to_json) %>"
     data-food-off-search-labels-map-value="<%= json_escape(I18n.t('views.foods.show.labels_map').transform_keys(&:to_s).to_json) %>"
     data-food-off-search-ns-descs-value="<%= json_escape(I18n.t('views.foods.show.nutriscore_description').transform_keys(&:to_s).to_json) %>"
     data-food-off-search-nova-descs-value="<%= json_escape(I18n.t('views.foods.show.nova_description').transform_keys(&:to_s).to_json) %>"
     data-food-off-search-eco-descs-value="<%= json_escape(I18n.t('views.foods.show.ecoscore_description').transform_keys(&:to_s).to_json) %>"
     data-action="barcode-scanner:product@document->food-off-search#handleBarcodeProduct">

  <div data-controller="tabs" data-tabs-active-tab-value="<%= @food.errors.any? ? 'manual' : 'off' %>">

    <%# ── En-tête ── %>
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.foods.add_food") %></h1>

      <div class="flex items-center gap-2">
        <i class="fas fa-circle-info text-sm text-ink-muted hover:text-ink-primary transition-colors cursor-default"
           data-tooltip="<%= t('views.foods.new.info_tooltip') %>"></i>
        <div class="flex gap-1 p-1 bg-surface-base rounded-xl border border-surface-border/40">
          <button type="button"
                  data-tabs-target="tab"
                  data-tab="off"
                  data-action="click->tabs#switchTab click->food-off-search#focusInput"
                  data-active-classes="bg-surface-raised text-ink-primary shadow-sm"
                  data-inactive-classes="text-ink-muted hover:text-ink-primary"
                  class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all bg-surface-raised text-ink-primary shadow-sm">
            <i class="fas fa-magnifying-glass text-xs"></i>
            <%= t("views.foods.new.tab_off") %>
          </button>
          <button type="button"
                  data-tabs-target="tab"
                  data-tab="manual"
                  data-action="click->tabs#switchTab"
                  data-active-classes="bg-surface-raised text-ink-primary shadow-sm"
                  data-inactive-classes="text-ink-muted hover:text-ink-primary"
                  class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all text-ink-muted hover:text-ink-primary">
            <i class="fas fa-pen-to-square text-xs"></i>
            <%= t("views.foods.new.tab_manual") %>
          </button>
        </div>
      </div>
    </div>

    <%# ── Panel import rapide ── %>
    <div id="off-tab" data-tabs-target="content">

      <%# Recherche Ciqual %>
      <div class="relative mb-5">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i class="fas fa-magnifying-glass text-ink-subtle text-sm" data-food-off-search-target="searchIcon"></i>
        </div>
        <input type="text"
               class="input-dark w-full pl-10 pr-9 text-sm"
               autocomplete="off"
               placeholder="<%= t("views.foods.off_search.placeholder") %>"
               data-food-off-search-target="input"
               data-action="input->food-off-search#search">
        <button type="button"
                class="hidden absolute inset-y-0 right-0 pr-3 flex items-center text-ink-subtle hover:text-ink-muted transition-colors"
                data-food-off-search-target="clearBtn"
                data-action="click->food-off-search#clearSearch">
          <i class="fas fa-times text-sm"></i>
        </button>
      </div>

      <%# Type hint %>
      <div data-food-off-search-target="typeHint" class="text-center py-6">
        <p class="text-sm text-ink-muted mb-1"><%= t("views.foods.off_search.type_hint") %></p>
        <p class="text-xs text-ink-subtle"><%= t("views.foods.off_search.type_hint_sub") %></p>
      </div>

      <%# Aucun résultat %>
      <div data-food-off-search-target="emptyState" class="hidden text-center py-8">
        <i class="fas fa-circle-exclamation text-surface-border text-3xl mb-3 block"></i>
        <p class="text-sm text-ink-subtle"><%= t("views.foods.off_search.empty") %></p>
      </div>

      <%# Résultats %>
      <div data-food-off-search-target="results"
           class="hidden max-h-[16rem] overflow-y-auto rounded-xl border border-surface-border/40 divide-y divide-surface-border/20 mb-5">
      </div>

      <%# Séparateur %>
      <div class="flex items-center gap-3 my-6">
        <div class="flex-1 h-px bg-surface-border/40"></div>
        <span class="text-xs text-ink-subtle uppercase tracking-wider"><%= t("views.foods.off_search.or_barcode") %></span>
        <div class="flex-1 h-px bg-surface-border/40"></div>
      </div>

      <%= render "foods/barcode_scan_panel", lookup_url: barcode_import_foods_path, auto_open_camera: false, show_cancel_link: true %>
    </div>

    <%# ── Panel manuel ── %>
    <div id="manual-tab" data-tabs-target="content" class="hidden">
      <%= render "form", food: @food %>
    </div>

  </div>
</div>
