<% content_for :page_title, t("views.foods.page_title") %>

<div class="max-w-6xl mx-auto mt-16 card p-8">
    <!-- En-tête avec titre, recherche et actions -->
  <header class="mb-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <!-- Titre -->
      <h1 class="text-2xl font-bold text-ink-primary flex-shrink-0"><%= t("views.foods.title") %></h1>

      <!-- Barre de recherche -->
      <div class="flex-1 max-w-md lg:mx-6">
        <%= form_with url: foods_path, method: :get, local: true, class: "relative" do |f| %>
          <% if params[:q].present? %>
            <% params[:q].each do |key, value| %>
              <%= hidden_field_tag "q[#{key}]", value %>
            <% end %>
          <% end %>

          <%= text_field_tag :query, params[:query],
              class: "input-dark pl-10 #{params[:query].present? ? 'pr-10' : ''} py-1.5 text-sm",
              placeholder: t("views.foods.search_placeholder"),
              autocomplete: "off" %>

          <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-ink-subtle pointer-events-none"></i>

          <% if params[:query].present? %>
            <%= link_to foods_path, class: "absolute right-3 top-1/2 -translate-y-1/2 text-ink-subtle hover:text-ink-muted transition-colors" do %>
              <i class="fas fa-times"></i>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <!-- Bouton d'ajout -->
      <%= link_to new_food_path, class: "btn-primary flex-shrink-0" do %>
        <i class="fas fa-plus"></i>
        <%= t("views.foods.add_food") %>
      <% end %>
    </div>
  </header>

  <!-- Tableau des aliments -->
  <div class="bg-surface-base rounded-lg overflow-hidden border border-surface-border/40">
    <div class="overflow-x-auto">
      <table class="min-w-full table-dark">
        <%= render "table_headers" %>
        <tbody>
          <%= render partial: "table_row", collection: @foods, as: :food %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <% if @pagy&.pages&.> 1 %>
    <div class="mt-6 flex justify-center">
      <%= render PaginationComponent.new(pagy: @pagy, full_result_option: true) %>
    </div>
  <% elsif @pagy.nil? && params[:full_result] == "true" %>
    <div class="mt-6 flex justify-center">
      <%= render PaginationComponent.new(pagy: nil, full_result_option: true) %>
    </div>
  <% end %>
</div>
