<% content_for :page_title, t("views.foods.page_title") %>

<div class="max-w-6xl mx-auto mt-16 card p-8">
  <!-- En-tête avec titre, recherche et actions -->
  <header class="mb-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <!-- Titre + compteur -->
      <div class="flex-shrink-0">
        <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.foods.title") %></h1>
        <% total = @pagy ? @pagy.count : @foods.size %>
        <p class="text-xs text-ink-subtle mt-0.5"><%= t("shared.food_count", count: total) %></p>
      </div>

      <!-- Barre de recherche -->
      <div class="flex-1 max-w-md lg:mx-6">
        <%= form_with url: foods_path, method: :get, local: true,
              data: { controller: "search", turbo_frame: "foods_results" },
              class: "relative" do |f| %>
          <% if params[:q].present? %>
            <% params[:q].each do |key, value| %>
              <%= hidden_field_tag "q[#{key}]", value %>
            <% end %>
          <% end %>
          <%= hidden_field_tag :label_id,     params[:label_id]     if params[:label_id].present? %>
          <%= hidden_field_tag :favorites,    params[:favorites]    if params[:favorites].present? %>
          <%= hidden_field_tag :in_stock,     params[:in_stock]     if params[:in_stock].present? %>
          <%= hidden_field_tag :out_of_stock, params[:out_of_stock] if params[:out_of_stock].present? %>

          <%= text_field_tag :query, params[:query],
              class: "input-dark pl-10 #{params[:query].present? ? 'pr-10' : ''} py-1.5 text-sm",
              placeholder: t("views.foods.search_placeholder"),
              autocomplete: "off",
              data: { action: "input->search#input" } %>

          <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-ink-subtle pointer-events-none"></i>

          <% if params[:query].present? %>
            <%= link_to foods_path(label_id: params[:label_id], favorites: params[:favorites], in_stock: params[:in_stock], out_of_stock: params[:out_of_stock]),
                  data: { turbo_frame: "foods_results" },
                  class: "absolute right-3 top-1/2 -translate-y-1/2 text-ink-subtle hover:text-ink-muted transition-colors" do %>
              <i class="fas fa-times"></i>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <!-- Actions principales -->
      <div class="flex items-center gap-2 flex-shrink-0">
        <%= link_to new_food_path, class: "btn-primary #{@foods.empty? ? 'invisible pointer-events-none' : ''}" do %>
          <i class="fas fa-plus"></i>
          <%= t("views.foods.add_food") %>
        <% end %>
      </div>
    </div>
  </header>

  <!-- Filtres + actions bulk sur une seule ligne -->
  <%
    filter_params = {
      label_id:     params[:label_id].presence,
      favorites:    params[:favorites].presence,
      in_stock:     params[:in_stock].presence,
      out_of_stock: params[:out_of_stock].presence
    }.compact
    active_filter = @filtering_favorites || @filtering_in_stock || @filtering_out_of_stock || @selected_label_id
  %>
  <div class="flex items-center justify-between gap-3 mb-5">

    <!-- Filtres sémantiques (flex-wrap) + dropdown labels -->
    <div class="flex flex-wrap items-center gap-2">
      <%# Tous les aliments — préserve le filtre label actif %>
      <% no_semantic_filter = !@filtering_favorites && !@filtering_in_stock && !@filtering_out_of_stock %>
      <%= link_to foods_path(query: params[:query], q: params[:q]&.to_unsafe_h, label_id: params[:label_id]),
            class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border transition-colors #{no_semantic_filter ? 'bg-brand/20 text-brand border-brand/50' : 'bg-surface-hover text-ink-muted border-surface-border hover:border-brand/30 hover:text-ink-primary'}" do %>
        <%= t("views.foods.all_foods") %>
      <% end %>

      <%# Favoris %>
      <%= link_to foods_path(query: params[:query], q: params[:q]&.to_unsafe_h, favorites: "true", label_id: params[:label_id]),
            class: "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@filtering_favorites ? 'bg-amber-400/15 text-amber-400 border-amber-400/40' : 'bg-surface-hover text-ink-muted border-surface-border hover:border-amber-400/30 hover:text-amber-400'}" do %>
        <i class="fas fa-star text-xs"></i>
        <%= t("views.foods.favorites_filter") %>
      <% end %>

      <%# En stock %>
      <%= link_to foods_path(query: params[:query], q: params[:q]&.to_unsafe_h, in_stock: "true", label_id: params[:label_id]),
            class: "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@filtering_in_stock ? 'bg-status-success/10 text-status-success border-status-success/30' : 'bg-surface-hover text-ink-muted border-surface-border hover:border-status-success/30 hover:text-status-success'}" do %>
        <i class="fas fa-check text-xs"></i>
        <%= t("views.foods.in_stock_filter") %>
      <% end %>

      <%# À racheter %>
      <%= link_to foods_path(query: params[:query], q: params[:q]&.to_unsafe_h, out_of_stock: "true", label_id: params[:label_id]),
            class: "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@filtering_out_of_stock ? 'bg-status-danger/10 text-status-danger border-status-danger/30' : 'bg-surface-hover text-ink-muted border-surface-border hover:border-status-danger/30 hover:text-status-danger'}" do %>
        <i class="fas fa-circle-xmark text-xs"></i>
        <%= t("views.foods.out_of_stock_filter") %>
      <% end %>

      <%# Dropdown labels — juste après les filtres sémantiques %>
      <% if @food_labels.any? %>
        <span class="w-px h-4 bg-surface-border/60 mx-0.5"></span>
        <div data-controller="filter-dropdown" class="relative">
          <button type="button"
                  data-action="click->filter-dropdown#toggle"
                  data-filter-dropdown-target="trigger"
                  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border transition-colors <%= @selected_label_id ? 'bg-surface-hover text-ink-primary border-surface-border' : 'bg-surface-hover text-ink-muted border-surface-border hover:text-ink-primary' %>">
            <% if @selected_label_id && (active_label = @food_labels.find { |l| l.id == @selected_label_id }) %>
              <span class="w-1.5 h-1.5 rounded-full <%= active_label.color_style[:dot] %> shrink-0"></span>
              <span data-filter-dropdown-target="label"><%= active_label.name %></span>
            <% else %>
              <i class="fas fa-tag text-xs"></i>
              <span data-filter-dropdown-target="label"><%= t("views.foods.labels_filter") %></span>
            <% end %>
            <i class="fas fa-chevron-down text-xs transition-transform duration-150" data-filter-dropdown-target="icon"></i>
          </button>

          <div data-filter-dropdown-target="dropdown"
               class="hidden absolute left-0 top-full mt-1.5 min-w-40 bg-surface-raised border border-surface-border/50 rounded-xl shadow-xl overflow-hidden z-50 py-1">
            <%= link_to foods_path(query: params[:query], favorites: params[:favorites].presence, in_stock: params[:in_stock].presence, out_of_stock: params[:out_of_stock].presence),
                  class: "flex items-center gap-2 px-3 py-2 text-xs transition-colors #{@selected_label_id.nil? ? 'text-ink-primary bg-surface-hover' : 'text-ink-muted hover:text-ink-primary hover:bg-surface-hover'}" do %>
              <span class="w-1.5 h-1.5 rounded-full bg-ink-subtle/50 shrink-0"></span>
              <%= t("views.foods.all_labels") %>
            <% end %>
            <div class="mx-2 my-1 h-px bg-surface-border/40"></div>
            <% @food_labels.each do |label| %>
              <% style = label.color_style %>
              <%= link_to foods_path(query: params[:query], label_id: label.id, favorites: params[:favorites].presence, in_stock: params[:in_stock].presence, out_of_stock: params[:out_of_stock].presence),
                    class: "flex items-center gap-2 px-3 py-2 text-xs transition-colors #{@selected_label_id == label.id ? 'text-ink-primary bg-surface-hover' : 'text-ink-muted hover:text-ink-primary hover:bg-surface-hover'}" do %>
                <span class="w-1.5 h-1.5 rounded-full <%= style[:dot] %> shrink-0"></span>
                <%= label.name %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Actions bulk : tout en stock + tout à racheter + cart (icônes seules, style cohérent) -->
    <div class="flex items-center gap-1.5 shrink-0">
      <%= button_to bulk_pantry_foods_path,
            method: :patch,
            params: filter_params.merge(status: "true"),
            title: t("views.foods.pantry_all_in"),
            class: "w-8 h-8 rounded-md inline-flex items-center justify-center border bg-status-success/15 text-status-success border-status-success/30 hover:bg-status-success/25 transition-colors" do %>
        <i class="fas fa-house text-xs"></i>
      <% end %>
      <%= button_to bulk_pantry_foods_path,
            method: :patch,
            params: filter_params.merge(status: "false"),
            title: t("views.foods.pantry_all_out"),
            class: "w-8 h-8 rounded-md inline-flex items-center justify-center border bg-status-danger/15 text-status-danger border-status-danger/30 hover:bg-status-danger/25 transition-colors" do %>
        <i class="fas fa-bag-shopping text-xs"></i>
      <% end %>

      <%# Cart — tout à droite, toujours visible, pastille si items manquants %>
      <%= turbo_frame_tag "missing_foods_bar" do %>
        <div class="relative inline-flex">
          <%= button_to add_missing_to_shopping_list_foods_path,
                method: :post,
                title: t("views.foods.add_missing_tooltip"),
                form: { data: { turbo_frame: "_top" }, class: "contents" },
                class: "w-8 h-8 rounded-md inline-flex items-center justify-center border transition-colors #{@missing_count > 0 ? 'bg-brand/15 text-brand border-brand/30 hover:bg-brand/25' : 'bg-surface-hover text-ink-subtle/40 border-surface-border/40 opacity-40 pointer-events-none'}" do %>
            <i class="fas fa-cart-plus text-xs"></i>
          <% end %>
          <% if @missing_count > 0 %>
            <span class="absolute -top-1.5 -right-1.5 min-w-[1.1rem] h-[1.1rem] px-0.5 rounded-full bg-brand text-zinc-900 text-[9px] font-bold flex items-center justify-center leading-none pointer-events-none"><%= @missing_count %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Tableau des aliments ou empty state -->
  <%= turbo_frame_tag "foods_results" do %>
  <% if @foods.empty? %>
    <div class="text-center py-12 border-2 border-dashed border-surface-border/50 rounded-xl bg-surface-base">
      <div class="w-14 h-14 mx-auto mb-3 bg-surface-raised rounded-full flex items-center justify-center border border-surface-border/40">
        <% if @filtering_favorites && params[:query].blank? && params[:label_id].blank? %>
          <i class="fas fa-star text-amber-400 text-xl"></i>
        <% elsif @filtering_in_stock && params[:query].blank? && params[:label_id].blank? %>
          <i class="fas fa-boxes-stacked text-status-success text-xl"></i>
        <% elsif @filtering_out_of_stock && params[:query].blank? && params[:label_id].blank? %>
          <i class="fas fa-circle-check text-status-success text-xl"></i>
        <% else %>
          <i class="fas fa-utensils text-brand text-xl"></i>
        <% end %>
      </div>
      <% if @filtering_favorites && params[:query].blank? && params[:label_id].blank? %>
        <h3 class="text-lg font-semibold text-ink-primary mb-1"><%= t("views.foods.no_favorites.title") %></h3>
        <p class="text-ink-muted mb-4"><%= t("views.foods.no_favorites.description") %></p>
        <%= link_to foods_path, class: "btn-secondary" do %>
          <i class="fas fa-list"></i>
          <%= t("views.foods.no_favorites.see_all") %>
        <% end %>
      <% elsif @filtering_in_stock && params[:query].blank? && params[:label_id].blank? %>
        <h3 class="text-lg font-semibold text-ink-primary mb-1"><%= t("views.foods.no_in_stock.title") %></h3>
        <p class="text-ink-muted mb-4"><%= t("views.foods.no_in_stock.description") %></p>
        <%= link_to foods_path, class: "btn-secondary" do %>
          <i class="fas fa-list"></i>
          <%= t("views.foods.no_in_stock.see_all") %>
        <% end %>
      <% elsif @filtering_out_of_stock && params[:query].blank? && params[:label_id].blank? %>
        <h3 class="text-lg font-semibold text-ink-primary mb-1"><%= t("views.foods.no_out_of_stock.title") %></h3>
        <p class="text-ink-muted mb-4"><%= t("views.foods.no_out_of_stock.description") %></p>
        <%= link_to foods_path, class: "btn-secondary" do %>
          <i class="fas fa-list"></i>
          <%= t("views.foods.no_out_of_stock.see_all") %>
        <% end %>
      <% elsif params[:query].present? || params[:q]&.values&.any?(&:present?) || params[:label_id].present? || @filtering_favorites || @filtering_in_stock || @filtering_out_of_stock %>
        <h3 class="text-lg font-semibold text-ink-primary mb-1"><%= t("views.foods.no_results.title") %></h3>
        <% search_term = params[:query].presence || params.dig(:q, :name_cont).presence %>
        <p class="text-ink-muted mb-4">
          <% if search_term %>
            <%= t("views.foods.no_results.description", query: search_term) %>
          <% else %>
            <%= t("views.foods.no_results.no_match") %>
          <% end %>
        </p>
        <%= link_to foods_path, class: "btn-secondary" do %>
          <i class="fas fa-times"></i>
          <%= t("views.foods.no_results.clear") %>
        <% end %>
      <% else %>
        <h3 class="text-lg font-semibold text-ink-primary mb-1"><%= t("views.foods.empty_state.title") %></h3>
        <p class="text-ink-muted mb-4"><%= t("views.foods.empty_state.description") %></p>
        <%= link_to new_food_path, class: "btn-primary", data: { turbo_frame: "_top" } do %>
          <i class="fas fa-plus"></i>
          <%= t("views.foods.empty_state.cta") %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-surface-base rounded-lg border border-surface-border/40">
      <div class="overflow-x-auto rounded-lg">
        <table class="min-w-full table-dark">
          <%= render "table_headers" %>
          <tbody>
            <%= render partial: "table_row", collection: @foods, as: :food,
                  locals: { active_in_stock: @filtering_in_stock.present?, active_out_of_stock: @filtering_out_of_stock.present? } %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <!-- Pagination -->
  <% if @pagy&.pages&.> 1 %>
    <div class="mt-6 flex justify-center">
      <%= render PaginationComponent.new(pagy: @pagy, full_result_option: true) %>
    </div>
  <% elsif @pagy.nil? && params[:full_result] == "true" %>
    <div class="mt-6 flex justify-center">
      <%= render PaginationComponent.new(pagy: nil, full_result_option: true) %>
    </div>
  <% end %>
  <% end %> <%# /turbo_frame_tag foods_results %>
</div>
