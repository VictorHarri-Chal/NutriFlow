<%= turbo_frame_tag "food_show_panel" do %>
  <div class="flex flex-col h-full min-h-screen" data-controller="tabs">

    <%# ── Header ── %>
    <div class="flex items-start justify-between gap-4 p-5 border-b border-surface-border/50 shrink-0">
      <div class="min-w-0">
        <h2 class="text-base font-bold text-ink-primary leading-tight break-words"><%= @food.name %></h2>
        <div class="flex items-center flex-wrap gap-2 mt-1.5">
          <% case @food.source
             when :off %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-brand/10 text-brand border border-brand/30">
              <i class="fas fa-barcode text-[9px]"></i>
              <%= t("views.foods.show.source.off") %>
            </span>
          <% when :ciqual %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-status-success/10 text-status-success border border-status-success/30">
              <i class="fas fa-database text-[9px]"></i>
              <%= t("views.foods.show.source.ciqual") %>
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-surface-hover text-ink-subtle border border-surface-border/50">
              <i class="fas fa-pencil text-[9px]"></i>
              <%= t("views.foods.show.source.manual") %>
            </span>
          <% end %>
        </div>
      </div>
      <div class="flex items-center gap-1 shrink-0">
        <%= link_to edit_food_path(@food),
              class: "w-8 h-8 flex items-center justify-center rounded-lg text-ink-subtle hover:text-ink-primary hover:bg-surface-hover transition-colors",
              data: { turbo_frame: "_top" } do %>
          <i class="fas fa-pen text-sm"></i>
        <% end %>
        <button type="button"
                class="w-8 h-8 flex items-center justify-center rounded-lg text-ink-subtle hover:text-ink-primary hover:bg-surface-hover transition-colors"
                data-action="click->food-detail-panel#close">
          <i class="fas fa-xmark text-sm"></i>
        </button>
      </div>
    </div>

    <%
      _ns_grade  = %w[a b c d e].include?(@food.nutriscore_grade&.downcase) ? @food.nutriscore_grade.downcase : nil
      _nova_num  = @food.nova_group.present? && (1..4).include?(@food.nova_group.to_i) ? @food.nova_group.to_i : nil
      _eco_grade = %w[a-plus a b c d e f].include?(@food.ecoscore_grade&.downcase) ? @food.ecoscore_grade.downcase : nil
      _has_quality = _ns_grade.present? || _nova_num.present? || _eco_grade.present? ||
                    @food.additives.present? || @food.labels.present? ||
                    @food.allergens.present? || @food.traces.present?
    %>

    <%# ── Tabs ── %>
    <div class="shrink-0 border-b border-surface-border/50 px-5">
      <div class="flex gap-1 -mb-px">
        <button type="button"
                class="px-3 py-3 text-sm font-medium border-b-2 transition-colors"
                data-tabs-target="tab"
                data-action="click->tabs#switchTab"
                data-tab="nutrition"
                data-active-classes="border-brand text-brand"
                data-inactive-classes="border-transparent text-ink-muted hover:text-ink-primary">
          <%= t("views.foods.show.tabs.nutrition") %>
        </button>
        <% if _has_quality %>
          <button type="button"
                  class="px-3 py-3 text-sm font-medium border-b-2 transition-colors"
                  data-tabs-target="tab"
                  data-action="click->tabs#switchTab"
                  data-tab="quality"
                  data-active-classes="border-brand text-brand"
                  data-inactive-classes="border-transparent text-ink-muted hover:text-ink-primary">
            <%= t("views.foods.show.tabs.quality") %>
          </button>
        <% end %>
        <button type="button"
                class="px-3 py-3 text-sm font-medium border-b-2 transition-colors"
                data-tabs-target="tab"
                data-action="click->tabs#switchTab"
                data-tab="info"
                data-active-classes="border-brand text-brand"
                data-inactive-classes="border-transparent text-ink-muted hover:text-ink-primary">
          <%= t("views.foods.show.tabs.info") %>
        </button>
      </div>
    </div>

    <%# ── Tab panels ── %>
    <div class="flex-1 overflow-y-auto">

      <%# ── Tab Nutrition ── %>
      <div id="nutrition-tab" data-tabs-target="content" class="p-5 space-y-5">

        <%# Calories %>
        <div class="text-center py-4 bg-surface-base rounded-xl border border-surface-border/40">
          <div class="text-4xl font-bold text-brand leading-none"><%= format_macro(@food.calories) %></div>
          <div class="text-xs text-ink-subtle mt-1.5"><%= t("views.foods.show.kcal_per_100g") %></div>
        </div>

        <%# Macros principales + étiquette étendue fusionnées %>
        <div>
          <h3 class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3"><%= t("views.foods.show.macros") %></h3>
          <div class="bg-surface-base rounded-xl border border-surface-border/40 divide-y divide-surface-border/30">
            <% [
              { value: @food.proteins,     label: t("activerecord.attributes.food.proteins"),       unit: "g" },
              { value: @food.carbs,        label: t("activerecord.attributes.food.carbs"),           unit: "g" },
              { value: @food.fats,         label: t("activerecord.attributes.food.fats"),            unit: "g" },
              { value: @food.sugars,       label: t("activerecord.attributes.food.sugars"),          unit: "g" },
              { value: @food.fiber,        label: t("views.foods.show.nutrients.fiber"),             unit: "g" },
              { value: @food.saturated_fat, label: t("views.foods.show.nutrients.saturated_fat"),   unit: "g" },
              { value: @food.salt,         label: t("views.foods.show.nutrients.salt"),              unit: "g" }
            ].each do |row| %>
              <div class="flex items-center justify-between px-4 py-2.5">
                <span class="text-sm text-ink-muted"><%= row[:label] %></span>
                <% if row[:value].present? %>
                  <span class="text-sm font-semibold text-ink-primary"><%= format_macro(row[:value]) %> <span class="text-xs font-normal text-ink-subtle"><%= row[:unit] %></span></span>
                <% else %>
                  <span class="text-sm text-ink-subtle">—</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <%
          mn = (@food.micronutrients || {}).transform_keys(&:to_s)
          present_minerals = Micronutrient.minerals.map(&:key).select { |k| mn[k.to_s].present? }
          present_vitamins = Micronutrient.vitamins.map(&:key).select { |k| mn[k.to_s].present? }
        %>
        <% if present_minerals.any? %>
          <div>
            <h3 class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3"><%= t("views.foods.show.minerals") %></h3>
            <div class="bg-surface-base rounded-xl border border-surface-border/40 divide-y divide-surface-border/30">
              <% present_minerals.each do |key| %>
                <div class="flex items-center justify-between px-4 py-2.5">
                  <span class="text-sm text-ink-muted"><%= t("views.foods.show.nutrients.#{key}") %></span>
                  <span class="text-sm font-semibold text-ink-primary"><%= mn[key.to_s] %> <span class="text-xs font-normal text-ink-subtle"><%= Micronutrient.find(key).unit %></span></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if present_vitamins.any? %>
          <div>
            <h3 class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3"><%= t("views.foods.show.vitamins") %></h3>
            <div class="bg-surface-base rounded-xl border border-surface-border/40 divide-y divide-surface-border/30">
              <% present_vitamins.each do |key| %>
                <div class="flex items-center justify-between px-4 py-2.5">
                  <span class="text-sm text-ink-muted"><%= t("views.foods.show.nutrients.#{key}") %></span>
                  <span class="text-sm font-semibold text-ink-primary"><%= mn[key.to_s] %> <span class="text-xs font-normal text-ink-subtle"><%= Micronutrient.find(key).unit %></span></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>

      <%# ── Tab Qualité ── %>
      <% if _has_quality %>
      <div id="quality-tab" data-tabs-target="content" class="hidden p-5 space-y-4">

        <%
          ns_colors  = { "a" => "#038141", "b" => "#85BB2F", "c" => "#FECB02", "d" => "#EE8100", "e" => "#E63E11" }
          nova_colors = { 1 => "#038141", 2 => "#85BB2F", 3 => "#EE8100", 4 => "#E63E11" }
          eco_colors = { "a-plus" => "#006400", "a" => "#038141", "b" => "#85BB2F", "c" => "#FECB02", "d" => "#EE8100", "e" => "#E63E11", "f" => "#8B1A1A" }
          eco_labels = { "a-plus" => "A+" }

          scores = [
            {
              label:       "Nutri-Score",
              color:       ns_colors[_ns_grade],
              badge_text:  _ns_grade&.upcase,
              description: _ns_grade.present? ? t("views.foods.show.nutriscore_description.#{_ns_grade}", default: "") : nil
            },
            {
              label:       "NOVA#{_nova_num ? " #{_nova_num}" : ""}",
              color:       nova_colors[_nova_num],
              badge_text:  _nova_num&.to_s,
              description: _nova_num ? t("views.foods.show.nova_description.#{_nova_num}", default: "") : nil
            },
            {
              label:       "Éco-Score",
              color:       eco_colors[_eco_grade],
              badge_text:  eco_labels[_eco_grade] || _eco_grade&.upcase,
              description: _eco_grade.present? ? t("views.foods.show.ecoscore_description.#{_eco_grade}", default: _eco_grade.upcase) : nil
            }
          ].select { |s| s[:badge_text].present? }
        %>

        <% scores.each do |score| %>
          <div class="bg-surface-base rounded-xl border border-surface-border/40 p-4">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 rounded-xl flex items-center justify-center shrink-0 text-white text-2xl font-black"
                   style="background-color: <%= score[:color] || '#52525B' %>;">
                <%= score[:badge_text] %>
              </div>
              <div>
                <div class="text-sm font-semibold text-ink-primary"><%= score[:label] %></div>
                <div class="text-xs text-ink-muted mt-0.5"><%= score[:description] %></div>
              </div>
            </div>
          </div>
        <% end %>

        <%# ── Allergènes ── %>
        <% if @food.allergens.present? %>
          <div class="bg-surface-base rounded-xl border border-surface-border/40 p-4">
            <h4 class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3"><%= t("views.foods.show.allergens") %></h4>
            <div class="flex flex-wrap gap-1.5">
              <% @food.allergens.each do |allergen| %>
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-status-danger/10 border border-status-danger/30 text-status-danger">
                  <i class="fas fa-triangle-exclamation text-[9px]"></i>
                  <%= translate_allergen(allergen) %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── Traces ── %>
        <% if @food.traces.present? %>
          <div class="bg-surface-base rounded-xl border border-surface-border/40 p-4">
            <h4 class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3"><%= t("views.foods.show.traces") %></h4>
            <div class="flex flex-wrap gap-1.5">
              <% @food.traces.each do |trace| %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-surface-hover border border-surface-border/50 text-ink-muted">
                  <%= translate_allergen(trace) %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── Additifs ── %>
        <% if @food.additives.present? %>
          <div class="bg-surface-base rounded-xl border border-surface-border/40 p-4">
            <h4 class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3"><%= t("views.foods.show.additives") %></h4>
            <div class="flex flex-wrap gap-1.5">
              <% @food.additives.each do |additive| %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-surface-hover border border-surface-border/50 text-ink-muted">
                  <%= additive.gsub("-", " ") %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── Labels & Certifications ── %>
        <% if @food.labels.present? %>
          <div class="bg-surface-base rounded-xl border border-surface-border/40 p-4">
            <h4 class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3"><%= t("views.foods.show.labels") %></h4>
            <div class="flex flex-wrap gap-1.5">
              <% @food.labels.each do |label| %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-surface-hover border border-surface-border/50 text-ink-muted">
                  <%= translate_label(label) %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>
      <% end %>

      <%# ── Tab Infos ── %>
      <div id="info-tab" data-tabs-target="content" class="hidden p-5 space-y-5">

        <%# Métadonnées %>
        <div class="bg-surface-base rounded-xl border border-surface-border/40 divide-y divide-surface-border/30">
          <% if @food.brand.present? %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-sm text-ink-muted"><%= t("activerecord.attributes.food.brand") %></span>
              <span class="text-sm font-medium text-ink-primary"><%= @food.brand %></span>
            </div>
          <% end %>
          <% if @food.category.present? %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-sm text-ink-muted"><%= t("views.foods.form.category") %></span>
              <span class="text-sm font-medium text-ink-primary"><%= t("views.shopping_lists.categories.#{@food.category}") %></span>
            </div>
          <% end %>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-sm text-ink-muted"><%= t("views.foods.show.logged_count") %></span>
            <span class="text-sm font-medium text-ink-primary"><%= @usage_count %> <%= t("views.foods.show.times") %></span>
          </div>
          <% if @food.off_id.present? %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-sm text-ink-muted"><%= t("views.foods.show.off_id_label") %></span>
              <span class="text-xs font-mono text-ink-subtle truncate max-w-[140px]"><%= @food.off_id %></span>
            </div>
          <% end %>
        </div>


      </div>

    </div>
  </div>
<% end %>
