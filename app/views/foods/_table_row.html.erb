<tr class="hover:bg-gray-50 transition-colors">
  <td class="px-4 py-3 font-medium text-gray-900"><%= food.name %></td>
  <td class="px-4 py-3 text-gray-600"><%= food.brand.presence || "—" %></td>
  <td class="px-4 py-3">
    <%= render FoodLabelsComponent.new(food: food) %>
  </td>
  <td class="px-4 py-3 text-gray-800"><%= food.calories %> kcal</td>
  <td class="px-4 py-3 text-gray-800"><%= food.proteins %> g</td>
  <td class="px-4 py-3 text-gray-800"><%= food.carbs %> g</td>
  <td class="px-4 py-3 text-gray-800"><%= food.fats %> g</td>
  <td class="px-4 py-3 text-gray-800"><%= food.sugars %> g</td>
  <td class="px-4 py-3">
    <div class="flex items-center justify-center gap-2">
      <%= link_to edit_food_path(food),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors",
            title: t("shared.edit") do %>
        <i class="fas fa-pen text-sm"></i>
      <% end %>

      <%= delete_link_with_confirm(
            food_path(food),
            confirm: t("views.foods.delete_confirm", name: food.name),
            icon_class: "fas fa-trash text-sm",
            title: t("shared.delete"),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors") %>
    </div>
  </td>
</tr>
