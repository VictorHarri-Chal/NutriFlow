<% filter_in_stock    = local_assigns.fetch(:active_in_stock, false) %>
<% filter_out_of_stock = local_assigns.fetch(:active_out_of_stock, false) %>

<tr class="group" id="food_<%= food.id %>">

  <%# Aliment + Marque %>
  <td>
    <div class="font-medium text-ink-primary leading-tight"><%= food.name %></div>
    <% if food.brand.present? %>
      <div class="text-xs text-ink-subtle mt-0.5"><%= food.brand %></div>
    <% end %>
  </td>

  <%# Labels %>
  <td><%= render FoodLabelsComponent.new(food: food) %></td>

  <%# Calories %>
  <td class="text-right whitespace-nowrap">
    <span class="text-base font-bold text-brand"><%= format_macro(food.calories) %></span>
    <span class="text-xs text-ink-subtle ml-0.5">kcal</span>
  </td>

  <%# Protéines %>
  <td class="text-right whitespace-nowrap">
    <span class="text-sm font-medium text-ink-primary"><%= format_macro(food.proteins) %></span>
    <span class="text-xs text-ink-subtle/50 ml-0.5">g</span>
  </td>

  <%# Glucides %>
  <td class="text-right whitespace-nowrap">
    <span class="text-sm font-medium text-ink-primary"><%= format_macro(food.carbs) %></span>
    <span class="text-xs text-ink-subtle/50 ml-0.5">g</span>
  </td>

  <%# Lipides %>
  <td class="text-right whitespace-nowrap">
    <span class="text-sm font-medium text-ink-primary"><%= format_macro(food.fats) %></span>
    <span class="text-xs text-ink-subtle/50 ml-0.5">g</span>
  </td>

  <%# Utilisations %>
  <td class="text-center whitespace-nowrap">
    <% count = @usage_counts.fetch(food.id, 0) %>
    <% if count > 0 %>
      <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-surface-hover text-ink-muted"><%= count %></span>
    <% else %>
      <span class="text-ink-subtle/30 text-sm">—</span>
    <% end %>
  </td>

  <%# Actions %>
  <td class="text-right">
    <div class="flex items-center justify-end gap-1">

      <%# Actions secondaires — apparaissent au survol %>
      <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
        <%# Favori %>
        <%= link_to toggle_favorite_food_path(food),
              class: "inline-flex items-center justify-center w-8 h-8 rounded-lg transition-colors #{food.favorite? ? 'text-amber-400 hover:text-amber-300 hover:bg-amber-400/10' : 'text-ink-subtle hover:text-amber-400 hover:bg-amber-400/10'}",
              title: food.favorite? ? t("views.foods.remove_favorite") : t("views.foods.add_favorite"),
              data: { turbo_method: :patch } do %>
          <i class="<%= food.favorite? ? 'fas' : 'far' %> fa-star text-sm"></i>
        <% end %>

        <%= link_to duplicate_food_path(food),
              class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-ink-muted hover:bg-surface-hover transition-colors",
              title: t("views.foods.duplicate"),
              data: { turbo_method: :post, turbo_frame: "_top" } do %>
          <i class="fas fa-copy text-sm"></i>
        <% end %>

        <%= link_to edit_food_path(food),
              class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-brand hover:bg-surface-hover transition-colors",
              title: t("shared.edit"),
              data: { turbo_frame: "_top" } do %>
          <i class="fas fa-pen text-sm"></i>
        <% end %>

        <%= delete_link_with_confirm(
              food_path(food),
              confirm: t("views.foods.delete_confirm", name: food.name),
              icon_class: "fas fa-trash text-sm",
              title: t("shared.delete"),
              class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors") %>
      </div>

      <%# Pantry toggle — toujours visible, tout à droite %>
      <%= button_to toggle_pantry_food_path(food),
            method: :patch,
            params: { filter_in_stock: filter_in_stock, filter_out_of_stock: filter_out_of_stock },
            title: food.in_pantry? ? t("views.foods.pantry_in_stock") : t("views.foods.pantry_out_of_stock"),
            form: { class: "contents" },
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg transition-colors #{food.in_pantry? ? 'text-status-success hover:text-status-success/70 hover:bg-status-success/10' : 'text-ink-subtle/40 hover:text-status-success hover:bg-status-success/10'}" do %>
        <i class="fas <%= food.in_pantry? ? 'fa-circle-check' : 'fa-circle-xmark' %> text-sm"></i>
      <% end %>

    </div>
  </td>

</tr>
