<tr class="group">
  <td class="font-medium text-ink-primary"><%= food.name %></td>
  <td class="text-ink-muted"><%= food.brand.presence || "—" %></td>
  <td>
    <%= render FoodLabelsComponent.new(food: food) %>
  </td>
  <td class="text-brand font-semibold"><%= format_macro(food.calories) %></td>
  <td class="text-ink-primary font-medium"><%= format_macro(food.proteins) %></td>
  <td class="text-ink-muted"><%= format_macro(food.carbs) %></td>
  <td class="text-ink-muted"><%= format_macro(food.fats) %></td>
  <td class="text-ink-subtle"><%= format_macro(food.sugars) %></td>
  <td class="text-center text-ink-subtle text-sm whitespace-nowrap">
    <% count = @usage_counts.fetch(food.id, 0) %>
    <% if count > 0 %>
      <span class="text-ink-muted font-medium"><%= count %></span>
    <% else %>
      <span class="text-ink-subtle/40">—</span>
    <% end %>
  </td>
  <td class="table-sticky-col bg-surface-raised group-hover:bg-surface-hover" style="--sticky-bg: #27272A;">
    <div class="flex items-center justify-center gap-2">
      <%= link_to duplicate_food_path(food),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-ink-muted hover:bg-surface-hover transition-colors",
            title: t("views.foods.duplicate"),
            data: { turbo_method: :post } do %>
        <i class="fas fa-copy text-sm"></i>
      <% end %>

      <%= link_to edit_food_path(food),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-brand hover:bg-surface-hover transition-colors",
            title: t("shared.edit") do %>
        <i class="fas fa-pen text-sm"></i>
      <% end %>

      <%= delete_link_with_confirm(
            food_path(food),
            confirm: t("views.foods.delete_confirm", name: food.name),
            icon_class: "fas fa-trash text-sm",
            title: t("shared.delete"),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors") %>
    </div>
  </td>
</tr>
