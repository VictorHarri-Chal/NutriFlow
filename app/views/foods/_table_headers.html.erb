<thead>
  <tr>
    <th class="whitespace-nowrap"><%= food_sort_link(:name, Food.human_attribute_name(:name)) %></th>
    <th class="whitespace-nowrap"><%= food_sort_link(:brand, Food.human_attribute_name(:brand)) %></th>
    <th class="whitespace-nowrap"><%= t("views.foods.labels_col") %></th>
    <th class="whitespace-nowrap"><%= food_sort_link(:calories, "#{Food.human_attribute_name(:calories)} (kcal)") %></th>
    <th class="whitespace-nowrap"><%= food_sort_link(:proteins, "#{Food.human_attribute_name(:proteins)} (g)") %></th>
    <th class="whitespace-nowrap"><%= food_sort_link(:carbs, "#{Food.human_attribute_name(:carbs)} (g)") %></th>
    <th class="whitespace-nowrap"><%= food_sort_link(:fats, "#{Food.human_attribute_name(:fats)} (g)") %></th>
    <th class="whitespace-nowrap"><%= food_sort_link(:sugars, "#{Food.human_attribute_name(:sugars)} (g)") %></th>
    <th class="text-center whitespace-nowrap"><%= t("views.foods.usages_col") %></th>
    <th class="text-center whitespace-nowrap table-sticky-col bg-surface-base" style="--sticky-bg: #18181B;"><%= t("shared.actions") %></th>
