<%# pe: ProgramExercise, last_performance: { at:, sets: } | nil %>
<% exercise = pe.exercise %>
<div class="fixed inset-0 z-50 flex items-center justify-center p-4"
     data-controller="modal"
     data-action="click->modal#handleBackdropClick keydown@document->modal#handleEscape">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <div class="relative w-full max-w-md bg-surface-raised border border-surface-border/50 rounded-2xl shadow-2xl transition-all duration-200 ease-out scale-95 opacity-0 flex flex-col max-h-[85vh] overflow-hidden"
       data-modal-target="panel">

    <div class="flex items-center justify-between px-5 py-4 border-b border-surface-border/40 flex-shrink-0">
      <div class="flex items-center gap-1.5 min-w-0">
        <h3 class="text-sm font-semibold text-ink-primary break-words"><%= exercise.name.capitalize %></h3>
        <i class="fas fa-circle-info text-xs text-ink-subtle/40 hover:text-ink-subtle cursor-default transition-colors shrink-0"
           title="<%= t('views.workout_sets.set_editor.info_tooltip') %>"></i>
      </div>
      <button type="button" class="btn-ghost w-8 h-8 !p-0 flex items-center justify-center flex-shrink-0"
              data-action="click->modal#close">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <%= form_with model: pe,
          url: pe.persisted? ? program_exercise_path(pe) : program_day_program_exercises_path(pe.program_day),
          method: pe.persisted? ? :patch : :post,
          scope: :program_exercise,
          html: { novalidate: true,
                  data: { controller: "nested-form", nested_form_wrapper_selector_value: ".pe-sets-container",
                          nested_form_max_items_value: 10 } },
          class: "flex flex-col flex-1 min-h-0" do |f| %>

      <%= f.hidden_field :exercise_id %>

      <div class="px-5 py-4 overflow-y-auto min-h-0 flex-1">
        <%= render "shared/form_errors", record: pe, margin_class: "mb-3" %>

        <% info_primary_rows = [
             (exercise.target_muscle.present? ? [t("views.exercises.show.primary_muscle"), t_muscle(exercise.target_muscle)] : nil),
             (exercise.secondary_muscles.present? ? [t("views.exercises.show.secondary_muscles"), exercise.secondary_muscles.map { |m| t_muscle(m) }.join(", ")] : nil),
           ].compact
           info_detail_rows = [
             (exercise.difficulty.present? ? [t("views.exercises.filter_difficulty"), t("views.exercises.difficulty.#{exercise.difficulty}", default: exercise.difficulty)] : nil),
             (exercise.equipment.present? ? [t("views.exercises.filter_equipment"), t_equipment(exercise.equipment)] : nil),
             (exercise.category.present? ? [t("views.exercises.custom.fields.category"), t_category(exercise.category)] : nil),
             (exercise.tension_profile.present? ? [t("views.exercises.filter_tension_profile"), t("views.exercises.tension_profile.#{exercise.tension_profile}", default: exercise.tension_profile)] : nil),
           ].compact
        %>
        <% if info_primary_rows.any? || info_detail_rows.any? %>
          <div class="bg-surface-base border border-surface-border/40 rounded-xl divide-y divide-surface-border/30 mb-4"
               <%= 'data-controller="collapsible"'.html_safe if info_detail_rows.any? %>>
            <% info_primary_rows.each do |label, value| %>
              <div class="flex items-baseline justify-between gap-3 px-3.5 py-2">
                <span class="text-[11px] text-ink-subtle flex-shrink-0"><%= label %></span>
                <span class="text-[11.5px] text-ink-muted text-right break-words"><%= value %></span>
              </div>
            <% end %>
            <% if info_detail_rows.any? %>
              <div class="hidden divide-y divide-surface-border/30" data-collapsible-target="content">
                <% info_detail_rows.each do |label, value| %>
                  <div class="flex items-baseline justify-between gap-3 px-3.5 py-2">
                    <span class="text-[11px] text-ink-subtle flex-shrink-0"><%= label %></span>
                    <span class="text-[11.5px] text-ink-muted text-right break-words"><%= value %></span>
                  </div>
                <% end %>
              </div>
              <div class="flex items-center gap-1.5 px-3.5 py-2 text-[10.5px] text-ink-subtle hover:text-ink-muted cursor-pointer select-none transition-colors"
                   data-action="click->collapsible#toggle" data-collapsible-target="trigger">
                <i class="fas fa-chevron-down text-[9px] transition-transform duration-200" data-collapsible-target="icon"></i>
                <%= t("views.workout_sets.set_editor.exercise_info_toggle") %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div>
          <template data-nested-form-target="template">
            <%= f.fields_for :program_exercise_sets, ProgramExerciseSet.new, child_index: "NEW_RECORD" do |set_form| %>
              <%= render "workout_programs/set_fields", f: set_form %>
            <% end %>
          </template>

          <div data-nested-form-target="emptyState" style="<%= pe.program_exercise_sets.any? ? 'display:none;' : '' %>"
               class="text-center py-6 border-2 border-dashed border-surface-border/40 rounded-xl">
            <div class="w-10 h-10 mx-auto mb-2.5 bg-surface-hover rounded-full flex items-center justify-center">
              <i class="fas fa-layer-group text-brand text-sm"></i>
            </div>
            <h4 class="text-xs font-semibold text-ink-primary mb-1"><%= t("views.workout_sets.set_editor.no_sets_title") %></h4>
            <p class="text-[10px] text-ink-muted mb-3 px-6"><%= t("views.workout_sets.set_editor.no_sets_description") %></p>
            <button type="button" data-action="click->nested-form#add" class="btn-primary text-xs px-3 py-1.5">
              <%= t("views.workout_sets.set_editor.add_set") %>
            </button>
          </div>

          <div class="pe-sets-container">
            <%= f.fields_for :program_exercise_sets do |set_form| %>
              <%= render "workout_programs/set_fields", f: set_form %>
            <% end %>
          </div>

          <button type="button" data-nested-form-target="addButton" data-action="click->nested-form#add"
                  style="<%= pe.program_exercise_sets.any? ? '' : 'display:none;' %>"
                  class="w-full justify-center items-center border border-dashed border-surface-border/50 rounded-xl py-2 text-[11px] text-ink-muted hover:text-ink-primary hover:border-surface-border transition-colors mt-1">
            <%= t("views.workout_sets.set_editor.add_set") %>
          </button>
        </div>

        <div class="mt-4 pt-3 border-t border-surface-border/30">
          <label class="text-[11px] font-medium text-ink-muted mb-1 flex items-center gap-1.5">
            <i class="fas fa-hourglass-half text-[9px]"></i>
            <%= t("views.workout_sets.set_editor.rest_label") %>
          </label>
          <%= f.number_field :rest_seconds, min: 0, step: 5,
                class: "w-full text-xs bg-surface-base border border-surface-border/40 rounded-lg px-3 py-2 text-ink-primary placeholder:text-ink-subtle/40 focus:outline-none focus:border-brand/50 transition-colors",
                data: { controller: "digit-limit", action: "input->digit-limit#limit", digit_limit_max_integer_digits_value: 4 } %>
        </div>

        <div class="mt-3">
          <label class="text-[11px] font-medium text-ink-muted mb-1 flex items-center gap-1.5">
            <i class="fas fa-comment-alt text-[9px]"></i>
            <%= t("views.workout_sets.set_editor.notes_label") %>
          </label>
          <%= f.text_area :notes, rows: 3, maxlength: 500,
                class: "w-full text-xs bg-surface-base border border-surface-border/40 rounded-lg px-3 py-2 text-ink-primary placeholder:text-ink-subtle/40 focus:outline-none focus:border-brand/50 transition-colors",
                style: "resize: vertical;" %>
        </div>

        <% if last_performance.present? %>
          <div class="mt-3">
            <label class="text-[11px] font-medium text-ink-muted mb-1 block"><%= t("views.workout_sets.set_editor.last_performance_title") %></label>
            <div class="bg-surface-hover/30 border border-surface-border/30 rounded-lg px-3 py-2 text-[10px] text-ink-muted">
              <%= l(last_performance[:at].to_date, format: :short) %> ·
              <%= last_performance[:sets].map { |s| s.weight_kg.to_f > 0 ? "#{s.reps} × #{s.weight_kg.to_f} kg" : "#{s.reps} × #{t('views.workout_sets.set_editor.bodyweight_abbr')}" }.join("  ·  ") %>
              <% if last_performance[:sets].any?(&:is_pr) %>
                <span class="shrink-0 text-[8px] font-bold text-brand bg-brand/10 border border-brand/30 rounded px-1 py-px leading-none"><%= t("views.workout_sets.set_editor.last_performance_pr_badge") %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex justify-end gap-2 px-5 py-4 border-t border-surface-border/40 flex-shrink-0">
        <button type="button" class="btn-secondary" data-action="click->modal#close">
          <%= t("views.workout_sets.set_editor.cancel_btn") %>
        </button>
        <button type="submit"
                data-nested-form-target="submitButton"
                <%= "disabled" if pe.program_exercise_sets.empty? %>
                class="btn-primary disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-brand disabled:shadow-none">
          <%= t("views.workout_sets.set_editor.save_btn") %>
        </button>
      </div>
    <% end %>
  </div>
</div>
