<%# pe: ProgramExercise, last_performance: { at:, sets: } | nil %>
<div class="fixed inset-0 z-50 flex items-center justify-center p-4"
     data-controller="modal"
     data-action="click->modal#handleBackdropClick keydown@document->modal#handleEscape">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <div class="relative w-full max-w-md bg-surface-raised border border-surface-border/50 rounded-2xl shadow-2xl transition-all duration-200 ease-out scale-95 opacity-0 flex flex-col max-h-[85vh] overflow-hidden"
       data-modal-target="panel">

    <div class="flex items-center justify-between px-5 py-4 border-b border-surface-border/40 flex-shrink-0">
      <div class="flex items-center gap-1.5 min-w-0">
        <h3 class="text-sm font-semibold text-ink-primary truncate"><%= pe.exercise.name.capitalize %></h3>
        <i class="fas fa-circle-info text-xs text-ink-subtle/40 hover:text-ink-subtle cursor-default transition-colors shrink-0"
           title="<%= t('views.workout_programs.set_editor.info_tooltip') %>"></i>
      </div>
      <button type="button" class="btn-ghost w-8 h-8 !p-0 flex items-center justify-center flex-shrink-0"
              data-action="click->modal#close">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <%= form_with model: pe, url: program_exercise_path(pe), method: :patch, scope: :program_exercise,
          html: { novalidate: true }, class: "flex flex-col flex-1 min-h-0" do |f| %>

      <div class="px-5 py-4 overflow-y-auto min-h-0 flex-1">
        <% if pe.errors.any? %>
          <div class="mb-3 text-[11px] text-status-danger bg-status-danger/10 border border-status-danger/30 rounded-lg px-3 py-2">
            <ul class="list-disc list-inside space-y-0.5">
              <% pe.errors.full_messages.uniq.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".pe-sets-container">
          <template data-nested-form-target="template">
            <%= f.fields_for :program_exercise_sets, ProgramExerciseSet.new, child_index: "NEW_RECORD" do |set_form| %>
              <%= render "workout_programs/set_fields", f: set_form %>
            <% end %>
          </template>

          <div data-nested-form-target="emptyState" style="<%= pe.program_exercise_sets.any? ? 'display:none;' : '' %>"
               class="text-center py-6 border-2 border-dashed border-surface-border/40 rounded-xl">
            <div class="w-10 h-10 mx-auto mb-2.5 bg-surface-hover rounded-full flex items-center justify-center">
              <i class="fas fa-layer-group text-brand text-sm"></i>
            </div>
            <h4 class="text-xs font-semibold text-ink-primary mb-1"><%= t("views.workout_programs.set_editor.no_sets_title") %></h4>
            <p class="text-[10px] text-ink-muted mb-3 px-6"><%= t("views.workout_programs.set_editor.no_sets_description") %></p>
            <button type="button" data-action="click->nested-form#add" class="btn-primary text-xs px-3 py-1.5">
              <%= t("views.workout_programs.set_editor.add_set") %>
            </button>
          </div>

          <div class="pe-sets-container">
            <%= f.fields_for :program_exercise_sets do |set_form| %>
              <%= render "workout_programs/set_fields", f: set_form %>
            <% end %>
          </div>

          <button type="button" data-nested-form-target="addButton" data-action="click->nested-form#add"
                  style="<%= pe.program_exercise_sets.any? ? '' : 'display:none;' %>"
                  class="w-full justify-center items-center border border-dashed border-surface-border/50 rounded-xl py-2 text-[11px] text-ink-muted hover:text-ink-primary hover:border-surface-border transition-colors mt-1">
            <%= t("views.workout_programs.set_editor.add_set") %>
          </button>
        </div>

        <div class="mt-4 pt-3 border-t border-surface-border/30">
          <label class="text-[11px] font-medium text-ink-muted mb-1 flex items-center gap-1.5">
            <i class="fas fa-hourglass-half text-[9px]"></i>
            <%= t("views.workout_programs.set_editor.rest_label") %>
          </label>
          <%= f.number_field :rest_seconds, min: 0, step: 5,
                class: "w-full text-xs bg-surface-base border border-surface-border/40 rounded-lg px-3 py-2 text-ink-primary placeholder:text-ink-subtle/40 focus:outline-none focus:border-brand/50 transition-colors" %>
        </div>

        <div class="mt-3">
          <label class="text-[11px] font-medium text-ink-muted mb-1 flex items-center gap-1.5">
            <i class="fas fa-comment-alt text-[9px]"></i>
            <%= t("views.workout_programs.set_editor.notes_label") %>
          </label>
          <%= f.text_area :notes, rows: 3,
                class: "w-full text-xs bg-surface-base border border-surface-border/40 rounded-lg px-3 py-2 text-ink-primary placeholder:text-ink-subtle/40 focus:outline-none focus:border-brand/50 transition-colors",
                style: "resize: vertical;" %>
        </div>

        <% if last_performance.present? %>
          <div class="mt-3">
            <label class="text-[11px] font-medium text-ink-muted mb-1 block"><%= t("views.workout_programs.set_editor.last_performance_title") %></label>
            <div class="bg-surface-hover/30 border border-surface-border/30 rounded-lg px-3 py-2 text-[10px] text-ink-muted">
              <%= t("views.workout_programs.set_editor.last_performance_ago", time: time_ago_in_words(last_performance[:at])) %> ·
              <%= last_performance[:sets].map { |s| "#{s.reps}×#{s.weight_kg.to_f}" }.join(", ") %>
              <% if last_performance[:sets].any?(&:is_pr) %>
                <span class="shrink-0 text-[8px] font-bold text-brand bg-brand/10 border border-brand/30 rounded px-1 py-px leading-none"><%= t("views.workout_programs.set_editor.last_performance_pr_badge") %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex justify-end gap-2 px-5 py-4 border-t border-surface-border/40 flex-shrink-0">
        <button type="button" class="btn-secondary" data-action="click->modal#close">
          <%= t("views.workout_programs.set_editor.cancel_btn") %>
        </button>
        <button type="submit" class="btn-primary">
          <%= t("views.workout_programs.set_editor.save_btn") %>
        </button>
      </div>
    <% end %>
  </div>
</div>
