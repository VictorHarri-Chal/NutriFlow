<%# day: ProgramDay, program: WorkoutProgram %>

<div class="flex flex-col bg-surface-raised border border-surface-border/40 rounded-xl h-full"
     id="program_day_<%= day.id %>">

  <%# ── Day header ── %>
  <div class="px-3 py-2.5 border-b border-surface-border/40 bg-surface-base/60 rounded-t-xl"
       data-controller="collapsible"
       data-collapsible-group="copy-panels"
       data-collapsible-dismiss-on-outside-click>

    <%# Abbr row with copy button %>
    <div class="flex items-center justify-between mb-1.5">
      <div class="w-5 shrink-0"></div>
      <p class="text-[10px] font-bold uppercase tracking-widest text-ink-subtle/60 text-center flex-1">
        <%= day.day_abbr %>
      </p>
      <% if day.program_exercises.any? %>
        <button type="button"
                data-action="click->collapsible#toggle"
                title="<%= t("views.workout_programs.day.copy_to_title") %>"
                class="w-5 h-5 flex items-center justify-center rounded text-ink-subtle/30 hover:text-ink-subtle/70 transition-colors cursor-pointer shrink-0">
          <i class="fas fa-copy text-[9px]"></i>
        </button>
      <% else %>
        <div class="w-5 shrink-0"></div>
      <% end %>
    </div>

    <%# Copy targets panel — inline, no absolute positioning to avoid overflow clipping %>
    <div data-collapsible-target="content" class="hidden mb-2">
      <p class="text-[9px] font-semibold uppercase tracking-wider text-ink-subtle/40 mb-1.5">
        <%= t("views.workout_programs.day.copy_to_title") %>
      </p>
      <div class="grid grid-cols-3 gap-1">
        <% program.program_days.reject { |d| d.id == day.id }.each do |target| %>
          <% copy_url = copy_to_workout_program_program_day_path(program, day) %>
          <% if target.program_exercises.any? %>
            <button type="button"
                    class="text-center py-1 text-[10px] rounded-lg border border-surface-border/40 text-ink-muted hover:bg-surface-hover hover:text-ink-primary hover:border-surface-border/60 transition-colors cursor-pointer"
                    data-action="click->confirm#show"
                    data-url="<%= copy_url %>"
                    data-confirm-params="<%= { target_day_id: target.id }.to_json %>"
                    data-method="post"
                    data-confirm-message="<%= t("views.workout_programs.day.copy_to_confirm") %>"
                    data-confirm-label="<%= t("views.workout_programs.day.copy_confirm_btn") %>">
              <%= target.day_abbr %>
            </button>
          <% else %>
            <button type="button"
                    class="text-center py-1 text-[10px] rounded-lg border border-surface-border/40 text-ink-muted hover:bg-surface-hover hover:text-ink-primary hover:border-surface-border/60 transition-colors cursor-pointer"
                    data-action="click->confirm#submit"
                    data-url="<%= copy_url %>"
                    data-confirm-params="<%= { target_day_id: target.id }.to_json %>"
                    data-method="post">
              <%= target.day_abbr %>
            </button>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Inline editable session name %>
    <%= form_with url: workout_program_program_day_path(program, day),
          method: :patch,
          scope: :program_day,
          class: "w-full" do |f| %>
      <%= f.text_field :name,
            value: day.name,
            placeholder: t("views.workout_programs.day.rest_placeholder"),
            class: "w-full text-center text-sm font-bold bg-transparent border border-transparent rounded-lg px-1 py-1 text-ink-primary placeholder:text-ink-subtle/30 hover:border-surface-border/60 focus:border-brand/50 focus:outline-none focus:bg-surface-hover transition-colors cursor-text",
            data: { action: "blur->auto-submit#submit keydown.enter->auto-submit#submit",
                    controller: "auto-submit" } %>
    <% end %>
  </div>

  <%# ── Duration + Notes metadata ── %>
  <%= form_with url: workout_program_program_day_path(program, day),
        method: :patch,
        html: { novalidate: true },
        class: "px-2 pt-2 pb-1 border-b border-surface-border/20 space-y-1" do %>
    <div class="flex items-center gap-1.5">
      <i class="fas fa-clock text-[9px] text-ink-subtle/50 shrink-0 w-3 text-center"></i>
      <div class="relative flex-1">
        <%= number_field_tag "program_day[duration_minutes]", day.duration_minutes,
              min: 0, step: 1,
              placeholder: t("views.workout_programs.day.duration_placeholder"),
              class: "w-full pr-6 text-[10px] bg-transparent border border-transparent rounded px-1 py-0.5 text-ink-muted placeholder:text-ink-subtle/30 hover:border-surface-border/50 focus:border-brand/40 focus:outline-none focus:bg-surface-hover transition-colors cursor-text",
              data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
        <span class="absolute right-1 top-1/2 -translate-y-1/2 text-[9px] text-ink-subtle/40 pointer-events-none">min</span>
      </div>
    </div>
    <div class="flex items-start gap-1.5">
      <i class="fas fa-comment-alt text-[9px] text-ink-subtle/50 shrink-0 w-3 text-center mt-1.5"></i>
      <%= text_area_tag "program_day[notes]", day.notes,
            rows: 2,
            placeholder: t("views.workout_programs.day.notes_placeholder"),
            class: "w-full text-[10px] bg-transparent border border-transparent rounded px-1 py-0.5 text-ink-muted placeholder:text-ink-subtle/30 hover:border-surface-border/50 focus:border-brand/40 focus:outline-none focus:bg-surface-hover transition-all cursor-text min-h-[28px] focus:min-h-[56px]",
            style: "resize: vertical; overflow-y: auto;",
            data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
    </div>
  <% end %>

  <%# ── Exercise list ── %>
  <div class="flex-1 p-2 space-y-1.5 overflow-y-auto"
       id="program_day_exercises_<%= day.id %>"
       data-controller="sortable-list"
       data-sortable-list-url-value="<%= reorder_workout_program_program_day_program_exercises_path(program, day) %>">
    <% if day.program_exercises.empty? %>
      <div class="py-6 text-center" id="program_day_<%= day.id %>_empty">
        <p class="text-[10px] text-ink-subtle/40 italic"><%= t("views.workout_programs.day.empty_hint") %></p>
      </div>
    <% else %>
      <% day.program_exercises.each do |pe| %>
        <%= render "workout_programs/program_exercise", program: program, day: day, pe: pe %>
      <% end %>
    <% end %>
  </div>

  <%# ── Add exercise combobox ── %>
  <div class="p-2 border-t border-surface-border/30 rounded-b-xl bg-surface-raised">
    <div data-controller="program-builder"
         data-program-builder-search-path-value="<%= search_exercises_path %>"
         data-program-builder-favorites-path-value="<%= favorites_exercises_path(format: :json) %>"
         data-program-builder-favorites-label-value="<%= t("views.exercises.source_favorites") %>"
         data-program-builder-create-path-value="<%= workout_program_program_day_program_exercises_path(program, day) %>"
         data-program-builder-no-results-value="<%= t("views.workout_programs.day.no_exercise_found") %>"
         class="relative">
      <div class="relative">
        <i class="fas fa-plus absolute left-2.5 top-1/2 -translate-y-1/2 text-ink-subtle/50 text-[10px] pointer-events-none"></i>
        <input type="text"
               data-program-builder-target="input"
               data-action="focus->program-builder#open input->program-builder#input keydown->program-builder#keydown"
               class="w-full pl-7 pr-3 py-1.5 text-xs bg-surface-base border border-surface-border/40 rounded-lg text-ink-primary placeholder:text-ink-subtle/40 focus:outline-none focus:border-brand/50 transition-colors cursor-text"
               placeholder="<%= t("views.workout_programs.day.add_exercise") %>"
               autocomplete="off">
      </div>
      <div data-program-builder-target="dropdown"
           class="hidden bg-surface-raised border border-surface-border/60 rounded-lg overflow-y-auto">
      </div>
    </div>
  </div>

</div>
