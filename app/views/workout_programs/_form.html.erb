<%= form_with model: program, class: "space-y-5" do |f| %>
  <% if program.errors.any? %>
    <div class="bg-status-danger_dim/20 border border-status-danger/30 rounded-lg px-4 py-3 text-sm text-status-danger">
      <%= program.errors.full_messages.first %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, t("views.workout_programs.form.name"), class: "label-dark block mb-1" %>
    <%= f.text_field :name, class: "input-dark", placeholder: t("views.workout_programs.form.name_placeholder"), autofocus: true %>
  </div>

  <div>
    <%= f.label :split_type, t("views.workout_programs.form.split_type"), class: "label-dark block mb-1" %>
    <div data-controller="custom-select" class="relative">
      <%= f.select :split_type,
            WorkoutProgram::SPLIT_TYPES.map { |k| [t("views.workout_programs.split_types.#{k}"), k] },
            {},
            class: "sr-only", data: { custom_select_target: "select" } %>
      <button type="button" data-action="click->custom-select#toggle"
              class="input-dark flex items-center justify-between cursor-pointer w-full text-left">
        <span data-custom-select-target="label" class="text-ink-subtle"></span>
        <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
      </button>
      <div data-custom-select-target="dropdown" data-custom-select-dropdown
           class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-52 overflow-y-auto"></div>
    </div>
  </div>

  <div class="flex justify-end gap-3 pt-2 border-t border-surface-border/40">
    <%= link_to t("shared.cancel"), program.persisted? ? workout_program_path(program) : workout_programs_path, class: "btn-ghost" %>
    <%= f.submit program.persisted? ? t("shared.save") : t("views.workout_programs.form.create_btn"),
          class: "btn-primary cursor-pointer" %>
  </div>
<% end %>
