<%# set: ProgramExerciseSet %>
<span class="inline-flex items-center gap-1 bg-surface-hover/60 border border-surface-border/40 rounded-full px-2 py-0.5 text-[10px] font-semibold text-brand">
  <span class="w-1.5 h-1.5 rounded-full <%= set_type_dot_class(set.dominant_type) %>"></span>
  <% if (type_label = set_chip_type_label(set)).present? %>
    <span class="text-ink-muted font-bold uppercase text-[8px] tracking-wide"><%= type_label %></span>
  <% end %>
  <%= set.reps_target %>×<%= set.bodyweight? ? t("views.workout_programs.set_editor.bodyweight_abbr") : set.weight_target.to_f %>
</span>
