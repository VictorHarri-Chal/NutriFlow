<%# pe: ProgramExercise %>
<div class="flex items-center gap-2 flex-wrap">
  <span class="text-[11px] font-semibold text-brand/70"><%= pe.label %></span>
  <% if pe.rest_seconds.present? %>
    <% mins = pe.rest_seconds / 60; secs = pe.rest_seconds % 60 %>
    <% rest_label = mins > 0 ? "#{mins}min#{secs > 0 ? "#{secs}s" : ""}" : "#{secs}s" %>
    <span class="flex items-center gap-0.5 text-[10px] text-ink-subtle/50">
      <i class="fas fa-hourglass-half text-[8px]"></i>
      <%= rest_label %>
    </span>
  <% end %>
</div>
<% if pe.notes.present? %>
  <p class="text-[10px] text-ink-subtle/40 italic leading-snug mt-0.5"><%= pe.notes %></p>
<% end %>
