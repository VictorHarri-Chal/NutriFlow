<%# pe: ProgramExercise, program: WorkoutProgram, day: ProgramDay %>
<%# open: bool (optional) — true = start expanded (used for newly added exercises) %>
<% expanded = local_assigns[:open] %>

<div class="group relative bg-surface-base border border-surface-border/30 rounded-lg px-3 py-2 cursor-pointer hover:bg-surface-hover/20 hover:border-surface-border/50 transition-colors duration-150"
     id="program_exercise_<%= pe.id %>"
     data-sortable-id="<%= pe.id %>"
     data-pe-exercise-id="<%= pe.exercise_id %>"
     data-controller="collapsible"
     data-action="click->collapsible#toggle"
     data-collapsible-dismiss-on-outside-click
     <%= expanded ? "data-collapsible-open-by-default" : "" %>>

  <%# Drag handle: full-width top strip — doesn't compress the title %>
  <div data-drag-handle
       data-action="click->collapsible#stopEvent"
       class="absolute inset-x-0 top-0 h-3 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-grab active:cursor-grabbing z-10 rounded-t-lg">
    <div class="flex gap-0.5 pointer-events-none">
      <span class="block w-3 h-px bg-surface-border/70 rounded-full"></span>
      <span class="block w-3 h-px bg-surface-border/70 rounded-full"></span>
      <span class="block w-3 h-px bg-surface-border/70 rounded-full"></span>
    </div>
  </div>

  <%# ── Header: name + delete (full width, not compressed) ── %>
  <div class="flex items-center justify-between gap-1 mb-1.5">
    <span class="text-xs font-medium text-ink-primary leading-tight line-clamp-2 flex-1">
      <%= pe.exercise.name.capitalize %>
    </span>
    <%= link_to workout_program_program_day_program_exercise_path(program, day, pe),
          data: { turbo_method: :delete, action: "click->confirm#show click->collapsible#stopEvent", confirm_message: t("views.workout_programs.confirm_remove_exercise") },
          class: "opacity-0 group-hover:opacity-100 text-ink-subtle/40 hover:text-red-400 transition-all text-[10px] p-0.5 cursor-pointer shrink-0" do %>
      <i class="fas fa-times"></i>
    <% end %>
  </div>

  <%# ── Always-visible summary: label + rest + notes ── %>
  <div id="pe_<%= pe.id %>_meta">
    <div class="flex items-center gap-2 flex-wrap">
      <span class="text-[11px] font-semibold text-brand/70"><%= pe.label %></span>
      <% if pe.rest_seconds.present? %>
        <% mins = pe.rest_seconds / 60; secs = pe.rest_seconds % 60 %>
        <% rest_label = mins > 0 ? "#{mins}min#{secs > 0 ? "#{secs}s" : ""}" : "#{secs}s" %>
        <span class="flex items-center gap-0.5 text-[10px] text-ink-subtle/50">
          <i class="fas fa-hourglass-half text-[8px]"></i>
          <%= rest_label %>
        </span>
      <% end %>
    </div>
    <% if pe.notes.present? %>
      <p class="text-[10px] text-ink-subtle/40 italic leading-snug mt-0.5"><%= pe.notes %></p>
    <% end %>
  </div>

  <%# ── Collapsible body: editing inputs (stopEvent prevents clicks here from re-toggling) ── %>
  <div data-collapsible-target="content"
       data-action="click->collapsible#stopEvent"
       class="<%= expanded ? "mt-2" : "hidden" %>">

    <div class="border-t border-surface-border/20 pt-2">
      <%= form_with url: workout_program_program_day_program_exercise_path(program, day, pe),
            method: :patch,
            scope: :program_exercise,
            html: { novalidate: true },
            class: "space-y-1.5" do |f| %>

        <div class="grid grid-cols-7 gap-1">
          <div class="text-center col-span-2">
            <label class="text-[9px] text-ink-subtle/60 uppercase tracking-wider block mb-0.5"><%= t("views.workout_programs.day.sets") %></label>
            <%= f.number_field :sets, value: pe.sets, min: 1, max: 10, step: 1,
                  class: "w-full text-center text-[11px] font-semibold bg-surface-hover border border-surface-border/30 rounded px-0.5 py-1 text-ink-primary focus:outline-none focus:border-brand/50 cursor-text",
                  data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
          </div>
          <div class="text-center col-span-2">
            <label class="text-[9px] text-ink-subtle/60 uppercase tracking-wider block mb-0.5"><%= t("views.workout_programs.day.reps") %></label>
            <%= f.number_field :reps_target, value: pe.reps_target, min: 1, max: 100, step: 1,
                  class: "w-full text-center text-[11px] font-semibold bg-surface-hover border border-surface-border/30 rounded px-0.5 py-1 text-ink-primary focus:outline-none focus:border-brand/50 cursor-text",
                  data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
          </div>
          <div class="text-center col-span-3">
            <label class="text-[9px] text-ink-subtle/60 uppercase tracking-wider block mb-0.5"><%= t("views.workout_programs.day.weight_kg") %></label>
            <%= f.number_field :weight_target, value: pe.weight_target, min: 0, step: 0.5,
                  placeholder: "—",
                  class: "w-full text-center text-[11px] font-semibold bg-surface-hover border border-surface-border/30 rounded px-0.5 py-1 text-ink-primary focus:outline-none focus:border-brand/50 cursor-text",
                  data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
          </div>
        </div>

        <div class="mt-1.5 space-y-1 border-t border-surface-border/20 pt-1.5">
          <div class="flex items-center gap-1.5">
            <i class="fas fa-hourglass-half text-[8px] text-ink-subtle/40 shrink-0 w-3 text-center"></i>
            <div class="relative flex-1">
              <%= f.number_field :rest_seconds, value: pe.rest_seconds, min: 0, step: 5,
                    placeholder: t("views.workout_programs.day.rest_placeholder"),
                    class: "w-full pr-7 text-[10px] bg-transparent border border-transparent rounded px-1 py-0.5 text-ink-muted placeholder:text-ink-subtle/30 hover:border-surface-border/50 focus:border-brand/40 focus:outline-none focus:bg-surface-hover transition-colors cursor-text",
                    data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
              <span class="absolute right-1.5 top-1/2 -translate-y-1/2 text-[9px] text-ink-subtle/30 pointer-events-none">sec</span>
            </div>
          </div>
          <div class="flex items-start gap-1.5">
            <i class="fas fa-comment-alt text-[8px] text-ink-subtle/40 shrink-0 w-3 text-center mt-1.5"></i>
            <%= f.text_area :notes, value: pe.notes, rows: 1,
                  placeholder: t("views.workout_programs.day.notes_placeholder"),
                  class: "w-full text-[10px] bg-transparent border border-transparent rounded px-1 py-0.5 text-ink-muted placeholder:text-ink-subtle/30 hover:border-surface-border/50 focus:border-brand/40 focus:outline-none focus:bg-surface-hover transition-all cursor-text min-h-[20px] focus:min-h-[48px]",
                  style: "resize: vertical;",
                  data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
          </div>
        </div>

      <% end %>
    </div>

  </div>

</div>
