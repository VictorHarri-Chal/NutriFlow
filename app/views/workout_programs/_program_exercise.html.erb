<%# pe: ProgramExercise, program: WorkoutProgram, day: ProgramDay %>
<div class="group relative bg-surface-base border border-surface-border/30 rounded-lg px-3 py-2 hover:bg-surface-hover/20 hover:border-surface-border/50 transition-colors duration-150"
     id="program_exercise_<%= pe.id %>"
     data-sortable-id="<%= pe.id %>"
     data-pe-exercise-id="<%= pe.exercise_id %>">

  <%# Drag handle: full-width top strip — reorders, never opens the modal %>
  <div data-drag-handle
       class="absolute inset-x-0 top-0 h-3 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-grab active:cursor-grabbing z-10 rounded-t-lg">
    <div class="flex gap-0.5 pointer-events-none">
      <span class="block w-3 h-px bg-surface-border/70 rounded-full"></span>
      <span class="block w-3 h-px bg-surface-border/70 rounded-full"></span>
      <span class="block w-3 h-px bg-surface-border/70 rounded-full"></span>
    </div>
  </div>

  <%# Delete — sibling of the open-modal link, not nested inside it %>
  <%= link_to program_exercise_path(pe),
        data: { turbo_method: :delete, action: "click->confirm#show", confirm_message: t("views.workout_programs.confirm_remove_exercise") },
        class: "absolute top-1.5 right-1.5 z-10 opacity-0 group-hover:opacity-100 text-ink-subtle/40 hover:text-status-danger transition-all text-[10px] p-0.5 cursor-pointer" do %>
    <i class="fas fa-times"></i>
  <% end %>

  <%# Everything else opens the edit modal %>
  <%= link_to edit_program_exercise_path(pe), data: { turbo_stream: true }, class: "block cursor-pointer" do %>
    <div class="pr-4 mb-1.5">
      <span class="text-xs font-medium text-ink-primary leading-tight break-words">
        <%= pe.exercise.name.capitalize %>
      </span>
    </div>

    <% if pe.program_exercise_sets.any? %>
      <div class="flex items-center gap-1 flex-wrap">
        <% pe.program_exercise_sets.each do |set| %>
          <%= render "workout_programs/set_chip", set: set %>
        <% end %>
      </div>
    <% end %>

    <% if pe.rest_seconds.present? %>
      <span class="flex items-center gap-0.5 text-[10px] text-ink-subtle/50 mt-1">
        <i class="fas fa-hourglass-half text-[8px]"></i>
        <%= rest_seconds_label(pe.rest_seconds) %>
      </span>
    <% end %>

    <% if pe.notes.present? %>
      <p class="text-[10px] text-ink-subtle/40 italic leading-snug mt-0.5"><%= pe.notes %></p>
    <% end %>
  <% end %>
</div>
