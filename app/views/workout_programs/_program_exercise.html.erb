<%# pe: ProgramExercise, program: WorkoutProgram, day: ProgramDay %>

<div class="group relative bg-surface-base border border-surface-border/30 rounded-lg px-3 py-2"
     id="program_exercise_<%= pe.id %>"
     data-pe-exercise-id="<%= pe.exercise_id %>">

  <%# Exercise name + delete %>
  <div class="flex items-start justify-between gap-1 mb-2">
    <span class="text-xs font-medium text-ink-primary leading-tight line-clamp-2 flex-1"><%= pe.exercise.name.capitalize %></span>
    <%= link_to workout_program_program_day_program_exercise_path(program, day, pe),
          data: { turbo_method: :delete, action: "click->confirm#show", confirm_message: t("views.workout_programs.confirm_remove_exercise") },
          class: "opacity-0 group-hover:opacity-100 shrink-0 text-ink-subtle/40 hover:text-red-400 transition-all text-[10px] p-0.5 cursor-pointer" do %>
      <i class="fas fa-times"></i>
    <% end %>
  </div>

  <%# Inline form — sets × reps × weight %>
  <%= form_with url: workout_program_program_day_program_exercise_path(program, day, pe),
        method: :patch,
        scope: :program_exercise,
        html: { novalidate: true },
        class: "space-y-1.5" do |f| %>

    <div class="grid grid-cols-7 gap-1">
      <div class="text-center col-span-2">
        <label class="text-[9px] text-ink-subtle/60 uppercase tracking-wider block mb-0.5"><%= t("views.workout_programs.day.sets") %></label>
        <%= f.number_field :sets, value: pe.sets, min: 1, max: 10, step: 1,
              class: "w-full text-center text-[11px] font-semibold bg-surface-hover border border-surface-border/30 rounded px-0.5 py-1 text-ink-primary focus:outline-none focus:border-brand/50 cursor-text",
              data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
      </div>
      <div class="text-center col-span-2">
        <label class="text-[9px] text-ink-subtle/60 uppercase tracking-wider block mb-0.5"><%= t("views.workout_programs.day.reps") %></label>
        <%= f.number_field :reps_target, value: pe.reps_target, min: 1, max: 100, step: 1,
              class: "w-full text-center text-[11px] font-semibold bg-surface-hover border border-surface-border/30 rounded px-0.5 py-1 text-ink-primary focus:outline-none focus:border-brand/50 cursor-text",
              data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
      </div>
      <div class="text-center col-span-3">
        <label class="text-[9px] text-ink-subtle/60 uppercase tracking-wider block mb-0.5"><%= t("views.workout_programs.day.weight_kg") %></label>
        <%= f.number_field :weight_target, value: pe.weight_target, min: 0, step: 0.5,
              placeholder: "—",
              class: "w-full text-center text-[11px] font-semibold bg-surface-hover border border-surface-border/30 rounded px-0.5 py-1 text-ink-primary focus:outline-none focus:border-brand/50 cursor-text",
              data: { action: "blur->auto-submit#submit", controller: "auto-submit" } %>
      </div>
    </div>

  <% end %>

</div>
