<!DOCTYPE html>
<html>
  <head>
    <title>NutriFlow — <%= yield(:title).presence || t("views.devise.sessions.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= asset_path('logo.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path('logo.png') %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>

  <body class="bg-surface-base min-h-screen flex items-center justify-center">
    <div class="fixed top-4 right-4 z-50 space-y-2">
      <% if flash[:notice] %>
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-status-success/15 border border-status-success/40 shadow-lg text-sm text-status-success max-w-sm"
             data-controller="auto-dismiss">
          <i class="fas fa-check-circle text-base shrink-0"></i>
          <span><%= flash[:notice] %></span>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-status-danger/15 border border-status-danger/40 shadow-lg text-sm text-status-danger max-w-sm"
             data-controller="auto-dismiss">
          <i class="fas fa-circle-exclamation text-base shrink-0"></i>
          <span><%= flash[:alert] %></span>
        </div>
      <% end %>
    </div>
    <div class="w-full max-w-md px-4">
      <%= yield %>
    </div>
  </body>
</html>
