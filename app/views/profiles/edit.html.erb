<% content_for :page_title, t("views.profiles.edit.title") %>

<div class="max-w-4xl mx-auto mt-16">

  <div class="card p-8">
    <h1 class="text-2xl font-bold text-ink-primary mb-8"><%= t("views.profiles.edit.title") %></h1>

    <%= simple_form_for @profile, url: profile_path, method: :patch do |f| %>
      <% if @profile.errors.any? %>
        <div class="mb-6 flex items-start gap-3 px-4 py-3 rounded-xl bg-status-danger/10 border border-status-danger/30 text-sm text-status-danger">
          <i class="fas fa-circle-exclamation mt-0.5 shrink-0"></i>
          <ul class="list-none space-y-0.5">
            <% @profile.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div class="space-y-8">

        <%# ── Informations personnelles ── %>
        <div>
          <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
            <i class="fas fa-user text-brand text-xs"></i>
            <%= t("views.profiles.show.personal_info") %>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <%= f.input :name,
                label: t("views.profiles.edit.name"),
                input_html: { class: "input-dark", autocomplete: "off" },
                label_html: { class: "label-dark" } %>
            <%= f.input :age,
                label: t("views.profiles.edit.age"),
                input_html: { class: "input-dark" },
                label_html: { class: "label-dark" } %>
          </div>
        </div>

        <%# ── Données physiques ── %>
        <div class="border-t border-surface-border/40 pt-6">
          <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
            <i class="fas fa-ruler text-brand text-xs"></i>
            <%= t("views.profiles.show.physical_data") %>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <%= f.label :weight, t("views.profiles.edit.weight"), class: "label-dark block mb-1.5" %>
              <div class="relative">
                <%= f.number_field :weight, step: 0.1, class: "input-dark pr-10" %>
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">kg</span>
              </div>
            </div>
            <div>
              <%= f.label :height, t("views.profiles.edit.height"), class: "label-dark block mb-1.5" %>
              <div class="relative">
                <%= f.number_field :height, step: 0.1, class: "input-dark pr-10" %>
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">cm</span>
              </div>
            </div>
            <div>
              <%= f.label :water_goal_ml, t("views.profiles.edit.water_goal_ml"), class: "label-dark block mb-1.5" %>
              <div class="relative">
                <%= f.number_field :water_goal_ml, step: 50, min: 0, max: 10000, class: "input-dark pr-10" %>
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">ml</span>
              </div>
            </div>
          </div>
        </div>

        <%# ── Genre ── %>
        <div class="border-t border-surface-border/40 pt-6">
          <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
            <i class="fas fa-venus-mars text-brand text-xs"></i>
            <%= t("views.profiles.edit.gender") %>
          </h2>
          <div class="grid grid-cols-3 gap-3">
            <% [
              { value: "male",   icon: "fa-mars",        label: t("views.profiles.edit.gender_male") },
              { value: "female", icon: "fa-venus",       label: t("views.profiles.edit.gender_female") },
              { value: "other",  icon: "fa-genderless",  label: t("views.profiles.edit.gender_other") }
            ].each do |opt| %>
              <label class="cursor-pointer">
                <%= f.radio_button :gender, opt[:value], class: "sr-only peer" %>
                <span class="flex flex-col items-center gap-2 p-4 rounded-xl border text-center transition-colors
                             bg-surface-hover border-surface-border/50 text-ink-muted
                             hover:border-brand/30 hover:text-ink-primary
                             peer-checked:bg-brand/10 peer-checked:border-brand peer-checked:text-brand">
                  <i class="fas <%= opt[:icon] %> text-lg"></i>
                  <span class="text-xs font-semibold"><%= opt[:label] %></span>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <%# ── Activité quotidienne (poste) ── %>
        <div class="border-t border-surface-border/40 pt-6">
          <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
            <i class="fas fa-briefcase text-brand text-xs"></i>
            <%= t("views.profiles.edit.job_activity_level") %>
          </h2>
          <p class="text-xs text-ink-subtle mb-4"><%= t("views.profiles.edit.job_activity_level_hint") %></p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <% [
              { value: "desk_job",       icon: "fa-laptop",        kcal: 150 },
              { value: "light_activity", icon: "fa-person-walking", kcal: 300 },
              { value: "standing_job",   icon: "fa-person",         kcal: 500 },
              { value: "physical_job",   icon: "fa-hard-hat",       kcal: 800 }
            ].each do |opt| %>
              <label class="cursor-pointer">
                <%= f.radio_button :job_activity_level, opt[:value], class: "sr-only peer" %>
                <span class="flex flex-col items-center gap-2 p-4 rounded-xl border text-center transition-colors
                             bg-surface-hover border-surface-border/50 text-ink-muted
                             hover:border-brand/30 hover:text-ink-primary
                             peer-checked:bg-brand/10 peer-checked:border-brand peer-checked:text-brand">
                  <i class="fas <%= opt[:icon] %> text-xl"></i>
                  <span class="text-xs font-semibold leading-tight">
                    <%= t("enumerize.profile.job_activity_level.#{opt[:value]}") %>
                  </span>
                  <span class="text-[10px] text-ink-subtle/60 peer-checked:text-brand/60">
                    +<%= opt[:kcal] %> kcal
                  </span>
                </span>
              </label>
            <% end %>
          </div>

          <%# Pas par jour (défaut profil) %>
          <div class="mt-4">
            <%= f.label :default_daily_steps, t("views.profiles.edit.default_daily_steps"), class: "label-dark block mb-1.5" %>
            <p class="text-xs text-ink-subtle mb-2"><%= t("views.profiles.edit.default_daily_steps_hint") %></p>
            <div class="relative max-w-xs">
              <%= f.number_field :default_daily_steps, min: 0, max: 99_999, step: 1, class: "input-dark pr-14" %>
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">pas/j</span>
            </div>
          </div>
        </div>

        <%# ── Objectif ── %>
        <div class="border-t border-surface-border/40 pt-6">
          <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
            <i class="fas fa-bullseye text-brand text-xs"></i>
            <%= t("views.profiles.edit.goal") %>
          </h2>
          <div class="grid grid-cols-3 gap-3">
            <% [
              { value: "weight_loss", icon: "fa-arrow-trend-down", label: t("views.daily_calorie_requirements.weight_loss") },
              { value: "maintenance", icon: "fa-equals",            label: t("views.daily_calorie_requirements.maintenance") },
              { value: "muscle_gain", icon: "fa-dumbbell",          label: t("views.daily_calorie_requirements.muscle_gain") }
            ].each do |opt| %>
              <label class="cursor-pointer">
                <%= f.radio_button :goal, opt[:value], class: "sr-only peer" %>
                <span class="flex flex-col items-center gap-3 p-5 rounded-xl border text-center transition-colors
                             bg-surface-hover border-surface-border/50 text-ink-muted
                             hover:border-brand/30 hover:text-ink-primary
                             peer-checked:bg-brand/10 peer-checked:border-brand peer-checked:text-brand">
                  <i class="fas <%= opt[:icon] %> text-2xl"></i>
                  <span class="text-xs font-semibold leading-tight"><%= opt[:label] %></span>
                </span>
              </label>
            <% end %>
          </div>

          <div class="mt-4">
            <%= f.label :goal_weight, t("views.profiles.edit.goal_weight"), class: "label-dark block mb-1.5" %>
            <div class="relative">
              <%= f.number_field :goal_weight, step: 0.1, min: 20, max: 400, class: "input-dark pr-10" %>
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">kg</span>
            </div>
          </div>
        </div>

      </div>

      <%# ── Actions ── %>
      <div class="flex justify-center gap-4 mt-10 pt-6 border-t border-surface-border/40">
        <%= link_to t("shared.cancel"), profile_path, class: "btn-ghost" %>
        <%= f.button :submit, t("shared.save"), class: "btn-primary px-8" %>
      </div>
    <% end %>
  </div>
</div>
