<% content_for :page_title, t("views.profiles.edit.title") %>

<div class="max-w-4xl mx-auto mt-16 card p-8">
  <div class="flex justify-between items-center rounded-lg p-4">
    <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.profiles.edit.title") %></h1>
  </div>

  <%= simple_form_for @profile, url: profile_path, method: :patch, html: { class: "bg-surface-base rounded-lg border border-surface-border/40 p-6" } do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-6">
        <%= f.input :name,
            label: t("views.profiles.edit.name"),
            wrapper_html: { class: "mb-4" },
            input_html: { class: "input-dark" } %>

        <%= f.input :age,
            label: t("views.profiles.edit.age"),
            wrapper_html: { class: "mb-4" },
            input_html: { class: "input-dark" } %>

        <%= f.input :weight,
            label: t("views.profiles.edit.weight"),
            as: :numeric,
            input_html: { class: "input-dark" },
            wrapper_html: { class: "mb-4" } %>
      </div>

      <div class="space-y-6">
        <%= f.input :height,
            label: t("views.profiles.edit.height"),
            as: :numeric,
            input_html: { class: "input-dark" },
            wrapper_html: { class: "mb-4" } %>

        <%= f.input :gender,
            label: t("views.profiles.edit.gender"),
            collection: Profile.gender.values.map { |g| [g.text, g] },
            wrapper_html: { class: "mb-4 relative" },
            input_html: { class: "input-dark select-chevron appearance-none pr-10" } %>

        <%= f.input :activity_level,
            label: t("views.profiles.edit.activity_level"),
            collection: Profile.activity_level.values.map { |al| [al.text, al] },
            wrapper_html: { class: "mb-4 relative" },
            input_html: { class: "input-dark select-chevron appearance-none pr-10" } %>
      </div>
    </div>

    <div class="mt-6">
      <%= f.input :goal,
          label: t("views.profiles.edit.goal"),
          collection: Profile.goal.values.map { |g| [g.text, g] },
          wrapper_html: { class: "mb-6 relative" },
          input_html: { class: "input-dark select-chevron appearance-none pr-10" } %>
    </div>

    <div class="flex justify-center space-x-4 pt-8 mt-8">
      <%= link_to t("shared.cancel"), profile_path, class: "btn-ghost" %>
      <%= f.button :submit, t("shared.save"), class: "btn-primary" %>
    </div>
  <% end %>
</div>
