<% content_for :page_title, t("views.profiles.show.title") %>

<div class="max-w-6xl mx-auto mt-16 space-y-6">

  <%# ── En-tête ── %>
  <div class="card p-6 flex items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-brand/15 border-2 border-brand/30 flex items-center justify-center shrink-0">
        <span class="text-xl font-bold text-brand"><%= (@profile.name.presence || @user.email).first.upcase %></span>
      </div>
      <div>
        <h1 class="text-xl font-bold text-ink-primary"><%= @profile.name.presence || @user.email %></h1>
        <p class="text-sm text-ink-subtle"><%= @user.email %></p>
      </div>
    </div>
    <%= link_to edit_profile_path, class: "btn-primary shrink-0" do %>
      <i class="fas fa-pen text-xs"></i>
      <%= t("views.profiles.show.edit_link") %>
    <% end %>
  </div>

  <%# ── Contenu principal ── %>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">

    <%# ══ COLONNE GAUCHE ══ %>
    <div class="lg:col-span-3 space-y-5">

      <%# Données physiques %>
      <div class="card p-6">
        <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-5 flex items-center gap-2">
          <i class="fas fa-ruler text-brand text-xs"></i>
          <%= t("views.profiles.show.physical_data") %>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <%= @profile.age || "—" %><% if @profile.age %><span class="text-sm font-normal text-ink-subtle ml-0.5">ans</span><% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-calendar-days text-xs"></i>
              <%= t("views.profiles.show.age") %>
            </div>
          </div>
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <%= @profile.weight || "—" %><% if @profile.weight %><span class="text-sm font-normal text-ink-subtle ml-0.5">kg</span><% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-weight-scale text-xs"></i>
              <%= t("views.profiles.show.weight") %>
            </div>
          </div>
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <%= @profile.height || "—" %><% if @profile.height %><span class="text-sm font-normal text-ink-subtle ml-0.5">cm</span><% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-ruler-vertical text-xs"></i>
              <%= t("views.profiles.show.height") %>
            </div>
          </div>
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <% if @profile.goal_weight %>
                <%= @profile.goal_weight %><span class="text-sm font-normal text-ink-subtle ml-0.5">kg</span>
              <% else %>
                <span class="text-ink-subtle">—</span>
              <% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-bullseye text-xs"></i>
              <%= t("views.profiles.show.goal_weight") %>
            </div>
          </div>
        </div>

        <% if @bmi %>
          <div class="mt-4 flex items-center justify-between px-4 py-3 bg-surface-base rounded-lg border border-surface-border/40">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-calculator text-xs"></i>
              <%= t("views.profiles.show.bmi") %>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-lg font-bold text-ink-primary"><%= @bmi %></span>
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold
                           <%= @bmi < 18.5 ? 'bg-blue-400/15 text-blue-400' :
                               @bmi < 25   ? 'bg-status-success/15 text-status-success' :
                               @bmi < 30   ? 'bg-status-warning/15 text-status-warning' :
                                             'bg-status-danger/15 text-status-danger' %>">
                <%= t("views.profiles.show.bmi_#{@bmi < 18.5 ? 'underweight' : @bmi < 25 ? 'normal' : @bmi < 30 ? 'overweight' : 'obese'}") %>
              </span>
            </div>
          </div>
        <% end %>
      </div>

      <%# Mode de vie %>
      <div class="card p-6">
        <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
          <i class="fas fa-person-running text-brand text-xs"></i>
          <%= t("views.profiles.show.lifestyle_section") %>
        </h2>
        <div class="divide-y divide-surface-border/30">
          <div class="flex items-center justify-between py-3">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-venus-mars text-xs w-3 text-center"></i>
              <%= t("views.profiles.show.gender") %>
            </div>
            <span class="text-sm font-medium text-ink-primary"><%= @profile.gender.present? ? @profile.gender_text : "—" %></span>
          </div>
          <div class="flex items-center justify-between py-3">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-bolt text-xs w-3 text-center"></i>
              <%= t("views.profiles.show.activity_level") %>
            </div>
            <span class="text-sm font-medium text-ink-primary"><%= @profile.activity_level.present? ? @profile.activity_level_text : "—" %></span>
          </div>
          <div class="flex items-center justify-between py-3">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-bullseye text-xs w-3 text-center"></i>
              <%= t("views.profiles.show.goal") %>
            </div>
            <% if @profile.goal.present? %>
              <span class="text-xs font-semibold px-3 py-1 rounded-full bg-brand/15 border border-brand/30 text-brand">
                <%= @profile.goal_text %>
              </span>
            <% else %>
              <span class="text-sm text-ink-subtle">—</span>
            <% end %>
          </div>
        </div>
      </div>

    </div>

    <%# ══ COLONNE DROITE — Besoins caloriques ══ %>
    <div class="lg:col-span-2">
      <div class="sticky top-8 card p-5 space-y-4">

        <h3 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide flex items-center gap-2">
          <i class="fas fa-fire text-brand text-xs"></i>
          <%= t("views.profiles.show.calorie_needs_title") %>
        </h3>

        <% if @profile.weight.present? && @profile.height.present? && @profile.age.present? %>

          <%# Objectif actif — valeur mise en avant %>
          <% active_kcal = @profile.goal&.weight_loss? ? @calories_weight_loss :
                           @profile.goal&.muscle_gain?  ? @calories_muscle_gain :
                           @calories_maintenance %>
          <div class="text-center py-3 bg-surface-base rounded-xl border border-surface-border/40">
            <% if @profile.goal.present? %>
              <div class="text-xs font-semibold text-brand uppercase tracking-wide mb-1"><%= @profile.goal_text %></div>
            <% end %>
            <div class="text-4xl font-bold text-brand leading-tight"><%= active_kcal %></div>
            <div class="text-xs text-ink-subtle mt-0.5">kcal / jour</div>
          </div>

          <%# Les 3 scénarios %>
          <div class="space-y-2">
            <% [
              { key: "weight_loss",  kcal: @calories_weight_loss,  icon: "fa-arrow-trend-down" },
              { key: "maintenance",  kcal: @calories_maintenance,   icon: "fa-equals" },
              { key: "muscle_gain",  kcal: @calories_muscle_gain,   icon: "fa-dumbbell" }
            ].each do |s| %>
              <% active = @profile.goal.to_s == s[:key] %>
              <div class="flex items-center justify-between px-3 py-2 rounded-lg transition-colors
                          <%= active ? 'bg-brand/10 border border-brand/30' : 'bg-surface-base border border-surface-border/40' %>">
                <div class="flex items-center gap-2">
                  <i class="fas <%= s[:icon] %> text-xs <%= active ? 'text-brand' : 'text-ink-subtle' %>"></i>
                  <span class="text-xs <%= active ? 'font-semibold text-brand' : 'text-ink-muted' %>">
                    <%= t("views.daily_calorie_requirements.#{s[:key]}") %>
                  </span>
                </div>
                <span class="text-sm font-bold <%= active ? 'text-brand' : 'text-ink-primary' %>">
                  <%= s[:kcal] %> <span class="text-xs font-normal text-ink-subtle">kcal</span>
                </span>
              </div>
            <% end %>
          </div>

          <%# Macros cibles %>
          <% if @protein_goal && @fats_goal && @carbs_goal %>
            <div class="border-t border-surface-border/40 pt-3">
              <div class="text-xs font-semibold text-ink-subtle uppercase tracking-wide mb-3">
                <%= t("views.daily_calorie_requirements.macro_goals_title") %>
              </div>
              <div class="grid grid-cols-3 gap-2">
                <div class="text-center p-2.5 bg-surface-base rounded-lg border border-surface-border/30">
                  <div class="text-sm font-bold text-blue-400"><%= @protein_goal.round %><span class="text-xs font-normal text-ink-subtle">g</span></div>
                  <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.show.proteins_short") %></div>
                </div>
                <div class="text-center p-2.5 bg-surface-base rounded-lg border border-surface-border/30">
                  <div class="text-sm font-bold text-amber-400"><%= @carbs_goal %><span class="text-xs font-normal text-ink-subtle">g</span></div>
                  <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.show.carbs_short") %></div>
                </div>
                <div class="text-center p-2.5 bg-surface-base rounded-lg border border-surface-border/30">
                  <div class="text-sm font-bold text-rose-400"><%= @fats_goal.round %><span class="text-xs font-normal text-ink-subtle">g</span></div>
                  <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.show.fats_short") %></div>
                </div>
              </div>
            </div>
          <% end %>

        <% else %>
          <%# Profil incomplet %>
          <div class="text-center py-8">
            <i class="fas fa-fire text-surface-border text-3xl mb-3 block"></i>
            <p class="text-xs text-ink-subtle leading-relaxed mb-4"><%= t("views.profiles.show.incomplete_hint") %></p>
            <%= link_to edit_profile_path, class: "btn-primary text-sm" do %>
              <i class="fas fa-pen text-xs"></i>
              <%= t("views.profiles.show.complete_cta") %>
            <% end %>
          </div>
        <% end %>

      </div>
    </div>

  </div>
</div>
