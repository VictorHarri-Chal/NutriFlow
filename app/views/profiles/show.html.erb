<% content_for :page_title, t("views.profiles.show.title") %>

<div class="max-w-6xl mx-auto mt-16 space-y-6">

  <%# ── En-tête ── %>
  <div class="card p-6 flex items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-brand/15 border-2 border-brand/30 flex items-center justify-center shrink-0">
        <span class="text-xl font-bold text-brand"><%= (@profile.name.presence || @user.email).first.upcase %></span>
      </div>
      <div>
        <h1 class="text-xl font-bold text-ink-primary"><%= @profile.name.presence || @user.email %></h1>
        <p class="text-sm text-ink-subtle"><%= @user.email %></p>
      </div>
    </div>
    <%= link_to edit_profile_path, class: "btn-primary shrink-0" do %>
      <i class="fas fa-pen text-xs"></i>
      <%= t("views.profiles.show.edit_link") %>
    <% end %>
  </div>

  <%# ── Contenu principal ── %>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">

    <%# ══ COLONNE GAUCHE ══ %>
    <div class="lg:col-span-3 space-y-5">

      <%# Données physiques %>
      <div class="card p-6">
        <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-5 flex items-center gap-2">
          <i class="fas fa-ruler text-brand text-xs"></i>
          <%= t("views.profiles.show.physical_data") %>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <%= @profile.age || "—" %><% if @profile.age %><span class="text-sm font-normal text-ink-subtle ml-0.5"><%= t("views.profiles.show.age_unit") %></span><% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-calendar-days text-xs"></i>
              <%= t("views.profiles.show.age") %>
            </div>
          </div>
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <%= @profile.weight || "—" %><% if @profile.weight %><span class="text-sm font-normal text-ink-subtle ml-0.5">kg</span><% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-weight-scale text-xs"></i>
              <%= t("views.profiles.show.weight") %>
            </div>
          </div>
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <%= @profile.height || "—" %><% if @profile.height %><span class="text-sm font-normal text-ink-subtle ml-0.5">cm</span><% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-ruler-vertical text-xs"></i>
              <%= t("views.profiles.show.height") %>
            </div>
          </div>
          <div class="text-center p-4 bg-surface-base rounded-xl border border-surface-border/40">
            <div class="text-2xl font-bold text-ink-primary leading-tight">
              <% if @profile.goal_weight %>
                <%= @profile.goal_weight %><span class="text-sm font-normal text-ink-subtle ml-0.5">kg</span>
              <% else %>
                <span class="text-ink-subtle">—</span>
              <% end %>
            </div>
            <div class="flex items-center justify-center gap-1 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-bullseye text-xs"></i>
              <%= t("views.profiles.show.goal_weight") %>
            </div>
            <% if (weeks = @profile.estimated_weeks_to_goal) %>
              <div class="text-[10px] text-ink-subtle/50 mt-1">
                <%= t("views.profiles.show.goal_weight_estimate", weeks: weeks) %>
              </div>
            <% end %>
          </div>
        </div>

        <% if @bmi %>
          <div class="mt-4 flex items-center justify-between px-4 py-3 bg-surface-base rounded-lg border border-surface-border/40">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-calculator text-xs"></i>
              <%= t("views.profiles.show.bmi") %>
              <div class="relative group inline-flex items-center">
                <i class="fas fa-circle-info text-xs text-ink-subtle/40 hover:text-ink-subtle cursor-default transition-colors"></i>
                <div class="absolute left-0 top-4 z-10 w-64 hidden group-hover:block
                            bg-surface-raised border border-surface-border/60 rounded-xl shadow-lg p-3 normal-case font-normal">
                  <p class="text-[11px] font-semibold text-ink-primary mb-1"><%= t("views.profiles.show.bmi_info_title") %></p>
                  <p class="text-[10px] text-ink-subtle leading-relaxed"><%= t("views.profiles.show.bmi_info_text") %></p>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-lg font-bold text-ink-primary"><%= @bmi %></span>
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold
                           <%= @bmi < 18.5 ? 'bg-status-info/15 text-status-info' :
                               @bmi < 25   ? 'bg-status-success/15 text-status-success' :
                               @bmi < 30   ? 'bg-status-warning/15 text-status-warning' :
                                             'bg-status-danger/15 text-status-danger' %>">
                <%= t("views.profiles.show.bmi_#{@bmi < 18.5 ? 'underweight' : @bmi < 25 ? 'normal' : @bmi < 30 ? 'overweight' : 'obese'}") %>
              </span>
            </div>
          </div>
        <% end %>
      </div>

      <%# Mode de vie %>
      <div class="card p-6">
        <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
          <i class="fas fa-person-running text-brand text-xs"></i>
          <%= t("views.profiles.show.lifestyle_section") %>
        </h2>
        <div class="divide-y divide-surface-border/30">
          <div class="flex items-center justify-between py-3">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-venus-mars text-xs w-3 text-center"></i>
              <%= t("views.profiles.show.gender") %>
            </div>
            <span class="text-sm font-medium text-ink-primary"><%= @profile.gender.present? ? @profile.gender_text : "—" %></span>
          </div>
          <div class="flex items-center justify-between py-3">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-bolt text-xs w-3 text-center"></i>
              <%= t("views.profiles.show.job_activity_level") %>
            </div>
            <span class="text-sm font-medium text-ink-primary"><%= @profile.job_activity_level.present? ? @profile.job_activity_level_text : "—" %></span>
          </div>
          <div class="flex items-center justify-between py-3">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-shoe-prints text-xs w-3 text-center"></i>
              <%= t("views.profiles.show.default_daily_steps") %>
            </div>
            <span class="text-sm font-medium text-ink-primary">
              <%= number_with_delimiter(@profile.default_daily_steps || 6000) %>
              <span class="text-xs text-ink-subtle ml-0.5"><%= t("views.calendars.breakdown.steps_unit") %></span>
            </span>
          </div>
          <div class="flex items-center justify-between py-3">
            <div class="flex items-center gap-2 text-sm text-ink-subtle">
              <i class="fas fa-droplet text-xs w-3 text-center"></i>
              <%= t("views.profiles.show.water_goal") %>
            </div>
            <div class="text-right">
              <span class="text-sm font-medium text-ink-primary">
                <%= number_with_delimiter(@profile.water_goal_ml || 2000) %>
                <span class="text-xs text-ink-subtle ml-0.5">ml</span>
              </span>
              <% if (estimated = @profile.computed_water_goal_ml) && estimated != (@profile.water_goal_ml || 2000) %>
                <div class="text-[10px] text-ink-subtle/50">
                  <i class="fas fa-droplet text-status-info/50 mr-0.5"></i><%= t("views.profiles.show.water_goal_estimated", ml: number_with_delimiter(estimated)) %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

    </div>

    <%# ══ COLONNE DROITE — Besoins caloriques ══ %>
    <div class="lg:col-span-2">
      <div class="sticky top-8 card p-5 space-y-4">

        <h3 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide flex items-center gap-2">
          <i class="fas fa-fire text-brand text-xs"></i>
          <%= t("views.profiles.show.calorie_needs_title") %>
          <div class="relative group inline-flex items-center ml-auto">
            <i class="fas fa-circle-info text-xs text-ink-subtle/40 hover:text-ink-subtle cursor-default transition-colors"></i>
            <div class="absolute right-0 top-4 z-10 w-64 hidden group-hover:block
                        bg-surface-raised border border-surface-border/60 rounded-xl shadow-lg p-3 normal-case tracking-normal font-normal">
              <p class="text-[11px] font-semibold text-ink-primary mb-1.5"><%= t("views.profiles.show.formula_hint_title") %></p>
              <div class="space-y-1.5 text-[10px] text-ink-subtle leading-relaxed">
                <p><%= t("views.profiles.show.formula_hint_formula") %></p>
                <p><%= t("views.profiles.show.formula_hint_goals") %></p>
              </div>
            </div>
          </div>
        </h3>

        <%# Objectif actif — apport cible mis en avant %>
        <% active_kcal = @profile.goal&.weight_loss? ? @calories_weight_loss :
                         @profile.goal&.muscle_gain?  ? @calories_muscle_gain :
                         @calories_maintenance %>
        <div class="text-center py-3 bg-surface-base rounded-xl border border-surface-border/40">
          <div class="text-4xl font-bold text-brand leading-tight"><%= active_kcal %></div>
          <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.profiles.show.calories_to_eat_per_day") %></div>
        </div>

        <%# Les 3 scénarios (basés sur le TDEE = @calories_maintenance) %>
        <div class="space-y-2">
          <% [
            { key: "weight_loss",  kcal: @calories_weight_loss,  icon: "fa-arrow-trend-down", suffix: t("views.profiles.show.rate_per_week", rate: number_with_precision(@weight_loss_rate, precision: 2, strip_insignificant_zeros: true)) },
            { key: "maintenance",  kcal: @calories_maintenance,   icon: "fa-equals",           suffix: t("views.profiles.show.tdee_label") },
            { key: "muscle_gain",  kcal: @calories_muscle_gain,   icon: "fa-dumbbell",         suffix: t("views.profiles.show.rate_per_week", rate: "+#{number_with_precision(@muscle_gain_rate, precision: 2, strip_insignificant_zeros: true)}") }
          ].each do |s| %>
            <% active = @profile.goal.to_s == s[:key] %>
            <div class="flex items-center justify-between px-3 py-2 rounded-lg transition-colors
                        <%= active ? 'bg-brand/10 border border-brand/30' : 'bg-surface-base border border-surface-border/40' %>">
              <div class="flex items-center gap-2 min-w-0">
                <i class="fas <%= s[:icon] %> text-xs <%= active ? 'text-brand' : 'text-ink-subtle' %> shrink-0"></i>
                <div class="min-w-0">
                  <span class="text-xs <%= active ? 'font-semibold text-brand' : 'text-ink-muted' %> block">
                    <%= t("views.profiles.show.#{s[:key]}") %>
                  </span>
                  <span class="text-[10px] text-ink-subtle/50 block"><%= s[:suffix] %></span>
                </div>
              </div>
              <span class="text-sm font-bold shrink-0 <%= active ? 'text-brand' : 'text-ink-primary' %>">
                <%= s[:kcal] %> <span class="text-xs font-normal text-ink-subtle">kcal</span>
              </span>
            </div>
          <% end %>
        </div>

        <%# Macros cibles (basées sur l'objectif actif) %>
        <% if @protein_goal && @fats_goal && @carbs_goal %>
          <div class="border-t border-surface-border/40 pt-3">
            <div class="flex items-center gap-1.5 mb-3">
              <div class="text-xs font-semibold text-ink-subtle uppercase tracking-wide">
                <%= t("views.profiles.show.macro_goals_title") %>
              </div>
              <div class="relative group inline-flex items-center">
                <i class="fas fa-circle-info text-xs text-ink-subtle/40 hover:text-ink-subtle cursor-default transition-colors"></i>
                <div class="absolute left-0 top-4 z-10 w-64 hidden group-hover:block
                            bg-surface-raised border border-surface-border/60 rounded-xl shadow-lg p-3 normal-case tracking-normal font-normal">
                  <p class="text-[11px] font-semibold text-ink-primary mb-1.5"><%= t("views.profiles.show.macro_info_title") %></p>
                  <div class="space-y-1.5 text-[10px] text-ink-subtle leading-relaxed">
                    <p><%= t("views.profiles.show.macro_info_protein") %></p>
                    <p><%= t("views.profiles.show.macro_info_fat") %></p>
                    <p><%= t("views.profiles.show.macro_info_carbs") %></p>
                    <p class="pt-1.5 border-t border-surface-border/40"><%= t("views.profiles.show.tdee_estimate_note", steps: @profile.default_daily_steps || 6000) %></p>
                  </div>
                </div>
              </div>
            </div>
            <% if @profile.macro_calories_exceed_goal? %>
              <div class="flex items-center gap-2 px-3 py-2 mb-2 rounded-lg bg-status-danger/10 border border-status-danger/25 text-[11px] text-status-danger">
                <i class="fas fa-triangle-exclamation shrink-0"></i>
                <span><%= t("views.profiles.show.macro_low_calorie_warning") %></span>
              </div>
            <% end %>
            <div class="grid grid-cols-3 gap-2">
              <div class="text-center p-2.5 bg-surface-base rounded-lg border border-surface-border/30">
                <i class="fas fa-dumbbell text-ink-subtle text-xs mb-1 block"></i>
                <div class="text-sm font-bold text-ink-primary"><%= @protein_goal.round %><span class="text-xs font-normal text-ink-subtle">g</span></div>
                <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.show.proteins_short") %></div>
                <div class="text-[9px] text-ink-subtle/70 mt-0.5">
                  <%= t("views.profiles.show.per_kg", value: 2) %> · <%= t("views.profiles.show.macro_kcal_suffix", kcal: (@protein_goal * 4).round) %>
                </div>
              </div>
              <div class="text-center p-2.5 bg-surface-base rounded-lg border border-surface-border/30">
                <i class="fas fa-bread-slice text-ink-subtle text-xs mb-1 block"></i>
                <div class="text-sm font-bold text-ink-primary"><%= @carbs_goal %><span class="text-xs font-normal text-ink-subtle">g</span></div>
                <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.show.carbs_short") %></div>
                <div class="text-[9px] text-ink-subtle/70 mt-0.5">
                  <%= t("views.profiles.show.carbs_residual_hint") %> · <%= t("views.profiles.show.macro_kcal_suffix", kcal: (@carbs_goal * 4).round) %>
                </div>
              </div>
              <div class="text-center p-2.5 bg-surface-base rounded-lg border border-surface-border/30">
                <i class="fas fa-oil-can text-ink-subtle text-xs mb-1 block"></i>
                <div class="text-sm font-bold text-ink-primary"><%= @fats_goal.round %><span class="text-xs font-normal text-ink-subtle">g</span></div>
                <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.show.fats_short") %></div>
                <div class="text-[9px] text-ink-subtle/70 mt-0.5">
                  <%= t("views.profiles.show.fat_percent_hint", percent: (Profile::FAT_PERCENT_OF_CALORIES * 100).round) %> · <%= t("views.profiles.show.macro_kcal_suffix", kcal: (@fats_goal * 9).round) %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

      </div>
    </div>

  </div>
</div>
