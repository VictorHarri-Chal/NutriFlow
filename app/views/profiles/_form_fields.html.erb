<div class="space-y-8"
     data-controller="water-goal-estimator goal-rate-estimator"
     data-water-goal-estimator-activity-labels-value="<%= {
       desk_job:       t('enumerize.profile.job_activity_level.desk_job'),
       light_activity: t('enumerize.profile.job_activity_level.light_activity'),
       standing_job:   t('enumerize.profile.job_activity_level.standing_job'),
       physical_job:   t('enumerize.profile.job_activity_level.physical_job')
     }.to_json %>"
     data-goal-rate-estimator-default-loss-rate-value="<%= @profile.default_weight_loss_rate %>"
     data-goal-rate-estimator-default-gain-rate-value="<%= @profile.default_muscle_gain_rate %>"
     data-goal-rate-estimator-unit-label-value="<%= t('views.profiles.edit.goal_rate_unit') %>"
     data-goal-rate-estimator-rate-min-value="<%= Profile::GOAL_RATE_RANGE.min %>"
     data-goal-rate-estimator-rate-max-value="<%= Profile::GOAL_RATE_RANGE.max %>"
     data-goal-rate-estimator-estimate-template-value="<%= t('views.profiles.edit.goal_rate_estimate_template', weeks: '__WEEKS__', weight: '__WEIGHT__') %>"
     data-goal-rate-estimator-goal-weight-touched-value="<%= @profile.goal_weight.present? %>">

  <%= render "profiles/essential_fields", f: f %>

  <%# ── Activité quotidienne (poste) ── %>
  <div class="border-t border-surface-border/40 pt-6">
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-briefcase text-brand text-xs"></i>
      <%= t("views.profiles.edit.job_activity_level") %>
    </h2>
    <p class="text-xs text-ink-subtle mb-4"><%= t("views.profiles.edit.job_activity_level_hint") %></p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <% [
        { value: "desk_job",       icon: "fa-laptop",         kcal: 150 },
        { value: "light_activity", icon: "fa-shoe-prints",    kcal: 300 },
        { value: "standing_job",   icon: "fa-person-walking", kcal: 500 },
        { value: "physical_job",   icon: "fa-hard-hat",       kcal: 800 }
      ].each do |opt| %>
        <label class="cursor-pointer">
          <%= f.radio_button :job_activity_level, opt[:value], class: "sr-only peer",
              data: { action: "change->water-goal-estimator#update" } %>
          <span class="flex flex-col items-center gap-2 p-4 rounded-xl border text-center transition-colors
                       bg-surface-hover border-surface-border/50 text-ink-muted
                       hover:border-brand/30 hover:text-ink-primary
                       peer-checked:bg-brand/10 peer-checked:border-brand peer-checked:text-brand">
            <i class="fas <%= opt[:icon] %> text-xl"></i>
            <span class="text-xs font-semibold leading-tight">
              <%= t("enumerize.profile.job_activity_level.#{opt[:value]}") %>
            </span>
            <span class="text-[10px] text-ink-subtle/60 peer-checked:text-brand/60">
              +<%= opt[:kcal] %> kcal
            </span>
          </span>
        </label>
      <% end %>
    </div>

    <%# Pas par jour (défaut profil) %>
    <div class="mt-4">
      <%= f.label :default_daily_steps, t("views.profiles.edit.default_daily_steps"), class: "label-dark block mb-1.5" %>
      <p class="text-xs text-ink-subtle mb-2"><%= t("views.profiles.edit.default_daily_steps_hint") %></p>
      <div class="relative">
        <%= f.number_field :default_daily_steps, min: 0, max: 99_999, step: 1, class: "input-dark pr-14",
              data: { controller: "digit-limit",
                      action: "input->digit-limit#limit",
                      digit_limit_max_integer_digits_value: 5 } %>
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">pas/j</span>
      </div>
    </div>
  </div>

  <%# ── Objectif ── %>
  <div class="border-t border-surface-border/40 pt-6">
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-bullseye text-brand text-xs"></i>
      <%= t("views.profiles.edit.goal") %>
      <div class="relative group inline-flex items-center">
        <i class="fas fa-circle-info text-xs text-ink-subtle/40 hover:text-ink-subtle cursor-default transition-colors"></i>
        <div class="absolute left-0 top-5 z-10 w-72 hidden group-hover:block
                    bg-surface-raised border border-surface-border/60 rounded-xl shadow-lg p-3 normal-case tracking-normal">
          <p class="text-[11px] font-semibold text-ink-primary mb-2"><%= t("views.profiles.edit.goal_locked_title") %></p>
          <div class="space-y-1.5 text-[10px] text-ink-subtle leading-relaxed">
            <div class="flex items-center gap-2">
              <i class="fas fa-arrow-trend-down text-ink-subtle/60 w-3 text-center"></i>
              <span><%= t("views.profiles.edit.goal_locked_loss") %></span>
            </div>
            <div class="flex items-center gap-2">
              <i class="fas fa-equals text-ink-subtle/60 w-3 text-center"></i>
              <span><%= t("views.profiles.edit.goal_locked_maintenance") %></span>
            </div>
            <div class="flex items-center gap-2">
              <i class="fas fa-dumbbell text-ink-subtle/60 w-3 text-center"></i>
              <span><%= t("views.profiles.edit.goal_locked_gain") %></span>
            </div>
          </div>
        </div>
      </div>
    </h2>

    <div class="text-center py-6 px-4 border-2 border-dashed border-surface-border/40 rounded-xl <%= @profile.profile_ready_for_goal? ? 'hidden' : '' %>"
         data-goal-rate-estimator-target="placeholder">
      <i class="fas fa-weight-scale text-ink-subtle/40 text-xl mb-2 block"></i>
      <p class="text-xs text-ink-subtle"><%= t("views.profiles.edit.goal_requires_weight") %></p>
    </div>

    <div class="<%= @profile.profile_ready_for_goal? ? '' : 'hidden' %>" data-goal-rate-estimator-target="content">

    <%# Poids cible — pilote l'objectif ci-dessous %>
    <div class="mb-4">
      <%= f.label :goal_weight, t("views.profiles.edit.goal_weight"), class: "label-dark block mb-1.5" %>
      <div class="relative">
        <%= f.number_field :goal_weight, step: 0.1, min: 20, max: 400,
              value: @profile.goal_weight || @profile.weight,
              class: "input-dark pr-10",
              data: { controller: "digit-limit",
                      action: "input->goal-rate-estimator#goalWeightChanged input->goal-rate-estimator#update input->digit-limit#limit",
                      goal_rate_estimator_target: "goalWeightInput",
                      digit_limit_max_integer_digits_value: 3,
                      digit_limit_max_decimal_digits_value: 1 } %>
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">kg</span>
      </div>
    </div>

    <%# Cartes — affichage seul, déterminées par le poids cible %>
    <% implied_goal = @profile.implied_goal_direction || @profile.goal.to_s.presence %>
    <div class="grid grid-cols-3 gap-3">
      <% [
        { value: "weight_loss", icon: "fa-arrow-trend-down", label: t("views.profiles.show.weight_loss") },
        { value: "maintenance", icon: "fa-equals",            label: t("views.profiles.show.maintenance") },
        { value: "muscle_gain", icon: "fa-dumbbell",          label: t("views.profiles.show.muscle_gain") }
      ].each do |opt| %>
        <% active = implied_goal == opt[:value] %>
        <div class="flex flex-col items-center gap-3 p-5 rounded-xl border text-center transition-colors
                    <%= active ? 'bg-brand/10 border-brand text-brand' : 'bg-surface-hover border-surface-border/50 text-ink-muted opacity-50' %>"
             data-goal-rate-estimator-target="goalCard" data-goal-value="<%= opt[:value] %>">
          <i class="fas <%= opt[:icon] %> text-2xl"></i>
          <span class="text-xs font-semibold leading-tight"><%= opt[:label] %></span>
        </div>
      <% end %>
    </div>

    <%
      goal_rate_min = implied_goal == "muscle_gain" ? 0.0 : Profile::GOAL_RATE_RANGE.min.to_f
      goal_rate_max = implied_goal == "weight_loss" ? 0.0 : Profile::GOAL_RATE_RANGE.max.to_f
      goal_rate_display = if @profile.goal_rate_kg_per_week.nonzero?
                            @profile.goal_rate_kg_per_week.to_f
                          elsif implied_goal == "weight_loss"
                            @profile.default_weight_loss_rate
                          elsif implied_goal == "muscle_gain"
                            @profile.default_muscle_gain_rate
                          else
                            0.0
                          end
    %>
    <div class="mt-4 <%= implied_goal.blank? || implied_goal == "maintenance" ? 'hidden' : '' %>"
         data-goal-rate-estimator-target="rateRow">
      <%= f.label :goal_rate_kg_per_week, t("views.profiles.edit.goal_rate"), class: "label-dark block mb-1" %>
      <p class="text-xs text-ink-subtle mb-3"><%= t("views.profiles.edit.goal_rate_hint") %></p>
      <div class="flex items-center gap-2">
        <span class="text-xs text-ink-subtle w-8 text-center shrink-0" data-goal-rate-estimator-target="rateMinLabel">
          <%= number_with_precision(goal_rate_min, precision: 1, strip_insignificant_zeros: true) %>
        </span>
        <%= f.range_field :goal_rate_kg_per_week,
              value: goal_rate_display,
              min: goal_rate_min, max: goal_rate_max, step: 0.05,
              class: "flex-1 h-1.5 rounded-full appearance-none bg-surface-hover cursor-pointer accent-brand",
              data: { action: "input->goal-rate-estimator#update",
                      goal_rate_estimator_target: "rateInput" } %>
        <span class="text-xs text-ink-subtle w-8 text-center shrink-0" data-goal-rate-estimator-target="rateMaxLabel">
          <%= number_with_precision(goal_rate_max, precision: 1, strip_insignificant_zeros: true) %>
        </span>
        <span class="text-sm font-bold text-brand whitespace-nowrap shrink-0" data-goal-rate-estimator-target="rateDisplay">
          <%= goal_rate_display.positive? ? "+" : "" %><%= number_with_precision(goal_rate_display, precision: 2, strip_insignificant_zeros: true) %> <%= t("views.profiles.edit.goal_rate_unit") %>
        </span>
      </div>
      <div data-goal-rate-estimator-target="warningLoss" class="hidden mt-2 flex items-center gap-2 px-3 py-2 rounded-lg bg-status-danger/10 border border-status-danger/25 text-[11px] text-status-danger">
        <i class="fas fa-triangle-exclamation shrink-0"></i>
        <span>
          <span class="font-semibold"><%= t("views.profiles.edit.goal_rate_attention_prefix") %> :</span>
          <%= t("views.profiles.edit.goal_rate_warning_loss") %>
        </span>
      </div>
      <div data-goal-rate-estimator-target="warningGain" class="hidden mt-2 flex items-center gap-2 px-3 py-2 rounded-lg bg-status-danger/10 border border-status-danger/25 text-[11px] text-status-danger">
        <i class="fas fa-triangle-exclamation shrink-0"></i>
        <span>
          <span class="font-semibold"><%= t("views.profiles.edit.goal_rate_attention_prefix") %> :</span>
          <%= t("views.profiles.edit.goal_rate_warning_gain") %>
        </span>
      </div>
      <div class="mt-2 px-3 py-2 rounded-lg bg-brand/10 border border-brand/25 text-[11px] text-brand flex items-center gap-3">
        <div data-goal-rate-estimator-target="estimateRow" class="hidden flex items-center gap-2">
          <i class="fas fa-hourglass-half shrink-0"></i>
          <span>
            <span class="font-semibold"><%= t("views.profiles.edit.goal_rate_estimate_prefix") %> :</span>
            <span data-goal-rate-estimator-target="estimateValue"></span>
          </span>
        </div>
        <span class="ml-auto text-brand/60 whitespace-nowrap"><%= t("views.profiles.edit.goal_rate_computed_hint") %></span>
      </div>
    </div>

    </div>
  </div>

  <%# ── Objectif hydratation ── %>
  <div class="border-t border-surface-border/40 pt-6">
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-droplet text-brand text-xs"></i>
      <%= t("views.profiles.show.water_goal") %>
    </h2>
    <%
      estimated       = @profile.computed_water_goal_ml
      show_hint       = estimated && estimated != @profile.water_goal_ml.to_i
      w               = @profile.weight.to_f
      act_offset      = Profile::WATER_ACTIVITY_OFFSET_ML[@profile.job_activity_level&.to_sym] || 0
      act_label       = @profile.job_activity_level.present? ? @profile.job_activity_level_text : nil
      formula_parts   = []
      if w > 0
        formula_parts << "#{w.to_i} kg × 33 ml/kg"
        formula_parts << "× 0,9 (femme)" if @profile.gender.to_s == "female"
        formula_parts << "#{act_label} +#{act_offset} ml" if act_offset > 0 && act_label
        formula_parts << "arrondi à 50 ml"
      end
    %>
    <div>
      <%= f.label :water_goal_ml, t("views.profiles.edit.water_goal_ml"), class: "label-dark block mb-1.5" %>
      <div class="relative">
        <%= f.number_field :water_goal_ml, step: 50, min: 0, max: 10000,
            id: "profile_water_goal_ml",
            data: { controller: "digit-limit",
                    action: "input->water-goal-estimator#update input->digit-limit#limit",
                    water_goal_estimator_target: "goalInput",
                    digit_limit_max_integer_digits_value: 4 },
            class: "input-dark pr-10" %>
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">ml</span>
      </div>
      <div data-water-goal-estimator-target="hintRow"
           class="mt-2 px-3 py-2 rounded-lg bg-brand/10 border border-brand/25 text-[11px] text-brand <%= show_hint ? '' : 'hidden' %>">
        <div class="flex items-center justify-between gap-4">
          <span class="flex items-center gap-2 shrink-0">
            <i class="fas fa-droplet shrink-0"></i>
            <span>
              <span class="font-semibold"><%= t("views.profiles.edit.water_goal_estimated_prefix") %> :</span>
              <span data-water-goal-estimator-target="estimatedValue">
                <%= estimated ? "#{number_with_delimiter(estimated)} ml/j" : "" %>
              </span>
            </span>
            <button type="button"
                    data-action="click->water-goal-estimator#use"
                    class="shrink-0 px-2 py-0.5 rounded-md text-[10px] font-semibold bg-brand/15 text-brand border border-brand/30 hover:bg-brand/25 transition-colors">
              <%= t("views.profiles.edit.water_goal_use_estimated") %>
            </button>
          </span>
          <span data-water-goal-estimator-target="formulaText"
                class="text-[10px] text-brand/60 leading-snug text-right">
            <%= formula_parts.join(" · ") %>
          </span>
        </div>
      </div>
    </div>
  </div>

</div>
