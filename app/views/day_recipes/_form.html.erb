<%= simple_form_for([day, day_recipe]) do |f| %>
  <div class="grid grid-cols-1 gap-4">
    <%= f.association :recipe,
        collection: @recipes,
        prompt: t("views.day_recipes.form.select_recipe"),
        disabled: !day_recipe.new_record?,
        input_html: {
          class: "input-dark select-chevron appearance-none pr-10"
        },
        label_html: { class: "label-dark" } %>

    <% if @day_food_groups.any? %>
      <%= f.association :day_food_group,
          collection: @day_food_groups,
          prompt: t("views.day_foods.form.select_group"),
          input_html: {
            class: "input-dark select-chevron appearance-none pr-10"
          },
          label_html: { class: "label-dark" },
          label: t("views.day_recipes.form.food_group") %>
    <% else %>
      <div class="form-group">
        <label class="label-dark block mb-3"><%= t("views.day_recipes.form.food_group") %></label>
        <div class="text-center py-6 px-4 border border-surface-border rounded-lg bg-surface-base">
          <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
            <i class="fas fa-utensils text-ink-subtle"></i>
          </div>
          <h3 class="text-sm font-medium text-ink-primary mb-1"><%= t("shared.no_food_groups") %></h3>
          <p class="text-ink-subtle text-xs mb-3"><%= t("shared.create_groups_in_settings") %></p>
        </div>
      </div>
    <% end %>

    <%= f.input :quantity,
        as: :numeric,
        min: 0.1,
        input_html: {
          class: "input-dark",
          value: day_recipe.new_record? ? 100 : day_recipe.quantity
        },
        label_html: { class: "label-dark" },
        append: "g" %>

    <%= f.input :use_recipe_quantity,
        as: :boolean,
        input_html: { class: "h-4 w-4 text-brand focus:ring-brand/50 border-surface-border rounded" },
        label_html: { class: "label-dark" },
        label: t("views.day_recipes.form.use_recipe_quantity") %>
  </div>

  <div class="flex justify-center gap-4 mt-8">
    <button type="button"
            data-controller="close-frame"
            data-action="click->close-frame#close"
            class="btn-ghost">
      <%= t("shared.cancel") %>
    </button>
    <%= f.button :submit, submit_text, class: "btn-primary" %>
  </div>
<% end %>
