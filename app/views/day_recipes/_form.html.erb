<script id="recipes-data" type="application/json">
  <%= json_escape(@recipes.map { |r|
    { id: r.id, name: r.name, calories: r.total_calories.round,
      proteins: r.total_proteins.round(1), carbs: r.total_carbs.round(1), fats: r.total_fats.round(1),
      totalWeight: r.total_weight.to_f,
      favorite: r.favorite,
      items: r.recipe_items.map { |ri| { foodId: ri.food_id, foodName: ri.food.name, quantity: ri.quantity.to_f, unit: ri.unit } } }
  }.to_json).html_safe %>
</script>

<script id="foods-data" type="application/json">
  <%= json_escape(@foods.to_json(only: [:id, :name, :calories, :proteins, :carbs, :fats, :sugars, :favorite])).html_safe %>
</script>

<%= simple_form_for(day_recipe.persisted? ? day_recipe : [day, day_recipe],
      html: {
        data: {
          controller: "day-recipe-preview day-recipe-customize",
          action: "input->day-recipe-preview#update input->day-recipe-customize#onFieldChange",
          "day-recipe-customize-open-on-connect-value": day_recipe.customized? && day_recipe.errors.any?
        }
      }) do |f| %>
  <div class="space-y-4">

    <% if day_recipe.errors.any? %>
      <div class="text-xs text-status-danger bg-status-danger/10 border border-status-danger/30 rounded-lg px-3 py-2">
        <ul class="list-disc list-inside space-y-0.5">
          <% day_recipe.errors.full_messages.uniq.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── Recette ── %>
    <div>
      <label class="label-dark block mb-1.5"><%= t("views.day_recipes.form.recipe_label") %></label>
      <% if day_recipe.new_record? %>
        <div data-controller="food-combobox"
             data-food-combobox-selected-id-value="0"
             data-food-combobox-source-value="recipes-data"
             data-food-combobox-suffix-value="kcal"
             data-food-combobox-no-results-value="<%= t('views.day_recipes.form.no_recipe_found') %>"
             data-food-combobox-recent-ids-value="<%= (@recent_recipe_ids || []).to_json %>"
             data-food-combobox-favorites-label-value="<%= t('views.foods.favorites_section') %>"
             data-food-combobox-recents-label-value="<%= t('views.foods.recents_section') %>"
             data-food-combobox-all-label-value="<%= t('views.day_recipes.all_section') %>"
             class="relative">
          <%= f.hidden_field :recipe_id, data: {
                "food-combobox-target": "hiddenId",
                "day-recipe-preview-target": "recipeId",
                "day-recipe-customize-target": "recipeId"
              } %>
          <div class="relative">
            <input type="text"
                   class="input-dark pl-8 text-sm"
                   placeholder="<%= t("views.day_recipes.form.search_recipe") %>"
                   autocomplete="off"
                   data-food-combobox-target="input"
                   data-action="focus->food-combobox#open input->food-combobox#filter keydown->food-combobox#keydown">
            <i class="fas fa-search absolute left-2.5 top-1/2 -translate-y-1/2 text-ink-subtle text-xs pointer-events-none"></i>
          </div>
          <div class="hidden absolute z-50 w-full mt-1 max-h-52 overflow-y-auto bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl"
               data-food-combobox-target="dropdown"></div>
        </div>
      <% else %>
        <%# Édition — recette non modifiable %>
        <%= f.hidden_field :recipe_id, data: {
              "day-recipe-preview-target": "recipeId",
              "day-recipe-customize-target": "recipeId"
            } %>
        <div class="flex items-center gap-2 px-3 py-2.5 bg-surface-base border border-surface-border/50 rounded-lg">
          <i class="fas fa-lock text-xs text-ink-subtle shrink-0"></i>
          <span class="text-sm text-ink-primary"><%= day_recipe.recipe&.name %></span>
        </div>
      <% end %>
    </div>

    <%# ── Quantité + Groupe ── %>
    <div class="grid grid-cols-2 gap-3">

      <%# Quantité %>
      <div class="<%= 'opacity-60 pointer-events-none' if day_recipe.customized? %>" data-day-recipe-customize-target="globalQuantityFields">
        <label class="label-dark block mb-1.5"><%= t("shared.quantity") %></label>
        <div class="relative">
          <%# Readonly (not disabled) when customized: it must stay visible-but-inert while
              still submitting its frozen value (a disabled input is dropped from the request
              entirely, which would silently null out the base quantity on every future save). %>
          <%= f.number_field :quantity,
                min: 1, step: 0.1,
                value: day_recipe.new_record? ? nil : day_recipe.quantity.to_f.round(1),
                disabled: day_recipe.use_recipe_quantity? && !day_recipe.customized?,
                readonly: day_recipe.customized?,
                class: "input-dark text-sm pr-8",
                data: {
                  "day-recipe-preview-target": "quantity",
                  "day-recipe-customize-target": "quantityInput",
                  controller: "digit-limit",
                  action: "input->digit-limit#limit",
                  digit_limit_max_integer_digits_value: 4,
                  digit_limit_max_decimal_digits_value: 1
                } %>
          <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">g</span>
        </div>
      </div>

      <%# Groupe de repas %>
      <div>
        <% if @day_food_groups.any? %>
          <label class="label-dark block mb-1.5"><%= t("views.day_recipes.form.food_group") %></label>
          <div data-controller="custom-select" class="relative">
            <%= f.association :day_food_group,
                collection: @day_food_groups,
                prompt: t("views.day_foods.form.select_group"),
                label: false,
                input_html: { class: "sr-only", data: { custom_select_target: "select" } } %>
            <button type="button" data-action="click->custom-select#toggle"
                    class="input-dark flex items-center justify-between cursor-pointer w-full text-left text-sm">
              <span data-custom-select-target="label" class="text-ink-subtle truncate min-w-0 flex-1"></span>
              <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
            </button>
            <div data-custom-select-target="dropdown"
                 class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-48 overflow-y-auto"></div>
          </div>
        <% else %>
          <label class="label-dark block mb-1.5"><%= t("views.day_recipes.form.food_group") %></label>
          <div class="flex items-center gap-2 px-3 py-2.5 rounded-lg bg-surface-base border border-surface-border/50 text-xs text-ink-subtle">
            <i class="fas fa-utensils shrink-0"></i>
            <span><%= t("shared.no_food_groups") %></span>
          </div>
        <% end %>
      </div>

    </div>

    <%# ── Utiliser la quantité totale ── %>
    <label class="flex items-center gap-3 cursor-pointer select-none <%= 'opacity-60 pointer-events-none' if day_recipe.customized? %>"
           data-day-recipe-customize-target="globalQuantityFields">
      <%# Not disabled when customized — same reason as the quantity field above:
          it must keep submitting its frozen value on every future save. Checkboxes
          ignore `readonly`, so tabindex removes it from the keyboard tab order instead. %>
      <%= f.check_box :use_recipe_quantity, label: false,
            class: "sr-only peer",
            checked: day_recipe.use_recipe_quantity?,
            tabindex: day_recipe.customized? ? -1 : 0,
            data: {
              "day-recipe-preview-target": "useRecipeQty",
              "day-recipe-customize-target": "useRecipeQtyInput",
              action: "change->day-recipe-preview#update"
            } %>
      <div class="relative w-9 h-5 rounded-full shrink-0 transition-colors bg-surface-border peer-checked:bg-brand
                  after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:w-4 after:h-4 after:rounded-full after:bg-white after:shadow after:transition-transform peer-checked:after:translate-x-4"></div>
      <span class="text-sm text-ink-muted"><%= t("views.day_recipes.form.use_recipe_quantity") %></span>
    </label>

    <%= f.hidden_field :customized, data: { "day-recipe-customize-target": "customizedField" } %>

    <%# ── Aperçu macros (affiché dès qu'un plat est sélectionné) ── %>
    <div data-day-recipe-preview-target="panel" class="hidden bg-surface-base rounded-lg border border-surface-border/40 px-4 py-3">
      <div class="flex items-center gap-4">
        <div class="text-center shrink-0 w-14">
          <div class="text-xl font-bold text-brand leading-tight" data-day-recipe-preview-target="calories">0</div>
          <div class="text-xs text-ink-subtle">kcal</div>
        </div>
        <div class="flex-1 grid grid-cols-3 gap-2 border-l border-surface-border/40 pl-4">
          <div class="text-center">
            <div class="text-sm font-semibold text-ink-primary">
              <span data-day-recipe-preview-target="proteins">0</span><span class="text-xs font-normal text-ink-subtle">g</span>
            </div>
            <div class="text-xs text-ink-subtle"><%= t("views.recipes.show.proteins_short") %></div>
          </div>
          <div class="text-center">
            <div class="text-sm font-semibold text-ink-primary">
              <span data-day-recipe-preview-target="carbs">0</span><span class="text-xs font-normal text-ink-subtle">g</span>
            </div>
            <div class="text-xs text-ink-subtle"><%= t("views.recipes.show.carbs_short") %></div>
          </div>
          <div class="text-center">
            <div class="text-sm font-semibold text-ink-primary">
              <span data-day-recipe-preview-target="fats">0</span><span class="text-xs font-normal text-ink-subtle">g</span>
            </div>
            <div class="text-xs text-ink-subtle"><%= t("views.recipes.show.fats_short") %></div>
          </div>
        </div>
      </div>
    </div>

    <%= render "day_recipes/customize_modal", f: f, day_recipe: day_recipe, day: day %>
  </div>

  <div class="flex items-center justify-between gap-3 mt-5 pt-4 border-t border-surface-border/40">
    <button type="button"
            title="<%= t("views.day_recipes.form.customize_tooltip") %>"
            data-action="click->day-recipe-customize#open"
            data-day-recipe-customize-target="gearButton"
            <%= "disabled" if day_recipe.recipe_id.blank? %>
            class="btn-ghost w-10 h-10 !p-0 flex items-center justify-center disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-transparent disabled:hover:text-ink-muted">
      <i class="fas fa-sliders text-sm"></i>
    </button>

    <div class="flex gap-3">
      <button type="button"
              data-controller="close-frame"
              data-action="click->close-frame#close"
              class="btn-ghost text-sm">
        <%= t("shared.cancel") %>
      </button>
      <%= f.button :submit, submit_text, class: "btn-primary" %>
    </div>
  </div>
<% end %>
