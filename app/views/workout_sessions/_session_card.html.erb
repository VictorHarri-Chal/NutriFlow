<%# Renders a single workout session summary card %>
<div class="bg-surface-base border border-surface-border/40 rounded-xl p-4 space-y-3">

  <%# Header: stats + actions %>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-3 flex-wrap">
      <% if workout_session.duration_minutes.present? %>
        <span class="flex items-center gap-1.5 text-xs text-ink-muted">
          <i class="fas fa-clock text-ink-subtle text-[10px]"></i>
          <%= workout_session.duration_minutes %> min
        </span>
      <% end %>
      <% if workout_session.rpe.present? %>
        <span class="flex items-center gap-1.5 text-xs text-ink-muted">
          <i class="fas fa-fire text-ink-subtle text-[10px]"></i>
          RPE <%= workout_session.rpe %>/10
        </span>
      <% end %>
      <% cal = workout_session.estimated_calories(current_user.profile&.weight&.to_f) %>
      <span class="flex items-center gap-1.5 text-xs text-brand font-medium">
        <i class="fas fa-bolt text-[10px]"></i>
        ~<%= cal %> kcal
      </span>
    </div>

    <% if defined?(show_actions) && show_actions %>
      <div class="flex items-center gap-1 flex-shrink-0">
        <%= link_to edit_day_workout_session_path(workout_session.day, workout_session),
            class: "p-1.5 text-ink-subtle hover:text-ink-primary transition-colors",
            data: { turbo_frame: "item_form" } do %>
          <i class="fas fa-pen text-xs"></i>
        <% end %>
        <%= link_to day_workout_session_path(workout_session.day, workout_session),
            class: "p-1.5 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors",
            data: {
              turbo_method: :delete,
              action: "click->confirm#show",
              confirm_message: t("views.workout_sessions.confirm_delete")
            } do %>
          <i class="fas fa-trash text-xs"></i>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Exercises grouped %>
  <div class="space-y-2">
    <% workout_session.grouped_sets.each do |exercise, sets| %>
      <div class="flex items-start gap-3">
        <span class="text-xs font-medium text-ink-primary capitalize min-w-0 flex-1 truncate pt-0.5">
          <%= exercise.name %>
        </span>
        <div class="flex flex-wrap gap-1 justify-end">
          <% sets.each do |s| %>
            <%
              weight = s.weight_kg.present? && s.weight_kg > 0
              reps   = s.reps.present? && s.reps > 0
              next unless weight || reps
              label  = if weight && reps
                         "#{number_with_precision(s.weight_kg, precision: 1, strip_insignificant_zeros: true)}kg × #{s.reps}"
                       elsif reps
                         "PDC × #{s.reps}"
                       else
                         "#{number_with_precision(s.weight_kg, precision: 1, strip_insignificant_zeros: true)}kg"
                       end
            %>
            <span class="text-xs text-ink-subtle bg-surface-hover border border-surface-border/30 rounded-md px-2 py-0.5 whitespace-nowrap">
              <%= label %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if workout_session.notes.present? %>
    <p class="text-xs text-ink-subtle italic border-t border-surface-border/30 pt-2">
      <%= workout_session.notes %>
    </p>
  <% end %>

</div>
