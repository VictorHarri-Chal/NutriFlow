<div data-sidebar-target="desktopSideMenu" class="w-64 flex flex-col fixed inset-y-0 z-50 -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out">

  <div class="flex-1 flex flex-col min-h-0 bg-surface-raised border-r border-surface-border/50">
    <div class="flex-1 flex flex-col pb-4 overflow-y-auto">
      <div class="flex items-center flex-shrink-0 px-4 py-4 border-b border-surface-border/50 bg-surface-base">
        <%= link_to calendars_path, class: "flex items-center gap-2" do %>
          <%= image_tag "logo.png", class: "h-16 w-auto", alt: "NutriFlow logo" %>
          <h1 class="text-ink-primary text-xl font-bold">NutriFlow</h1>
        <% end %>
      </div>
      <div class="flex-shrink-0 border-b border-surface-border/40">
        <%= link_to profile_path, class: "group flex items-center gap-3 px-4 py-3 hover:bg-surface-hover transition-colors" do %>
          <% display_name = current_user.profile&.name.presence || current_user.email %>
          <div class="flex-shrink-0 h-8 w-8 rounded-full bg-brand flex items-center justify-center text-zinc-900 text-xs font-bold">
            <%= display_name[0].upcase %>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-medium text-ink-primary truncate group-hover:text-brand transition-colors"><%= display_name %></p>
            <p class="text-xs text-ink-subtle"><%= t("views.shared.sidebar.profile") %></p>
          </div>
          <i class="fas fa-chevron-right text-xs text-ink-subtle group-hover:text-brand transition-colors flex-shrink-0"></i>
        <% end %>
      </div>
    <%= render "shared/sidebar_elements" %>
    </div>
  </div>
</div>
