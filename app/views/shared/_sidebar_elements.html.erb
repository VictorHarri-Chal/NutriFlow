
<nav class="mt-6 flex flex-col h-full px-4">
    <div class="space-y-2">
        <%= link_to calendars_path, class: current_page?(calendars_path) ? "nav-link-active" : "nav-link" do %>
            <i class="fas fa-calendar-alt w-5 h-5 mr-3"></i>
            <span class="font-medium pb-1"><%= t("views.shared.sidebar.calendar") %></span>
        <% end %>

        <%= link_to foods_path, class: current_page?(foods_path) ? "nav-link-active" : "nav-link" do %>
            <i class="fas fa-utensils w-5 h-5 mr-3"></i>
            <span class="font-medium pb-1"><%= t("views.shared.sidebar.foods") %></span>
        <% end %>

        <%= link_to recipes_path, class: current_page?(recipes_path) ? "nav-link-active" : "nav-link" do %>
            <i class="fas fa-book-open w-5 h-5 mr-3"></i>
            <span class="font-medium pb-1"><%= t("views.shared.sidebar.recipes") %></span>
        <% end %>

        <%= link_to daily_calorie_requirement_path, class: current_page?(daily_calorie_requirement_path) ? "nav-link-active" : "nav-link" do %>
            <i class="fas fa-fire-flame-simple w-5 h-5 mr-3"></i>
            <span class="font-medium pb-1"><%= t("views.shared.sidebar.calorie_requirement") %></span>
        <% end %>
    </div>
    <div class="mt-auto pt-4 border-t border-surface-border/40">
        <%= link_to setting_path, class: "nav-link" do %>
            <i class="fas fa-cog w-5 h-5 mr-3"></i>
            <span class="font-medium pb-1"><%= t("views.shared.sidebar.settings") %></span>
        <% end %>
        <%= logout_link_with_confirm(destroy_user_session_path) %>
    </div>
</nav>
