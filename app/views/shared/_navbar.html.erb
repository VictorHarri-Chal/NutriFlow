<nav id="main-navbar"
     data-sidebar-target="navbar"
     class="h-16 bg-surface-raised border-b border-surface-border/50 fixed top-0 left-0 w-full md:pl-64 z-40 transition-[padding-left] duration-300 ease-in-out print:hidden">
  <div class="h-full py-0 flex items-center px-4">
    <button data-sidebar-target="desktopSideBarOpeningButton" data-action="click->sidebar#desktopToggle" class="mr-4 p-2 hidden">
      <i class="fas fa-bars text-brand text-xl"></i>
    </button>

    <h1 class="text-2xl font-bold text-ink-primary ml-2 mr-auto">
      <%= yield :page_title %>
    </h1>

    <div class="flex items-center gap-3">
      <%= link_to new_scan_path,
            class: "flex items-center justify-center w-14 h-[38px] rounded-xl bg-surface-hover border border-surface-border/40 text-ink-primary shadow-lg hover:bg-brand hover:text-zinc-900 transition-colors",
            data: { turbo_stream: true, tooltip: t("views.scans.navbar_tooltip") } do %>
        <i class="fas fa-barcode text-base" aria-hidden="true"></i>
      <% end %>

      <% if content_for?(:navbar_actions) %>
        <%= yield :navbar_actions %>
      <% end %>
    </div>
  </div>
</nav>
