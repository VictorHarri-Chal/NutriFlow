<div class="fixed top-4 right-4 z-50 space-y-2">
  <% if flash[:notice] %>
    <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-status-success/15 border border-status-success/40 shadow-lg text-sm text-status-success max-w-sm"
         data-controller="auto-dismiss">
      <i class="fas fa-check-circle text-base shrink-0"></i>
      <span><%= flash[:notice] %></span>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-status-danger/15 border border-status-danger/40 shadow-lg text-sm text-status-danger max-w-sm"
         data-controller="auto-dismiss">
      <i class="fas fa-circle-exclamation text-base shrink-0"></i>
      <span><%= flash[:alert] %></span>
    </div>
  <% end %>
</div>
