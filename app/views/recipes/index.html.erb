<% content_for :page_title, t("views.recipes.title") %>

<div class="max-w-7xl mx-auto mt-16 card p-8">
  <!-- En-tête avec titre, recherche et actions -->
  <header class="mb-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <!-- Titre + compteur -->
      <div class="flex-shrink-0">
        <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.recipes.title") %></h1>
        <% total = @pagy ? @pagy.count : @recipes.size %>
        <p class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.recipe_count", count: total) %></p>
      </div>

      <!-- Barre de recherche -->
      <div class="flex-1 max-w-md lg:mx-6">
        <%= form_with url: recipes_path, method: :get, local: true, class: "relative" do |f| %>
          <%= hidden_field_tag :sort,      params[:sort]      if params[:sort].present? %>
          <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>

          <%= text_field_tag :query, params[:query],
              class: "input-dark pl-10 #{params[:query].present? ? 'pr-10' : ''} py-1.5 text-sm",
              placeholder: t("views.recipes.search_placeholder"),
              autocomplete: "off" %>

          <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-ink-subtle pointer-events-none"></i>

          <% if params[:query].present? %>
            <%= link_to recipes_path(sort: params[:sort]), class: "absolute right-3 top-1/2 -translate-y-1/2 text-ink-subtle hover:text-ink-muted transition-colors" do %>
              <i class="fas fa-times"></i>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <!-- Bouton d'ajout -->
      <% truly_empty = (@pagy ? @pagy.count : @recipes.size) == 0 && params[:query].blank? %>
      <%= link_to new_recipe_path, class: "btn-primary flex-shrink-0 #{truly_empty ? 'invisible pointer-events-none' : ''}" do %>
        <i class="fas fa-plus"></i>
        <%= t("views.recipes.new_recipe") %>
      <% end %>
    </div>
  </header>

  <!-- Barre source + tri -->
  <div class="flex flex-wrap items-center gap-3 mb-6">
    <%# Source tabs %>
    <div class="flex items-center gap-1.5">
      <% [
        { source: nil,         label: t("views.recipes.source_all"),       icon: "fa-list" },
        { source: "favorites", label: t("views.recipes.source_favorites"), icon: "fa-star" }
      ].each do |tab| %>
        <% active = tab[:source].nil? ? @source.blank? : @source == tab[:source] %>
        <%= link_to recipes_path(source: tab[:source], sort: params[:sort], query: params[:query]),
            class: "inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-xl text-sm font-medium border transition-colors #{ active ? 'bg-brand text-surface-base border-brand' : 'bg-surface-raised border-surface-border/40 text-ink-muted hover:text-ink-primary hover:border-surface-border/70' }" do %>
          <i class="fas <%= tab[:icon] %> text-xs"></i>
          <%= tab[:label] %>
        <% end %>
      <% end %>
    </div>

    <%# Séparateur %>
    <% unless params[:query].present? %>
      <%
        sort_defaults = { "name" => "asc", "date" => "desc", "calories" => "desc", "proteins" => "desc" }
        current_sort  = params[:sort].presence || "name"
        current_dir   = params[:direction].presence || sort_defaults[current_sort]
      %>
      <div class="h-5 w-px bg-surface-border/40 mx-1"></div>
      <span class="text-xs text-ink-subtle font-medium"><%= t("views.recipes.sort_label") %></span>
      <% [
        ["name",     t("views.recipes.sort_name")],
        ["date",     t("views.recipes.sort_date")],
        ["calories", t("views.recipes.sort_calories")],
        ["proteins", t("views.recipes.sort_proteins")]
      ].each do |key, label| %>
        <%
          active   = current_sort == key
          next_dir = active ? (current_dir == "asc" ? "desc" : "asc") : sort_defaults[key]
          arrow    = active ? (current_dir == "asc" ? " ↑" : " ↓") : ""
        %>
        <%= link_to recipes_path(sort: key, direction: next_dir, source: @source, query: params[:query]),
              class: "inline-flex items-center px-3 py-1.5 rounded-xl text-xs font-medium border transition-colors #{active ? 'bg-brand text-surface-base border-brand' : 'bg-surface-raised border-surface-border/40 text-ink-muted hover:text-ink-primary hover:border-surface-border/70'}" do %>
          <%= label %><%= arrow %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <% if @recipes.any? %>
    <!-- Grille de cartes -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @recipes.each do |recipe| %>
        <%= render RecipeCardComponent.new(recipe: recipe, current_user: current_user) %>
      <% end %>
    </div>

    <!-- Pagination -->
    <% if @pagy&.pages&.> 1 %>
      <div class="mt-8 flex justify-center">
        <%= render PaginationComponent.new(pagy: @pagy) %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-12 border-2 border-dashed border-surface-border/50 rounded-xl bg-surface-base">
      <div class="w-14 h-14 mx-auto mb-3 bg-surface-raised rounded-full flex items-center justify-center border border-surface-border/40">
        <% if @source == "favorites" %>
          <i class="fas fa-star text-amber-400/60 text-xl"></i>
        <% elsif params[:query].present? %>
          <i class="fas fa-search text-ink-subtle text-xl"></i>
        <% else %>
          <i class="fas fa-bowl-food text-brand text-xl"></i>
        <% end %>
      </div>
      <h3 class="text-lg font-semibold text-ink-primary mb-1">
        <% if params[:query].present? %>
          <%= t("views.recipes.no_results") %>
        <% elsif @source == "favorites" %>
          <%= t("views.recipes.no_favorites") %>
        <% else %>
          <%= t("views.recipes.no_recipes") %>
        <% end %>
      </h3>
      <p class="text-ink-muted mb-4">
        <% if params[:query].present? %>
          <%= t("views.recipes.no_results_for", query: params[:query]) %>
        <% elsif @source == "favorites" %>
          <%= t("views.recipes.no_favorites_hint") %>
        <% else %>
          <%= t("views.recipes.create_first") %>
        <% end %>
      </p>
      <% if @source == "favorites" %>
        <%= link_to recipes_path, class: "btn-secondary" do %>
          <i class="fas fa-list"></i>
          <%= t("views.recipes.no_favorites_see_all") %>
        <% end %>
      <% elsif !params[:query].present? %>
        <%= link_to new_recipe_path, class: "btn-primary" do %>
          <i class="fas fa-plus"></i>
          <%= t("views.recipes.new_recipe") %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
