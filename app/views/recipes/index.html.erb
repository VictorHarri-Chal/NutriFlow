<% content_for :page_title, t("views.recipes.title") %>

<div class="max-w-7xl mx-auto mt-16 card p-8">
  <!-- En-tête avec titre, recherche et actions -->
  <header class="mb-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <!-- Titre + compteur -->
      <div class="flex-shrink-0">
        <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.recipes.title") %></h1>
        <% total = @pagy ? @pagy.count : @recipes.size %>
        <p class="text-xs text-ink-subtle mt-0.5"><%= t("views.recipes.recipe_count", count: total) %></p>
      </div>

      <!-- Barre de recherche -->
      <div class="flex-1 max-w-md lg:mx-6">
        <%= form_with url: recipes_path, method: :get, local: true, class: "relative" do |f| %>
          <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>

          <%= text_field_tag :query, params[:query],
              class: "input-dark pl-10 #{params[:query].present? ? 'pr-10' : ''} py-1.5 text-sm",
              placeholder: t("views.recipes.search_placeholder"),
              autocomplete: "off" %>

          <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-ink-subtle pointer-events-none"></i>

          <% if params[:query].present? %>
            <%= link_to recipes_path(sort: params[:sort]), class: "absolute right-3 top-1/2 -translate-y-1/2 text-ink-subtle hover:text-ink-muted transition-colors" do %>
              <i class="fas fa-times"></i>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <!-- Bouton d'ajout -->
      <%= link_to new_recipe_path, class: "btn-primary flex-shrink-0" do %>
        <i class="fas fa-plus"></i>
        <%= t("views.recipes.new_recipe") %>
      <% end %>
    </div>
  </header>

  <!-- Barre de tri (masquée pendant une recherche) -->
  <% unless params[:query].present? %>
    <div class="flex items-center gap-2 mb-6">
      <span class="text-xs text-ink-subtle font-medium mr-1"><%= t("views.recipes.sort_label") %></span>
      <% [["name", t("views.recipes.sort_name")], ["newest", t("views.recipes.sort_newest")], ["oldest", t("views.recipes.sort_oldest")], ["calories", t("views.recipes.sort_calories")], ["proteins", t("views.recipes.sort_proteins")]].each do |key, label| %>
        <% active = (params[:sort] || "name") == key %>
        <%= link_to recipes_path(sort: key, query: params[:query]),
              class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border transition-colors #{active ? 'bg-brand text-zinc-900 border-brand' : 'bg-surface-hover text-ink-muted border-surface-border hover:border-brand/50'}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @recipes.any? %>
    <!-- Grille de cartes -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @recipes.each do |recipe| %>
        <%= render RecipeCardComponent.new(recipe: recipe, current_user: current_user) %>
      <% end %>
    </div>

    <!-- Pagination -->
    <% if @pagy&.pages&.> 1 %>
      <div class="mt-8 flex justify-center">
        <%= render PaginationComponent.new(pagy: @pagy) %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-12 border-2 border-dashed border-surface-border/50 rounded-xl bg-surface-base">
      <div class="w-14 h-14 mx-auto mb-3 bg-surface-raised rounded-full flex items-center justify-center border border-surface-border/40">
        <i class="fas fa-bowl-food text-brand text-xl"></i>
      </div>
      <h3 class="text-lg font-semibold text-ink-primary mb-1">
        <%= params[:query].present? ? t("views.recipes.no_results") : t("views.recipes.no_recipes") %>
      </h3>
      <p class="text-ink-muted mb-4">
        <%= params[:query].present? ? t("views.recipes.no_results_for", query: params[:query]) : t("views.recipes.create_first") %>
      </p>
      <% unless params[:query].present? %>
        <%= link_to new_recipe_path, class: "btn-primary" do %>
          <i class="fas fa-plus"></i>
          <%= t("views.recipes.new_recipe") %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
