<div class="flex items-start gap-3 py-2 px-1 rounded-lg hover:bg-surface-base/50 transition-colors group"
     data-nested-form-target="item">

  <%# ── Combobox aliment ── %>
  <div class="flex-1 min-w-0"
       data-controller="food-combobox"
       data-food-combobox-selected-id-value="<%= f.object.food_id.to_i %>"
       data-food-combobox-food-name-value="<%= f.object.food&.name.to_s %>"
       data-food-combobox-no-results-value="<%= t('views.day_foods.form.no_food_found') %>">

    <%= f.hidden_field :food_id, data: { "food-combobox-target": "hiddenId" } %>

    <div class="relative">
      <input type="text"
             class="input-dark pl-8 text-sm <%= 'border-status-danger focus:ring-status-danger/50 focus:border-status-danger' if f.object.errors[:food_id].any? %>"
             placeholder="<%= t("views.recipes.item_fields.search_food") %>"
             autocomplete="off"
             value="<%= f.object.food&.name.to_s %>"
             data-food-combobox-target="input"
             data-action="focus->food-combobox#open input->food-combobox#filter keydown->food-combobox#keydown">
      <i class="fas fa-search absolute left-2.5 top-1/2 -translate-y-1/2 text-ink-subtle text-xs pointer-events-none"></i>
    </div>

    <% if f.object.errors[:food_id].any? %>
      <p class="mt-1 text-xs text-status-danger flex items-center gap-1">
        <i class="fas fa-circle-exclamation text-[10px]"></i>
        <%= t("views.recipes.item_fields.error_food") %>
      </p>
    <% end %>

    <%# Dropdown (positionné en fixed par le controller JS) %>
    <div class="hidden max-h-52 overflow-y-auto bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl"
         data-food-combobox-target="dropdown">
    </div>
  </div>

  <%# ── Quantité + unité ── %>
  <div class="flex gap-1 shrink-0">
    <%# Nombre %>
    <div class="w-16">
      <%= f.number_field :quantity,
            min: 1, step: 1,
            value: f.object.quantity.present? ? f.object.quantity.to_i : 100,
            class: "input-dark text-sm text-center w-full #{f.object.errors[:quantity].any? ? 'border-status-danger focus:ring-status-danger/50 focus:border-status-danger' : ''}",
            placeholder: "100" %>
      <% if f.object.errors[:quantity].any? %>
        <p class="mt-1 text-xs text-status-danger flex items-center gap-1">
          <i class="fas fa-circle-exclamation text-[10px]"></i>
          <%= t("views.recipes.item_fields.error_quantity") %>
        </p>
      <% end %>
    </div>

    <%# Sélecteur d'unité %>
    <div data-controller="unit-select" class="relative shrink-0 w-16">
      <%= f.hidden_field :unit,
            value: f.object.unit.presence || "g",
            data: { "unit-select-target": "hiddenInput" } %>

      <button type="button"
              data-action="click->unit-select#toggle"
              data-unit-select-target="trigger"
              class="input-dark w-full text-sm flex items-center justify-between gap-1 cursor-pointer select-none px-2">
        <span data-unit-select-target="label" class="text-ink-muted"><%= f.object.unit.presence || "g" %></span>
        <i class="fas fa-chevron-down text-[10px] text-ink-subtle transition-transform duration-150"
           data-unit-select-target="icon"></i>
      </button>

      <div data-unit-select-target="dropdown"
           class="hidden absolute top-full mt-1 left-0 min-w-[4.5rem] bg-surface-raised border border-surface-border/50 rounded-xl shadow-xl overflow-hidden z-50 py-1">
        <% RecipeItem::UNITS.each do |unit| %>
          <button type="button"
                  data-action="click->unit-select#select"
                  data-value="<%= unit %>"
                  class="w-full text-left px-3 py-2 text-xs text-ink-muted hover:text-ink-primary hover:bg-surface-hover transition-colors">
            <%= unit %>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Supprimer ── %>
  <div class="shrink-0 pt-1.5">
    <button type="button"
            class="w-8 h-8 flex items-center justify-center rounded-lg text-ink-subtle opacity-0 group-hover:opacity-100 hover:text-status-danger hover:bg-status-danger_dim/20 transition-all"
            title="<%= t("views.recipes.item_fields.remove") %>"
            data-action="nested-form#remove">
      <i class="fas fa-times text-sm"></i>
    </button>
    <%= f.hidden_field :_destroy, value: "false", data: { nested_form_target: "destroyField" } %>
  </div>

</div>
