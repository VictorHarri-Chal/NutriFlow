<div class="bg-surface-raised rounded-lg border border-surface-border/50 p-4" data-nested-form-target="item">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div data-controller="select-filter">
      <label class="label-dark"><%= t("views.recipes.item_fields.food") %></label>
      <div class="relative mb-1">
        <input type="text"
               class="input-dark pl-8 py-1.5 text-sm"
               placeholder="<%= t("views.recipes.item_fields.search_food") %>"
               autocomplete="off"
               data-select-filter-target="input"
               data-action="input->select-filter#filter">
        <i class="fas fa-search absolute left-2.5 top-1/2 -translate-y-1/2 text-ink-subtle text-xs pointer-events-none"></i>
      </div>
      <%= f.input :food_id,
                  label: false,
                  collection: current_user.foods.order(:name),
                  label_method: :name,
                  value_method: :id,
                  include_blank: t("views.recipes.item_fields.select_blank"),
                  input_html: { class: "input-dark", data: { select_filter_target: "select" } } %>
    </div>

    <div>
      <%= f.input :quantity,
                  label: t("views.recipes.item_fields.quantity"),
                  as: :decimal,
                  input_html: { step: 1, min: 1, class: "input-dark" },
                  label_html: { class: "label-dark" } %>
    </div>

    <div class="flex items-end">
      <button type="button"
              class="btn-danger w-full"
              data-action="nested-form#remove">
        <i class="fas fa-trash mr-2"></i>
        <%= t("views.recipes.item_fields.remove") %>
      </button>
      <%= f.hidden_field :_destroy, value: "false", data: { nested_form_target: "destroyField" } %>
    </div>
  </div>
</div>
