<%= simple_form_for(recipe) do |f| %>

  <%# ── Données aliments pour les combobox (lues par food_combobox_controller.js + recipe_builder_controller.js) ── %>
  <script id="foods-data" type="application/json">
    <%= json_escape(current_user.foods.order(:name).select(:id, :name, :calories, :proteins, :carbs, :fats, :sugars, :fiber, :saturated_fat, :salt, :micronutrients, :allergens, :traces).to_json).html_safe %>
  </script>

  <%# ── Labels i18n pour micronutriments et allergènes (lus par recipe_builder_controller.js) ── %>
  <script id="recipe-labels-data" type="application/json">
    <%= json_escape({
      micronutrients: {
        calcium: t("views.foods.show.nutrients.calcium"),
        iron: t("views.foods.show.nutrients.iron"),
        magnesium: t("views.foods.show.nutrients.magnesium"),
        potassium: t("views.foods.show.nutrients.potassium"),
        sodium: t("views.foods.show.nutrients.sodium"),
        zinc: t("views.foods.show.nutrients.zinc"),
        cholesterol: t("views.foods.show.nutrients.cholesterol"),
        vitamin_c: t("views.foods.show.nutrients.vitamin_c"),
        vitamin_d: t("views.foods.show.nutrients.vitamin_d"),
        vitamin_b12: t("views.foods.show.nutrients.vitamin_b12"),
        vitamin_a: t("views.foods.show.nutrients.vitamin_a"),
        vitamin_b9: t("views.foods.show.nutrients.vitamin_b9"),
        epa: t("views.foods.show.nutrients.epa"),
        dha: t("views.foods.show.nutrients.dha")
      },
      micronutrient_units: {
        calcium: "mg", iron: "mg", magnesium: "mg", potassium: "mg",
        sodium: "mg", zinc: "mg", cholesterol: "mg",
        vitamin_c: "mg", vitamin_d: "µg", vitamin_b12: "µg",
        vitamin_a: "µg", vitamin_b9: "µg", epa: "g", dha: "g"
      },
      allergens: {
        milk: t("views.foods.show.allergens_map.milk"),
        eggs: t("views.foods.show.allergens_map.eggs"),
        gluten: t("views.foods.show.allergens_map.gluten"),
        wheat: t("views.foods.show.allergens_map.wheat"),
        rye: t("views.foods.show.allergens_map.rye"),
        barley: t("views.foods.show.allergens_map.barley"),
        oats: t("views.foods.show.allergens_map.oats"),
        spelt: t("views.foods.show.allergens_map.spelt"),
        nuts: t("views.foods.show.allergens_map.nuts"),
        almonds: t("views.foods.show.allergens_map.almonds"),
        hazelnuts: t("views.foods.show.allergens_map.hazelnuts"),
        walnuts: t("views.foods.show.allergens_map.walnuts"),
        cashews: t("views.foods.show.allergens_map.cashews"),
        pecans: t("views.foods.show.allergens_map.pecans"),
        brazil_nuts: t("views.foods.show.allergens_map.brazil_nuts"),
        pistachios: t("views.foods.show.allergens_map.pistachios"),
        macadamia: t("views.foods.show.allergens_map.macadamia"),
        peanuts: t("views.foods.show.allergens_map.peanuts"),
        soybeans: t("views.foods.show.allergens_map.soybeans"),
        fish: t("views.foods.show.allergens_map.fish"),
        crustaceans: t("views.foods.show.allergens_map.crustaceans"),
        celery: t("views.foods.show.allergens_map.celery"),
        mustard: t("views.foods.show.allergens_map.mustard"),
        sesame: t("views.foods.show.allergens_map.sesame"),
        sulphites: t("views.foods.show.allergens_map.sulphites"),
        sulphur_dioxide_and_sulphites: t("views.foods.show.allergens_map.sulphur_dioxide_and_sulphites"),
        lupin: t("views.foods.show.allergens_map.lupin"),
        molluscs: t("views.foods.show.allergens_map.molluscs")
      }
    }.to_json).html_safe %>
  </script>

  <div data-controller="recipe-builder" data-action="input->recipe-builder#update">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">

      <%# ══════════════════ COLONNE GAUCHE ══════════════════ %>
      <div class="lg:col-span-3 space-y-6">

        <%# Nom %>
        <%= f.input :name,
                    label: t("views.recipes.form.name"),
                    input_html: { class: "input-dark", autofocus: true, autocomplete: "off", maxlength: 80 },
                    label_html: { class: "label-dark" } %>

        <%# Instructions — accordéon collapsible %>
        <div data-controller="collapsible">
          <button type="button"
                  class="flex items-center justify-between w-full group"
                  data-action="click->collapsible#toggle">
            <span class="label-dark mb-0 group-hover:text-ink-primary transition-colors">
              <%= t("views.recipes.form.instructions") %>
              <span class="text-ink-subtle font-normal ml-1 text-xs">(<%= t("views.recipes.form.instructions_optional") %>)</span>
            </span>
            <i class="fas fa-chevron-down text-xs text-ink-subtle transition-transform duration-200 group-hover:text-ink-muted"
               data-collapsible-target="icon"></i>
          </button>

          <div class="hidden mt-2" data-collapsible-target="content">
            <%= f.input :instructions,
                        as: :text,
                        label: false,
                        input_html: {
                          rows: 4,
                          maxlength: 2000,
                          class: "input-dark resize-y text-sm"
                        } %>
          </div>
        </div>

        <%# ── Ingrédients ── %>
        <div data-controller="nested-form" data-nested-form-wrapper-selector-value=".ingredients-container">

          <div class="flex items-center justify-between mb-3">
            <h2 class="text-base font-semibold text-ink-primary"><%= t("views.recipes.form.ingredients") %></h2>
            <% if recipe.errors[:base].any? %>
              <p class="text-xs text-status-danger flex items-center gap-1">
                <i class="fas fa-circle-exclamation text-[10px]"></i>
                <%= recipe.errors[:base].first %>
              </p>
            <% end %>
          </div>

          <%# En-têtes colonnes — masqués si liste vide %>
          <div class="flex items-center gap-3 px-1 pb-2 border-b border-surface-border/40 mb-1"
               data-nested-form-target="headerRow">
            <div class="flex-1 text-xs text-ink-subtle font-medium uppercase tracking-wider"><%= t("views.recipes.item_fields.food_col") %></div>
            <div class="w-36 shrink-0 text-xs text-ink-subtle font-medium uppercase tracking-wider text-center"><%= t("views.recipes.item_fields.quantity_col") %></div>
            <div class="w-8 shrink-0"></div>
          </div>

          <%# Liste des ingrédients %>
          <div class="ingredients-container divide-y divide-surface-border/30">
            <%= f.simple_fields_for :recipe_items do |item_fields| %>
              <%= render "shared/ingredient_fields", f: item_fields, unit_class: RecipeItem, i18n_scope: "views.recipes.item_fields", width_class: "w-16", quantity_step: 0.1, quantity_round: 1 %>
            <% end %>

            <%# Empty state %>
            <div class="text-center py-10" data-nested-form-target="emptyState">
              <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
                <i class="fas fa-bowl-food text-ink-subtle"></i>
              </div>
              <p class="text-sm text-ink-muted mb-3"><%= t("views.recipes.form.add_ingredient_hint") %></p>
              <button type="button"
                      class="btn-primary text-sm"
                      data-action="nested-form#add">
                <i class="fas fa-plus"></i>
                <%= t("views.recipes.form.add_first_ingredient") %>
              </button>
            </div>
          </div>

          <%# Bouton ajouter — discret, en bas de liste %>
          <button type="button"
                  class="mt-4 w-full flex items-center justify-center gap-2 px-4 py-2.5 text-sm text-ink-subtle hover:text-brand border border-dashed border-surface-border/50 hover:border-brand/50 rounded-lg hover:bg-brand/5 transition-colors"
                  data-action="nested-form#add"
                  data-nested-form-target="addButton">
            <i class="fas fa-plus text-xs"></i>
            <%= t("views.recipes.form.add_ingredient") %>
          </button>

          <%# Template pour les nouveaux ingrédients %>
          <template data-nested-form-target="template">
            <%= f.simple_fields_for :recipe_items, recipe.recipe_items.build, child_index: "NEW_RECORD" do |item_fields| %>
              <%= render "shared/ingredient_fields", f: item_fields, unit_class: RecipeItem, i18n_scope: "views.recipes.item_fields", width_class: "w-16", quantity_step: 0.1, quantity_round: 1 %>
            <% end %>
          </template>
        </div>

      </div><%# fin col gauche %>

      <%# ══════════════════ COLONNE DROITE — Récap live ══════════════════ %>
      <div class="lg:col-span-2">
        <div class="sticky top-8 card p-5 space-y-4">

          <h3 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide flex items-center gap-2">
            <i class="fas fa-chart-pie text-brand text-xs"></i>
            <%= t("views.recipes.form.live_summary") %>
          </h3>

          <%# État vide %>
          <div data-recipe-builder-target="emptyPanel" class="text-center py-6">
            <i class="fas fa-chart-pie text-surface-border text-3xl mb-3 block"></i>
            <p class="text-xs text-ink-subtle leading-relaxed"><%= t("views.recipes.form.summary_empty_hint") %></p>
          </div>

          <%# Stats (cachées au départ) %>
          <div data-recipe-builder-target="statsPanel" class="hidden">

            <%# Poids + Calories %>
            <div class="space-y-1 mb-4 pb-4 border-b border-surface-border/40">
              <div class="flex items-center justify-between">
                <span class="text-xs text-ink-subtle"><%= t("views.recipes.show.total_weight_short") %></span>
                <span class="text-xs font-semibold text-ink-primary tabular-nums">
                  <span data-recipe-builder-target="totalWeight">0</span> g
                </span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-xs text-ink-subtle"><%= t("views.recipes.show.calories") %></span>
                <span class="text-base font-bold text-brand tabular-nums">
                  <span data-recipe-builder-target="totalCalories">0</span> kcal
                </span>
              </div>
            </div>

            <%# Macronutriments %>
            <div class="mb-4">
              <p class="text-[10px] font-semibold text-ink-subtle uppercase tracking-wider mb-2">
                <%= t("views.recipes.form.macros_section") %>
              </p>
              <div class="space-y-1">
                <% [
                  { target: "totalProteins", label: t("views.recipes.show.proteins_short") },
                  { target: "totalCarbs",    label: t("views.recipes.show.carbs_short") },
                  { target: "totalFats",     label: t("views.recipes.show.fats_short") },
                  { target: "totalSugars",   label: t("views.recipes.show.sugars_short") },
                  { target: "totalFiber",    label: t("views.recipes.show.fiber_short") },
                  { target: "totalSaturatedFat", label: t("views.recipes.show.saturated_fat_short") },
                  { target: "totalSalt",     label: t("views.recipes.show.salt_short") }
                ].each do |row| %>
                  <div class="flex items-center justify-between py-0.5 border-b border-surface-border/20 last:border-0">
                    <span class="text-xs text-ink-muted"><%= row[:label] %></span>
                    <span class="text-xs font-semibold text-ink-primary tabular-nums">
                      <span data-recipe-builder-target="<%= row[:target] %>">0</span> g
                    </span>
                  </div>
                <% end %>
              </div>
            </div>

            <%# Micronutriments (affichés si non vides) %>
            <div data-recipe-builder-target="micronutrientsSection" class="hidden mb-4">
              <p class="text-[10px] font-semibold text-ink-subtle uppercase tracking-wider mb-2">
                <%= t("views.recipes.form.micronutrients_section") %>
              </p>
              <div data-recipe-builder-target="micronutrientsList" class="space-y-0.5"></div>
            </div>

            <%# Allergènes (affichés si présents) %>
            <div data-recipe-builder-target="allergensSection" class="hidden mb-4">
              <p class="text-[10px] font-semibold text-ink-subtle uppercase tracking-wider mb-2">
                <%= t("views.recipes.form.allergens_section") %>
              </p>
              <div data-recipe-builder-target="allergensList" class="flex flex-wrap gap-1"></div>
            </div>

            <%# Détail par ingrédient %>
            <div class="border-t border-surface-border/40 pt-3">
              <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] font-semibold text-ink-subtle uppercase tracking-wider"><%= t("views.recipes.form.ingredients") %></span>
                <span class="text-xs font-semibold text-ink-muted tabular-nums" data-recipe-builder-target="ingredientCount">0</span>
              </div>
              <div data-recipe-builder-target="ingredientList" class="space-y-0"></div>
            </div>

          </div><%# fin statsPanel %>

        </div>
      </div><%# fin col droite %>

    </div>

    <%# ── Actions ── %>
    <div class="flex justify-center gap-4 mt-10 pt-6 border-t border-surface-border/40">
      <% if recipe.persisted? %>
        <%= link_to t("shared.cancel"), recipe_path(recipe), class: "btn-ghost" %>
      <% else %>
        <%= link_to t("shared.cancel"), recipes_path, class: "btn-ghost" %>
      <% end %>
      <%= f.button :submit, t("shared.save"), class: "btn-primary px-8" %>
    </div>

  </div><%# fin recipe-builder %>
<% end %>
