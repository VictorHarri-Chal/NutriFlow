<% content_for :page_title do %>
  <%= t("views.recipes.show.page_title") %>
<% end %>

<div class="max-w-7xl mx-auto mt-16">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Contenu principal (2/3 de la largeur) -->
    <div class="lg:col-span-2 space-y-6">
      <div class="card p-8">
        <!-- En-tête avec navigation -->
        <div class="flex items-center gap-4 mb-6">
          <%= link_to recipes_path, class: "text-ink-subtle hover:text-ink-muted transition" do %>
            <i class="fas fa-arrow-left text-xl"></i>
          <% end %>
          <h1 class="text-3xl font-bold text-ink-primary flex-1"><%= @recipe.name %></h1>
        </div>

        <!-- Résumé nutritionnel -->
        <div class="bg-surface-base rounded-lg border border-brand/20 p-6 mb-8">
          <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4"><%= t("views.recipes.show.nutritional_values") %></h2>
          <div class="grid grid-cols-3 md:grid-cols-6 gap-4">
            <div class="text-center">
              <div class="text-xl font-bold text-ink-muted"><%= @recipe.total_weight %><span class="text-xs font-normal text-ink-subtle ml-0.5">g</span></div>
              <div class="text-xs text-ink-subtle mt-1"><%= t("views.recipes.show.total_weight_short") %></div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-brand"><%= @recipe.total_calories %><span class="text-xs font-normal text-ink-subtle ml-0.5">kcal</span></div>
              <div class="text-xs text-ink-subtle mt-1"><%= t("views.recipes.show.calories") %></div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-ink-primary"><%= @recipe.total_proteins %><span class="text-xs font-normal text-ink-subtle ml-0.5">g</span></div>
              <div class="text-xs text-ink-subtle mt-1"><%= t("views.recipes.show.proteins_short") %></div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-ink-primary"><%= @recipe.total_carbs %><span class="text-xs font-normal text-ink-subtle ml-0.5">g</span></div>
              <div class="text-xs text-ink-subtle mt-1"><%= t("views.recipes.show.carbs_short") %></div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-ink-primary"><%= @recipe.total_fats %><span class="text-xs font-normal text-ink-subtle ml-0.5">g</span></div>
              <div class="text-xs text-ink-subtle mt-1"><%= t("views.recipes.show.fats_short") %></div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-ink-primary"><%= @recipe.total_sugars %><span class="text-xs font-normal text-ink-subtle ml-0.5">g</span></div>
              <div class="text-xs text-ink-subtle mt-1"><%= t("views.recipes.show.sugars_short") %></div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Ingrédients -->
          <div>
            <h2 class="text-lg font-semibold text-ink-primary mb-4"><%= t("views.recipes.show.ingredients") %></h2>
            <div class="bg-surface-base rounded-lg overflow-hidden border border-surface-border/40">
              <table class="min-w-full table-dark">
                <thead>
                  <tr>
                    <th><%= t("views.recipes.show.food_col") %></th>
                    <th><%= t("views.recipes.show.quantity_col") %></th>
                    <th><%= t("views.recipes.show.calories") %></th>
                  </tr>
                </thead>
                <tbody>
                  <% @recipe.recipe_items.each do |item| %>
                    <tr>
                      <td class="font-medium text-ink-primary">
                        <%= item.food.name %>
                      </td>
                      <td class="text-ink-muted">
                        <%= item.quantity %> g
                      </td>
                      <td class="font-semibold text-brand">
                        <%= item.total_calories %> kcal
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Instructions -->
          <div>
            <h2 class="text-lg font-semibold text-ink-primary mb-4"><%= t("views.recipes.show.instructions") %></h2>
            <% if @recipe.instructions.present? %>
              <div class="bg-surface-base rounded-lg border border-surface-border/40 p-6">
                <div class="prose prose-sm max-w-none">
                  <%= simple_format(@recipe.instructions, class: "text-ink-muted leading-relaxed") %>
                </div>
              </div>
            <% else %>
              <div class="bg-surface-base rounded-lg border border-surface-border/40 p-6 text-center">
                <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
                  <i class="fas fa-clipboard text-ink-subtle"></i>
                </div>
                <p class="text-ink-muted text-sm"><%= t("views.recipes.show.no_instructions") %></p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center justify-center gap-1 mt-8 pt-5 border-t border-surface-border/30">
          <%= link_to duplicate_recipe_path(@recipe),
                data: { turbo_method: :post },
                class: "flex items-center gap-1.5 px-3 py-1.5 text-xs text-ink-subtle hover:text-ink-primary hover:bg-surface-hover rounded-lg transition-colors" do %>
            <i class="fas fa-copy text-xs"></i>
            <%= t("views.recipes.show.duplicate") %>
          <% end %>
          <div class="w-px h-4 bg-surface-border/50 mx-1"></div>
          <%= link_to edit_recipe_path(@recipe),
                class: "flex items-center gap-1.5 px-3 py-1.5 text-xs text-ink-subtle hover:text-ink-primary hover:bg-surface-hover rounded-lg transition-colors" do %>
            <i class="fas fa-pen text-xs"></i>
            <%= t("views.recipes.show.edit") %>
          <% end %>
          <div class="w-px h-4 bg-surface-border/50 mx-1"></div>
          <%= delete_link_with_confirm(recipe_path(@recipe),
                confirm: t("views.recipes.show.delete_confirm"),
                text: t("views.recipes.show.delete"),
                class: "flex items-center gap-1.5 px-3 py-1.5 text-xs text-status-danger hover:text-red-400 hover:bg-status-danger_dim/20 rounded-lg transition-colors") %>
        </div>
      </div>

    </div>

    <!-- Sidebar (1/3 de la largeur) -->
    <div class="lg:col-span-1">
      <div class="sticky top-8 z-30">
        <%= render RecipeSidebarComponent.new(recipe: @recipe, current_user: current_user) %>
      </div>
    </div>
  </div>
</div>
