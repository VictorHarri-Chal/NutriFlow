<% content_for :page_title do %>
  <%= t("views.recipes.show.page_title") %>
<% end %>

<div class="max-w-7xl mx-auto mt-16">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Contenu principal (2/3 de la largeur) -->
    <div class="lg:col-span-2">
      <div class="card p-8">
        <!-- En-tête avec navigation -->
        <div class="flex items-center gap-4 mb-6">
          <%= link_to recipes_path, class: "text-ink-subtle hover:text-ink-muted transition" do %>
            <i class="fas fa-arrow-left text-xl"></i>
          <% end %>
          <h1 class="text-3xl font-bold text-ink-primary"><%= @recipe.name %></h1>
        </div>

        <!-- Résumé nutritionnel -->
        <div class="bg-surface-base rounded-lg border border-brand/20 p-6 mb-8">
          <h2 class="text-lg font-semibold text-ink-primary mb-4"><%= t("views.recipes.show.nutritional_values") %></h2>
          <div class="grid grid-cols-2 md:grid-cols-6 gap-4">
            <div class="text-center">
              <div class="text-2xl font-bold text-ink-muted"><%= @recipe.total_weight %></div>
              <div class="text-sm text-ink-subtle"><%= t("views.recipes.show.total_weight") %></div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-brand"><%= @recipe.total_calories %></div>
              <div class="text-sm text-ink-subtle"><%= t("views.recipes.show.calories") %></div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-ink-primary"><%= @recipe.total_proteins %></div>
              <div class="text-sm text-ink-subtle"><%= t("views.recipes.show.proteins") %></div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-ink-primary"><%= @recipe.total_carbs %></div>
              <div class="text-sm text-ink-subtle"><%= t("views.recipes.show.carbs") %></div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-ink-primary"><%= @recipe.total_fats %></div>
              <div class="text-sm text-ink-subtle"><%= t("views.recipes.show.fats") %></div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-ink-primary"><%= @recipe.total_sugars %></div>
              <div class="text-sm text-ink-subtle"><%= t("views.recipes.show.sugars") %></div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
          <!-- Ingrédients -->
          <div>
            <h2 class="text-xl font-semibold text-ink-primary mb-4"><%= t("views.recipes.show.ingredients") %></h2>
            <div class="bg-surface-base rounded-lg overflow-hidden border border-surface-border/40">
              <table class="min-w-full table-dark">
                <thead>
                  <tr>
                    <th><%= t("views.recipes.show.food_col") %></th>
                    <th><%= t("views.recipes.show.quantity_col") %></th>
                    <th><%= t("views.recipes.show.calories") %></th>
                  </tr>
                </thead>
                <tbody>
                  <% @recipe.recipe_items.each do |item| %>
                    <tr>
                      <td class="font-medium text-ink-primary">
                        <%= item.food.name %>
                      </td>
                      <td class="text-ink-muted">
                        <%= item.quantity %> g
                      </td>
                      <td class="font-semibold text-brand">
                        <%= item.total_calories %> kcal
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Instructions -->
          <div>
            <h2 class="text-xl font-semibold text-ink-primary mb-4"><%= t("views.recipes.show.instructions") %></h2>
            <% if @recipe.instructions.present? %>
              <div class="bg-surface-base rounded-lg border border-surface-border/40 p-6">
                <div class="prose prose-sm max-w-none">
                  <%= simple_format(@recipe.instructions, class: "text-ink-muted leading-relaxed") %>
                </div>
              </div>
            <% else %>
              <div class="bg-surface-base rounded-lg border border-surface-border/40 p-6 text-center">
                <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
                  <i class="fas fa-clipboard text-ink-subtle"></i>
                </div>
                <p class="text-ink-muted"><%= t("views.recipes.show.no_instructions") %></p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Système de commentaires -->
        <%= render RecipeCommentsComponent.new(recipe: @recipe, current_user: current_user) %>

        <!-- Actions en bas -->
        <div class="flex justify-center gap-4">
          <%= link_to edit_recipe_path(@recipe), class: "btn-secondary" do %>
            <i class="fas fa-pen"></i>
            <%= t("views.recipes.show.edit") %>
          <% end %>

          <%= delete_link_with_confirm(recipe_path(@recipe),
                                      confirm: t("views.recipes.show.delete_confirm"),
                                      text: t("views.recipes.show.delete"),
                                      class: "btn-danger") %>
        </div>
      </div>
    </div>

    <!-- Sidebar (1/3 de la largeur) -->
    <div class="lg:col-span-1">
      <div class="sticky top-8 z-30">
        <%= render RecipeSidebarComponent.new(recipe: @recipe, current_user: current_user) %>
      </div>
    </div>
  </div>
</div>
