<% content_for :page_title, @recipe.name %>

<div class="max-w-5xl mx-auto mt-16">

  <%# ── Navigation + Actions ── %>
  <div class="flex items-center justify-between mb-6">
    <%= link_to recipes_path, class: "inline-flex items-center gap-2 text-sm text-ink-muted hover:text-ink-primary transition-colors" do %>
      <i class="fas fa-arrow-left text-xs"></i>
      <%= t("views.recipes.show.back_to_list") %>
    <% end %>

    <div class="flex items-center gap-2">
      <%= link_to toggle_favorite_recipe_path(@recipe),
            id: "recipe_show_fav_btn_#{@recipe.id}",
            data: { turbo_method: :patch },
            aria: { label: @recipe.favorite? ? t("views.recipes.favorites.remove") : t("views.recipes.favorites.add") },
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm border transition-colors focus:outline-none #{ @recipe.favorite? ? 'text-ink-subtle border-surface-border/40 bg-surface-raised hover:text-ink-primary hover:border-surface-border' : 'text-amber-400 border-amber-400/40 bg-amber-400/10 hover:bg-amber-400/15' }" do %>
        <i class="<%= @recipe.favorite? ? 'fas' : 'far' %> fa-star text-xs"></i>
        <%= @recipe.favorite? ? t("views.recipes.favorites.remove") : t("views.recipes.favorites.add") %>
      <% end %>
      <div data-controller="recipe-shopping-popup" class="relative">
        <button type="button"
                data-action="click->recipe-shopping-popup#open"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-ink-muted bg-surface-raised border border-surface-border/40 hover:text-ink-primary hover:border-surface-border transition-colors">
          <i class="fas fa-cart-plus text-xs"></i>
          <%= t("views.recipes.show.add_to_shopping_list") %>
        </button>

        <div data-recipe-shopping-popup-target="panel"
             class="opacity-0 scale-95 pointer-events-none transition-all duration-150 origin-top-right
                    absolute right-0 top-full mt-2 w-72
                    bg-surface-raised border border-surface-border/40 rounded-2xl shadow-2xl z-50 p-1.5">

          <%= button_to add_to_shopping_list_recipe_path(@recipe),
                method: :post,
                params: { smart: "true" },
                class: "w-full text-left flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-surface-hover transition-colors",
                form: { data: { turbo_stream: true, action: "submit->recipe-shopping-popup#close" } } do %>
            <div class="flex-shrink-0 w-7 h-7 rounded-lg bg-status-success/10 border border-status-success/30 flex items-center justify-center">
              <i class="fas fa-check text-[10px] text-status-success"></i>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-medium text-ink-primary leading-tight"><%= t("views.recipes.show.shopping_popup.smart_label") %></p>
              <p class="text-xs text-ink-subtle mt-0.5 leading-snug"><%= t("views.recipes.show.shopping_popup.smart_hint") %></p>
            </div>
          <% end %>

          <div class="mx-2 my-0.5 h-px bg-surface-border/30"></div>

          <%= button_to add_to_shopping_list_recipe_path(@recipe),
                method: :post,
                params: { smart: "false" },
                class: "w-full text-left flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-surface-hover transition-colors",
                form: { data: { turbo_stream: true, action: "submit->recipe-shopping-popup#close" } } do %>
            <div class="flex-shrink-0 w-7 h-7 rounded-lg bg-brand/10 border border-brand/30 flex items-center justify-center">
              <i class="fas fa-list text-[10px] text-brand"></i>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-medium text-ink-primary leading-tight"><%= t("views.recipes.show.shopping_popup.all_label") %></p>
              <p class="text-xs text-ink-subtle mt-0.5 leading-snug"><%= t("views.recipes.show.shopping_popup.all_hint") %></p>
            </div>
          <% end %>

        </div>
      </div>
      <%= link_to duplicate_recipe_path(@recipe),
            data: { turbo_method: :post },
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-ink-muted bg-surface-raised border border-surface-border/40 hover:text-ink-primary hover:border-surface-border transition-colors" do %>
        <i class="fas fa-copy text-xs"></i>
        <%= t("views.recipes.show.duplicate") %>
      <% end %>
      <%= link_to edit_recipe_path(@recipe),
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-ink-muted bg-surface-raised border border-surface-border/40 hover:text-ink-primary hover:border-surface-border transition-colors" do %>
        <i class="fas fa-pen text-xs"></i>
        <%= t("views.recipes.show.edit") %>
      <% end %>
      <%= delete_link_with_confirm(recipe_path(@recipe),
            confirm: t("views.recipes.show.delete_confirm"),
            text: t("views.recipes.show.delete"),
            icon_class: "fas fa-trash text-xs",
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-red-400/70 bg-surface-raised border border-surface-border/40 hover:text-red-400 hover:border-red-500/30 transition-colors") %>
    </div>
  </div>

  <%# ── Titre ── %>
  <div class="mb-5">
    <h1 class="text-2xl font-bold text-ink-primary leading-tight"><%= @recipe.name %></h1>
  </div>

  <%# ── Grille principale ── %>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">

    <%# ── Colonne principale (3/5) ── %>
    <div class="lg:col-span-3 space-y-4">

      <%# Nutrition -%>
      <%
        total_weight = @recipe.total_weight.to_f
        factor       = total_weight > 0 ? (100.0 / total_weight) : 0
        per100 = {
          calories:      (@recipe.total_calories      * factor).round(1),
          proteins:      (@recipe.total_proteins      * factor).round(1),
          carbs:         (@recipe.total_carbs         * factor).round(1),
          fats:          (@recipe.total_fats          * factor).round(1),
          sugars:        (@recipe.total_sugars        * factor).round(1),
          fiber:         (@recipe.total_fiber         * factor).round(1),
          saturated_fat: (@recipe.total_saturated_fat * factor).round(1),
          salt:          (@recipe.total_salt          * factor).round(1)
        }
      %>
      <div class="card p-5" data-controller="nutrition-toggle">

        <%# Header %>
        <div class="flex items-center justify-between mb-4">
          <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider">
            <%= t("views.recipes.show.nutritional_values") %>
          </p>
          <% if total_weight > 0 %>
            <div class="flex items-center gap-0.5 p-0.5 bg-surface-base rounded-lg border border-surface-border/40">
              <button type="button"
                      data-action="click->nutrition-toggle#showTotal"
                      data-nutrition-toggle-target="totalBtn"
                      class="px-2.5 py-1 text-[11px] font-medium rounded-md bg-surface-raised text-ink-primary shadow-sm transition-colors">
                <%= t("views.recipes.show.total_label") %>
              </button>
              <button type="button"
                      data-action="click->nutrition-toggle#showPer100"
                      data-nutrition-toggle-target="per100Btn"
                      class="px-2.5 py-1 text-[11px] font-medium rounded-md text-ink-subtle transition-colors">
                <%= t("views.recipes.show.per_100g_label") %>
              </button>
            </div>
          <% end %>
        </div>

        <%# Calories + Poids %>
        <div class="flex items-center justify-center gap-8 mb-4">
          <div class="text-center">
            <div class="text-3xl font-bold text-brand leading-none">
              <span data-nutrition-toggle-target="totalVal"><%= @recipe.total_calories %></span>
              <span data-nutrition-toggle-target="per100Val" class="hidden"><%= per100[:calories] %></span>
            </div>
            <div class="text-xs text-ink-subtle mt-1">
              <span data-nutrition-toggle-target="totalVal">kcal</span>
              <span data-nutrition-toggle-target="per100Val" class="hidden">kcal/100g</span>
            </div>
          </div>
          <div class="w-px h-10 bg-surface-border/50 shrink-0"></div>
          <div class="text-center">
            <div class="text-3xl font-bold text-ink-muted leading-none">
              <span data-nutrition-toggle-target="totalVal"><%= @recipe.total_weight %></span>
              <span data-nutrition-toggle-target="per100Val" class="hidden">100</span>
            </div>
            <div class="text-xs text-ink-subtle mt-1"><%= t("views.recipes.show.total_weight_short") %> (g)</div>
          </div>
        </div>

        <%# Macros principaux %>
        <div class="grid grid-cols-4 gap-2 pt-3 border-t border-surface-border/30">
          <% [
            { total: @recipe.total_proteins,      per100: per100[:proteins],      label: t("views.recipes.show.proteins_short") },
            { total: @recipe.total_carbs,         per100: per100[:carbs],         label: t("views.recipes.show.carbs_short") },
            { total: @recipe.total_fats,          per100: per100[:fats],          label: t("views.recipes.show.fats_short") },
            { total: @recipe.total_sugars,        per100: per100[:sugars],        label: t("views.recipes.show.sugars_short") }
          ].each do |m| %>
            <div class="text-center p-2 bg-surface-hover/50 rounded-lg">
              <div class="font-bold text-ink-primary text-sm">
                <span data-nutrition-toggle-target="totalVal"><%= m[:total] %></span>
                <span data-nutrition-toggle-target="per100Val" class="hidden"><%= m[:per100] %></span>
                g
              </div>
              <div class="text-[10px] text-ink-subtle mt-0.5"><%= m[:label] %></div>
            </div>
          <% end %>
        </div>

        <%# Macros étendus (fibres, ac. saturés, sel) %>
        <div class="grid grid-cols-3 gap-2 mt-2 pt-2 border-t border-surface-border/20">
          <% [
            { total: @recipe.total_fiber,         per100: per100[:fiber],         label: t("views.recipes.show.fiber_short") },
            { total: @recipe.total_saturated_fat, per100: per100[:saturated_fat], label: t("views.recipes.show.saturated_fat_short") },
            { total: @recipe.total_salt,          per100: per100[:salt],          label: t("views.recipes.show.salt_short") }
          ].each do |m| %>
            <div class="text-center px-2 py-1.5 rounded-lg bg-surface-base/60">
              <div class="text-xs font-semibold text-ink-muted">
                <span data-nutrition-toggle-target="totalVal"><%= m[:total] %></span>
                <span data-nutrition-toggle-target="per100Val" class="hidden"><%= m[:per100] %></span>
                g
              </div>
              <div class="text-[10px] text-ink-subtle/80 mt-0.5"><%= m[:label] %></div>
            </div>
          <% end %>
        </div>

      </div>

      <%# Ingrédients -%>
      <div class="card overflow-hidden">
        <div class="flex items-center justify-between px-5 py-3 border-b border-surface-border/40">
          <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider">
            <%= t("views.recipes.show.ingredients") %>
          </p>
          <span class="text-xs text-ink-subtle tabular-nums"><%= @recipe.recipe_items.size %></span>
        </div>
        <div class="overflow-y-auto" style="max-height: 280px;">
          <table class="min-w-full table-dark [&_td]:!py-4">
            <thead class="sticky top-0 z-10">
              <tr>
                <th><%= t("views.recipes.show.food_col") %></th>
                <th><%= t("views.recipes.show.quantity_col") %></th>
                <th><%= t("views.recipes.show.calories") %></th>
              </tr>
            </thead>
            <tbody>
              <% @recipe.recipe_items.each do |item| %>
                <tr>
                  <td class="font-medium text-ink-primary"><%= item.food.name %></td>
                  <td class="text-ink-muted"><%= item.quantity.frac.zero? ? item.quantity.to_i : item.quantity %> <%= item.unit %></td>
                  <td class="font-semibold text-brand"><%= item.total_calories %> kcal</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <%# Instructions -%>
      <div class="card overflow-hidden">
        <div class="px-5 py-3 border-b border-surface-border/40">
          <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider">
            <%= t("views.recipes.show.instructions") %>
          </p>
        </div>
        <% if @recipe.instructions.present? %>
          <div class="overflow-y-auto px-5 py-4" style="max-height: 200px;">
            <%= simple_format(@recipe.instructions, class: "text-sm text-ink-muted leading-relaxed") %>
          </div>
        <% else %>
          <div class="px-5 py-5 flex items-center gap-3 text-ink-subtle/50">
            <i class="fas fa-clipboard text-sm"></i>
            <span class="text-sm italic"><%= t("views.recipes.show.no_instructions") %></span>
          </div>
        <% end %>
      </div>

    </div>

    <%# ── Sidebar (2/5) ── %>
    <div class="lg:col-span-2">
      <div class="sticky top-6 space-y-4">
        <%= render RecipeSidebarComponent.new(recipe: @recipe, current_user: current_user) %>
      </div>
    </div>

  </div>
</div>
