<%= turbo_frame_tag dom_id(day_food_group) do %>
  <div class="py-2" data-controller="form-validation">
    <%= simple_form_for day_food_group, html: { class: "flex items-center gap-3" } do |f| %>
      <div class="flex-1">
        <%= f.input :name,
            label: false,
            wrapper: :default_with_inline_error,
            wrapper_html: { class: "mb-0" },
            input_html: {
              class: "input-dark",
              maxlength: 100,
              data: {
                form_validation_target: "input",
                action: "input->form-validation#input keyup->form-validation#keyup"
              }
            } %>
      </div>
      <%= button_tag type: "submit",
            class: "btn-primary w-8 h-8 p-0 shrink-0 flex items-center justify-center disabled:opacity-40 disabled:cursor-not-allowed",
            data: { form_validation_target: "submit" },
            title: t("shared.update"),
            "aria-label": t("shared.update") do %>
        <i class="fas fa-check text-xs"></i>
      <% end %>
      <%= link_to setting_path(tab: 'day_food_groups'),
            data: { turbo_frame: dom_id(day_food_group), role: "cancel-edit" },
            title: t("shared.cancel"),
            "aria-label": t("shared.cancel"),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg border border-status-danger/40 text-status-danger hover:bg-status-danger/10 transition-colors shrink-0" do %>
        <i class="fas fa-xmark text-xs"></i>
      <% end %>
    <% end %>
  </div>
<% end %>
