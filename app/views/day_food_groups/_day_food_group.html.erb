<%= turbo_frame_tag dom_id(day_food_group) do %>
  <div class="flex items-center justify-between py-3 group">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-surface-hover flex items-center justify-center shrink-0">
        <i class="fas fa-utensils text-xs text-ink-subtle"></i>
      </div>
      <div>
        <div class="text-sm font-medium text-ink-primary"><%= day_food_group.name %></div>
      </div>
    </div>
    <div class="opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1">
      <%= link_to edit_day_food_group_path(day_food_group),
            data: { turbo_frame: dom_id(day_food_group), action: "click->tabs#closeOpenEdits" },
            title: t("shared.edit"),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-brand hover:bg-surface-hover transition-colors" do %>
        <i class="fas fa-pen text-sm"></i>
      <% end %>
      <%= delete_link_with_confirm(
            day_food_group_path(day_food_group),
            confirm: t("views.settings.food_groups.delete_confirm"),
            icon_class: "fas fa-trash text-sm",
            title: t("shared.delete"),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger_dim/20 transition-colors") %>
    </div>
  </div>
<% end %>
