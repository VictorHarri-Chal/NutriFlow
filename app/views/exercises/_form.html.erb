<%= form_with model: exercise, class: "space-y-8", multipart: true do |f| %>

  <%# Erreurs %>
  <% if exercise.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4">
      <p class="text-sm font-semibold text-red-400 mb-2"><%= exercise.errors.count %> erreur(s) :</p>
      <ul class="space-y-1">
        <% exercise.errors.full_messages.each do |msg| %>
          <li class="text-sm text-red-400/80"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Informations générales ── %>
  <div>
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-dumbbell text-brand text-xs"></i>
      <%= t("views.exercises.custom.sections.general") %>
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <%= f.label :name, t("views.exercises.custom.fields.name"), class: "label-dark block mb-1.5" %>
        <%= f.text_field :name,
            class: "input-dark",
            placeholder: "Ex: Barbell Bench Press",
            autocomplete: "off" %>
      </div>
      <div>
        <%= f.label :body_part, t("views.exercises.custom.fields.body_part"), class: "label-dark block mb-1.5" %>
        <%= f.select :body_part,
            Exercise.body_parts.map { |p| [t_body_part(p), p] },
            { include_blank: "—" },
            class: "input-dark select-chevron appearance-none pr-10" %>
      </div>
      <div>
        <%= f.label :equipment, t("views.exercises.custom.fields.equipment"), class: "label-dark block mb-1.5" %>
        <%= f.select :equipment,
            Exercise.equipments.map { |e| [t_equipment(e), e] },
            { include_blank: "—" },
            class: "input-dark select-chevron appearance-none pr-10" %>
      </div>
    </div>
  </div>

  <%# ── Muscles ── %>
  <div class="border-t border-surface-border/40 pt-6">
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-person-running text-brand text-xs"></i>
      <%= t("views.exercises.custom.sections.muscles") %>
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :target_muscle, t("views.exercises.custom.fields.target_muscle"), class: "label-dark block mb-1.5" %>
        <%= f.select :target_muscle,
            %w[abs adductors abductors biceps calves cardiovascular_system delts forearms glutes hamstrings lats levator_scapulae pectorals quads serratus_anterior spine traps triceps upper_back].map { |m| [t_muscle(m.gsub("_", " ")), m.gsub("_", " ")] },
            { include_blank: "—" },
            class: "input-dark select-chevron appearance-none pr-10" %>
      </div>
      <div>
        <%= f.label :secondary_muscles_raw, t("views.exercises.custom.fields.secondary_muscles"), class: "label-dark block mb-1.5" %>
        <%= f.text_field :secondary_muscles_raw,
            value: Array(exercise.secondary_muscles).join(", "),
            class: "input-dark",
            autocomplete: "off" %>
        <p class="text-xs text-ink-subtle mt-1"><%= t("views.exercises.custom.fields.secondary_muscles_hint") %></p>
      </div>
    </div>
  </div>

  <%# ── Détails ── %>
  <div class="border-t border-surface-border/40 pt-6">
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-sliders text-brand text-xs"></i>
      <%= t("views.exercises.custom.sections.details") %>
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

      <%# Catégorie %>
      <div>
        <%= f.label :category, t("views.exercises.custom.fields.category"), class: "label-dark block mb-1.5" %>
        <%= f.select :category,
            %w[strength stretching cardio mobility plyometrics balance].map { |c| [t_category(c), c] },
            { include_blank: "—" },
            class: "input-dark select-chevron appearance-none pr-10" %>
      </div>

      <%# Niveau (radio cards) %>
      <div>
        <%= f.label :difficulty, t("views.exercises.custom.fields.difficulty"), class: "label-dark block mb-2" %>
        <div class="grid grid-cols-3 gap-2">
          <% [
            { value: "beginner",     icon: "fa-seedling",     key: "beginner",      color: "peer-checked:bg-green-500/10 peer-checked:border-green-500 peer-checked:text-green-400" },
            { value: "intermediate", icon: "fa-fire",         key: "intermediate",  color: "peer-checked:bg-amber-500/10 peer-checked:border-amber-500 peer-checked:text-amber-400" },
            { value: "advanced",     icon: "fa-bolt",         key: "advanced",      color: "peer-checked:bg-red-500/10 peer-checked:border-red-500 peer-checked:text-red-400" }
          ].each do |opt| %>
            <label class="cursor-pointer">
              <%= f.radio_button :difficulty, opt[:value], class: "sr-only peer" %>
              <span class="flex flex-col items-center gap-1.5 p-3 rounded-xl border text-center transition-colors
                           bg-surface-hover border-surface-border/50 text-ink-muted
                           hover:border-brand/30 hover:text-ink-primary
                           <%= opt[:color] %>">
                <i class="fas <%= opt[:icon] %> text-base"></i>
                <span class="text-xs font-semibold"><%= t("views.exercises.difficulty.#{opt[:key]}") %></span>
              </span>
            </label>
          <% end %>
        </div>
      </div>

    </div>
  </div>

  <%# ── Description & Instructions ── %>
  <div class="border-t border-surface-border/40 pt-6">
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-align-left text-brand text-xs"></i>
      <%= t("views.exercises.custom.sections.content") %>
    </h2>
    <div class="space-y-4">
      <div>
        <%= f.label :description, t("views.exercises.custom.fields.description"), class: "label-dark block mb-1.5" %>
        <%= f.text_area :description, rows: 3, class: "input-dark resize-none" %>
      </div>
      <div>
        <%= f.label :instructions, t("views.exercises.custom.fields.instructions"), class: "label-dark block mb-1.5" %>
        <%= f.text_area :instructions, rows: 6, class: "input-dark resize-none" %>
        <p class="text-xs text-ink-subtle mt-1"><%= t("views.exercises.custom.fields.instructions_hint") %></p>
      </div>
    </div>
  </div>

  <%# ── Image ── %>
  <div class="border-t border-surface-border/40 pt-6">
    <h2 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
      <i class="fas fa-image text-brand text-xs"></i>
      <%= t("views.exercises.custom.fields.image") %>
    </h2>
    <div class="space-y-3">
      <% if exercise.image.attached? %>
        <div class="w-24 h-24 rounded-xl overflow-hidden border border-surface-border/40">
          <%= image_tag url_for(exercise.image), class: "w-full h-full object-cover" %>
        </div>
      <% end %>
      <%= f.file_field :image,
          class: "block w-full text-sm text-ink-muted file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand/10 file:text-brand hover:file:bg-brand/20 cursor-pointer",
          accept: "image/jpeg,image/png" %>
      <p class="text-xs text-ink-subtle"><%= t("views.exercises.custom.fields.image_hint") %></p>
    </div>
  </div>

  <%# ── Actions ── %>
  <div class="flex justify-center gap-4 pt-6 border-t border-surface-border/40">
    <%= link_to t("shared.cancel"), exercises_path, class: "btn-ghost" %>
    <%= f.submit t("shared.save"), class: "btn-primary px-10" %>
  </div>

<% end %>
