<%= form_with model: exercise, class: "space-y-4", multipart: true do |f| %>

  <%# Erreurs %>
  <% if exercise.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4">
      <p class="text-sm font-semibold text-red-400 mb-2"><%= exercise.errors.count %> erreur(s) :</p>
      <ul class="space-y-1">
        <% exercise.errors.full_messages.each do |msg| %>
          <li class="text-sm text-red-400/80"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Nom %>
  <div>
    <%= f.label :name, t("views.exercises.custom.fields.name"), class: "label-dark block mb-1" %>
    <%= f.text_field :name, class: "input-dark cursor-text", autocomplete: "off" %>
  </div>

  <%# Groupe musculaire + Équipement %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :body_part, t("views.exercises.custom.fields.body_part"), class: "label-dark block mb-1" %>
      <div data-controller="custom-select" class="relative">
        <%= f.select :body_part,
            Exercise.body_parts.map { |p| [t_body_part(p), p] },
            { include_blank: "—" },
            class: "sr-only", data: { custom_select_target: "select" } %>
        <button type="button" data-action="click->custom-select#toggle"
                class="input-dark flex items-center justify-between cursor-pointer w-full text-left">
          <span data-custom-select-target="label" class="text-ink-subtle">—</span>
          <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
        </button>
        <div data-custom-select-target="dropdown" data-custom-select-dropdown
             class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-52 overflow-y-auto"></div>
      </div>
    </div>
    <div>
      <%= f.label :equipment, t("views.exercises.custom.fields.equipment"), class: "label-dark block mb-1" %>
      <div data-controller="custom-select" class="relative">
        <%= f.select :equipment,
            Exercise.equipments.map { |e| [t_equipment(e), e] },
            { include_blank: "—" },
            class: "sr-only", data: { custom_select_target: "select" } %>
        <button type="button" data-action="click->custom-select#toggle"
                class="input-dark flex items-center justify-between cursor-pointer w-full text-left">
          <span data-custom-select-target="label" class="text-ink-subtle">—</span>
          <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
        </button>
        <div data-custom-select-target="dropdown" data-custom-select-dropdown
             class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-52 overflow-y-auto"></div>
      </div>
    </div>
  </div>

  <%# Muscle principal + Muscles secondaires %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :target_muscle, t("views.exercises.custom.fields.target_muscle"), class: "label-dark block mb-1" %>
      <div data-controller="custom-select" class="relative">
        <%= f.select :target_muscle,
            %w[abs adductors abductors biceps calves cardiovascular_system delts forearms glutes hamstrings lats levator_scapulae pectorals quads serratus_anterior spine traps triceps upper_back].map { |m| [t_muscle(m.gsub("_", " ")), m.gsub("_", " ")] },
            { include_blank: "—" },
            class: "sr-only", data: { custom_select_target: "select" } %>
        <button type="button" data-action="click->custom-select#toggle"
                class="input-dark flex items-center justify-between cursor-pointer w-full text-left">
          <span data-custom-select-target="label" class="text-ink-subtle">—</span>
          <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
        </button>
        <div data-custom-select-target="dropdown" data-custom-select-dropdown
             class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-52 overflow-y-auto"></div>
      </div>
    </div>
    <div>
      <%= f.label :secondary_muscles_raw, t("views.exercises.custom.fields.secondary_muscles"), class: "label-dark block mb-1" %>
      <%= f.text_field :secondary_muscles_raw,
          value: Array(exercise.secondary_muscles).join(", "),
          class: "input-dark cursor-text",
          autocomplete: "off" %>
    </div>
  </div>

  <%# Catégorie + Difficulté %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :category, t("views.exercises.custom.fields.category"), class: "label-dark block mb-1" %>
      <div data-controller="custom-select" class="relative">
        <%= f.select :category,
            %w[strength stretching cardio mobility plyometrics balance].map { |c| [t_category(c), c] },
            { include_blank: "—" },
            class: "sr-only", data: { custom_select_target: "select" } %>
        <button type="button" data-action="click->custom-select#toggle"
                class="input-dark flex items-center justify-between cursor-pointer w-full text-left">
          <span data-custom-select-target="label" class="text-ink-subtle">—</span>
          <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
        </button>
        <div data-custom-select-target="dropdown" data-custom-select-dropdown
             class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-52 overflow-y-auto"></div>
      </div>
    </div>
    <div>
      <%= f.label :difficulty, t("views.exercises.custom.fields.difficulty"), class: "label-dark block mb-1" %>
      <div class="grid grid-cols-3 gap-2">
        <% [
          { value: "beginner",     icon: "fa-seedling", key: "beginner",      color: "peer-checked:bg-green-500/10 peer-checked:border-green-500 peer-checked:text-green-400" },
          { value: "intermediate", icon: "fa-fire",     key: "intermediate",  color: "peer-checked:bg-amber-500/10 peer-checked:border-amber-500 peer-checked:text-amber-400" },
          { value: "advanced",     icon: "fa-bolt",     key: "advanced",      color: "peer-checked:bg-red-500/10 peer-checked:border-red-500 peer-checked:text-red-400" }
        ].each do |opt| %>
          <label class="cursor-pointer">
            <%= f.radio_button :difficulty, opt[:value], class: "sr-only peer" %>
            <span class="flex flex-col items-center gap-1 p-2.5 rounded-xl border text-center transition-colors
                         bg-surface-hover border-surface-border/50 text-ink-muted
                         hover:border-brand/30 hover:text-ink-primary
                         <%= opt[:color] %>">
              <i class="fas <%= opt[:icon] %> text-sm"></i>
              <span class="text-xs font-semibold"><%= t("views.exercises.difficulty.#{opt[:key]}") %></span>
            </span>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <%# Description %>
  <div>
    <%= f.label :description, t("views.exercises.custom.fields.description"), class: "label-dark block mb-1" %>
    <%= f.text_area :description, rows: 3, class: "input-dark resize-none cursor-text" %>
  </div>

  <%# Instructions %>
  <div>
    <%= f.label :instructions, t("views.exercises.custom.fields.instructions"), class: "label-dark block mb-1" %>
    <%= f.text_area :instructions, rows: 5, class: "input-dark resize-none cursor-text" %>
  </div>

  <%# Image %>
  <div>
    <%= f.label :image, t("views.exercises.custom.fields.image"), class: "label-dark block mb-1" %>
    <% if exercise.image.attached? %>
      <div class="w-20 h-20 rounded-xl overflow-hidden border border-surface-border/40 mb-2">
        <%= image_tag url_for(exercise.image), class: "w-full h-full object-cover" %>
      </div>
    <% end %>
    <%= f.file_field :image,
        class: "block w-full text-sm text-ink-muted file:mr-4 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand/10 file:text-brand hover:file:bg-brand/20 cursor-pointer",
        accept: "image/jpeg,image/png" %>
    <p class="text-xs text-ink-subtle mt-1"><%= t("views.exercises.custom.fields.image_hint") %></p>
  </div>

  <%# Actions %>
  <div class="flex justify-center gap-4 pt-2 border-t border-surface-border/40">
    <%= link_to t("shared.cancel"), exercises_path, class: "btn-ghost" %>
    <%= f.submit t("shared.save"), class: "btn-primary px-10 cursor-pointer" %>
  </div>

<% end %>
