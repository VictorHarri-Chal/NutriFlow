<%# Remove empty state if present %>
<%= turbo_stream.remove "program_day_#{@day.id}_empty" %>

<%# Append the new exercise card to the day's exercise list %>
<%= turbo_stream.append "program_day_exercises_#{@day.id}" do %>
  <%= render "workout_programs/program_exercise", program: @program, day: @day, pe: @exercise, open: true %>
<% end %>

<%# Show copy button if this is the first exercise added %>
<% if @day.program_exercises.count == 1 %>
  <%= turbo_stream.replace "copy_btn_day_#{@day.id}" do %>
    <%= render "workout_programs/copy_button", program: @program, day: @day %>
  <% end %>
<% end %>
