<%# Remove empty state if present %>
<%= turbo_stream.remove "program_day_#{@day.id}_empty" %>

<%# Append the new exercise card to the day's exercise list %>
<%= turbo_stream.append "program_day_exercises_#{@day.id}" do %>
  <%= render "workout_programs/program_exercise", program: @program, day: @day, pe: @exercise %>
<% end %>

<%# Show copy button if this is the first exercise added %>
<% if @day.program_exercises.count == 1 %>
  <%= turbo_stream.replace "copy_btn_day_#{@day.id}" do %>
    <%= render "workout_programs/copy_button", program: @program, day: @day %>
  <% end %>
<% end %>

<%# Immediately open the edit modal so the user can add sets to the freshly added exercise %>
<%= turbo_stream.update "program_exercise_modal_root" do %>
  <%= render "workout_programs/exercise_modal", pe: @exercise, last_performance: nil %>
<% end %>

<%# Keep the tension balance panel in sync — it's populated at page load and
    otherwise never reflects exercises added since %>
<%= turbo_stream.replace "tension_balance_panel" do %>
  <%= render "workout_programs/tension_balance_panel", program: @program %>
<% end %>
