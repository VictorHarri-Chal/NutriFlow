<%# protocol: String — le protocole choisi avant l'affichage de l'avertissement %>
<div class="fixed inset-0 z-50 flex items-center justify-center p-4"
     data-controller="modal"
     data-action="click->modal#handleBackdropClick keydown@document->modal#handleEscape">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <div class="relative w-full max-w-sm bg-surface-raised border border-surface-border/50 rounded-2xl shadow-2xl transition-all duration-200 ease-out scale-95 opacity-0 flex flex-col max-h-[85vh] overflow-hidden"
       data-modal-target="panel">

    <div class="flex items-center justify-between px-5 py-4 border-b border-surface-border/40 flex-shrink-0">
      <h3 class="text-sm font-semibold text-ink-primary flex items-center gap-2">
        <i class="fas fa-triangle-exclamation text-status-warning text-sm"></i>
        <%= t("views.fasting_sessions.disclaimer.title") %>
      </h3>
      <button type="button" class="btn-ghost w-8 h-8 !p-0 flex items-center justify-center flex-shrink-0"
              data-action="click->modal#close">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <div class="px-5 py-4 overflow-y-auto min-h-0">
      <div class="p-3.5 rounded-xl border border-status-warning/30 bg-status-warning/10">
        <p class="text-sm text-ink-primary mb-2">
          <%= t("views.fasting_sessions.disclaimer.intro") %>
        </p>
        <ul class="list-disc list-inside space-y-1 text-sm text-ink-primary">
          <li><%= t("views.fasting_sessions.disclaimer.item_diabetes") %></li>
          <li><%= t("views.fasting_sessions.disclaimer.item_eating_disorder") %></li>
          <li><%= t("views.fasting_sessions.disclaimer.item_pregnancy") %></li>
          <li><%= t("views.fasting_sessions.disclaimer.item_minor") %></li>
        </ul>
      </div>
      <p class="text-sm text-ink-muted mt-3">
        <%= t("views.fasting_sessions.disclaimer.advice") %>
      </p>
    </div>

    <div class="flex items-center justify-between gap-2 px-5 py-4 border-t border-surface-border/40 flex-shrink-0">
      <button type="button" class="btn-secondary" data-action="click->modal#close">
        <%= t("views.fasting_sessions.disclaimer.cancel") %>
      </button>
      <%= button_to fasting_sessions_path,
            params: { protocol: protocol, acknowledge_disclaimer: "1" },
            method: :post,
            class: "btn-primary" do %>
        <%= t("views.fasting_sessions.disclaimer.acknowledge") %>
      <% end %>
    </div>
  </div>
</div>
