<% period_label = t("views.statistics.period_labels.#{@period}") %>

<% if @cardio_blocks.empty? %>
  <%= render "statistics/empty_state",
        icon:  "fa-person-running",
        title: t("views.statistics.cardio.no_data_title", period: period_label),
        hint:  t("views.statistics.cardio.no_data_hint") %>

<% else %>

  <%# ── KPI cards ── %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.cardio.kpi_minutes") %>
      </p>
      <p class="text-2xl font-bold text-brand">
        <%= @cardio_total_minutes %>
        <span class="text-xs font-normal text-ink-subtle ml-0.5">min</span>
      </p>
      <p class="text-xs text-ink-subtle mt-1.5">
        <%= t("views.statistics.cardio.kpi_hours_total", h: (@cardio_total_minutes / 60.0).round(1)) %>
      </p>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.cardio.kpi_calories") %>
      </p>
      <p class="text-2xl font-bold text-macro-calories">
        <%= number_with_delimiter(@cardio_total_calories) %>
        <span class="text-xs font-normal text-ink-subtle ml-0.5">kcal</span>
      </p>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.cardio.kpi_sessions") %>
      </p>
      <p class="text-2xl font-bold text-ink-primary">
        <%= @cardio_session_count %>
      </p>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.cardio.kpi_distance") %>
      </p>
      <p class="text-2xl font-bold text-ink-primary">
        <%= @cardio_total_distance %>
        <span class="text-xs font-normal text-ink-subtle ml-0.5"><%= t("views.statistics.cardio.kpi_distance_unit") %></span>
      </p>
      <% if @avg_speed %>
        <p class="text-xs text-ink-subtle mt-1.5">
          Moy. <%= @avg_speed %> <%= t("views.statistics.cardio.avg_speed_unit") %>
        </p>
      <% end %>
    </div>

  </div>

  <%# ── Activité + machines ── %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <div class="lg:col-span-2 bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4 flex items-center gap-2">
        <i class="fas fa-chart-bar text-brand text-xs"></i>
        <%= @period == 7 ? t("views.statistics.cardio.weekly_title_daily") : t("views.statistics.cardio.weekly_title") %>
      </h2>
      <div class="relative h-48">
        <canvas data-controller="bar-chart"
                data-bar-chart-labels-value="<%= @cardio_week_labels.to_json %>"
                data-bar-chart-data-value="<%= @cardio_week_data.to_json %>"
                data-bar-chart-unit-value="<%= t("views.statistics.cardio.weekly_unit") %>"
                data-bar-chart-color-value="#60A5FA">
        </canvas>
      </div>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4 flex items-center gap-2">
        <i class="fas fa-chart-pie text-brand text-xs"></i>
        <%= t("views.statistics.cardio.machine_title") %>
      </h2>
      <% if @machine_donut_data.any? %>
        <div class="relative h-48">
          <canvas data-controller="donut-chart"
                  data-donut-chart-labels-value="<%= @machine_donut_labels.to_json %>"
                  data-donut-chart-data-value="<%= @machine_donut_data.to_json %>">
          </canvas>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center h-48 gap-2 border border-dashed border-surface-border/50 rounded-xl text-center px-3">
          <i class="fas fa-chart-pie text-2xl text-ink-subtle/50"></i>
          <p class="text-xs text-ink-subtle"><%= t("views.statistics.cardio.no_data", period: period_label) %></p>
        </div>
      <% end %>
    </div>

  </div>

  <%# ── Distribution d'intensité ── %>
  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
    <h2 class="text-sm font-semibold text-ink-primary mb-1 flex items-center gap-2">
      <i class="fas fa-fire text-brand text-xs"></i>
      <%= t("views.statistics.cardio.intensity_title") %>
    </h2>
    <p class="text-xs text-ink-subtle mb-5"><%= t("views.statistics.cardio.intensity_subtitle") %></p>

    <% if @intensity_donut_data.sum > 0 %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <%# Donut %>
        <div class="relative h-44">
          <canvas data-controller="donut-chart"
                  data-donut-chart-labels-value="<%= @intensity_donut_labels.to_json %>"
                  data-donut-chart-data-value="<%= @intensity_donut_data.to_json %>"
                  data-donut-chart-colors-value="<%= ['#34D399', '#FBBF24', '#F87171'].to_json %>">
          </canvas>
        </div>

        <%# Barres de progression — 2 colonnes %>
        <div class="lg:col-span-2 flex flex-col justify-center space-y-4">
          <%
            intensity_items = [
              { color_bar: "bg-status-success", color_dot: "bg-status-success", label: t("views.statistics.cardio.intensity.light"),    desc: "MET < 6 — faible dépense",   val: @intensity_donut_data[0] },
              { color_bar: "bg-brand",          color_dot: "bg-brand",          label: t("views.statistics.cardio.intensity.moderate"), desc: "MET 6–9 — effort modéré",    val: @intensity_donut_data[1] },
              { color_bar: "bg-status-danger",  color_dot: "bg-status-danger",  label: t("views.statistics.cardio.intensity.intense"),  desc: "MET > 9 — effort intense",   val: @intensity_donut_data[2] },
            ]
            total_blocks = @intensity_donut_data.sum.to_f
          %>
          <% intensity_items.each do |item| %>
            <% next if item[:val] == 0 %>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                  <div class="w-2 h-2 rounded-full <%= item[:color_dot] %>"></div>
                  <span class="text-xs font-semibold text-ink-muted"><%= item[:label] %></span>
                  <span class="text-xs text-ink-subtle">— <%= item[:desc] %></span>
                </div>
                <span class="text-xs font-medium text-ink-muted"><%= item[:val] %> bloc<%= item[:val] != 1 ? "s" : "" %></span>
              </div>
              <div class="progress-track h-1.5">
                <div class="h-full rounded-full <%= item[:color_bar] %>"
                     style="width: <%= total_blocks > 0 ? (item[:val] / total_blocks * 100).round : 0 %>%"></div>
              </div>
            </div>
          <% end %>
        </div>

      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-8 gap-2 border border-dashed border-surface-border/50 rounded-xl text-center px-4">
        <i class="fas fa-fire text-2xl text-ink-subtle/50"></i>
        <p class="text-xs text-ink-subtle"><%= t("views.statistics.cardio.no_data", period: period_label) %></p>
      </div>
    <% end %>
  </div>

<% end %>
