<%# Locals: icon (fa class, e.g. "fa-utensils"), title, hint %>
<div class="flex flex-col items-center justify-center py-16 border-2 border-dashed border-surface-border/40 rounded-2xl text-center px-6">
  <div class="w-12 h-12 rounded-full bg-surface-raised flex items-center justify-center mb-4">
    <i class="fas <%= icon %> text-brand text-lg"></i>
  </div>
  <p class="text-base font-semibold text-ink-primary mb-1"><%= title %></p>
  <p class="text-sm text-ink-muted max-w-sm mb-5 leading-relaxed"><%= hint %></p>
  <%= link_to t("views.statistics.go_to_calendar"), root_path, class: "btn-secondary text-xs px-4 py-2" %>
</div>
