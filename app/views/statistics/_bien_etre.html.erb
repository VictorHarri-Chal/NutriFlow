<% period_label = t("views.statistics.period_labels.#{@period}") %>
<% has_wellbeing_data = @avg_energy || @avg_mood || @avg_sleep %>

<% if !has_wellbeing_data && !@avg_steps %>
  <%= render "statistics/empty_state",
        icon:  "fa-heart-pulse",
        title: t("views.statistics.bien_etre.no_data_title", period: period_label),
        hint:  t("views.statistics.bien_etre.no_data_hint") %>

<% else %>

  <%# ── KPI énergie / humeur / sommeil ── %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.bien_etre.kpi_energy") %>
      </p>
      <% if @avg_energy %>
        <p class="text-3xl font-bold text-brand">
          <%= @avg_energy %>
          <span class="text-sm font-normal text-ink-subtle ml-1"><%= t("views.statistics.bien_etre.out_of_five") %></span>
        </p>
        <div class="mt-3 progress-track h-1.5">
          <div class="h-full rounded-full bg-brand" style="width: <%= (@avg_energy / 5.0 * 100).round %>%"></div>
        </div>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle mb-2">—</p>
        <p class="text-xs text-ink-subtle leading-relaxed"><%= t("views.statistics.bien_etre.evolution_empty", period: period_label) %></p>
      <% end %>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.bien_etre.kpi_mood") %>
      </p>
      <% if @avg_mood %>
        <p class="text-3xl font-bold text-macro-proteins">
          <%= @avg_mood %>
          <span class="text-sm font-normal text-ink-subtle ml-1"><%= t("views.statistics.bien_etre.out_of_five") %></span>
        </p>
        <div class="mt-3 progress-track h-1.5">
          <div class="h-full rounded-full bg-macro-proteins" style="width: <%= (@avg_mood / 5.0 * 100).round %>%"></div>
        </div>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle mb-2">—</p>
        <p class="text-xs text-ink-subtle leading-relaxed"><%= t("views.statistics.bien_etre.evolution_empty", period: period_label) %></p>
      <% end %>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.bien_etre.kpi_sleep") %>
      </p>
      <% if @avg_sleep %>
        <p class="text-3xl font-bold text-macro-carbs">
          <%= @avg_sleep %>
          <span class="text-sm font-normal text-ink-subtle ml-1"><%= t("views.statistics.bien_etre.out_of_five") %></span>
        </p>
        <div class="mt-3 progress-track h-1.5">
          <div class="h-full rounded-full bg-macro-carbs" style="width: <%= (@avg_sleep / 5.0 * 100).round %>%"></div>
        </div>
      <% else %>
        <p class="text-2xl font-bold text-ink-subtle mb-2">—</p>
        <p class="text-xs text-ink-subtle leading-relaxed"><%= t("views.statistics.bien_etre.evolution_empty", period: period_label) %></p>
      <% end %>
    </div>

  </div>

  <%# ── Pas ── %>
  <div class="grid grid-cols-1 gap-4">

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-3">
        <%= t("views.statistics.bien_etre.kpi_steps") %>
      </p>
      <% if @avg_steps %>

        <%# KPI principal : moyenne + % %>
        <div class="flex items-end gap-2 mb-2">
          <p class="text-2xl font-bold text-status-success">
            <%= number_with_delimiter(@avg_steps) %>
            <span class="text-xs font-normal text-ink-subtle ml-0.5"><%= t("views.statistics.bien_etre.steps_unit") %></span>
          </p>
          <% if @steps_pct %>
            <p class="text-sm font-semibold text-ink-muted mb-0.5"><%= t("views.statistics.bien_etre.steps_pct", pct: @steps_pct) %></p>
          <% end %>
        </div>
        <% if @steps_goal.to_i > 0 %>
          <div class="progress-track h-1.5 mb-1.5">
            <div class="h-full rounded-full bg-status-success" style="width: <%= @steps_pct || 0 %>%"></div>
          </div>
          <p class="text-xs text-ink-subtle mb-4">
            <%= t("views.statistics.bien_etre.steps_goal", goal: number_with_delimiter(@steps_goal)) %>
          </p>
        <% end %>

        <%# Streak + taux de réussite %>
        <% if @steps_streak || @steps_success_total.to_i > 0 %>
          <div class="grid grid-cols-2 gap-3 mb-4">
            <% if @steps_streak %>
              <div class="bg-surface-hover rounded-xl px-3 py-2.5">
                <p class="text-[10px] font-medium text-ink-subtle uppercase tracking-wider mb-1.5">
                  <%= t("views.statistics.bien_etre.steps_streak_label") %>
                </p>
                <% if @steps_streak > 0 %>
                  <div class="flex items-baseline gap-1.5 leading-none">
                    <i class="fas fa-fire text-sm text-brand"></i>
                    <span class="text-2xl font-bold text-brand"><%= @steps_streak %></span>
                    <span class="text-[10px] text-ink-subtle">j</span>
                  </div>
                  <p class="text-[10px] text-ink-subtle mt-1">
                    <%= t("views.statistics.bien_etre.steps_streak", count: @steps_streak) %>
                  </p>
                <% else %>
                  <p class="text-lg font-bold text-ink-subtle/40 leading-none mb-1">—</p>
                  <p class="text-[10px] text-ink-subtle">
                    <%= t("views.statistics.bien_etre.steps_streak_zero") %>
                  </p>
                <% end %>
              </div>
            <% end %>
            <% if @steps_success_total.to_i > 0 %>
              <% steps_success_pct   = (@steps_success_reached.to_f / @steps_success_total * 100).round %>
              <% steps_success_color = steps_success_pct >= 75 ? "text-status-success" : steps_success_pct >= 50 ? "text-status-warning" : "text-status-danger" %>
              <div class="bg-surface-hover rounded-xl px-3 py-2.5">
                <p class="text-[10px] font-medium text-ink-subtle uppercase tracking-wider mb-1.5">
                  <%= t("views.statistics.bien_etre.steps_success_label") %>
                </p>
                <div class="flex items-baseline gap-1.5 leading-none">
                  <span class="text-2xl font-bold <%= steps_success_color %>"><%= steps_success_pct %>%</span>
                </div>
                <p class="text-[10px] text-ink-subtle mt-1">
                  <%= t("views.statistics.bien_etre.steps_success_rate",
                        reached: @steps_success_reached,
                        total:   @steps_success_total) %>
                </p>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Corrélation sport %>
        <% if @steps_sport_diff %>
          <div class="flex items-start gap-2 px-3 py-2 rounded-xl bg-surface-hover text-xs text-ink-muted">
            <i class="fas fa-dumbbell text-brand text-[10px] mt-0.5 shrink-0"></i>
            <span>
              <% diff = @steps_sport_diff.abs %>
              <% if @steps_sport_diff > 500 %>
                <%= t("views.statistics.bien_etre.steps_sport_more", steps: number_with_delimiter(diff)) %>
              <% elsif @steps_sport_diff < -500 %>
                <%= t("views.statistics.bien_etre.steps_sport_less", steps: number_with_delimiter(diff)) %>
              <% else %>
                <%= t("views.statistics.bien_etre.steps_sport_same") %>
              <% end %>
            </span>
          </div>
        <% end %>

        <%# Heatmap hebdomadaire %>
        <% if @steps_heatmap&.any? %>
          <div class="mt-4">
            <p class="text-[10px] font-medium text-ink-subtle uppercase tracking-wider mb-2">
              <%= t("views.statistics.bien_etre.steps_heatmap_title") %>
            </p>
            <%
              day_abbrs     = I18n.t("date.abbr_day_names")
              ordered_abbrs = day_abbrs.rotate(1)
            %>
            <div class="grid grid-cols-7 gap-1.5">
              <% @steps_heatmap.each_with_index do |entry, i| %>
                <%
                  pct = entry[:pct]
                  bg = if pct >= 100
                    "bg-status-success/70"
                  elsif pct >= 66
                    "bg-status-info/60"
                  elsif pct >= 33
                    "bg-status-warning/50"
                  elsif pct > 0
                    "bg-status-danger/40"
                  else
                    "bg-surface-hover"
                  end
                %>
                <div class="flex flex-col items-center gap-1">
                  <div class="w-full h-5 rounded <%= bg %>"
                       title="<%= l(entry[:date], format: :short) %> — <%= pct %>%"></div>
                  <span class="text-[9px] text-ink-subtle"><%= ordered_abbrs[i].to_s[0] %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      <% else %>
        <p class="text-2xl font-bold text-ink-subtle mb-2">—</p>
        <p class="text-xs text-ink-subtle leading-relaxed"><%= t("views.statistics.bien_etre.steps_empty") %></p>
      <% end %>
    </div>

  </div>

  <%# ── Évolution bien-être — multi-line chart ── %>
  <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
    <h2 class="text-sm font-semibold text-ink-primary mb-1 flex items-center gap-2">
      <i class="fas fa-chart-line text-brand text-xs"></i>
      <%= t("views.statistics.bien_etre.evolution_title") %>
    </h2>
    <% if @wb_labels&.any? %>
      <p class="text-xs text-ink-subtle mb-4">
        <%= t("views.statistics.bien_etre.days_logged", count: @wb_days.size) %>
      </p>
      <div class="relative h-56">
        <canvas data-controller="multi-line-chart"
                data-multi-line-chart-labels-value="<%= @wb_labels.to_json %>"
                data-multi-line-chart-data1-value="<%= @wb_energy_data.to_json %>"
                data-multi-line-chart-data2-value="<%= @wb_mood_data.to_json %>"
                data-multi-line-chart-data3-value="<%= @wb_sleep_data.to_json %>"
                data-multi-line-chart-label1-value="<%= t("views.statistics.bien_etre.evolution_energy") %>"
                data-multi-line-chart-label2-value="<%= t("views.statistics.bien_etre.evolution_mood") %>"
                data-multi-line-chart-label3-value="<%= t("views.statistics.bien_etre.evolution_sleep") %>"
                data-multi-line-chart-color1-value="#EAB308"
                data-multi-line-chart-color2-value="#34D399"
                data-multi-line-chart-color3-value="#60A5FA">
        </canvas>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center h-44 gap-3 border border-dashed border-surface-border/50 rounded-xl mt-2 text-center px-6">
        <i class="fas fa-chart-line text-3xl text-ink-subtle/40"></i>
        <p class="text-sm font-medium text-ink-muted"><%= t("views.statistics.bien_etre.evolution_title") %></p>
        <p class="text-xs text-ink-subtle max-w-xs leading-relaxed">
          <%= t("views.statistics.bien_etre.evolution_empty", period: period_label) %>
        </p>
      </div>
    <% end %>
  </div>

<% end %>
