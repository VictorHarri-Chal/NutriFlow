<% period_label = t("views.statistics.period_labels.#{@period}") %>

<% if @logged_days.empty? %>
  <%= render "statistics/empty_state",
        icon:  "fa-utensils",
        title: t("views.statistics.nutrition.no_data_title", period: period_label),
        hint:  t("views.statistics.nutrition.no_data_hint") %>

<% else %>

  <%# ── KPI cards (4 colonnes) ── %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.nutrition.kpi_avg_calories") %>
      </p>
      <p class="text-2xl font-bold text-macro-calories">
        <%= @avg_calories %>
        <span class="text-xs font-normal text-ink-subtle ml-0.5">kcal</span>
      </p>
      <% if @calorie_goal > 0 %>
        <%
          diff  = @avg_calories - @calorie_goal
          color = diff.abs <= (@calorie_goal * 0.05) ? "text-status-success" : diff > 0 ? "text-status-warning" : "text-ink-subtle"
        %>
        <p class="text-xs mt-1.5 <%= color %>">
          <%= diff >= 0 ? "+#{diff}" : diff %> vs objectif (<%= @calorie_goal %>)
        </p>
      <% end %>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.nutrition.kpi_days_logged") %>
      </p>
      <p class="text-2xl font-bold text-ink-primary">
        <%= @days_logged_count %>
        <span class="text-xs font-normal text-ink-subtle ml-0.5">/ <%= @total_period_days %> j</span>
      </p>
      <div class="mt-3 progress-track h-1.5">
        <div class="h-full rounded-full bg-brand transition-all"
             style="width: <%= (@days_logged_count.to_f / @total_period_days * 100).round %>%"></div>
      </div>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.nutrition.kpi_avg_proteins") %>
      </p>
      <p class="text-2xl font-bold text-macro-proteins">
        <%= @avg_proteins %>
        <span class="text-xs font-normal text-ink-subtle ml-0.5">g</span>
      </p>
      <div class="flex items-center gap-3 mt-1.5">
        <span class="text-xs text-ink-subtle">G <span class="text-macro-carbs font-medium"><%= @avg_carbs %>g</span></span>
        <span class="text-xs text-ink-subtle">L <span class="text-macro-fats font-medium"><%= @avg_fats %>g</span></span>
      </div>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl px-5 py-5">
      <p class="text-xs font-medium text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.statistics.nutrition.kpi_streak") %>
      </p>
      <p class="text-2xl font-bold text-brand">
        <%= @current_streak %>
        <span class="text-xs font-normal text-ink-subtle ml-0.5"><%= t("views.statistics.nutrition.streak_days", count: @current_streak) %></span>
      </p>
      <p class="text-xs text-ink-subtle mt-1.5"><%= t("views.statistics.nutrition.streak_best", n: @best_streak) %></p>
    </div>

  </div>

  <%# ── Calories + macros donut ── %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <div class="lg:col-span-2 bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4 flex items-center gap-2">
        <i class="fas fa-chart-line text-brand text-xs"></i>
        <%= t("views.statistics.nutrition.calories_title") %>
      </h2>
      <div class="relative h-48">
        <canvas data-controller="line-chart"
                data-line-chart-labels-value="<%= @cal_labels.to_json %>"
                data-line-chart-data-value="<%= @cal_data.to_json %>"
                data-line-chart-unit-value="kcal"
                data-line-chart-color-value="#60A5FA"
                data-line-chart-goal-value="<%= @calorie_goal %>">
        </canvas>
      </div>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4 flex items-center gap-2">
        <i class="fas fa-chart-pie text-brand text-xs"></i>
        <%= t("views.statistics.nutrition.macros_title") %>
      </h2>
      <div class="relative h-48">
        <canvas data-controller="donut-chart"
                data-donut-chart-labels-value="<%= @macros_donut_labels.to_json %>"
                data-donut-chart-data-value="<%= @macros_donut_data.to_json %>"
                data-donut-chart-colors-value="<%= ['#34D399', '#FBBF24', '#F87171'].to_json %>">
        </canvas>
      </div>
    </div>

  </div>

  <%# ── Protéines + répartition repas ── %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <div class="lg:col-span-2 bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4 flex items-center gap-2">
        <i class="fas fa-chart-area text-brand text-xs"></i>
        <%= t("views.statistics.nutrition.protein_title") %>
      </h2>
      <div class="relative h-48">
        <canvas data-controller="line-chart"
                data-line-chart-labels-value="<%= @protein_labels.to_json %>"
                data-line-chart-data-value="<%= @protein_data.to_json %>"
                data-line-chart-unit-value="<%= t("views.statistics.nutrition.protein_unit") %>"
                data-line-chart-color-value="#34D399">
        </canvas>
      </div>
    </div>

    <div class="bg-surface-raised border border-surface-border/40 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-ink-primary mb-4 flex items-center gap-2">
        <i class="fas fa-bowl-food text-brand text-xs"></i>
        <%= t("views.statistics.nutrition.meal_title") %>
      </h2>
      <% if @meal_breakdown_data&.any? %>
        <div class="relative h-48">
          <canvas data-controller="donut-chart"
                  data-donut-chart-labels-value="<%= @meal_breakdown_labels.to_json %>"
                  data-donut-chart-data-value="<%= @meal_breakdown_data.to_json %>">
          </canvas>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center h-48 gap-3 border border-dashed border-surface-border/50 rounded-xl px-4 text-center">
          <i class="fas fa-layer-group text-2xl text-ink-subtle/50"></i>
          <p class="text-xs text-ink-subtle leading-relaxed">
            <%= t("views.statistics.nutrition.meal_breakdown_empty") %>
          </p>
        </div>
      <% end %>
    </div>

  </div>

<% end %>
