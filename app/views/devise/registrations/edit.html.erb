<div class="max-w-lg mx-auto mt-16 card p-8">
  <h1 class="text-2xl font-bold text-ink-primary mb-8"><%= t("views.settings.security.change_password") %></h1>

  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>

    <div>
      <label class="label-dark"><%= t("views.settings.security.email_address") %></label>
      <%= f.input :email,
            label: false,
            required: true,
            autofocus: true,
            input_html: { class: "input-dark" } %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p class="text-sm text-ink-muted">En attente de confirmation pour : <%= resource.unconfirmed_email %></p>
    <% end %>

    <div>
      <label class="label-dark"><%= t("views.settings.security.new_password") %></label>
      <%= f.input :password,
            label: false,
            required: false,
            input_html: { autocomplete: "new-password", class: "input-dark" } %>
    </div>

    <div>
      <label class="label-dark"><%= t("views.settings.security.confirm_password") %></label>
      <%= f.input :password_confirmation,
            label: false,
            required: false,
            input_html: { autocomplete: "new-password", class: "input-dark" } %>
    </div>

    <div>
      <label class="label-dark"><%= t("views.settings.security.current_password") %></label>
      <%= f.input :current_password,
            label: false,
            required: true,
            input_html: { autocomplete: "current-password", class: "input-dark" } %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.button :submit, t("shared.update"), class: "btn-primary" %>
      <%= link_to t("shared.cancel"), :back, class: "btn-ghost" %>
    </div>
  <% end %>

  <div class="mt-8 pt-6 border-t border-surface-border/40">
    <%= delete_button_with_confirm(registration_path(resource_name),
                                  confirm: t("views.settings.security.delete_account_warning"),
                                  text: t("views.settings.security.delete_account_button"),
                                  class: "text-sm font-medium text-status-danger hover:text-red-400 transition-colors") %>
  </div>
</div>
