<div class="w-full">
  <!-- Card -->
  <div class="bg-surface-raised rounded-2xl border border-surface-border/50 shadow-2xl overflow-hidden">
    <!-- Amber top accent -->
    <div class="h-1 bg-gradient-to-r from-brand via-brand-hover to-brand"></div>

    <div class="px-8 py-10">
      <!-- Logo + branding -->
      <div class="flex flex-col items-center mb-8">
        <%= image_tag "logo.png", class: "h-14 w-auto mb-4", alt: "NutriFlow" %>
        <h1 class="text-2xl font-bold text-ink-primary">Créer un compte</h1>
        <p class="text-sm text-ink-subtle mt-1">Commencez à suivre votre nutrition</p>
      </div>

      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>

        <div>
          <label class="label-dark">Adresse e-mail</label>
          <%= f.input :email,
                label: false,
                required: false,
                autofocus: true,
                input_html: { autocomplete: "email", class: "input-dark", placeholder: "ton@email.com" } %>
        </div>

        <div>
          <label class="label-dark">Mot de passe</label>
          <%= f.input :password,
                label: false,
                required: false,
                input_html: { autocomplete: "new-password", class: "input-dark", placeholder: "8 caractères minimum" } %>
          <% if @minimum_password_length %>
            <p class="text-xs text-ink-subtle mt-1"><%= @minimum_password_length %> caractères minimum</p>
          <% end %>
        </div>

        <div>
          <label class="label-dark">Confirmer le mot de passe</label>
          <%= f.input :password_confirmation,
                label: false,
                required: false,
                input_html: { autocomplete: "new-password", class: "input-dark", placeholder: "••••••••" } %>
        </div>

        <div class="pt-1">
          <%= f.button :submit, "Créer mon compte",
                class: "btn-primary w-full justify-center py-2.5 text-base" %>
        </div>
      <% end %>
    </div>

    <!-- Footer -->
    <div class="px-8 pb-8 text-center">
      <p class="text-sm text-ink-subtle">
        Déjà un compte ?
        <%= link_to "Se connecter", new_session_path(resource_name),
              class: "font-semibold text-brand hover:text-brand-hover transition-colors" %>
      </p>
    </div>
  </div>
</div>
