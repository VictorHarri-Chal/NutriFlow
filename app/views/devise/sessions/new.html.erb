<% content_for :title, t("views.devise.sessions.title") %>
<div class="w-full">
  <div class="bg-surface-raised rounded-2xl border border-surface-border/50 shadow-2xl overflow-hidden">
    <div class="h-1 bg-gradient-to-r from-brand via-brand-hover to-brand"></div>

    <div class="px-8 py-10">
      <div class="flex flex-col items-center mb-8">
        <%= image_tag "logo.png", class: "h-28 w-auto mb-4", alt: "NutriFlow" %>
        <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.devise.sessions.title") %></h1>
        <p class="text-sm text-ink-subtle mt-1"><%= t("views.devise.sessions.subtitle") %></p>
      </div>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <%= f.error_notification %>

        <div>
          <label class="label-dark"><%= t("views.devise.shared.email") %></label>
          <%= f.input :email,
                label: false,
                required: false,
                autofocus: true,
                input_html: { autocomplete: "email", class: "input-dark", placeholder: t("views.devise.shared.email_placeholder") } %>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1">
            <label class="label-dark"><%= t("views.devise.shared.password") %></label>
            <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
              <%= link_to t("views.devise.sessions.forgot_password"), new_password_path(resource_name),
                    class: "text-xs text-ink-subtle hover:text-brand transition-colors" %>
            <% end %>
          </div>
          <%= f.input :password,
                label: false,
                required: false,
                input_html: { autocomplete: "current-password", class: "input-dark", placeholder: "••••••••" } %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.input :remember_me, as: :boolean, label: t("views.devise.sessions.remember_me"),
                  label_html: { class: "text-sm text-ink-muted cursor-pointer" },
                  input_html: { class: "rounded border-surface-border bg-surface-hover text-brand focus:ring-brand/50" },
                  wrapper: false %>
          </div>
        <% end %>

        <div class="pt-1">
          <%= f.button :submit, t("views.devise.sessions.submit"),
                class: "btn-primary w-full justify-center py-2.5 text-base" %>
        </div>
      <% end %>
    </div>

    <div class="px-8 pb-8 text-center">
      <p class="text-sm text-ink-subtle">
        <%= t("views.devise.sessions.no_account") %>
        <%= link_to t("views.devise.sessions.sign_up_link"), new_registration_path(resource_name),
              class: "font-semibold text-brand hover:text-brand-hover transition-colors" %>
      </p>
    </div>
  </div>
</div>
