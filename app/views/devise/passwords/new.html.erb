<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h2 class="text-center text-2xl font-bold tracking-tight text-ink-primary mb-8"><%= t("views.settings.security.forgot_password") %></h2>
  </div>
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "devise-form space-y-5" }) do |f| %>
      <%= f.error_notification %>
      <div>
        <label class="label-dark"><%= t("views.settings.security.email_address") %></label>
        <%= f.input :email, required: true, autofocus: true, label: false,
                    input_html: { autocomplete: "email", class: "input-dark" } %>
      </div>
      <div>
        <%= f.button :submit, t("views.settings.security.send_reset_link"), class: "btn-primary w-full justify-center" %>
      </div>
    <% end %>
    <%= render "devise/shared/links" %>
  </div>
</div>
