<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h2 class="text-center text-2xl font-bold tracking-tight text-ink-primary mb-8">Change your password</h2>
  </div>
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "devise-form space-y-5" }) do |f| %>
      <%= f.error_notification %>
      <%= f.input :reset_password_token, as: :hidden %>
      <%= f.full_error :reset_password_token %>
      <div>
        <label class="label-dark">New password</label>
        <%= f.input :password, label: false, required: true, autofocus: true,
                    hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password", class: "input-dark" } %>
      </div>
      <div>
        <label class="label-dark">Confirm your new password</label>
        <%= f.input :password_confirmation, label: false, required: true,
                    input_html: { autocomplete: "new-password", class: "input-dark" } %>
      </div>
      <div>
        <%= f.button :submit, "Change my password", class: "btn-primary w-full justify-center" %>
      </div>
    <% end %>
    <%= render "devise/shared/links" %>
  </div>
</div>
