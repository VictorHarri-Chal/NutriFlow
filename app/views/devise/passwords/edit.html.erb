<% content_for :title, t("views.devise.passwords.edit.title") %>
<div class="w-full">
  <div class="bg-surface-raised rounded-2xl border border-surface-border/50 shadow-2xl overflow-hidden">
    <div class="h-1 bg-gradient-to-r from-brand via-brand-hover to-brand"></div>

    <div class="px-8 py-10">
      <div class="flex flex-col items-center mb-8">
        <%= image_tag "logo.png", class: "h-28 w-auto mb-4", alt: "NutriFlow" %>
        <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.devise.passwords.edit.title") %></h1>
        <p class="text-sm text-ink-subtle mt-1"><%= t("views.devise.passwords.edit.subtitle") %></p>
      </div>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= f.input :reset_password_token, as: :hidden %>
        <%= render "shared/auth_flash_messages" %>
        <%= render "shared/form_errors", record: resource, margin_class: "" %>

        <div>
          <label class="label-dark"><%= t("views.devise.passwords.edit.new_password") %></label>
          <%= f.input :password,
                label: false,
                required: true,
                autofocus: true,
                hint: (@minimum_password_length ? t("views.devise.registrations.password_hint", count: @minimum_password_length) : nil),
                input_html: { autocomplete: "new-password", class: "input-dark", placeholder: "••••••••" } %>
        </div>

        <div>
          <label class="label-dark"><%= t("views.devise.passwords.edit.confirm_password") %></label>
          <%= f.input :password_confirmation,
                label: false,
                required: true,
                input_html: { autocomplete: "new-password", class: "input-dark", placeholder: "••••••••" } %>
        </div>

        <div class="pt-1">
          <%= f.button :submit, t("views.devise.passwords.edit.submit"),
                class: "btn-primary w-full justify-center py-2.5 text-base" %>
        </div>
      <% end %>
    </div>

    <div class="px-8 pb-8 text-center">
      <p class="text-sm text-ink-subtle">
        <%= link_to t("views.devise.shared.back_to_login"), new_session_path(resource_name),
              class: "font-semibold text-brand hover:text-brand-hover transition-colors" %>
      </p>
    </div>
  </div>
</div>
