<p style="margin:0 0 16px 0;"><%= t("views.devise.mailer.reset_password.greeting", email: @resource.email) %></p>

<p style="margin:0 0 24px 0;"><%= t("views.devise.mailer.reset_password.intro") %></p>

<p style="margin:0 0 24px 0; text-align:center;">
  <%= link_to t("views.devise.mailer.reset_password.action"), edit_password_url(@resource, reset_password_token: @token),
        style: "display:inline-block; background-color:#EAB308; color:#18181B; text-decoration:none; padding:12px 24px; border-radius:8px; font-weight:600; font-size:14px;" %>
</p>

<p style="margin:0 0 8px 0; color:#71717A; font-size:13px;"><%= t("views.devise.mailer.reset_password.ignore") %></p>
<p style="margin:0; color:#71717A; font-size:13px;"><%= t("views.devise.mailer.reset_password.no_change") %></p>
