<% content_for :title, t("views.devise.confirmations.new.title") %>
<div class="w-full">
  <div class="bg-surface-raised rounded-2xl border border-surface-border/50 shadow-2xl overflow-hidden">
    <div class="h-1 bg-gradient-to-r from-brand via-brand-hover to-brand"></div>

    <div class="px-8 py-10">
      <div class="flex flex-col items-center mb-8">
        <%= image_tag "logo.png", class: "h-28 w-auto mb-4", alt: "NutriFlow" %>
        <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.devise.confirmations.new.title") %></h1>
        <p class="text-sm text-ink-subtle mt-1 text-center"><%= t("views.devise.confirmations.new.subtitle") %></p>
      </div>

      <%= simple_form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
        <%= render "shared/auth_flash_messages" %>
        <%= render "shared/form_errors", record: resource, margin_class: "" %>
        <div>
          <label class="label-dark"><%= t("views.devise.shared.email") %></label>
          <%= f.input :email,
                label: false,
                required: true,
                autofocus: true,
                value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                input_html: { autocomplete: "email", class: "input-dark", placeholder: t("views.devise.shared.email_placeholder") } %>
        </div>

        <div class="pt-1">
          <%= f.button :submit, t("views.devise.confirmations.new.submit"),
                class: "btn-primary w-full justify-center py-2.5 text-base" %>
        </div>
      <% end %>
    </div>

    <div class="px-8 pb-8 text-center">
      <p class="text-sm text-ink-subtle">
        <%= link_to t("views.devise.shared.back_to_login"), new_session_path(resource_name),
              class: "font-semibold text-brand hover:text-brand-hover transition-colors" %>
      </p>
    </div>
  </div>
</div>
