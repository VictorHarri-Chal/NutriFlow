<%# Ferme la modale %>
<%= turbo_stream.update "shopping_modal_root" %>

<%# Toast de confirmation %>
<%= turbo_stream.prepend "flash_messages" do %>
  <div class="pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-xl bg-status-success/15 border border-status-success/40 shadow-lg text-sm text-status-success max-w-sm"
       data-controller="auto-dismiss">
    <i class="fas fa-check-circle text-base shrink-0"></i>
    <span><%= t("views.shopping_lists.items_added", count: @added_count) %></span>
  </div>
<% end %>

<%= turbo_stream.replace "shopping_list_items" do %>
  <%= render "shopping_lists/items_container",
        shopping_list:     @shopping_list,
        items_by_category: @items_by_category %>
<% end %>

<%= turbo_stream.replace "shopping_list_counter" do %>
  <%= render "shopping_lists/counter", unchecked_count: @unchecked_count %>
<% end %>

<%= turbo_stream.replace "shopping_list_badge" do %>
  <%= render "shared/shopping_badge", count: @unchecked_count %>
<% end %>

<%= turbo_stream.replace "shopping_export_bar" do %>
  <%= render "shopping_lists/export_bar",
        shopping_list:   @shopping_list,
        unchecked_count: @unchecked_count,
        has_checked:     @has_checked,
        has_items:       @has_items %>
<% end %>
