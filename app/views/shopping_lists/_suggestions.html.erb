<%# locals: (shopping_list:, suggested_foods:) %>
<div id="shopping_list_suggestions_modal_list">
  <% if suggested_foods.empty? %>
    <div class="py-10 flex flex-col items-center justify-center text-center px-4 border-2 border-dashed border-surface-border/40 rounded-xl">
      <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
        <i class="fas fa-repeat text-brand text-lg"></i>
      </div>
      <h3 class="text-sm font-semibold text-ink-primary mb-1"><%= t("views.shopping_lists.suggestions_empty_state.title") %></h3>
      <p class="text-xs text-ink-muted max-w-xs"><%= t("views.shopping_lists.suggestions_empty_state.hint") %></p>
    </div>
  <% else %>
    <div class="flex flex-wrap gap-2">
      <% suggested_foods.each do |food| %>
        <%= button_to shopping_list_shopping_list_items_path(shopping_list),
              method: :post,
              params: { shopping_list_item: { food_id: food.id } },
              form: { data: { turbo_stream: true } },
              class: "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border border-surface-border text-ink-muted hover:border-brand/40 hover:text-brand transition-colors" do %>
          <i class="fas <%= shopping_category_icon(food.category) %> text-[10px]"></i>
          <%= food.name %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
