<%# locals: (item:, shopping_list:) %>
<div id="shopping_list_item_<%= item.id %>"
     class="group flex items-center gap-3 px-4 py-3 hover:bg-surface-hover/20 transition-colors">

  <%# Checkbox %>
  <%= button_to shopping_list_shopping_list_item_path(shopping_list, item),
        method: :patch,
        params: { shopping_list_item: { checked: !item.checked } },
        class: "flex-shrink-0 w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand #{item.checked ? 'bg-brand border-brand' : 'border-surface-border hover:border-brand/60'}",
        form: { data: { turbo_stream: true } } do %>
    <% if item.checked %>
      <i class="fas fa-check text-[9px] text-zinc-900"></i>
    <% end %>
  <% end %>

  <%# Nom + quantité %>
  <div class="flex-1 min-w-0">
    <span class="text-sm font-medium transition-colors <%= item.checked ? 'text-ink-subtle line-through' : 'text-ink-primary' %>">
      <%= item.name %>
    </span>
    <% if item.quantity.present? %>
      <span class="text-xs text-ink-subtle ml-1.5"><%= item.quantity %></span>
    <% end %>
  </div>

  <%# Supprimer %>
  <%= button_to shopping_list_shopping_list_item_path(shopping_list, item),
        method: :delete,
        aria: { label: t("views.shopping_lists.delete_item") },
        class: "flex-shrink-0 w-7 h-7 rounded-lg text-ink-subtle hover:text-status-danger hover:bg-status-danger/10 flex items-center justify-center transition-colors opacity-0 group-hover:opacity-100",
        form: { data: { turbo_stream: true } } do %>
    <i class="fas fa-times text-xs"></i>
  <% end %>

</div>
