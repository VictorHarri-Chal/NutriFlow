<%# locals: (archived_lists:, pagy:) %>
<div class="fixed inset-0 z-50 flex items-center justify-center p-4"
     data-controller="modal"
     data-action="click->modal#handleBackdropClick keydown@document->modal#handleEscape">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <div class="relative w-full max-w-md bg-surface-raised border border-surface-border/50 rounded-2xl shadow-2xl transition-all duration-200 ease-out scale-95 opacity-0 flex flex-col max-h-[80vh] overflow-hidden"
       data-modal-target="panel">

    <div class="flex items-center justify-between px-5 py-4 border-b border-surface-border/40 flex-shrink-0">
      <h3 class="text-sm font-semibold text-ink-primary"><%= t("views.shopping_lists.history_heading") %></h3>
      <button type="button"
              class="btn-ghost w-8 h-8 !p-0 flex items-center justify-center flex-shrink-0"
              data-action="click->modal#close">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <div class="px-5 py-4 overflow-y-auto min-h-0 flex-1">
      <% if archived_lists.any? %>
        <div class="space-y-3">
          <% archived_lists.each do |list| %>
            <%= render "shopping_lists/archived_list_card", list: list %>
          <% end %>
        </div>

        <% if pagy&.pages&.> 1 %>
          <div class="mt-4">
            <%= render PaginationComponent.new(pagy: pagy, turbo_stream_links: true) %>
          </div>
        <% end %>
      <% else %>
        <div class="py-10 flex flex-col items-center justify-center text-center px-4 border-2 border-dashed border-surface-border/40 rounded-xl">
          <div class="w-12 h-12 mx-auto mb-3 bg-surface-hover rounded-full flex items-center justify-center">
            <i class="fas fa-clock-rotate-left text-brand text-lg"></i>
          </div>
          <h3 class="text-sm font-semibold text-ink-primary mb-1"><%= t("views.shopping_lists.history_empty_state.title") %></h3>
          <p class="text-xs text-ink-muted max-w-xs"><%= t("views.shopping_lists.history_empty_state.hint") %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
