<% content_for :title, t("views.onboarding.edit.title") %>
<div class="w-full">
  <div class="bg-surface-raised rounded-2xl border border-surface-border/50 shadow-2xl overflow-hidden">
    <div class="h-1 bg-gradient-to-r from-brand via-brand-hover to-brand"></div>

    <div class="px-8 py-10">
      <div class="flex flex-col items-center mb-8 text-center">
        <%= image_tag "logo.png", class: "h-20 w-auto mb-4", alt: "NutriFlow" %>
        <h1 class="text-2xl font-bold text-ink-primary"><%= t("views.onboarding.edit.title") %></h1>
        <p class="text-sm text-ink-subtle mt-1 max-w-md"><%= t("views.onboarding.edit.subtitle") %></p>
      </div>

      <%= simple_form_for @profile, url: onboarding_path, method: :patch do |f| %>
        <%= render "shared/auth_flash_messages" %>
        <%= render "profiles/form_errors" %>
        <div class="space-y-8">
          <%= render "profiles/essential_fields", f: f %>
        </div>

        <div class="mt-10 pt-6 border-t border-surface-border/40">
          <%= f.button :submit, t("views.onboarding.edit.submit"), class: "btn-primary w-full justify-center py-2.5 text-base" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
