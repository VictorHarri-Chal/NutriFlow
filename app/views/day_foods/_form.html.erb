<%= simple_form_for([day, day_food]) do |f| %>
  <div class="grid grid-cols-1 gap-4">
    <%= f.association :food,
        collection: @foods,
        prompt: t("views.day_foods.form.select_food"),
        disabled: !day_food.new_record?,
        input_html: {
          class: "w-full rounded border border-gray-300 bg-gray-50 focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition appearance-none pr-10 select-chevron"
        },
        label_html: { class: "font-medium text-gray-700" } %>

    <% if @day_food_groups.any? %>
      <%= f.association :day_food_group,
          collection: @day_food_groups,
          prompt: t("views.day_foods.form.select_group"),
          input_html: {
            class: "w-full rounded border border-gray-300 bg-gray-50 focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition appearance-none pr-10 select-chevron"
          },
          label_html: { class: "font-medium text-gray-700" },
          label: t("views.day_foods.form.food_group") %>
    <% else %>
      <div class="form-group">
        <label class="font-medium text-gray-700 block mb-3"><%= t("views.day_foods.form.food_group") %></label>
        <div class="text-center py-6 px-4 border border-gray-200 rounded-lg bg-gray-50">
          <div class="w-12 h-12 mx-auto mb-3 bg-gray-100 rounded-full flex items-center justify-center">
            <i class="fas fa-utensils text-gray-400"></i>
          </div>
          <h3 class="text-sm font-medium text-gray-900 mb-1"><%= t("shared.no_food_groups") %></h3>
          <p class="text-gray-500 text-xs mb-3"><%= t("shared.create_groups_in_settings") %></p>
        </div>
      </div>
    <% end %>

    <%= f.input :quantity,
        as: :numeric,
        min: 1,
        input_html: {
          class: "w-full rounded border border-gray-300 bg-gray-50 focus:bg-white focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition",
          value: day_food.new_record? ? 100 : day_food.quantity
        },
        label_html: { class: "font-medium text-gray-700" },
        append: "g" %>
  </div>

  <div class="flex justify-center gap-4 mt-8">
    <button type="button"
            data-controller="close-frame"
            data-action="click->close-frame#close"
            class="px-6 py-2 bg-gray-200 text-gray-800 rounded-lg shadow hover:bg-gray-300 transition font-semibold text-sm">
      <%= t("shared.cancel") %>
    </button>
    <%= f.button :submit, submit_text, class: "px-6 py-2 bg-blue-800 text-white rounded-lg shadow hover:bg-blue-600 transition font-semibold text-sm" %>
  </div>
<% end %>
