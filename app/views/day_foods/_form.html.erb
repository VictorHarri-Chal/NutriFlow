<script id="foods-data" type="application/json">
  <%= json_escape(@foods.to_json(only: [:id, :name, :calories, :proteins, :carbs, :fats, :sugars, :favorite])).html_safe %>
</script>

<%= simple_form_for([day, day_food]) do |f| %>
  <div data-controller="day-food-preview"
       data-action="input->day-food-preview#update"
       class="space-y-4">

    <%# ── Aliment ── %>
    <div>
      <label class="label-dark block mb-1.5"><%= t("views.day_foods.form.food_label") %></label>
      <% if day_food.new_record? %>
        <div data-controller="food-combobox"
             data-food-combobox-selected-id-value="0"
             data-food-combobox-no-results-value="<%= t('views.day_foods.form.no_food_found') %>"
             data-food-combobox-recent-ids-value="<%= (@recent_food_ids || []).to_json %>"
             data-food-combobox-favorites-label-value="<%= t('views.foods.favorites_section') %>"
             data-food-combobox-recents-label-value="<%= t('views.foods.recents_section') %>"
             data-food-combobox-all-label-value="<%= t('views.foods.all_section') %>">
          <%= f.hidden_field :food_id, data: {
                "food-combobox-target": "hiddenId",
                "day-food-preview-target": "foodId"
              } %>
          <div class="relative">
            <input type="text"
                   class="input-dark pl-8 text-sm"
                   placeholder="<%= t("views.day_foods.form.search_food") %>"
                   autocomplete="off"
                   data-food-combobox-target="input"
                   data-action="focus->food-combobox#open input->food-combobox#filter keydown->food-combobox#keydown">
            <i class="fas fa-search absolute left-2.5 top-1/2 -translate-y-1/2 text-ink-subtle text-xs pointer-events-none"></i>
          </div>
          <div class="hidden max-h-52 overflow-y-auto bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl"
               data-food-combobox-target="dropdown"></div>
        </div>
      <% else %>
        <%# Édition — aliment non modifiable %>
        <div class="flex items-center gap-2 px-3 py-2.5 bg-surface-base border border-surface-border/50 rounded-lg">
          <i class="fas fa-lock text-xs text-ink-subtle shrink-0"></i>
          <span class="text-sm text-ink-primary"><%= day_food.food&.name %></span>
        </div>
        <%= f.hidden_field :food_id, data: { "day-food-preview-target": "foodId" } %>
      <% end %>
    </div>

    <%# ── Quantité + Groupe ── %>
    <div class="grid grid-cols-2 gap-3">

      <%# Quantité %>
      <div>
        <label class="label-dark block mb-1.5"><%= t("shared.quantity") %></label>
        <div class="relative">
          <%= f.number_field :quantity,
                min: 1, step: 1,
                value: day_food.new_record? ? 100 : day_food.quantity.to_i,
                class: "input-dark text-sm pr-8",
                data: { "day-food-preview-target": "quantity" } %>
          <span class="absolute right-2.5 top-1/2 -translate-y-1/2 text-xs text-ink-subtle pointer-events-none">g</span>
        </div>
      </div>

      <%# Groupe de repas %>
      <% if @day_food_groups.any? %>
        <div>
          <label class="label-dark block mb-1.5"><%= t("views.day_foods.form.food_group") %></label>
          <div data-controller="custom-select" class="relative">
            <%= f.association :day_food_group,
                collection: @day_food_groups,
                prompt: t("views.day_foods.form.select_group"),
                label: false,
                input_html: { class: "sr-only", data: { custom_select_target: "select" } } %>
            <button type="button" data-action="click->custom-select#toggle"
                    class="input-dark flex items-center justify-between cursor-pointer w-full text-left text-sm">
              <span data-custom-select-target="label" class="text-ink-subtle truncate min-w-0 flex-1"></span>
              <i class="fas fa-chevron-down text-xs text-ink-subtle flex-shrink-0"></i>
            </button>
            <div data-custom-select-target="dropdown" data-custom-select-dropdown
                 class="hidden absolute z-50 w-full mt-1 bg-surface-raised border border-surface-border/60 rounded-lg shadow-2xl max-h-48 overflow-y-auto"></div>
          </div>
        </div>
      <% else %>
        <div>
          <label class="label-dark block mb-1.5"><%= t("views.day_foods.form.food_group") %></label>
          <div class="flex items-center gap-2 px-3 py-2.5 rounded-lg bg-surface-base border border-surface-border/50 text-xs text-ink-subtle">
            <i class="fas fa-utensils shrink-0"></i>
            <span><%= t("shared.no_food_groups") %></span>
          </div>
        </div>
      <% end %>

    </div>

    <%# ── Aperçu macros (affiché dès qu'un aliment est sélectionné) ── %>
    <div data-day-food-preview-target="panel" class="hidden bg-surface-base rounded-lg border border-surface-border/40 px-4 py-3">
      <div class="flex items-center gap-4">
        <div class="text-center shrink-0 w-14">
          <div class="text-xl font-bold text-brand leading-tight" data-day-food-preview-target="calories">0</div>
          <div class="text-xs text-ink-subtle">kcal</div>
        </div>
        <div class="flex-1 grid grid-cols-3 gap-2 border-l border-surface-border/40 pl-4">
          <div class="text-center">
            <div class="text-sm font-semibold text-ink-primary">
              <span data-day-food-preview-target="proteins">0</span><span class="text-xs font-normal text-ink-subtle">g</span>
            </div>
            <div class="text-xs text-ink-subtle"><%= t("views.recipes.show.proteins_short") %></div>
          </div>
          <div class="text-center">
            <div class="text-sm font-semibold text-ink-primary">
              <span data-day-food-preview-target="carbs">0</span><span class="text-xs font-normal text-ink-subtle">g</span>
            </div>
            <div class="text-xs text-ink-subtle"><%= t("views.recipes.show.carbs_short") %></div>
          </div>
          <div class="text-center">
            <div class="text-sm font-semibold text-ink-primary">
              <span data-day-food-preview-target="fats">0</span><span class="text-xs font-normal text-ink-subtle">g</span>
            </div>
            <div class="text-xs text-ink-subtle"><%= t("views.recipes.show.fats_short") %></div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <div class="flex justify-end gap-3 mt-5 pt-4 border-t border-surface-border/40">
    <button type="button"
            data-controller="close-frame"
            data-action="click->close-frame#close"
            class="btn-ghost text-sm">
      <%= t("shared.cancel") %>
    </button>
    <%= f.button :submit, submit_text, class: "btn-primary" %>
  </div>
<% end %>
