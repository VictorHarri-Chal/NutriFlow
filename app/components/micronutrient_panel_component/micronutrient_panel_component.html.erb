<div class="mt-2"
     data-controller="collapsible"
     data-collapsible-storage-key="micronutrient-panel">

  <div class="flex justify-center">
    <div class="group flex flex-col items-center gap-0.5 text-ink-subtle/60 hover:text-brand transition-colors py-1 px-4 cursor-pointer select-none"
         data-action="click->collapsible#toggle"
         data-collapsible-target="trigger"
         title="<%= t("views.calendars.micronutrients.trigger_title") %>">
      <i class="fas fa-chevron-down text-xs transition-transform duration-200" data-collapsible-target="icon"></i>
    </div>
  </div>

  <div class="hidden mt-4 space-y-4" data-collapsible-target="content">
    <div class="flex items-center justify-center gap-2">
      <div class="relative group inline-flex items-center rounded-full focus:outline-none focus-visible:ring-2 focus-visible:ring-brand"
           tabindex="0">
        <i class="fas fa-circle-info text-xs text-ink-subtle/40 hover:text-ink-subtle cursor-default transition-colors"></i>
        <div class="absolute left-1/2 -translate-x-1/2 top-4 z-10 w-72 hidden group-hover:block group-focus:block
                    bg-surface-raised border border-surface-border/60 rounded-xl shadow-lg p-3 normal-case font-normal">
          <p class="text-[11px] font-semibold text-ink-primary mb-1.5"><%= t("views.calendars.micronutrients.info_title") %></p>
          <p class="text-[10px] text-ink-subtle leading-relaxed"><%= t("views.calendars.micronutrients.info_text") %></p>
        </div>
      </div>
      <p class="text-sm font-medium text-ink-primary">
        <%= t("views.calendars.micronutrients.week_range",
              start: l(week_start, format: :short), end: l(week_end, format: :short)) %>
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
      <% groups.each do |title, entries| %>
        <div>
          <h4 class="text-[11px] font-semibold text-ink-subtle uppercase tracking-wide mb-2"><%= title %></h4>
          <div class="space-y-2.5">
            <% entries.each do |entry| %>
              <% data = coverage[entry.key] %>
              <div>
                <div class="flex items-center justify-between text-xs mb-1">
                  <span class="text-ink-muted"><%= entry.label %></span>
                  <% if data[:goal] %>
                    <span class="text-ink-subtle tabular-nums">
                      <%= number_with_precision(data[:consumed], precision: 1, strip_insignificant_zeros: true) %> / <%= number_with_precision(data[:goal], precision: 0) %> <%= entry.unit %><%= t("views.calendars.micronutrients.ceiling_suffix") if entry.nature == :ceiling %>
                    </span>
                  <% else %>
                    <span class="text-ink-subtle tabular-nums">
                      <%= number_with_precision(data[:consumed], precision: 1, strip_insignificant_zeros: true) %> <%= entry.unit %>
                    </span>
                  <% end %>
                </div>
                <div class="progress-track h-1">
                  <% if data[:goal] %>
                    <div class="h-full rounded-full <%= bar_color_class(entry, data) %>" style="width: <%= bar_width(data) %>%"></div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
