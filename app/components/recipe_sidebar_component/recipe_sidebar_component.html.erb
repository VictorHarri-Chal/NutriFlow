<div class="space-y-4">
  <%# ── Journal / notation ── %>
  <%= render RecipeRatingFormComponent.new(recipe: recipe, current_user: current_user) %>

  <%# ── Profil nutritionnel ── %>
  <div class="card p-5 space-y-4">
    <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider">
      <%= t("views.components.recipe_sidebar.macro_profile") %>
    </p>

    <%# Barre macros empilée %>
    <% if total_macro_kcal > 0 %>
      <div>
        <div class="flex h-2 rounded-full overflow-hidden gap-0.5 mb-3">
          <div class="bg-emerald-500 rounded-l-full" style="flex: <%= protein_pct %>"></div>
          <div class="bg-sky-400" style="flex: <%= carbs_pct %>"></div>
          <div class="bg-amber-400 rounded-r-full" style="flex: <%= fat_pct %>"></div>
        </div>
        <div class="flex items-center gap-3 text-xs">
          <span class="flex items-center gap-1.5 text-ink-muted">
            <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
            <%= t("views.components.recipe_sidebar.protein") %> <span class="font-semibold text-ink-primary tabular-nums"><%= protein_pct %>%</span>
          </span>
          <span class="flex items-center gap-1.5 text-ink-muted">
            <span class="w-2 h-2 rounded-full bg-sky-400 shrink-0"></span>
            <%= t("views.components.recipe_sidebar.carbs") %> <span class="font-semibold text-ink-primary tabular-nums"><%= carbs_pct %>%</span>
          </span>
          <span class="flex items-center gap-1.5 text-ink-muted">
            <span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
            <%= t("views.components.recipe_sidebar.fat") %> <span class="font-semibold text-ink-primary tabular-nums"><%= fat_pct %>%</span>
          </span>
        </div>
      </div>

      <%# Densité protéique %>
      <div class="flex items-center justify-between py-3 border-t border-surface-border/30">
        <div class="text-xs text-ink-subtle leading-tight">
          <%= t("views.components.recipe_sidebar.protein_density_label") %>
          <div class="text-[10px] text-ink-subtle/60 mt-0.5"><%= t("views.components.recipe_sidebar.protein_density_hint") %></div>
        </div>
        <div class="text-right">
          <span class="text-lg font-bold text-emerald-400 leading-none tabular-nums"><%= protein_density %></span>
          <span class="text-xs text-ink-subtle ml-0.5">g</span>
        </div>
      </div>
    <% end %>

    <%# Utilisation %>
    <div class="border-t border-surface-border/30 pt-3 space-y-2">
      <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider mb-2">
        <%= t("views.components.recipe_sidebar.usage") %>
      </p>
      <div class="flex items-center justify-between text-sm">
        <span class="text-ink-subtle"><%= t("views.components.recipe_sidebar.times_cooked_label") %></span>
        <span class="font-semibold text-ink-primary tabular-nums"><%= t("views.components.recipe_sidebar.times_cooked", count: times_cooked) %></span>
      </div>
      <% if last_cooked_date %>
        <div class="flex items-center justify-between text-sm">
          <span class="text-ink-subtle"><%= t("views.components.recipe_sidebar.last_cooked_label") %></span>
          <span class="font-semibold text-ink-primary tabular-nums"><%= I18n.l(last_cooked_date, format: :short) %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>
