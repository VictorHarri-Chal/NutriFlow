<div class="space-y-4">
  <%# ── Journal / notation ── %>
  <%= render RecipeRatingFormComponent.new(recipe: recipe, current_user: current_user) %>

  <%# ── Profil nutritionnel ── %>
  <div class="card p-5">
    <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider mb-4">
      <%= t("views.components.recipe_sidebar.macro_profile") %>
    </p>
    <% if total_macro_kcal > 0 %>
      <div class="flex h-2 rounded-full overflow-hidden gap-0.5 mb-3">
        <div class="bg-emerald-500 rounded-l-full" style="flex: <%= protein_pct %>"></div>
        <div class="bg-sky-400" style="flex: <%= carbs_pct %>"></div>
        <div class="bg-amber-400 rounded-r-full" style="flex: <%= fat_pct %>"></div>
      </div>
      <div class="flex items-center gap-3 text-xs">
        <span class="flex items-center gap-1.5 text-ink-muted">
          <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
          <%= t("views.components.recipe_sidebar.protein") %> <span class="font-semibold text-ink-primary tabular-nums"><%= protein_pct %>%</span>
        </span>
        <span class="flex items-center gap-1.5 text-ink-muted">
          <span class="w-2 h-2 rounded-full bg-sky-400 shrink-0"></span>
          <%= t("views.components.recipe_sidebar.carbs") %> <span class="font-semibold text-ink-primary tabular-nums"><%= carbs_pct %>%</span>
        </span>
        <span class="flex items-center gap-1.5 text-ink-muted">
          <span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
          <%= t("views.components.recipe_sidebar.fat") %> <span class="font-semibold text-ink-primary tabular-nums"><%= fat_pct %>%</span>
        </span>
      </div>
    <% end %>
  </div>

  <%# ── Micronutriments ── %>
  <% mn_list = ordered_micronutrients %>
  <% if mn_list.any? %>
    <div class="card p-5">
      <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider mb-3">
        <%= t("views.components.recipe_sidebar.micronutrients") %>
      </p>
      <div class="divide-y divide-surface-border/20">
        <% mn_list.each do |item| %>
          <div class="flex items-center justify-between py-1.5">
            <span class="text-xs text-ink-muted"><%= t("views.foods.show.nutrients.#{item[:key]}") %></span>
            <span class="text-xs font-semibold text-ink-primary tabular-nums">
              <%= number_with_precision(item[:value], precision: 1, strip_insignificant_zeros: true) %> <%= item[:unit] %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Allergènes & Traces ── %>
  <% if allergens.any? || traces.any? %>
    <div class="card p-5 space-y-3">
      <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider">
        <%= t("views.components.recipe_sidebar.allergens_and_traces") %>
      </p>

      <% if allergens.any? %>
        <div>
          <p class="text-[10px] font-medium text-ink-subtle uppercase tracking-wide mb-1.5">
            <%= t("views.components.recipe_sidebar.allergens") %>
          </p>
          <div class="flex flex-wrap gap-1.5">
            <% allergens.each do |a| %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-status-warning/10 text-status-warning border border-status-warning/30">
                <%= helpers.translate_allergen(a) %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if traces.any? %>
        <div>
          <p class="text-[10px] font-medium text-ink-subtle uppercase tracking-wide mb-1.5">
            <%= t("views.components.recipe_sidebar.traces") %>
          </p>
          <div class="flex flex-wrap gap-1.5">
            <% traces.each do |t_item| %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-surface-hover text-ink-muted border border-surface-border/50">
                <%= helpers.translate_allergen(t_item) %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Utilisation ── %>
  <div class="card p-5 space-y-2">
    <p class="text-xs font-semibold text-ink-subtle uppercase tracking-wider mb-1">
      <%= t("views.components.recipe_sidebar.usage") %>
    </p>
    <div class="flex items-center justify-between text-sm">
      <span class="text-ink-subtle"><%= t("views.components.recipe_sidebar.times_cooked_label") %></span>
      <span class="font-semibold text-ink-primary tabular-nums"><%= t("views.components.recipe_sidebar.times_cooked", count: times_cooked) %></span>
    </div>
    <% if last_cooked_date %>
      <div class="flex items-center justify-between text-sm">
        <span class="text-ink-subtle"><%= t("views.components.recipe_sidebar.last_cooked_label") %></span>
        <span class="font-semibold text-ink-primary tabular-nums"><%= I18n.l(last_cooked_date, format: :short) %></span>
      </div>
    <% end %>
  </div>

</div>
