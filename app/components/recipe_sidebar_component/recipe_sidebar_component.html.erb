<div class="space-y-4">
  <!-- Journal personnel -->
  <%= render RecipeRatingFormComponent.new(recipe: recipe, current_user: current_user) %>

  <!-- Résumé rapide -->
  <div class="card p-5">
    <h3 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center">
      <i class="fas fa-chart-pie text-brand mr-2"></i>
      <%= t("views.components.recipe_sidebar.summary") %>
    </h3>
    <dl class="space-y-2">
      <div class="flex justify-between items-center text-sm">
        <dt class="text-ink-subtle"><%= t("views.components.recipe_sidebar.ingredients_count") %></dt>
        <dd class="font-semibold text-ink-primary"><%= recipe.recipe_items.size %></dd>
      </div>
      <div class="flex justify-between items-center text-sm">
        <dt class="text-ink-subtle"><%= t("views.components.recipe_sidebar.total_weight") %></dt>
        <dd class="font-semibold text-ink-primary"><%= recipe.total_weight %> g</dd>
      </div>
      <div class="flex justify-between items-center text-sm border-t border-surface-border/40 pt-2 mt-2">
        <dt class="text-ink-subtle"><%= t("views.components.recipe_sidebar.kcal_per_100g") %></dt>
        <% kcal_per_100 = recipe.total_weight > 0 ? (recipe.total_calories / recipe.total_weight * 100).round(1) : 0 %>
        <dd class="font-semibold text-brand"><%= kcal_per_100 %> kcal</dd>
      </div>
    </dl>
  </div>
</div>
