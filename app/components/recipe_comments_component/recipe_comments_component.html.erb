<div class="card p-8 mb-8">
  <h3 class="text-xl font-bold text-ink-primary mb-6 flex items-center">
    <div class="w-10 h-10 bg-brand-muted rounded-lg flex items-center justify-center mr-3">
      <i class="fas fa-comments text-brand text-lg"></i>
    </div>
    <%= t("views.components.recipe_comments.title") %>
  </h3>

  <% if recipe.user == current_user %>
    <!-- Formulaire d'ajout de commentaire -->
    <div class="mb-8 p-6 card-section rounded-xl">
      <h4 class="text-sm font-semibold text-ink-muted mb-4 flex items-center">
        <i class="fas fa-plus-circle text-brand mr-2"></i>
        <%= t("views.components.recipe_comments.add_comment") %>
      </h4>
      <%= form_with model: [recipe, RecipeComment.new],
                    url: recipe_recipe_comments_path(recipe),
                    class: "space-y-4" do |f| %>

        <%= f.text_area :content,
                        rows: 3,
                        class: "input-dark resize-none",
                        placeholder: t("views.components.recipe_comments.placeholder") %>

        <div class="flex justify-end">
          <%= f.submit t("views.components.recipe_comments.add_btn"),
                        class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Liste des commentaires -->
  <% if comments.any? %>
    <div class="space-y-6">
      <% comments.each do |comment| %>
        <div class="bg-surface-base rounded-xl p-6 border border-surface-border/40 hover:border-surface-border transition-colors">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center mb-3">
                <div class="w-8 h-8 bg-surface-hover rounded-full flex items-center justify-center mr-3">
                  <i class="fas fa-user text-ink-muted text-sm"></i>
                </div>
                <div class="flex flex-col">
                  <span class="text-sm font-medium text-ink-primary"><%= t("views.components.recipe_comments.you") %></span>
                  <span class="text-xs text-ink-subtle flex items-center">
                    <i class="fas fa-clock mr-1"></i>
                    <%= comment.created_at.strftime("%d/%m/%Y à %H:%M") %>
                  </span>
                </div>
              </div>
              <div class="bg-surface-raised rounded-lg p-4 border-l-4 border-brand">
                <p class="text-ink-primary leading-relaxed text-sm"><%= comment.content %></p>
              </div>
            </div>

            <% if comment.user == current_user && recipe.user == current_user %>
              <div class="flex gap-2 ml-4">
                <%= button_to recipe_recipe_comment_path(recipe, comment),
                              method: :delete,
                              class: "w-8 h-8 text-status-danger hover:text-red-400 rounded-lg flex items-center justify-center transition-colors",
                              data: { confirm: t("views.components.recipe_comments.delete_confirm") } do %>
                  <i class="fas fa-trash text-sm"></i>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <div class="w-16 h-16 bg-surface-hover rounded-full flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-comment-slash text-ink-subtle text-xl"></i>
      </div>
      <p class="text-lg font-medium text-ink-muted mb-2"><%= t("views.components.recipe_comments.no_comments") %></p>
      <% if recipe.user == current_user %>
        <p class="text-sm text-ink-subtle"><%= t("views.components.recipe_comments.add_first_comment") %></p>
      <% end %>
    </div>
  <% end %>
</div>
