<%# Wrapper relatif : lien + bouton favori frères (évite lien dans lien) %>
<div class="relative group" id="recipe_<%= recipe.id %>">

  <%= link_to recipe_path(recipe), class: "block" do %>
    <div class="bg-surface-raised rounded-xl border border-surface-border/50 overflow-hidden hover:shadow-xl hover:border-brand/40 transition-all duration-300 transform hover:scale-[1.02]">

      <%# ── En-tête ── %>
      <div class="bg-surface-base border-t-2 border-brand px-5 py-4">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 pr-6">
            <h3 class="font-bold text-ink-primary text-base leading-tight group-hover:text-brand transition-colors truncate">
              <%= recipe.name %>
            </h3>
            <div class="flex items-center gap-1.5 mt-1.5 text-xs text-ink-subtle">
              <i class="fas fa-list-ul"></i>
              <%= t("views.components.recipe_card.ingredient_count", count: recipe.recipe_items.size) %>
              <% if user_rating > 0 %>
                <span class="text-ink-subtle/40">·</span>
                <i class="fas fa-star text-amber-400/60 text-[10px]"></i>
                <span><%= user_rating %>/5</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <%# ── Nutrition ── %>
      <div class="px-5 py-4">
        <div class="flex items-center justify-center gap-6 mb-4">
          <div class="text-center">
            <div class="text-2xl font-bold text-brand leading-tight"><%= recipe.total_calories %></div>
            <div class="text-xs text-ink-subtle">kcal</div>
          </div>
          <div class="w-px h-8 bg-surface-border/60 shrink-0"></div>
          <div class="text-center">
            <div class="text-2xl font-bold text-ink-muted leading-tight"><%= recipe.total_weight %></div>
            <div class="text-xs text-ink-subtle"><%= t("views.components.recipe_card.total_g") %></div>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-2">
          <div class="text-center p-2 bg-surface-hover/60 rounded-lg">
            <div class="font-bold text-ink-primary text-sm"><%= recipe.total_proteins %></div>
            <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.components.recipe_card.proteins") %></div>
          </div>
          <div class="text-center p-2 bg-surface-hover/60 rounded-lg">
            <div class="font-bold text-ink-primary text-sm"><%= recipe.total_carbs %></div>
            <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.components.recipe_card.carbs") %></div>
          </div>
          <div class="text-center p-2 bg-surface-hover/60 rounded-lg">
            <div class="font-bold text-ink-primary text-sm"><%= recipe.total_fats %></div>
            <div class="text-xs text-ink-subtle mt-0.5"><%= t("views.components.recipe_card.fats") %></div>
          </div>
        </div>
      </div>

    </div>
  <% end %>

  <%# Bouton favori — positionné en absolu, frère du lien %>
  <%= render "recipes/favorite_button", recipe: recipe %>

</div>
