<% if food.food_labels.any? %>
  <div class="flex flex-wrap gap-1">
    <% food.food_labels.each do |label| %>
      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-brand-muted text-brand border border-brand/30">
        <i class="fas fa-tag text-brand mr-1 text-xs"></i>
        <%= label.name %>
      </span>
    <% end %>
  </div>
<% else %>
  <span class="text-ink-subtle/40 text-xs">—</span>
<% end %>
