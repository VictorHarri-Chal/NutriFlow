<% if food.food_labels.any? %>
  <div class="flex flex-wrap gap-1">
    <% food.food_labels.each do |label| %>
      <% style = label.color_style %>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium <%= style[:bg] %> <%= style[:text] %> border <%= style[:border] %>">
        <span class="w-1.5 h-1.5 rounded-full <%= style[:dot] %> shrink-0"></span>
        <%= label.name %>
      </span>
    <% end %>
  </div>
<% else %>
  <span class="text-ink-subtle/40 text-xs">—</span>
<% end %>
