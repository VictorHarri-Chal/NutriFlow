<div class="card p-5"
     data-controller="recipe-rating"
     data-recipe-rating-current-rating-value="<%= existing_rating.present? && existing_rating > 0 ? existing_rating : 1 %>">

  <h3 class="text-sm font-semibold text-ink-subtle uppercase tracking-wide mb-4 flex items-center gap-2">
    <i class="fas fa-book-open text-brand text-xs"></i>
    <%= t("views.components.recipe_rating_form.title") %>
  </h3>

  <% if existing_rating && existing_rating > 0 %>

    <%# ── MODE LECTURE ── %>
    <div data-recipe-rating-target="viewMode">

      <%# Étoiles en lecture seule %>
      <div class="flex items-center gap-1 mb-3">
        <% 5.times do |i| %>
          <i class="fas fa-star text-base <%= i < existing_rating ? 'text-brand' : 'text-surface-border' %>"></i>
        <% end %>
        <span class="text-xs text-ink-subtle ml-1.5"><%= existing_rating %>/5</span>
      </div>

      <%# Commentaire en lecture seule %>
      <% if existing_comment.present? %>
        <div class="bg-surface-base rounded-lg border border-surface-border/40 px-4 py-3 mb-3">
          <p class="text-sm text-ink-muted leading-relaxed"><%= existing_comment %></p>
        </div>
      <% else %>
        <p class="text-xs text-ink-subtle italic mb-3"><%= t("views.components.recipe_rating_form.no_comment") %></p>
      <% end %>

      <button type="button"
              data-action="click->recipe-rating#edit"
              class="text-xs text-ink-subtle hover:text-ink-primary flex items-center gap-1.5 transition-colors">
        <i class="fas fa-pen text-xs"></i>
        <%= t("views.components.recipe_rating_form.edit_btn") %>
      </button>
    </div>

    <%# ── MODE ÉDITION (caché par défaut) ── %>
    <div data-recipe-rating-target="editMode" class="hidden">
      <%= form_with model: [recipe, current_user_rating || RecipeRating.new],
                    url: recipe_recipe_ratings_path(recipe),
                    method: :post,
                    class: "space-y-3" do |f| %>

        <%= f.text_area :comment,
                        value: existing_comment,
                        rows: 4,
                        class: "input-dark resize-none text-sm",
                        placeholder: t("views.components.recipe_rating_form.comment_placeholder") %>

        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-1"
               data-recipe-rating-target="starContainer"
               data-action="mouseleave->recipe-rating#leaveStars">
            <% 5.times do |i| %>
              <button type="button"
                      class="text-lg transition-transform hover:scale-110"
                      data-rating="<%= i + 1 %>"
                      data-recipe-rating-target="star"
                      data-action="click->recipe-rating#selectRating mouseenter->recipe-rating#hoverRating">
                <i class="fas fa-star text-ink-subtle"></i>
              </button>
            <% end %>
            <%= f.hidden_field :rating, value: existing_rating, data: { recipe_rating_target: "ratingInput" } %>
          </div>

          <div class="flex items-center gap-2">
            <button type="button"
                    data-action="click->recipe-rating#cancel"
                    class="text-xs text-ink-subtle hover:text-ink-primary px-3 py-1.5 rounded-lg hover:bg-surface-hover transition-colors">
              <%= t("shared.cancel") %>
            </button>
            <%= f.submit t("views.components.recipe_rating_form.update_btn"),
                          class: "text-xs font-medium text-ink-muted hover:text-ink-primary bg-surface-hover hover:bg-surface-border px-3 py-1.5 rounded-lg transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>

    <%# ── PAS ENCORE DE NOTE : form direct ── %>
    <div data-recipe-rating-target="editMode">
      <%= form_with model: [recipe, RecipeRating.new],
                    url: recipe_recipe_ratings_path(recipe),
                    method: :post,
                    class: "space-y-3" do |f| %>

        <%= f.text_area :comment,
                        rows: 4,
                        class: "input-dark resize-none text-sm",
                        placeholder: t("views.components.recipe_rating_form.comment_placeholder") %>

        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-1"
               data-recipe-rating-target="starContainer"
               data-action="mouseleave->recipe-rating#leaveStars">
            <% 5.times do |i| %>
              <button type="button"
                      class="text-lg transition-transform hover:scale-110"
                      data-rating="<%= i + 1 %>"
                      data-recipe-rating-target="star"
                      data-action="click->recipe-rating#selectRating mouseenter->recipe-rating#hoverRating">
                <i class="fas fa-star text-ink-subtle"></i>
              </button>
            <% end %>
            <%= f.hidden_field :rating, value: 1, data: { recipe_rating_target: "ratingInput" } %>
          </div>

          <%= f.submit t("views.components.recipe_rating_form.rate_btn"),
                        class: "text-xs font-medium text-ink-muted hover:text-ink-primary bg-surface-hover hover:bg-surface-border px-3 py-1.5 rounded-lg transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>

  <% end %>
</div>
